-- ════════════════════════════════════════════════════════════════════
--  POST-FX
-- ════════════════════════════════════════════════════════════════════
local atmo,bloom,cc,dof
local function setupFX()
	atmo=Lighting:FindFirstChildOfClass("Atmosphere") or Instance.new("Atmosphere",Lighting)
	atmo.Density=0; atmo.Haze=0; atmo.Color=Color3.fromRGB(100,50,150)
	atmo.Glare=0; atmo.Decay=Color3.fromRGB(200,150,255)
	bloom=Lighting:FindFirstChild("__PibbyBloom") or Instance.new("BloomEffect")
	bloom.Name="__PibbyBloom"; bloom.Intensity=0; bloom.Size=24; bloom.Threshold=0.95; bloom.Parent=Lighting
	cc=Lighting:FindFirstChild("__PibbyCC") or Instance.new("ColorCorrectionEffect")
	cc.Name="__PibbyCC"; cc.Brightness=0; cc.Contrast=0; cc.Saturation=0; cc.TintColor=Color3.new(1,1,1); cc.Parent=Lighting
	dof=Lighting:FindFirstChild("__PibbyDOF") or Instance.new("DepthOfFieldEffect")
	dof.Name="__PibbyDOF"; dof.FocusDistance=50; dof.InFocusRadius=50; dof.NearIntensity=0; dof.FarIntensity=0; dof.Parent=Lighting
end
setupFX()

-- ════════════════════════════════════════════════════════════════════
--  GRID ESPACIAL
-- ════════════════════════════════════════════════════════════════════
local function gKey(p)
	return math.floor(p.X/CFG.CellSize)..","..math.floor(p.Y/CFG.CellSize)..","..math.floor(p.Z/CFG.CellSize)
end
local function isOcc(pos)
	local cx,cy,cz=math.floor(pos.X/CFG.CellSize),math.floor(pos.Y/CFG.CellSize),math.floor(pos.Z/CFG.CellSize)
	for dx=-1,1 do for dy=-1,1 do for dz=-1,1 do
				local k=(cx+dx)..",".. (cy+dy)..",".. (cz+dz)
				if spatialGrid[k] then
					for _,p in ipairs(spatialGrid[k]) do
						if (p-pos).Magnitude<CFG.MinDist then return true end
					end
				end
			end end end
	return false
end
local function markOcc(pos)
	local k=gKey(pos); if not spatialGrid[k] then spatialGrid[k]={} end
	table.insert(spatialGrid[k],pos)
end

-- ════════════════════════════════════════════════════════════════════
--  RAYCAST
-- ════════════════════════════════════════════════════════════════════
local rpMain=RaycastParams.new()
rpMain.FilterType=Enum.RaycastFilterType.Exclude
rpMain.FilterDescendantsInstances={folder}

local rpNoPlayer=RaycastParams.new()
rpNoPlayer.FilterType=Enum.RaycastFilterType.Exclude

local function refreshNoPlayer()
	local ex={folder}
	for _,pl in ipairs(Players:GetPlayers()) do if pl.Character then table.insert(ex,pl.Character) end end
	rpNoPlayer.FilterDescendantsInstances=ex
end
local function castSurf(pos,dir,len,p)
	local r=workspace:Raycast(pos-dir*1.2,dir*(len or CFG.RayDown),p or rpMain)
	if r then return r.Position+r.Normal*CFG.SurfaceOff,r.Normal,r.Instance end
	return nil,nil,nil
end
local function nextSurf(from,move,sn,stepOvr)
	local step=stepOvr or CFG.StepSize
	local flat=(move-sn*move:Dot(sn)); flat=flat.Magnitude<0.001 and move or flat.Unit
	local sp,sn2=castSurf(from+flat*step+sn*1.5,-sn,CFG.RayDown)
	if sp then return sp,sn2,flat end
	if CFG.WallClimb then
		local wr=workspace:Raycast(from+sn*0.5,flat*CFG.SlopeRayLen,rpMain)
		if wr then return wr.Position+wr.Normal*CFG.SurfaceOff,wr.Normal,flat end
		local dr=workspace:Raycast(from+flat*step+sn*0.3,-sn*CFG.RayDown,rpMain)
		if dr then return dr.Position+dr.Normal*CFG.SurfaceOff,dr.Normal,flat end
	end
	return nil,nil,flat
end

-- ════════════════════════════════════════════════════════════════════
--  SPAWN HELPERS
-- ════════════════════════════════════════════════════════════════════
local function spawnBillboard(part)
	if not(part and part.Parent) then return end
	local bb=Instance.new("BillboardGui"); bb.Size=UDim2.new(0,120,0,28)
	bb.StudsOffset=Vector3.new(0,part.Size.Y*0.5+0.8,0); bb.AlwaysOnTop=false; bb.Parent=part
	local lbl=Instance.new("TextLabel"); lbl.Size=UDim2.new(1,0,1,0)
	lbl.BackgroundTransparency=1; lbl.Text=rG():format(math.random(10,99))
	lbl.TextColor3=rN(); lbl.TextSize=12+math.random()*6
	lbl.Font=math.random()<0.5 and Enum.Font.Code or Enum.Font.GothamBold
	lbl.TextStrokeTransparency=0.4; lbl.TextTransparency=1; lbl.Parent=bb
	task.spawn(function()
		TweenService:Create(lbl,TweenInfo.new(0.3),{TextTransparency=0}):Play()
		task.wait(2+math.random()*4)
		if not(part and part.Parent) then return end
		for _=1,math.random(2,5) do
			if not(part and part.Parent) then break end
			lbl.TextTransparency=1; task.wait(0.04+math.random()*0.1)
			lbl.TextTransparency=0; task.wait(0.04+math.random()*0.1)
		end
		TweenService:Create(lbl,TweenInfo.new(0.5),{TextTransparency=1}):Play()
		task.delay(0.6,function() if bb then bb:Destroy() end end)
	end)
end

local function spawnTendril(from,to,sn,age,isNeon,isRhizo)
	if partCount>=CFG.MaxParts then return nil end
	local len=(to-from).Magnitude; if len<0.05 then return nil end
	local p=Instance.new("Part"); p.Anchored=true; p.CanCollide=false; p.CastShadow=false
	local w=isRhizo and (CFG.RhizoWidth+math.random()*0.14) or (CFG.TendrilW+math.random()*0.11)
	local h=isRhizo and (CFG.RhizoHeight+math.random()*0.05) or (CFG.TendrilH+math.random()*0.03)
	p.Size=Vector3.new(w,h,len)
	local look=(to-from).Unit; local right=sn:Cross(look)
	right=right.Magnitude<0.001 and Vector3.new(1,0,0) or right.Unit
	p.CFrame=CFrame.fromMatrix((from+to)/2,right,look:Cross(right).Unit)
	if isNeon then p.Color=rN(); p.Material=Enum.Material.Neon
	elseif isRhizo then p.Color=rR(); p.Material=Enum.Material.SmoothPlastic
	else p.Color=mycelColor(age); p.Material=age>0.72 and Enum.Material.SmoothPlastic or Enum.Material.Fabric end
	p.Transparency=1; p.Parent=folder; partCount+=1
	TweenService:Create(p,TweenInfo.new(0.20),{Transparency=isNeon and 0 or (isRhizo and 0.08 or 0.04)}):Play()
	if isRhizo then
		local li=Instance.new("PointLight"); li.Color=Color3.fromRGB(110,0,190); li.Range=5; li.Brightness=0.35; li.Parent=p
	end
	if not isNeon and not isRhizo and age>0.58 and math.random()<0.28 then
		task.spawn(function()
			while p and p.Parent do
				task.wait(1.0+math.random()*4.5); if not(p and p.Parent) then break end
				if math.random()<0.20 then
					local oc,om=p.Color,p.Material; p.Color=rN(); p.Material=Enum.Material.Neon
					task.wait(0.02+math.random()*0.07)
					if p and p.Parent then p.Color=oc; p.Material=om end
				end
			end
		end)
	end
	return p
end

local function spawnBlob(pos,normal,radius,ageFrac)
	if partCount>=CFG.MaxParts then return nil end
	radius=radius or (CFG.BlobRadMin+math.random()*(CFG.BlobRadMax-CFG.BlobRadMin))
	ageFrac=ageFrac or 1
	local p=Instance.new("Part"); local shp=math.random(3)
	p.Shape=shp==1 and Enum.PartType.Ball or (shp==2 and Enum.PartType.Block or Enum.PartType.Cylinder)
	p.Anchored=true; p.CanCollide=false; p.CastShadow=false
	local ry=radius*(0.22+math.random()*0.52)
	p.Size=Vector3.new(radius,ry,radius*(0.75+math.random()*0.5))
	local br=normal:Cross(Vector3.new(0,0,1)); br=br.Magnitude<0.001 and Vector3.new(1,0,0) or br.Unit
	p.CFrame=CFrame.fromMatrix(pos+normal*(ry/2),br,normal,-br:Cross(normal).Unit)*CFrame.Angles(0,math.random()*math.pi*2,math.random()*0.35)
	local isNeon=math.random()<0.09
	p.Color=isNeon and rN() or (ageFrac>0.42 and rD() or mycelColor(ageFrac))
	p.Material=isNeon and Enum.Material.Neon or Enum.Material.SmoothPlastic
	p.Transparency=1; p.Parent=folder; partCount+=1
	TweenService:Create(p,TweenInfo.new(0.38,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Transparency=isNeon and 0 or 0.04}):Play()
	-- ── FIX: insertamos en blobReg con tick() global, sin iterar ──
	table.insert(blobReg,{pos=pos,time=tick()})
	if not isNeon and ageFrac>0.28 and math.random()<0.22 then
		local li=Instance.new("PointLight"); li.Color=Color3.fromRGB(95,0,175)
		li.Range=4+radius*2.2; li.Brightness=0.28+ageFrac*0.38; li.Parent=p
	end
	if not isNeon then
		task.spawn(function()
			while p and p.Parent do
				task.wait(2.5+math.random()*6); if not(p and p.Parent) then break end
				if math.random()<0.10 then
					local oc,om=p.Color,p.Material; p.Color=rN(); p.Material=Enum.Material.Neon
					task.wait(0.03+math.random()*0.09)
					if p and p.Parent then p.Color=oc; p.Material=om end
				end
			end
		end)
	end
	if math.random()<CFG.BillboardChance then task.delay(0.5+math.random()*2,function() spawnBillboard(p) end) end
	table.insert(bioLumReg,{part=p,pos=pos}); if #bioLumReg>250 then table.remove(bioLumReg,1) end
	return p
end

local function spawnFlash(pos,normal,scale)
	if partCount>=CFG.MaxParts then return end; scale=scale or 1
	local p=Instance.new("Part"); p.Anchored=true; p.CanCollide=false; p.CastShadow=false
	p.Shape=Enum.PartType.Ball; p.Size=Vector3.new(0.35,0.35,0.35)*scale
	p.Position=pos+normal*0.35; p.Color=rN(); p.Material=Enum.Material.Neon; p.Transparency=0
	p.Parent=folder; partCount+=1
	local li=Instance.new("PointLight"); li.Color=p.Color; li.Range=14*scale; li.Brightness=3; li.Parent=p
	TweenService:Create(p,TweenInfo.new(0.28),{Size=Vector3.new(4.5,4.5,4.5)*scale,Transparency=1}):Play()
	TweenService:Create(li,TweenInfo.new(0.28),{Brightness=0}):Play()
	task.delay(0.32,function() if p then p:Destroy(); partCount=math.max(0,partCount-1) end end)
end

-- ════════════════════════════════════════════════════════════════════
--  BLOBREF CLEANUP (separado, no dentro de iteraciones)
-- ════════════════════════════════════════════════════════════════════
local function cleanBlobReg()
	local t=tick(); local clean={}
	for _,b in ipairs(blobReg) do
		if t-b.time<=130 then table.insert(clean,b) end
	end
	blobReg=clean
end

-- ════════════════════════════════════════════════════════════════════
--  DENSIDAD DE BLOBS (solo lectura, sin modificar blobReg)
-- ════════════════════════════════════════════════════════════════════
local function getBlobDensity(pos,radius)
	local count=0
	for _,b in ipairs(blobReg) do
		if (b.pos-pos).Magnitude<radius then count+=1 end
	end
	return count
end

-- ════════════════════════════════════════════════════════════════════
--  RIZOMORFOS
-- ════════════════════════════════════════════════════════════════════
local function addRhizo(pos,dir,sn)
	if #nodes>=CFG.MaxNodes or partCount>=CFG.MaxParts then return end
	local fd=Vector3.new(dir.X,0,dir.Z); if fd.Magnitude<0.001 then return end
	local l=math.random(CFG.RhizoLifeMin,CFG.RhizoLifeMax)
	table.insert(nodes,{pos=pos,dir=fd.Unit,normal=sn or Vector3.new(0,1,0),life=l,maxLife=l,depth=0,age=0,nodeType="rhizo"})
end

-- ════════════════════════════════════════════════════════════════════
--  CUERPOS FRUCTÍFEROS
-- ════════════════════════════════════════════════════════════════════
local FTYPES={
	{stalkW=function() return 0.28+math.random()*0.18 end,segH=function() return 0.55+math.random()*0.9 end,
	capR=function() return 1.4+math.random()*2.2 end,capH=function() return 0.35+math.random()*0.28 end,
	col=function() return PAL.fruit[1] end,sporePeriod=9},
	{stalkW=function() return 0.16+math.random()*0.12 end,segH=function() return 0.7+math.random()*1.1 end,
	capR=function() return 0.18+math.random()*0.3 end,capH=function() return 0.6+math.random()*0.9 end,
	col=function() return PAL.fruit[2] end,sporePeriod=6},
	{stalkW=function() return 0.55+math.random()*0.4 end,segH=function() return 0.8+math.random()*1.2 end,
	capR=function() return 1.0+math.random()*3.0 end,capH=function() return 0.9+math.random()*1.2 end,
	col=function() return PAL.fruit[3] end,sporePeriod=13},
}

local function buildFruitingBody(pos,normal)
	if partCount>=CFG.MaxParts-25 or #fruitBodies>=CFG.FruitMaxBodies then return end
	local ft=FTYPES[math.random(#FTYPES)]; local parts={}; local totalH=0
	local segs=math.random(3,CFG.FruitSegMax)
	for seg=1,segs do
		if partCount>=CFG.MaxParts then break end
		local sh=ft.segH(); local sw=ft.stalkW()*(1-(seg/segs)*0.35); totalH+=sh
		local up=normal; local fwd=up:Cross(Vector3.new(1,0,0))
		fwd=fwd.Magnitude<0.001 and up:Cross(Vector3.new(0,0,1)) or fwd.Unit
		local sp=Instance.new("Part"); sp.Anchored=true; sp.CanCollide=false; sp.CastShadow=false
		sp.Size=Vector3.new(sw,sh,sw)
		sp.CFrame=CFrame.fromMatrix(pos+normal*(totalH-sh/2),fwd:Cross(up).Unit,up)*CFrame.Angles(0,math.random()*math.pi*2,0)
		local isN=(seg==segs) and math.random()<0.28; local tf=seg/segs
		sp.Color=isN and rN() or lerpC(ft.col(),rD(),tf*0.65)
		sp.Material=isN and Enum.Material.Neon or Enum.Material.SmoothPlastic
		sp.Transparency=1; sp.Parent=folder; partCount+=1
		task.delay(seg*0.12,function()
			if sp and sp.Parent then
				TweenService:Create(sp,TweenInfo.new(0.55,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Transparency=isN and 0 or 0.06}):Play()
			end
		end)
		table.insert(parts,sp)
	end
	if partCount<CFG.MaxParts then
		local cr=ft.capR(); local ch=ft.capH(); local up=normal
		local fwd=up:Cross(Vector3.new(1,0,0)); fwd=fwd.Magnitude<0.001 and up:Cross(Vector3.new(0,0,1)) or fwd.Unit
		local cap=Instance.new("Part"); cap.Shape=Enum.PartType.Ball
		cap.Anchored=true; cap.CanCollide=false; cap.CastShadow=false
		cap.Size=Vector3.new(cr*2,ch*1.4,cr*2)
		cap.CFrame=CFrame.fromMatrix(pos+normal*(totalH+ch*0.5),fwd:Cross(up).Unit,up)
		cap.Color=rN(); cap.Material=Enum.Material.Neon; cap.Transparency=1; cap.Parent=folder; partCount+=1
		local cl=Instance.new("PointLight"); cl.Color=cap.Color; cl.Range=20; cl.Brightness=2.5; cl.Parent=cap
		task.delay(segs*0.12+0.18,function()
			if cap and cap.Parent then TweenService:Create(cap,TweenInfo.new(0.6,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Transparency=0.04}):Play() end
		end)
		task.spawn(function()
			while cap and cap.Parent do
				task.wait(ft.sporePeriod*0.45+math.random()*2.5); if not(cap and cap.Parent) then break end
				TweenService:Create(cl,TweenInfo.new(0.28),{Brightness=6,Range=30}):Play()
				task.wait(0.28); TweenService:Create(cl,TweenInfo.new(1.0),{Brightness=2.5,Range=20}):Play()
			end
		end)
		table.insert(parts,cap)
	end
	table.insert(fruitBodies,{pos=pos,normal=normal,parts=parts,ft=ft,sporeT=0,born=tick()})
end

local function checkFruiting(dt)
	fruitTimer+=dt; if fruitTimer<CFG.FruitCooldown then return end
	fruitTimer=0
	if partCount>=CFG.MaxParts-30 or #fruitBodies>=CFG.FruitMaxBodies then return end
	-- Limpieza de blobReg (aquí es seguro porque no estamos iterando nodes ni spores)
	cleanBlobReg()
	local checked=0
	for i=#blobReg,math.max(1,#blobReg-60),-1 do
		checked+=1
		local b=blobReg[i]
		if b and b.time and (tick()-b.time)<70 and getBlobDensity(b.pos,CFG.FruitRadius)>=CFG.FruitDensity then
			local tooClose=false
			for _,fb in ipairs(fruitBodies) do
				if (fb.pos-b.pos).Magnitude<CFG.FruitRadius then tooClose=true; break end
			end
			if not tooClose then
				local gp,gn=castSurf(b.pos+Vector3.new(0,2,0),Vector3.new(0,-1,0))
				if gp then buildFruitingBody(gp,gn); break end
			end
		end
		if checked>20 then break end
	end
end

local function tickFruitBodies(dt)
	local dead={}
	for idx,fb in ipairs(fruitBodies) do
		fb.sporeT+=dt
		if fb.sporeT>=fb.ft.sporePeriod then
			fb.sporeT=0
			if #fb.parts>0 then
				local top=fb.parts[#fb.parts]
				if top and top.Parent then fb._launchPending={pos=top.Position,normal=fb.normal} end
			end
		end
		local alive=false
		for _,p in ipairs(fb.parts) do if p and p.Parent then alive=true; break end end
		if not alive then table.insert(dead,idx) end
	end
	for i=#dead,1,-1 do table.remove(fruitBodies,dead[i]) end
end

-- ════════════════════════════════════════════════════════════════════
--  ESPORAS
-- ════════════════════════════════════════════════════════════════════
local function launchSpore(fromPos,fromNormal)
	if sporeCount>=CFG.SporeMaxActive or partCount>=CFG.MaxParts then return end
	local angle=math.random()*math.pi*2; local dist=18+math.random()*CFG.SporeRange
	local target=fromPos+Vector3.new(math.cos(angle)*dist,0,math.sin(angle)*dist)
	refreshNoPlayer()
	local lp,ln=castSurf(target+Vector3.new(0,12,0),Vector3.new(0,-1,0),45,rpNoPlayer)
	if not lp then return end
	local sp=Instance.new("Part"); sp.Anchored=true; sp.CanCollide=false; sp.CastShadow=false
	sp.Shape=Enum.PartType.Ball; sp.Size=Vector3.new(0.28,0.28,0.28)
	sp.Position=fromPos+fromNormal*1.2; sp.Color=rN(); sp.Material=Enum.Material.Neon; sp.Transparency=0.15
	sp.Parent=folder; partCount+=1; sporeCount+=1
	local sl=Instance.new("PointLight"); sl.Color=sp.Color; sl.Range=7; sl.Brightness=1.2; sl.Parent=sp
	local ft=CFG.SporeFlightMin+math.random()*(CFG.SporeFlightMax-CFG.SporeFlightMin)
	local midH=CFG.SporeArcHeight*(0.45+math.random()*0.55)
	local midP=(fromPos+lp)/2+Vector3.new(0,midH,0)
	table.insert(spores,{part=sp,light=sl,startPos=fromPos+fromNormal*1.2,midPos=midP,
		landPos=lp,landNormal=ln,startTime=tick(),flightTime=ft,trail={},landed=false})
end

local function processFruitPending()
	for _,fb in ipairs(fruitBodies) do
		if fb._launchPending then launchSpore(fb._launchPending.pos,fb._launchPending.normal); fb._launchPending=nil end
	end
end

local function updateSpores(dt)
	local t=tick(); local dead={}
	for idx,s in ipairs(spores) do
		if not(s.part and s.part.Parent) then
			table.insert(dead,idx); sporeCount=math.max(0,sporeCount-1); continue
		end
		local elapsed=t-s.startTime; local frac=math.clamp(elapsed/s.flightTime,0,1)
		if frac>=1 then
			if not s.landed then
				s.landed=true; spawnFlash(s.landPos,s.landNormal,0.55)
				s.part:Destroy(); partCount=math.max(0,partCount-1); sporeCount=math.max(0,sporeCount-1)
				for _,tp in ipairs(s.trail) do if tp and tp.Parent then tp:Destroy(); partCount=math.max(0,partCount-1) end end
				local lp,ln=s.landPos,s.landNormal
				task.delay(CFG.SporeGermDelay,function()
					if partCount<CFG.MaxParts then
						local gp,gn=castSurf(lp+ln*2,-ln,8)
						if gp then
							spawnBlob(gp,gn,1.4+math.random()*0.8,0.15); markOcc(gp)
							for i=1,4 do
								local a=(i/4)*math.pi*2+(math.random()-0.5)*0.6
								local l=math.random(CFG.LifeMin,CFG.LifeMax)
								table.insert(nodes,{pos=gp,dir=Vector3.new(math.cos(a),0,math.sin(a)),
									normal=gn,life=l,maxLife=l,depth=0,age=0,nodeType="normal"})
							end
						end
					end
				end)
			end
			table.insert(dead,idx); continue
		end
		local t0=1-frac
		s.part.Position=t0*t0*s.startPos+2*t0*frac*s.midPos+frac*frac*s.landPos
			+Vector3.new(math.sin(elapsed*7.5)*0.25,0,math.cos(elapsed*6)*0.25)
		if math.floor(elapsed*4)>math.floor((elapsed-dt)*4) and partCount<CFG.MaxParts then
			local tr=Instance.new("Part"); tr.Anchored=true; tr.CanCollide=false; tr.CastShadow=false
			tr.Shape=Enum.PartType.Ball; tr.Size=Vector3.new(0.10,0.10,0.10)
			tr.Position=s.part.Position; tr.Color=s.part.Color; tr.Material=Enum.Material.Neon; tr.Transparency=0.4
			tr.Parent=folder; partCount+=1; table.insert(s.trail,tr)
			TweenService:Create(tr,TweenInfo.new(0.75),{Transparency=1,Size=Vector3.new(0.01,0.01,0.01)}):Play()
			task.delay(0.82,function() if tr and tr.Parent then tr:Destroy(); partCount=math.max(0,partCount-1) end end)
		end
	end
	for i=#dead,1,-1 do table.remove(spores,dead[i]) end
end

-- ════════════════════════════════════════════════════════════════════
--  BIOLUMINISCENCIA
-- ════════════════════════════════════════════════════════════════════
local function triggerBioPulse(origin)
	if #bioLumReg==0 then return end
	local batch={}
	for _,b in ipairs(bioLumReg) do
		if b.part and b.part.Parent then table.insert(batch,{p=b.part,d=(b.pos-origin).Magnitude}) end
	end
	table.sort(batch,function(a,b) return a.d<b.d end)
	for _,item in ipairs(batch) do
		local delay_=item.d/CFG.BioSpeed; local p=item.p
		task.delay(delay_,function()
			if not(p and p.Parent) then return end
			local oc,om=p.Color,p.Material
			p.Color=Color3.fromRGB(155,0,245); p.Material=Enum.Material.Neon
			task.wait(0.07+math.random()*0.05)
			if p and p.Parent then TweenService:Create(p,TweenInfo.new(0.45),{Color=oc}):Play(); p.Material=om end
		end)
	end
end
local function tickBioLum(dt)
	bioTimer+=dt; if bioTimer<CFG.BioInterval then return end
	bioTimer=0; if #blobReg>0 then triggerBioPulse(blobReg[math.random(#blobReg)].pos) end
end

-- ════════════════════════════════════════════════════════════════════
--  CONSUMO DEL MAPA
-- ════════════════════════════════════════════════════════════════════
local function tryConsume(pos)
	if not CFG.MapConsumeOn or math.random()>=CFG.MapConsumeChance then return end
	local dir=Vector3.new((math.random()-0.5)*2,-0.6,(math.random()-0.5)*2).Unit
	local r=workspace:Raycast(pos+Vector3.new(0,0.3,0),dir*CFG.MapConsumeRadius,rpMain)
	if not r then return end
	local inst=r.Instance
	if not inst or not inst:IsA("BasePart") then return end
	if inst.Name=="Baseplate" or inst:FindFirstAncestor("PibbyFolder") then return end
	if consumed[inst] or inst.Locked or not inst.Anchored then return end
	consumed[inst]=true
	task.spawn(function()
		local oc,om,ot,os=inst.Color,inst.Material,inst.Transparency,inst.Size
		TweenService:Create(inst,TweenInfo.new(CFG.MapConsumeTime*0.32),{Color=lerpC(oc,rD(),0.55)}):Play()
		task.wait(CFG.MapConsumeTime*0.32); if not(inst and inst.Parent) then consumed[inst]=nil; return end
		inst.Material=Enum.Material.Neon
		TweenService:Create(inst,TweenInfo.new(CFG.MapConsumeTime*0.3),{Color=rN(),Transparency=0.45}):Play()
		task.wait(CFG.MapConsumeTime*0.3); if not(inst and inst.Parent) then consumed[inst]=nil; return end
		spawnFlash(inst.Position,Vector3.new(0,1,0),math.clamp(inst.Size.Magnitude*0.18,0.4,3))
		TweenService:Create(inst,TweenInfo.new(CFG.MapConsumeTime*0.22),{Transparency=1,Size=os*0.08}):Play()
		task.wait(CFG.MapConsumeTime*0.22+0.1)
		if inst and inst.Parent then inst.Transparency=ot; inst.Color=oc; inst.Material=om; inst.Size=os end
		consumed[inst]=nil
	end)
end

-- ════════════════════════════════════════════════════════════════════
--  MEMORIA DE JUGADORES
-- ════════════════════════════════════════════════════════════════════
local function updateMemory()
	local t=tick()
	for _,pl in ipairs(Players:GetPlayers()) do
		local ch=pl.Character; if ch then
			local hrp=ch:FindFirstChild("HumanoidRootPart")
			if hrp then table.insert(playerMem,{pos=hrp.Position,time=t}) end
		end
	end
	for i=#playerMem,1,-1 do if t-playerMem[i].time>CFG.MemoryDecay then table.remove(playerMem,i) end end
	while #playerMem>120 do table.remove(playerMem,1) end
end
local function memBiasDir(pos)
	if #playerMem==0 or math.random()>CFG.MemoryBias then return nil end
	local best,bd=nil,math.huge
	for _,m in ipairs(playerMem) do
		local d=(m.pos-pos).Magnitude
		if d>6 and d<bd then best=m; bd=d end
	end
	if not best then return nil end
	local d=best.pos-pos; return Vector3.new(d.X,0,d.Z).Unit
end

-- ════════════════════════════════════════════════════════════════════
--  COMPETICIÓN DE COLONIAS
-- ════════════════════════════════════════════════════════════════════
local function checkColonyClash(nodePos,nodeDir)
	if clashCooldown>0 then return end
	for _,other in ipairs(nodes) do
		local d=(other.pos-nodePos).Magnitude
		if d<CFG.ColonyClashDist and d>0.1 and nodeDir:Dot(other.dir)<-0.3 and math.random()<CFG.ColonyClashChance then
			clashCooldown=30
			local cp=(nodePos+other.pos)/2
			task.spawn(function() for _=1,6 do spawnFlash(cp,Vector3.new(0,1,0),1.5+math.random()*1.5); task.wait(0.06) end end)
			task.spawn(function()
				task.wait(0.2); if partCount>=CFG.MaxParts then return end
				local gp,gn=castSurf(cp+Vector3.new(0,2,0),Vector3.new(0,-1,0))
				if gp then
					spawnBlob(gp,gn,3.5+math.random()*2,0.5)
					for i=1,6 do
						local a=(i/6)*math.pi*2; local l=math.random(8,18)
						table.insert(nodes,{pos=gp,dir=Vector3.new(math.cos(a),0,math.sin(a)),normal=gn,
							life=l,maxLife=l,depth=3,age=0.5,nodeType="normal"})
					end
				end
			end)
			task.spawn(function()
				local pb=Lighting.Brightness
				for _=1,3 do
					TweenService:Create(Lighting,TweenInfo.new(0.04),{Brightness=0}):Play(); task.wait(0.05)
					TweenService:Create(Lighting,TweenInfo.new(0.04),{Brightness=pb}):Play(); task.wait(0.04)
				end
			end)
			return true
		end
	end
end

-- ════════════════════════════════════════════════════════════════════
--  DISTORSIONES ÚNICAS POR JUGADOR
--  Cada jugador infectado recibe UN tipo que dura toda la infección
-- ════════════════════════════════════════════════════════════════════
local DISTORTION_TYPES = {"scanlines","static","chromatic","fragment","invert","zoom","drain"}
local playerDistortion = {}   -- player → tipo asignado
local distortionGuis   = {}   -- player → ScreenGui persistente

local function assignDistortion(player)
	-- Elige uno que no tenga ya otro jugador infectado (si hay slots libres)
	local used={}
	for _,t in pairs(playerDistortion) do used[t]=true end
	local available={}
	for _,t in ipairs(DISTORTION_TYPES) do if not used[t] then table.insert(available,t) end end
	if #available==0 then available=DISTORTION_TYPES end
	playerDistortion[player] = available[math.random(#available)]
	return playerDistortion[player]
end

local function startDistortionEffect(player, dtype)
	task.spawn(function()
		if not(player and player.Parent) then return end
		local sg=Instance.new("ScreenGui"); sg.Name="__PibbyDistort"; sg.ResetOnSpawn=false
		sg.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
		sg.Parent=player:WaitForChild("PlayerGui")
		distortionGuis[player]=sg

		if dtype=="scanlines" then
			-- Líneas horizontales oscuras que bajan por la pantalla
			local numLines=18
			for i=1,numLines do
				local line=Instance.new("Frame"); line.Size=UDim2.new(1,0,0,3)
				line.Position=UDim2.new(0,0,(i-1)/numLines,0)
				line.BackgroundColor3=rN(); line.BackgroundTransparency=0.55
				line.BorderSizePixel=0; line.Parent=sg
			end
			task.spawn(function()
				local offset=0
				while sg and sg.Parent and infected[player] do
					offset=(offset+0.008)%1
					for i,line in ipairs(sg:GetChildren()) do
						if line:IsA("Frame") then
							local y=((i-1)/numLines+offset)%1
							line.Position=UDim2.new(0,0,y,0)
							if math.random()<0.04 then line.BackgroundColor3=rN() end
						end
					end
					task.wait(0.04)
				end
			end)

		elseif dtype=="static" then
			-- Ruido estático: muchos cuadraditos pequeños que parpadean
			local pixels=60
			for _=1,pixels do
				local px=Instance.new("Frame")
				px.Size=UDim2.new(0,math.random(2,8),0,math.random(2,8))
				px.Position=UDim2.new(math.random()*0.98,0,math.random()*0.98,0)
				px.BackgroundColor3=math.random()<0.5 and rN() or rD()
				px.BackgroundTransparency=math.random()*0.5
				px.BorderSizePixel=0; px.Parent=sg
			end
			task.spawn(function()
				while sg and sg.Parent and infected[player] do
					for _,px in ipairs(sg:GetChildren()) do
						if px:IsA("Frame") and math.random()<0.35 then
							px.Position=UDim2.new(math.random()*0.98,0,math.random()*0.98,0)
							px.BackgroundColor3=math.random()<0.5 and rN() or rD()
							px.BackgroundTransparency=0.2+math.random()*0.6
							px.Visible=math.random()<0.7
						end
					end
					task.wait(0.05)
				end
			end)

		elseif dtype=="chromatic" then
			-- Aberración cromática: capas rojo/azul desplazadas
			local function makeLayer(col, xOff, yOff, trans)
				local f=Instance.new("Frame"); f.Size=UDim2.new(1,0,1,0)
				f.Position=UDim2.new(0,xOff,0,yOff); f.BackgroundColor3=col
				f.BackgroundTransparency=trans; f.BorderSizePixel=0; f.Parent=sg
			end
			makeLayer(Color3.fromRGB(255,0,0), 4, 0, 0.82)
			makeLayer(Color3.fromRGB(0,0,255),-4, 0, 0.82)
			-- Texto glitch que se desplaza
			local glitchLbl=Instance.new("TextLabel"); glitchLbl.Size=UDim2.new(1,0,0,30)
			glitchLbl.BackgroundTransparency=1; glitchLbl.Font=Enum.Font.Code
			glitchLbl.TextSize=20; glitchLbl.TextStrokeTransparency=0.4
			glitchLbl.TextTransparency=0.3; glitchLbl.Parent=sg
			task.spawn(function()
				while sg and sg.Parent and infected[player] do
					glitchLbl.Position=UDim2.new(0,(math.random()-0.5)*14,math.random()*0.9,0)
					glitchLbl.Text=rG():format(math.random(10,99))
					glitchLbl.TextColor3=rN()
					task.wait(0.12+math.random()*0.25)
				end
			end)

		elseif dtype=="fragment" then
			-- Pantalla "fragmentada": franjas verticales desplazadas
			local segs=6
			for i=1,segs do
				local f=Instance.new("Frame"); local w=1/segs
				f.Size=UDim2.new(w,0,1,0); f.Position=UDim2.new((i-1)*w,0,0,0)
				f.BackgroundColor3=rD(); f.BackgroundTransparency=0.88
				f.BorderSizePixel=0; f.Parent=sg
			end
			task.spawn(function()
				while sg and sg.Parent and infected[player] do
					for _,f in ipairs(sg:GetChildren()) do
						if f:IsA("Frame") and math.random()<0.20 then
							local origY=f.Position.Y.Scale
							f.Position=UDim2.new(f.Position.X.Scale,0,origY+(math.random()-0.5)*0.04,0)
							if math.random()<0.08 then f.BackgroundColor3=rN(); f.BackgroundTransparency=0.6 end
						end
					end
					task.wait(0.08)
				end
			end)

		elseif dtype=="invert" then
			-- Overlay oscuro que pulsa + inversión periódica breve
			local ov=Instance.new("Frame"); ov.Size=UDim2.new(1,0,1,0)
			ov.Position=UDim2.new(0,0,0,0); ov.BackgroundColor3=Color3.fromRGB(0,0,0)
			ov.BackgroundTransparency=0.82; ov.BorderSizePixel=0; ov.Parent=sg
			task.spawn(function()
				while sg and sg.Parent and infected[player] do
					-- Pulso
					TweenService:Create(ov,TweenInfo.new(0.3),{BackgroundTransparency=0.55}):Play()
					task.wait(0.3)
					TweenService:Create(ov,TweenInfo.new(0.5),{BackgroundTransparency=0.88}):Play()
					task.wait(1.5+math.random()*3)
					-- Flash neon breve
					if math.random()<0.25 then
						ov.BackgroundColor3=rN(); ov.BackgroundTransparency=0.4
						task.wait(0.06); ov.BackgroundColor3=Color3.fromRGB(0,0,0); ov.BackgroundTransparency=0.82
					end
				end
			end)

		elseif dtype=="zoom" then
			-- Distorsión de zoom: overlay que escala
			local zf=Instance.new("Frame"); zf.Size=UDim2.new(1.3,0,1.3,0)
			zf.Position=UDim2.new(-0.15,0,-0.15,0); zf.BackgroundColor3=rD()
			zf.BackgroundTransparency=0.90; zf.BorderSizePixel=0; zf.Parent=sg
			local zLbl=Instance.new("TextLabel"); zLbl.Size=UDim2.new(1,0,0,40)
			zLbl.Position=UDim2.new(0,0,0.45,0); zLbl.BackgroundTransparency=1
			zLbl.Font=Enum.Font.Code; zLbl.TextSize=24; zLbl.TextTransparency=1
			zLbl.TextStrokeTransparency=0.4; zLbl.Parent=sg
			task.spawn(function()
				while sg and sg.Parent and infected[player] do
					task.wait(0.8+math.random()*2)
					-- Glitch de escala
					local scl=0.88+math.random()*0.28
					TweenService:Create(zf,TweenInfo.new(0.06),{
						Size=UDim2.new(scl,0,scl,0),
						Position=UDim2.new(-(scl-1)/2,0,-(scl-1)/2,0)
					}):Play()
					zLbl.Text=rG():format(math.random(10,99)); zLbl.TextColor3=rN()
					TweenService:Create(zLbl,TweenInfo.new(0.1),{TextTransparency=0}):Play()
					task.wait(0.08+math.random()*0.12)
					TweenService:Create(zf,TweenInfo.new(0.08),{Size=UDim2.new(1.3,0,1.3,0),Position=UDim2.new(-0.15,0,-0.15,0)}):Play()
					TweenService:Create(zLbl,TweenInfo.new(0.3),{TextTransparency=1}):Play()
				end
			end)

		elseif dtype=="drain" then
			-- Pantalla se "vacía": barras negras que van comiendo desde los lados
			local top=Instance.new("Frame"); top.Size=UDim2.new(1,0,0,0)
			top.Position=UDim2.new(0,0,0,0); top.BackgroundColor3=rD()
			top.BackgroundTransparency=0.0; top.BorderSizePixel=0; top.Parent=sg
			local bot=Instance.new("Frame"); bot.Size=UDim2.new(1,0,0,0)
			bot.Position=UDim2.new(0,0,1,0); bot.BackgroundColor3=rD()
			bot.BackgroundTransparency=0.0; bot.BorderSizePixel=0; bot.Parent=sg
			task.spawn(function()
				while sg and sg.Parent and infected[player] do
					local h=math.random()*0.12
					TweenService:Create(top,TweenInfo.new(0.4),{Size=UDim2.new(1,0,h,0)}):Play()
					TweenService:Create(bot,TweenInfo.new(0.4),{Size=UDim2.new(1,0,h,0),Position=UDim2.new(0,0,1-h,0)}):Play()
					if math.random()<0.15 then top.BackgroundColor3=rN(); bot.BackgroundColor3=rN() end
					task.wait(1.2+math.random()*2.5)
					TweenService:Create(top,TweenInfo.new(0.6),{Size=UDim2.new(1,0,0,0)}):Play()
					TweenService:Create(bot,TweenInfo.new(0.6),{Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,1,0)}):Play()
					task.wait(0.8+math.random()*1.5)
				end
			end)
		end
	end)
end

local function stopDistortion(player)
	if distortionGuis[player] then
		distortionGuis[player]:Destroy()
		distortionGuis[player]=nil
	end
	playerDistortion[player]=nil
end

-- ════════════════════════════════════════════════════════════════════
--  CORRUPCIÓN DE NPCs (cualquier Humanoid que no sea jugador)
-- ════════════════════════════════════════════════════════════════════
local function isPlayerCharacter(model)
	for _,pl in ipairs(Players:GetPlayers()) do
		if pl.Character==model then return true end
	end
	return false
end

local function corruptNpc(model)
	if infectedNpcs[model] then return end
	local hum=model:FindFirstChildOfClass("Humanoid")
	local hrp=model:FindFirstChild("HumanoidRootPart")
	if not hum or not hrp then return end
	infectedNpcs[model]=true
	print("[Pibby] NPC corrompido: "..model.Name)

	task.spawn(function()
		-- Fase 1: oscurecer cuerpo gradualmente
		for _,p in ipairs(model:GetDescendants()) do
			if p:IsA("BasePart") then
				task.spawn(function()
					task.wait(math.random()*1.5)
					TweenService:Create(p,TweenInfo.new(1.2),{Color=rD()}):Play()
					-- Añade bloques de corrupción pequeños
					if math.random()<0.4 then
						task.wait(1.5+math.random())
						local b=Instance.new("Part"); b.Name="PibbyBlock"
						b.CanCollide=false; b.Anchored=false; b.CastShadow=false
						b.Size=p.Size*(0.3+math.random()*0.4)
						b.CFrame=p.CFrame*CFrame.Angles(math.random()*math.pi,math.random()*math.pi,math.random()*math.pi)
						local isN=math.random()<0.25
						b.Color=isN and rN() or rD(); b.Material=isN and Enum.Material.Neon or Enum.Material.SmoothPlastic
						b.Transparency=1; b.Parent=p
						local w=Instance.new("WeldConstraint"); w.Part0=b; w.Part1=p; w.Parent=b
						TweenService:Create(b,TweenInfo.new(0.4,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Transparency=isN and 0 or 0.1}):Play()
					end
				end)
			end
		end

		-- Luz morada en la cabeza del NPC
		local npcHead=model:FindFirstChild("Head")
		if npcHead then
			local hl=Instance.new("PointLight"); hl.Color=Color3.fromRGB(180,0,255); hl.Range=16; hl.Brightness=3; hl.Parent=npcHead
		end

		-- Fase 2: acelerar al NPC y hacerlo perseguir jugadores
		task.wait(2.5)
		if not(model and model.Parent and infectedNpcs[model]) then return end
		hum.WalkSpeed=(hum.WalkSpeed or 16)*CFG.NpcChaseSpeed*1.8

		-- Parpadeo neon periódico
		task.spawn(function()
			while model and model.Parent and infectedNpcs[model] do
				task.wait(0.8+math.random()*2.5)
				if not(model and model.Parent) then break end
				for _,p in ipairs(model:GetDescendants()) do
					if p:IsA("BasePart") and math.random()<0.15 then
						local oc,om=p.Color,p.Material; p.Color=rN(); p.Material=Enum.Material.Neon
						task.wait(0.03+math.random()*0.07)
						if p and p.Parent then p.Color=oc; p.Material=om end
					end
				end
			end
		end)

		-- Bucle de persecución: mueve al NPC hacia el jugador más cercano
		task.spawn(function()
			while model and model.Parent and infectedNpcs[model] and hum and hum.Health>0 do
				task.wait(0.5)
				if not(model and model.Parent) then break end
				local closest,closestDist=nil,math.huge
				for _,pl in ipairs(Players:GetPlayers()) do
					local ch=pl.Character
					if ch then
						local ph=ch:FindFirstChild("HumanoidRootPart")
						if ph then
							local d=(ph.Position-hrp.Position).Magnitude
							if d<closestDist then closest=ph; closestDist=d end
						end
					end
				end
				if closest then
					hum:MoveTo(closest.Position)
					-- Si está muy cerca, intenta infectar
					if closestDist<CFG.NpcInfectRadius then
						for _,pl in ipairs(Players:GetPlayers()) do
							if not infected[pl] then
								local ch=pl.Character
								if ch then
									local ph=ch:FindFirstChild("HumanoidRootPart")
									if ph and (ph.Position-hrp.Position).Magnitude<CFG.NpcInfectRadius then
										if math.random()<CFG.NpcInfectChance*10 then
											-- startInfection se define más abajo pero Lua lo resolverá
											task.spawn(function() startInfection(pl) end)
										end
									end
								end
							end
						end
						-- Mini flash al tocar
						if math.random()<0.08 then
							spawnFlash(hrp.Position,Vector3.new(0,1,0),0.5)
						end
					end
				end
				-- Emite pequeño micelio al caminar
				if math.random()<0.03 and partCount<CFG.MaxParts then
					local gp,gn=castSurf(hrp.Position,Vector3.new(0,-1,0),5)
					if gp then spawnBlob(gp,gn,0.5+math.random()*0.5,0.6) end
				end
			end
		end)
	end)
end

local function scanNpcs()
	-- Busca Humanoids en workspace que no sean jugadores
	for _,obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and not isPlayerCharacter(obj) and not infectedNpcs[obj] then
			local hum=obj:FindFirstChildOfClass("Humanoid")
			local hrp=obj:FindFirstChild("HumanoidRootPart")
			if hum and hrp then
				-- Comprueba si hay micelio cerca
				for _,b in ipairs(blobReg) do
					if (b.pos-hrp.Position).Magnitude<CFG.NpcCorruptRadius then
						corruptNpc(obj); break
					end
				end
			end
		end
	end
	-- Limpia NPCs muertos del registro
	for model,_ in pairs(infectedNpcs) do
		if not(model and model.Parent) then infectedNpcs[model]=nil end
	end
end

-- ════════════════════════════════════════════════════════════════════
--  NODOS Y OLEADAS
-- ════════════════════════════════════════════════════════════════════
local function rotXZ(v,a)
	local c,s=math.cos(a),math.sin(a); return Vector3.new(v.X*c-v.Z*s,0,v.X*s+v.Z*c).Unit
end
local function addNode(pos,dir,sn,life,depth,age,nType)
	if #nodes>=CFG.MaxNodes or partCount>=CFG.MaxParts then return end
	local fd=Vector3.new(dir.X,0,dir.Z); if fd.Magnitude<0.001 then return end
	local l=life or math.random(CFG.LifeMin,CFG.LifeMax)
	table.insert(nodes,{pos=pos,dir=fd.Unit,normal=sn or Vector3.new(0,1,0),
		life=l,maxLife=l,depth=depth or 0,age=age or 0,nodeType=nType or "normal"})
end
local function getOrigin()
	-- 1. Si el script vive dentro de una BasePart, esa ES la Part Infeccion
	if script.Parent and script.Parent:IsA("BasePart") then
		-- Asegura que se llame "Infeccion" para que el resto del código la encuentre
		if script.Parent.Name ~= "Infeccion" then script.Parent.Name = "Infeccion" end
		return script.Parent.Position
	end
	-- 2. Busca una Part llamada "Infeccion" en el workspace
	local p = workspace:FindFirstChild("Infeccion")
	if p and p:IsA("BasePart") then return p.Position end
	-- 3. Fallback: crea UNA sola Part (solo si realmente no hay ninguna)
	local a = Instance.new("Part"); a.Name="Infeccion"; a.Anchored=true; a.CanCollide=false
	a.Shape=Enum.PartType.Block; a.Size=Vector3.new(4,4,4); a.Position=Vector3.new(0,5,0)
	a.Color=Color3.fromRGB(255,0,255); a.Material=Enum.Material.Neon; a.Parent=workspace
	return a.Position
end
local function spawnWave(origin)
	local gp,gn=castSurf(origin+Vector3.new(0,2,0),Vector3.new(0,-1,0),CFG.RayDown)
	if not gp then gp=origin; gn=Vector3.new(0,1,0) end
	spawnBlob(gp,gn,4.5+math.random()*3.5,0.04); markOcc(gp)
	task.spawn(function() for _=1,5 do spawnFlash(gp,gn,1.3); task.wait(0.07) end end)
	local rays=math.random(8,13)
	for i=1,rays do
		local a=(i/rays)*math.pi*2+(math.random()-0.5)*0.55
		addNode(gp,Vector3.new(math.cos(a),0,math.sin(a)),gn,math.random(CFG.LifeMin+8,CFG.LifeMax+16),0,0,"normal")
	end
	for _=1,math.random(2,3) do
		local a=math.random()*math.pi*2; addRhizo(gp,Vector3.new(math.cos(a),0,math.sin(a)),gn)
	end
end

-- ════════════════════════════════════════════════════════════════════
--  INFECCIÓN DE JUGADORES — 5 ETAPAS
-- ════════════════════════════════════════════════════════════════════
local BODY_R15={"LeftFoot","RightFoot","LeftLowerLeg","RightLowerLeg","LeftUpperLeg","RightUpperLeg",
	"LowerTorso","UpperTorso","LeftLowerArm","RightLowerArm","LeftUpperArm","RightUpperArm","LeftHand","RightHand","Neck","Head"}
local BODY_R6={"Left Leg","Right Leg","Torso","Left Arm","Right Arm","Head"}

local function attachBlock(part,delay_,szMult)
	task.delay(delay_,function()
		if not(part and part.Parent) then return end
		szMult=szMult or 1
		local b=Instance.new("Part"); b.Name="PibbyBlock"; b.CanCollide=false; b.Anchored=false; b.CastShadow=false
		b.Size=Vector3.new(part.Size.X*(0.42+math.random()*0.48)*szMult,part.Size.Y*(0.33+math.random()*0.42)*szMult,part.Size.Z*(0.42+math.random()*0.48)*szMult)
		b.CFrame=part.CFrame*CFrame.new((math.random()-0.5)*part.Size.X*0.42,(math.random()-0.5)*part.Size.Y*0.42,(math.random()-0.5)*part.Size.Z*0.42)
			*CFrame.Angles(math.random()*math.pi,math.random()*math.pi,math.random()*math.pi)
		local isN=math.random()<0.20; b.Color=isN and rN() or rD()
		b.Material=isN and Enum.Material.Neon or Enum.Material.SmoothPlastic
		b.Transparency=1; b.Parent=part
		local w=Instance.new("WeldConstraint"); w.Part0=b; w.Part1=part; w.Parent=b
		TweenService:Create(b,TweenInfo.new(0.42,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Transparency=isN and 0 or 0.07}):Play()
		if not isN then
			task.spawn(function()
				while b and b.Parent do
					task.wait(2+math.random()*5.5); if not(b and b.Parent) then break end
					if math.random()<0.17 then
						local oc,om=b.Color,b.Material; b.Color=rN(); b.Material=Enum.Material.Neon
						task.wait(0.02+math.random()*0.09)
						if b and b.Parent then b.Color=oc; b.Material=om end
					end
				end
			end)
		end
	end)
end

local function screenMsg(player,txt,col,dur)
	task.spawn(function()
		if not(player and player.Parent) then return end
		local sg=Instance.new("ScreenGui"); sg.ResetOnSpawn=false
		local lbl=Instance.new("TextLabel"); lbl.Size=UDim2.new(1,0,0,42)
		lbl.Position=UDim2.new(0,0,0.06+math.random()*0.55,0)
		lbl.BackgroundTransparency=1; lbl.Text=txt; lbl.TextColor3=col or rN()
		lbl.TextSize=16+math.random()*16
		lbl.Font=math.random()<0.5 and Enum.Font.Code or Enum.Font.GothamBold
		lbl.TextStrokeTransparency=0.35; lbl.TextTransparency=1; lbl.Parent=sg
		sg.Parent=player:WaitForChild("PlayerGui")
		TweenService:Create(lbl,TweenInfo.new(0.2),{TextTransparency=0}):Play()
		task.wait((dur or 2)-0.2)
		TweenService:Create(lbl,TweenInfo.new(0.4),{TextTransparency=1}):Play()
		task.delay(0.5,function() if sg then sg:Destroy() end end)
	end)
end

function startInfection(player)   -- sin "local" para que scanNpcs y corruptNpc la puedan llamar forward
	if infected[player] then return end
	local data={stage=0,stageStart=tick()}; infected[player]=data

	-- Asigna distorsión única
	local dtype=assignDistortion(player)
	print("[Pibby] "..player.Name.." — infectado | distorsión: "..dtype)

	task.spawn(function()
		local char=player.Character; if not char then infected[player]=nil; return end
		local isR15=char:FindFirstChild("LowerTorso")~=nil
		local bOrder=isR15 and BODY_R15 or BODY_R6
		local hrp=char:FindFirstChild("HumanoidRootPart")
		local head=char:FindFirstChild("Head")
		local hum=char:FindFirstChildOfClass("Humanoid")

		-- Inicia distorsión de pantalla inmediatamente
		startDistortionEffect(player,dtype)

		if hrp then
			local gl=Instance.new("PointLight"); gl.Color=Color3.fromRGB(80,0,180)
			gl.Range=13; gl.Brightness=1.3; gl.Parent=hrp
			TweenService:Create(gl,TweenInfo.new(3.5),{Brightness=0}):Play()
			task.delay(3.6,function() if gl then gl:Destroy() end end)
		end
		screenMsg(player,"...",Color3.fromRGB(220,220,220),1.5)

		-- ETAPA 1
		data.stage=1
		local mid=math.ceil(#bOrder/2)
		for i=1,mid do
			local pt=char:FindFirstChild(bOrder[i])
			if pt and pt:IsA("BasePart") then
				TweenService:Create(pt,TweenInfo.new(1.3),{Color=PAL.mycel[1]}):Play()
				attachBlock(pt,i*CFG.BlockClimbSpeed)
				if math.random()<0.55 then attachBlock(pt,i*CFG.BlockClimbSpeed+0.28,0.48) end
			end
			task.wait(CFG.BlockClimbSpeed*0.78); if not infected[player] then return end
		end

		-- ETAPA 2
		task.wait(0.9); if not infected[player] then return end
		data.stage=2
		if hum then hum.WalkSpeed=math.max(4,(hum.WalkSpeed or 16)*0.70) end
		screenMsg(player,"ERROR",Color3.fromRGB(255,40,40),1.2)
		for i=mid+1,#bOrder-1 do
			local pt=char:FindFirstChild(bOrder[i])
			if pt and pt:IsA("BasePart") then
				TweenService:Create(pt,TweenInfo.new(1.0),{Color=mycelColor(0.42)}):Play()
				attachBlock(pt,(i-mid)*CFG.BlockClimbSpeed)
				if math.random()<0.6 then attachBlock(pt,(i-mid)*CFG.BlockClimbSpeed+0.22,0.55) end
			end
			task.wait(CFG.BlockClimbSpeed*0.68); if not infected[player] then return end
		end

		-- ETAPA 3
		task.wait(0.9); if not infected[player] then return end
		data.stage=3
		if hum then hum.WalkSpeed=math.max(2,(hum.WalkSpeed or 16)*0.48) end
		if head then
			TweenService:Create(head,TweenInfo.new(0.5),{Color=PAL.dark[1]}):Play()
			for _=1,5 do attachBlock(head,math.random()*0.5) end
			local hl=Instance.new("PointLight"); hl.Color=Color3.fromRGB(220,0,255); hl.Range=24; hl.Brightness=4.5; hl.Parent=head
		end
		for _,pt in ipairs(char:GetDescendants()) do
			if pt:IsA("BasePart") then
				task.spawn(function() task.wait(math.random()*0.7); TweenService:Create(pt,TweenInfo.new(0.75),{Color=rD()}):Play() end)
			end
		end
		screenMsg(player,"[ INFECTADO ]",Color3.fromRGB(255,0,255),3)

		-- ETAPA 4
		task.wait(CFG.Stage4Delay-CFG.Stage3Delay); if not infected[player] then return end
		data.stage=4
		for _,pt in ipairs(char:GetDescendants()) do
			if pt:IsA("BasePart") then
				task.spawn(function()
					while char.Parent and infected[player] and data.stage>=4 do
						if math.random()<0.08 then
							pt.Color=rN(); pt.Material=Enum.Material.Neon
							task.wait(0.02+math.random()*0.07)
							if pt and pt.Parent then pt.Color=rD(); pt.Material=Enum.Material.SmoothPlastic end
						end
						task.wait(0.04+math.random()*0.20)
					end
				end)
			end
		end
		task.spawn(function()
			while char and char.Parent and infected[player] and data.stage>=4 do
				task.wait(2.2+math.random()*5)
				if hrp then hrp.AssemblyLinearVelocity=Vector3.new((math.random()-0.5)*55,9+math.random()*22,(math.random()-0.5)*55) end
				if head then
					local fl=Instance.new("PointLight"); fl.Color=rN(); fl.Range=30; fl.Brightness=7; fl.Parent=head
					TweenService:Create(fl,TweenInfo.new(0.55),{Brightness=0}):Play()
					task.delay(0.6,function() if fl then fl:Destroy() end end)
				end
				screenMsg(player,rG():format(math.random(60,99)),nil,1.5)
			end
		end)

		-- ETAPA 5
		task.wait(CFG.Stage5Delay-CFG.Stage4Delay); if not infected[player] then return end
		data.stage=5
		screenMsg(player,"CONSCIOUSNESS OVERRIDE COMPLETE",Color3.fromRGB(255,0,255),4.5)
		task.spawn(function()
			while char and char.Parent and infected[player] and data.stage==5 do
				task.wait(1.2+math.random()*2.5)
				if not(char and char.Parent and hrp) then break end
				if partCount<CFG.MaxParts-10 then
					local gp,gn=castSurf(hrp.Position,Vector3.new(0,-1,0),7)
					if gp then
						spawnFlash(gp,gn,0.7)
						for _=1,math.random(2,3) do
							local a=math.random()*math.pi*2; local l=math.random(8,18)
							table.insert(nodes,{pos=gp,dir=Vector3.new(math.cos(a),0,math.sin(a)),normal=gn,
								life=l,maxLife=l,depth=5,age=0.55,nodeType="normal"})
						end
					end
				end
			end
		end)
	end)
end

local function tickSpread()
	for pl,data in pairs(infected) do
		if data.stage>=4 then
			local ch=pl.Character; if ch then
				local hrp=ch:FindFirstChild("HumanoidRootPart"); if hrp then
					for _,opl in ipairs(Players:GetPlayers()) do
						if opl~=pl and not infected[opl] then
							local och=opl.Character; if och then
								local oh=och:FindFirstChild("HumanoidRootPart")
								if oh and (oh.Position-hrp.Position).Magnitude<CFG.SpreadRadius then
									if math.random()<CFG.SpreadChance then startInfection(opl) end
								end
							end
						end
					end
				end
			end
		end
	end
end

-- ════════════════════════════════════════════════════════════════════
--  5 FASES DE CORRUPCIÓN DEL SERVIDOR
-- ════════════════════════════════════════════════════════════════════
local function activatePhase(phase)
	if phaseFlags[phase] then return end; phaseFlags[phase]=true; currentPhase=phase
	print("[Pibby] ══════ FASE "..phase.." ══════")
	if phase==1 then
		-- Cielo: empieza a teñirse de morado oscuro, niebla aparece suavemente
		TweenService:Create(Lighting,TweenInfo.new(5),{Ambient=Color3.fromRGB(22,0,42),OutdoorAmbient=Color3.fromRGB(10,0,20),FogColor=Color3.fromRGB(45,0,80),FogEnd=900,FogStart=220,Brightness=0.88}):Play()
		TweenService:Create(bloom,TweenInfo.new(5),{Intensity=0.28,Threshold=0.88}):Play()
		TweenService:Create(cc,TweenInfo.new(5),{Saturation=-0.12,TintColor=Color3.fromRGB(232,214,255)}):Play()
		-- Atmósfera: polvo morado tenue aparece, el cielo empieza a decaer
		-- Atmósfera fase 1: leve contaminación morada
		task.spawn(function()
			for step=1,20 do
				task.wait(0.25)
				atmo.Density = math.min(0.08, atmo.Density + 0.004)
				atmo.Haze    = math.min(0.4,  atmo.Haze    + 0.02)
				atmo.Glare   = math.min(0.05, atmo.Glare   + 0.0025)
			end
			atmo.Color = Color3.fromRGB(85, 40, 120)
			atmo.Decay = Color3.fromRGB(180, 130, 220)
		end)
		atmo.Color=Color3.fromRGB(80,20,120)
		atmo.Decay=Color3.fromRGB(160,80,220)
		atmo.Glare=0.02
		-- El cielo pasa de día a atardecer morado en 15s
		TweenService:Create(Lighting, TweenInfo.new(15, Enum.EasingStyle.Sine), {
			ClockTime = 18.5,          -- atardecer
			GeographicLatitude = 30
		}):Play()
	elseif phase==2 then
		-- Cielo: noche total, niebla morada espesa, halos en objetos brillantes
		TweenService:Create(Lighting,TweenInfo.new(6),{Ambient=Color3.fromRGB(15,0,32),OutdoorAmbient=Color3.fromRGB(7,0,15),FogColor=Color3.fromRGB(30,0,65),FogEnd=420,FogStart=75,Brightness=0.62}):Play()
		TweenService:Create(bloom,TweenInfo.new(5),{Intensity=0.75,Threshold=0.78}):Play()
		TweenService:Create(cc,TweenInfo.new(5),{Saturation=-0.28,Contrast=0.08,TintColor=Color3.fromRGB(205,182,255)}):Play()
		-- Atmósfera: bruma morada densa, el horizonte se tiñe de negro
		-- Atmósfera fase 2: neblina morada se extiende
		task.spawn(function()
			for step=1,30 do
				task.wait(0.2)
				atmo.Density = math.min(0.22, atmo.Density + 0.005)
				atmo.Haze    = math.min(1.1,  atmo.Haze    + 0.023)
				atmo.Glare   = math.min(0.12, atmo.Glare   + 0.004)
			end
			atmo.Color = Color3.fromRGB(60, 20, 100)
			atmo.Decay = Color3.fromRGB(140, 80, 180)
		end)
		atmo.Color=Color3.fromRGB(40,0,80)
		atmo.Decay=Color3.fromRGB(100,0,160)
		atmo.Glare=0.06
		-- El cielo pasa a medianoche corrupta (luna morada)
		TweenService:Create(Lighting, TweenInfo.new(10, Enum.EasingStyle.Sine), {
			ClockTime = 22.0,          -- casi medianoche
			GeographicLatitude = 0
		}):Play()
		TweenService:Create(Lighting,TweenInfo.new(8),{
			ShadowSoftness=1,
			ExposureCompensation=-0.4
		}):Play()
		task.spawn(function()
			while currentPhase>=2 do
				task.wait(7+math.random()*11); local pb=Lighting.Brightness
				TweenService:Create(Lighting,TweenInfo.new(0.07),{Brightness=0}):Play(); task.wait(0.05+math.random()*0.12)
				TweenService:Create(Lighting,TweenInfo.new(0.06),{Brightness=pb}):Play(); task.wait(0.05)
				if math.random()<0.38 then
					TweenService:Create(Lighting,TweenInfo.new(0.05),{Brightness=0}):Play(); task.wait(0.04)
					TweenService:Create(Lighting,TweenInfo.new(0.05),{Brightness=pb}):Play()
				end
			end
		end)
		task.spawn(function()
			while currentPhase>=2 do
				task.wait(2.5+math.random()*5)
				local tgts={}
				for _,v in ipairs(workspace:GetDescendants()) do
					if v:IsA("BasePart") and not v:FindFirstAncestor("PibbyFolder") and v.Name~="Baseplate" and not v.Locked then table.insert(tgts,v) end
				end
				if #tgts==0 then task.wait(2); continue end
				for _=1,math.min(math.random(2,5),#tgts) do
					local t=tgts[math.random(#tgts)]
					task.spawn(function()
						if not(t and t.Parent) then return end
						local oc,om=t.Color,t.Material; t.Color=rN(); t.Material=Enum.Material.Neon
						task.wait(0.04+math.random()*0.09)
						if t and t.Parent then t.Color=oc; t.Material=om end
					end)
				end
			end
		end)
	elseif phase==3 then
		-- Cielo: oscuridad total, niebla negra-morada aplasta el horizonte
		TweenService:Create(Lighting,TweenInfo.new(7),{Ambient=Color3.fromRGB(9,0,22),OutdoorAmbient=Color3.fromRGB(4,0,10),FogColor=Color3.fromRGB(18,0,45),FogEnd=190,FogStart=28,Brightness=0.33}):Play()
		TweenService:Create(bloom,TweenInfo.new(6),{Intensity=1.45,Threshold=0.66}):Play()
		TweenService:Create(cc,TweenInfo.new(6),{Saturation=-0.48,Contrast=0.18,TintColor=Color3.fromRGB(172,144,255)}):Play()
		TweenService:Create(dof,TweenInfo.new(6),{FarIntensity=0.28,FocusDistance=28,InFocusRadius=18}):Play()
		-- Atmósfera: neblina espesa viola-negra, el cielo parece podrirse
		-- Atmósfera fase 3: oscuridad y corrupción visibles
		task.spawn(function()
			for step=1,35 do
				task.wait(0.2)
				atmo.Density = math.min(0.48, atmo.Density + 0.008)
				atmo.Haze    = math.min(2.4,  atmo.Haze    + 0.042)
				atmo.Glare   = math.min(0.22, atmo.Glare   + 0.006)
			end
			atmo.Color = Color3.fromRGB(45, 5, 80)
			atmo.Decay = Color3.fromRGB(100, 40, 150)
		end)
		atmo.Decay=Color3.fromRGB(30,0,60)
		atmo.Glare=0.12
		-- ★ NOCHE TOTAL ★ (transición dramática de 8 segundos)
		TweenService:Create(Lighting, TweenInfo.new(8, Enum.EasingStyle.Sine), {
			ClockTime        = 0,      -- medianoche exacta
			GeographicLatitude = 0,
		}):Play()
		TweenService:Create(Lighting,TweenInfo.new(10),{
			ExposureCompensation=-0.8,
			ShadowSoftness=1
		}):Play()
		-- Mensaje de anuncio de noche para todos los jugadores
		task.delay(1, function()
			for _,pl in ipairs(Players:GetPlayers()) do
				screenMsg(pl, "[ NOCHE ETERNA ]", Color3.fromRGB(120,0,255), 3)
			end
		end)
		-- Pulsos de oscuridad en el cielo
		task.spawn(function()
			while currentPhase>=3 do
				task.wait(12+math.random()*18)
				-- El cielo "respira" con el micelio
				TweenService:Create(Lighting,TweenInfo.new(1.5),{Brightness=0.06}):Play()
				task.wait(1.8)
				TweenService:Create(Lighting,TweenInfo.new(2.0),{Brightness=0.33}):Play()
			end
		end)
		task.spawn(function()
			while currentPhase>=3 do
				task.wait(9+math.random()*14)
				for _,pl in ipairs(Players:GetPlayers()) do screenMsg(pl,rG():format(math.random(38,70)),nil,2.2) end
			end
		end)
	elseif phase==4 then
		-- Cielo: apagado casi total, bruma negra a 7 studs, realidad se fragmenta
		TweenService:Create(Lighting,TweenInfo.new(5),{Ambient=Color3.fromRGB(4,0,13),OutdoorAmbient=Color3.fromRGB(2,0,7),FogColor=Color3.fromRGB(7,0,20),FogEnd=75,FogStart=7,Brightness=0.09}):Play()
		TweenService:Create(bloom,TweenInfo.new(5),{Intensity=2.8,Threshold=0.52}):Play()
		TweenService:Create(cc,TweenInfo.new(5),{Saturation=-0.68,Contrast=0.32,TintColor=Color3.fromRGB(132,104,255)}):Play()
		TweenService:Create(dof,TweenInfo.new(5),{FarIntensity=0.55,NearIntensity=0.18,FocusDistance=13,InFocusRadius=9}):Play()
		-- Atmósfera: absolutamente densa, el cielo ya no existe, solo micelio
		-- Atmósfera fase 4: casi opaca, luz de micelio
		task.spawn(function()
			for step=1,40 do
				task.wait(0.15)
				atmo.Density = math.min(0.82, atmo.Density + 0.014)
				atmo.Haze    = math.min(5.5,  atmo.Haze    + 0.13)
				atmo.Glare   = math.min(0.45, atmo.Glare   + 0.011)
			end
			atmo.Color = Color3.fromRGB(20, 0, 55)
			atmo.Decay = Color3.fromRGB(60, 10, 100)
		end)
		-- Pulso de color en la atmósfera sincronizado con el micelio
		task.spawn(function()
			while currentPhase >= 4 do
				task.wait(3.5 + math.random()*4)
				local nc = rN()
				TweenService:Create(atmo, TweenInfo.new(0.08), {Color=nc}):Play()
				task.wait(0.1)
				TweenService:Create(atmo, TweenInfo.new(0.5), {Color=Color3.fromRGB(20,0,55)}):Play()
			end
		end)
		atmo.Color=Color3.fromRGB(8,0,20)
		atmo.Decay=Color3.fromRGB(4,0,10)
		atmo.Glare=0.0   -- el sol ya no existe
		TweenService:Create(Lighting,TweenInfo.new(6),{
			ExposureCompensation=-1.4,
			ShadowSoftness=1
		}):Play()
		-- El cielo parpadea con el latido del micelio
		task.spawn(function()
			while currentPhase>=4 do
				task.wait(3+math.random()*6)
				local flashDen = atmo.Density
				atmo.Density = math.min(1, flashDen + 0.12)
				task.wait(0.3)
				atmo.Density = flashDen
			end
		end)
		task.spawn(function()
			while currentPhase>=4 do
				task.wait(0.45+math.random()*2.2); local nc=rN()
				TweenService:Create(Lighting,TweenInfo.new(0.04),{Ambient=nc,FogColor=nc}):Play()
				task.wait(0.03+math.random()*0.08)
				TweenService:Create(Lighting,TweenInfo.new(0.04),{Ambient=Color3.fromRGB(4,0,13),FogColor=Color3.fromRGB(7,0,20)}):Play()
			end
		end)
		task.spawn(function()
			while currentPhase>=4 do
				task.wait(0.5+math.random()*1.1)
				local ap={}
				for _,v in ipairs(workspace:GetDescendants()) do
					if v:IsA("BasePart") and not v:FindFirstAncestor("PibbyFolder") and v.Name~="Baseplate" then table.insert(ap,v) end
				end
				if #ap==0 then continue end
				for _=1,math.min(math.random(14,32),#ap) do
					local t=ap[math.random(#ap)]
					task.spawn(function()
						if not(t and t.Parent) then return end
						local oc,om,os=t.Color,t.Material,t.Size
						t.Color=math.random()<0.52 and rN() or rD()
						t.Material=math.random()<0.32 and Enum.Material.Neon or Enum.Material.SmoothPlastic
						if math.random()<0.24 then
							TweenService:Create(t,TweenInfo.new(0.05),{Size=Vector3.new(os.X*(0.38+math.random()*1.9),os.Y*(0.38+math.random()*2.3),os.Z*(0.38+math.random()*1.9))}):Play()
							task.wait(0.07+math.random()*0.13)
							if t and t.Parent then TweenService:Create(t,TweenInfo.new(0.14),{Size=os}):Play() end
						end
						task.wait(0.04+math.random()*0.15)
						if t and t.Parent then t.Color=oc; t.Material=om end
					end)
				end
				if math.random()<0.09 then
					for _,pl in ipairs(Players:GetPlayers()) do screenMsg(pl,rG():format(math.random(75,95)),nil,1.8) end
				end
			end
		end)
	elseif phase==5 then
		-- Cielo: el VOID. No hay cielo, no hay distancia, solo micelio
		TweenService:Create(Lighting,TweenInfo.new(7),{Ambient=Color3.fromRGB(2,0,7),OutdoorAmbient=Color3.fromRGB(0,0,3),FogColor=Color3.fromRGB(3,0,11),FogEnd=38,FogStart=2,Brightness=0.03}):Play()
		TweenService:Create(bloom,TweenInfo.new(6),{Intensity=4.5,Threshold=0.38}):Play()
		TweenService:Create(cc,TweenInfo.new(6),{Saturation=-1,Contrast=0.48,TintColor=Color3.fromRGB(102,62,255)}):Play()
		TweenService:Create(dof,TweenInfo.new(6),{FarIntensity=1,NearIntensity=0.5,FocusDistance=7,InFocusRadius=4}):Play()
		-- Atmósfera: pared sólida de oscuridad, el mundo dejó de existir más allá de 2 studs
		-- Atmósfera fase 5: apocalipsis total — cielo inexistente
		task.spawn(function()
			for step=1,45 do
				task.wait(0.12)
				atmo.Density = math.min(1,   atmo.Density + 0.018)
				atmo.Haze    = math.min(10,   atmo.Haze    + 0.2)
				atmo.Glare   = math.min(0.95, atmo.Glare   + 0.021)
			end
			atmo.Color = Color3.fromRGB(8, 0, 22)
			atmo.Decay = Color3.fromRGB(25, 0, 55)
		end)
		-- La atmósfera pulsa entre negro y morado caótico
		task.spawn(function()
			while currentPhase >= 5 do
				task.wait(1.2 + math.random()*2)
				TweenService:Create(atmo, TweenInfo.new(0.06), {
					Color = rN(),
					Decay = rD()
				}):Play()
				task.wait(0.08 + math.random()*0.12)
				TweenService:Create(atmo, TweenInfo.new(0.35), {
					Color = Color3.fromRGB(8,0,22),
					Decay = Color3.fromRGB(25,0,55)
				}):Play()
			end
		end)
		atmo.Decay=Color3.fromRGB(0,0,0)   -- el horizonte es la nada absoluta
		atmo.Glare=0.0
		TweenService:Create(Lighting,TweenInfo.new(8),{
			ExposureCompensation=-2.0,
			ShadowSoftness=1
		}):Play()
		-- El "cielo" pulsa con el color del micelio de forma agresiva
		task.spawn(function()
			while currentPhase>=5 do
				task.wait(1.2+math.random()*2.8)
				-- Pulso de color neon que tiñe toda la atmósfera
				local nc = rN()
				atmo.Color = lerpC(Color3.fromRGB(15,0,40), nc, 0.25)
				atmo.Decay  = lerpC(Color3.fromRGB(0,0,0), nc, 0.15)
				task.wait(0.12)
				atmo.Color = Color3.fromRGB(15,0,40)
				atmo.Decay  = Color3.fromRGB(0,0,0)
			end
		end)
		task.spawn(function()
			while currentPhase>=5 do
				task.wait(2.8+math.random()*5); local flip=math.random()<0.18
				local newG=origGravity*(0.08+math.random()*1.9)*(flip and -1 or 1)
				TweenService:Create(workspace,TweenInfo.new(0.55),{Gravity=newG}):Play()
				task.wait(0.55+math.random()*1.8)
				TweenService:Create(workspace,TweenInfo.new(1.2),{Gravity=origGravity}):Play()
			end
		end)
		task.spawn(function()
			while currentPhase>=5 do
				task.wait(1.8+math.random()*4)
				for _,pl in ipairs(Players:GetPlayers()) do screenMsg(pl,rG():format(math.random(95,100)),nil,2.2) end
			end
		end)
		task.spawn(function()
			while currentPhase>=5 do
				task.wait(0.3+math.random()*0.7)
				local ap={}
				for _,v in ipairs(workspace:GetDescendants()) do
					if v:IsA("BasePart") and not v:FindFirstAncestor("PibbyFolder") and v.Name~="Baseplate" then table.insert(ap,v) end
				end
				if #ap==0 then continue end
				for _=1,math.min(math.random(20,45),#ap) do
					local t=ap[math.random(#ap)]
					task.spawn(function()
						if not(t and t.Parent) then return end
						local oc,om,os=t.Color,t.Material,t.Size
						t.Color=math.random()<0.6 and rN() or rD()
						t.Material=math.random()<0.4 and Enum.Material.Neon or Enum.Material.SmoothPlastic
						if math.random()<0.35 then
							TweenService:Create(t,TweenInfo.new(0.04),{Size=Vector3.new(os.X*(0.2+math.random()*2.5),os.Y*(0.2+math.random()*2.8),os.Z*(0.2+math.random()*2.5))}):Play()
							task.wait(0.05+math.random()*0.1)
							if t and t.Parent then TweenService:Create(t,TweenInfo.new(0.16),{Size=os}):Play() end
						end
						task.wait(0.04+math.random()*0.12)
						if t and t.Parent then t.Color=oc; t.Material=om end
					end)
				end
			end
		end)
	end
end

local function checkPhases()
	if     partCount>=CFG.Phase5At and not phaseFlags[5] then activatePhase(5)
	elseif partCount>=CFG.Phase4At and not phaseFlags[4] then activatePhase(4)
	elseif partCount>=CFG.Phase3At and not phaseFlags[3] then activatePhase(3)
	elseif partCount>=CFG.Phase2At and not phaseFlags[2] then activatePhase(2)
	elseif partCount>=CFG.Phase1At and not phaseFlags[1] then activatePhase(1) end
end

-- ════════════════════════════════════════════════════════════════════
--  TICK DEL MICELIO
-- ════════════════════════════════════════════════════════════════════
local function tickMycelium()
	if clashCooldown>0 then clashCooldown-=1 end
	local nxt={}
	for _,node in ipairs(nodes) do
		if node.life<=0 then
			local gp,gn=castSurf(node.pos+node.normal,-node.normal,4)
			if gp then spawnBlob(gp,gn,CFG.BlobRadMin+math.random()*0.65,0.88) end
			continue
		end
		local isRhizo=node.nodeType=="rhizo"; local af=1-(node.life/node.maxLife)
		local wander=isRhizo and 0.13 or (0.26+af*0.58)
		local baseDir=node.dir
		local mb=memBiasDir(node.pos); if mb then baseDir=(baseDir+mb*CFG.MemoryBias).Unit end
		local newDir=rotXZ(baseDir,(math.random()-0.5)*math.pi*wander)
		local step=isRhizo and CFG.RhizoStep or CFG.StepSize
		local np,nn,ud=nextSurf(node.pos,newDir,node.normal,step)
		if not np then continue end
		if not isRhizo then
			if isOcc(np) then if math.random()<0.18 then spawnFlash(np,nn,0.45) end; continue end
			markOcc(np)
		end
		if not isRhizo then checkColonyClash(np,ud or newDir) end
		local isNeon=math.random()<CFG.NeonChance*(1+af*(isRhizo and 0.4 or 1.1))
		local tp=spawnTendril(node.pos,np,nn,af,isNeon,isRhizo)
		if tp and math.random()<0.14 then
			table.insert(bioLumReg,{part=tp,pos=np}); if #bioLumReg>250 then table.remove(bioLumReg,1) end
		end
		if math.random()<CFG.BlobChance*(isRhizo and 0.25 or 1) then
			spawnBlob(np,nn,CFG.BlobRadMin+math.random()*(CFG.BlobRadMax-CFG.BlobRadMin)*0.55,af)
		end
		if af>0.62 and math.random()<0.07 then spawnFlash(np,nn,0.45) end
		tryConsume(np)
		if af>0.78 and math.random()<CFG.SporeChance and sporeCount<CFG.SporeMaxActive then launchSpore(np,nn) end
		table.insert(nxt,{pos=np,dir=ud or newDir,normal=nn,life=node.life-1,maxLife=node.maxLife,depth=node.depth,age=node.age+1,nodeType=node.nodeType})
		if math.random()<(isRhizo and 0.04 or CFG.BranchChance) and node.depth<CFG.MaxDepth then
			local bs=math.random()>0.5 and 1 or -1
			local bLife=math.max(5,math.floor(node.life*CFG.BranchDecay))
			addNode(np,rotXZ(ud or newDir,bs*(math.pi*(isRhizo and 0.13 or 0.27)+math.random()*0.52)),nn,bLife,node.depth+1,node.age,"normal")
		end
		if not isRhizo and node.depth==0 and math.random()<CFG.RhizoChance then addRhizo(np,ud or newDir,nn) end
		for _,pl in ipairs(Players:GetPlayers()) do
			if not infected[pl] then
				local ch=pl.Character; if ch then
					local h=ch:FindFirstChild("HumanoidRootPart")
					if h and (h.Position-np).Magnitude<CFG.PlayerRadius then startInfection(pl) end
				end
			end
		end
	end
	nodes=nxt; checkPhases()
end

-- ════════════════════════════════════════════════════════════════════
--  HEARTBEAT
-- ════════════════════════════════════════════════════════════════════
RunService.Heartbeat:Connect(function(dt)
	timer_acc+=dt; waveTimer+=dt; memTimer+=dt; npcScanTimer+=dt

	if infectionReady then
		if timer_acc>=CFG.TickRate then
			timer_acc=0
			if #nodes>0 then tickMycelium()
			elseif partCount<CFG.MaxParts then
				local o=getOrigin(); spawnWave(o+Vector3.new(math.random(-28,28),0,math.random(-28,28)))
			end
		end
		if waveTimer>=CFG.AutoWaveSec then
			waveTimer=0; local o=getOrigin(); spawnWave(o+Vector3.new(math.random(-62,62),0,math.random(-62,62)))
		end
	end
	if memTimer>=CFG.MemoryUpdateRate then memTimer=0; updateMemory() end
	if npcScanTimer>=CFG.NpcScanInterval then npcScanTimer=0; scanNpcs() end

	updateSpores(dt); tickFruitBodies(dt); processFruitPending()
	checkFruiting(dt); tickBioLum(dt); tickSpread()

	gridCleanT+=dt
	if gridCleanT>=90 then
		gridCleanT=0
		if partCount<CFG.MaxParts*0.4 then spatialGrid={} end
		for i=#bioLumReg,1,-1 do
			if not(bioLumReg[i].part and bioLumReg[i].part.Parent) then table.remove(bioLumReg,i) end
		end
	end
end)


-- ════════════════════════════════════════════════════════════════════
--  NUEVOS SISTEMAS v3.2 — INFECCIÓN AVANZADA + MICELIO MEJORADO
-- ════════════════════════════════════════════════════════════════════

-- ── NUEVAS VARIABLES GLOBALES ────────────────────────────────────────
local tendrilRegistry  = {}   -- {part, pos, age} para pulsos y anastomosis
local clusterZones     = {}   -- {pos, radius, time} zonas de alta densidad
local aerialNodes      = {}   -- nodos que cuelgan desde techos
local networkPulseT    = 0
local clusterScanT     = 0
local anastomosisT     = 0
local aerialT          = 0
local infectionHudGuis = {}   -- player → HUD de progreso
local veinGuis         = {}   -- player → ScreenGui de venas
local heartbeatGuis    = {}   -- player → ScreenGui de "latido"
local parasiteActive   = {}   -- player → bool
local infectionPct     = {}   -- player → 0..100

-- Velocidad de expansión por fase (multiplicador del TickRate)
local PHASE_SPEED = {1.0, 0.82, 0.65, 0.45, 0.28}

local function getExpansionSpeed()
	local p = math.max(1, math.min(5, currentPhase+1))
	return CFG.TickRate * PHASE_SPEED[p]
end

-- ════════════════════════════════════════════════════════════════════
--  REGISTRO DE TENDRILS (para pulsación y anastomosis)
-- ════════════════════════════════════════════════════════════════════
local function registerTendril(part, pos, age)
	if not (part and part.Parent) then return end
	table.insert(tendrilRegistry, {part=part, pos=pos, age=age, pulse=0})
	if #tendrilRegistry > 400 then table.remove(tendrilRegistry, 1) end
end

-- ════════════════════════════════════════════════════════════════════
--  PULSOS EN TODA LA RED (onda de color que viaja desde el origen)
--  Más denso y visible que la bioluminiscencia
-- ════════════════════════════════════════════════════════════════════
local function triggerNetworkPulse()
	if #tendrilRegistry == 0 then return end
	local origin = getOrigin()
	local pulseColor = rN()
	local maxD = 0

	-- Calcula distancia máxima
	for _,t in ipairs(tendrilRegistry) do
		local d = (t.pos - origin).Magnitude
		if d > maxD then maxD = d end
	end
	if maxD < 1 then return end

	for _,t in ipairs(tendrilRegistry) do
		local p = t.part
		if not (p and p.Parent) then continue end
		local d = (t.pos - origin).Magnitude
		local delay_ = (d / maxD) * 2.8  -- onda tarda 2.8s en cruzar toda la red
		task.delay(delay_, function()
			if not (p and p.Parent) then return end
			local oc, om = p.Color, p.Material
			-- Color basado en edad del tendril: jóvenes → morado, viejos → neon
			local c = t.age > 0.6 and pulseColor or lerpC(Color3.fromRGB(180,0,255), pulseColor, t.age)
			p.Color = c; p.Material = Enum.Material.Neon
			task.wait(0.055 + math.random()*0.04)
			if p and p.Parent then
				TweenService:Create(p, TweenInfo.new(0.35), {Color=oc}):Play()
				p.Material = om
			end
		end)
	end
end

local function tickNetworkPulse(dt)
	networkPulseT += dt
	local interval = 8 - currentPhase * 1.2  -- más rápido en fases altas
	if networkPulseT >= math.max(2, interval) then
		networkPulseT = 0
		triggerNetworkPulse()
	end
end

-- ════════════════════════════════════════════════════════════════════
--  ZONAS CLUSTER (micelio que se densifica y forma masas oscuras)
-- ════════════════════════════════════════════════════════════════════
local function spawnCorruptionCluster(pos, normal)
	if partCount >= CFG.MaxParts - 8 then return end

	-- Masa central grande
	local crad = 3.5 + math.random()*4.5
	local cp = Instance.new("Part")
	cp.Shape = Enum.PartType.Ball
	cp.Anchored = true; cp.CanCollide = false; cp.CastShadow = false
	local cy = crad * (0.25 + math.random()*0.35)
	cp.Size = Vector3.new(crad*2, cy*2, crad*1.6)
	local br = normal:Cross(Vector3.new(0,0,1)); br = br.Magnitude<0.001 and Vector3.new(1,0,0) or br.Unit
	cp.CFrame = CFrame.fromMatrix(pos + normal*cy, br, normal, -br:Cross(normal).Unit)
		* CFrame.Angles(math.random()*math.pi, math.random()*math.pi*2, 0)
	cp.Color = rD(); cp.Material = Enum.Material.SmoothPlastic
	cp.Transparency = 1; cp.Parent = folder; partCount += 1

	TweenService:Create(cp, TweenInfo.new(0.8, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
		{Transparency = 0.05}):Play()

	-- Luz muy tenue oscura
	local li = Instance.new("PointLight"); li.Color = Color3.fromRGB(60,0,120)
	li.Range = crad*3; li.Brightness = 0.5; li.Parent = cp

	-- Satélites pequeños alrededor
	for _ = 1, math.random(3,7) do
		if partCount >= CFG.MaxParts then break end
		local angle = math.random()*math.pi*2
		local dist  = crad*0.6 + math.random()*crad*0.8
		local spos  = pos + normal*0.3
			+ Vector3.new(math.cos(angle)*dist, math.random()*cy*0.8, math.sin(angle)*dist)
		local sp = Instance.new("Part")
		sp.Shape = Enum.PartType.Ball; sp.Anchored = true; sp.CanCollide = false; sp.CastShadow = false
		local sr = 0.4 + math.random()*1.2
		sp.Size = Vector3.new(sr*2, sr, sr*2)
		sp.CFrame = CFrame.new(spos) * CFrame.Angles(math.random()*math.pi, math.random()*math.pi*2, 0)
		local isN = math.random() < 0.18
		sp.Color = isN and rN() or rD()
		sp.Material = isN and Enum.Material.Neon or Enum.Material.SmoothPlastic
		sp.Transparency = 1; sp.Parent = folder; partCount += 1
		task.delay(math.random()*0.5, function()
			if sp and sp.Parent then
				TweenService:Create(sp, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
					{Transparency = isN and 0 or 0.08}):Play()
			end
		end)
	end

	-- Parpadeo periódico en la masa
	task.spawn(function()
		while cp and cp.Parent do
			task.wait(3 + math.random()*6)
			if not (cp and cp.Parent) then break end
			local nc = rN()
			TweenService:Create(cp, TweenInfo.new(0.06), {Color=nc}):Play()
			li.Color = nc; li.Brightness = 2.5
			task.wait(0.07)
			TweenService:Create(cp, TweenInfo.new(0.25), {Color=rD()}):Play()
			TweenService:Create(li, TweenInfo.new(0.25), {Brightness=0.5, Color=Color3.fromRGB(60,0,120)}):Play()
		end
	end)

	table.insert(clusterZones, {pos=pos, radius=crad, time=tick()})
end

local function tickClusterScan(dt)
	clusterScanT += dt
	if clusterScanT < 12 then return end
	clusterScanT = 0
	if partCount >= CFG.MaxParts - 10 then return end

	-- Limpia clusters viejos del registro
	local t = tick(); local fresh = {}
	for _,c in ipairs(clusterZones) do
		if t - c.time < 180 then table.insert(fresh, c) end
	end
	clusterZones = fresh

	-- Busca zonas densas en blobReg
	if #blobReg < 20 then return end
	local sample = blobReg[math.random(math.max(1,#blobReg-30), #blobReg)]
	if not sample then return end

	local density = getBlobDensity(sample.pos, 10)
	if density < 18 then return end

	-- Verifica que no haya ya un cluster cerca
	for _,c in ipairs(clusterZones) do
		if (c.pos - sample.pos).Magnitude < c.radius*2.5 then return end
	end

	local gp,gn = castSurf(sample.pos + Vector3.new(0,3,0), Vector3.new(0,-1,0))
	if gp then spawnCorruptionCluster(gp, gn) end
end

-- ════════════════════════════════════════════════════════════════════
--  ANASTOMOSIS (reconexión de ramas cercanas con un puente)
--  Igual que los hongos reales: dos hifas que se fusionan al tocarse
-- ════════════════════════════════════════════════════════════════════
local anastomosisReg = {}  -- {pos} extremos de tendrils muertos (life==0)

local function tryAnastomosis()
	anastomosisT = 0
	if #anastomosisReg < 2 then return end
	if partCount >= CFG.MaxParts - 2 then return end

	-- Busca par cercano
	for i = #anastomosisReg, math.max(1, #anastomosisReg-25), -1 do
		for j = i-1, math.max(1, i-10), -1 do
			local a, b = anastomosisReg[i], anastomosisReg[j]
			local d = (a-b).Magnitude
			if d > 0.5 and d < 7 then
				-- Crea puente de fusión
				local mid = (a+b)/2
				local p = Instance.new("Part")
				p.Anchored=true; p.CanCollide=false; p.CastShadow=false
				p.Size = Vector3.new(0.18, 0.07, d)
				local look = (b-a).Unit
				local up = Vector3.new(0,1,0)
				local right = up:Cross(look); right = right.Magnitude<0.001 and Vector3.new(1,0,0) or right.Unit
				p.CFrame = CFrame.fromMatrix(mid, right, look:Cross(right).Unit)
				p.Color = lerpC(rD(), Color3.fromRGB(120,0,200), 0.4)
				p.Material = Enum.Material.SmoothPlastic
				p.Transparency = 1; p.Parent = folder; partCount += 1
				TweenService:Create(p, TweenInfo.new(0.3), {Transparency=0.12}):Play()

				-- Pequeño flash en el punto de fusión
				spawnFlash(mid, Vector3.new(0,1,0), 0.25)

				table.remove(anastomosisReg, i)
				table.remove(anastomosisReg, math.min(j, #anastomosisReg))
				return
			end
		end
	end

	-- Limita tamaño
	while #anastomosisReg > 80 do table.remove(anastomosisReg, 1) end
end

-- ════════════════════════════════════════════════════════════════════
--  MICELIO AÉREO (filamentos que cuelgan desde superficies superiores)
-- ════════════════════════════════════════════════════════════════════
local function trySpawnAerial(pos)
	-- Desde la posición actual, raycast hacia arriba buscando un techo
	local r = workspace:Raycast(pos + Vector3.new(0,0.5,0), Vector3.new(0,1,0)*18, rpMain)
	if not r then return end
	if r.Normal.Y > -0.3 then return end  -- Solo superficies que miren hacia abajo (techos)

	local ceilPos  = r.Position + r.Normal * CFG.SurfaceOff
	local dropLen  = (ceilPos - pos).Magnitude

	if dropLen < 1.5 or dropLen > 16 then return end
	if partCount >= CFG.MaxParts - 3 then return end

	-- Filamento colgante: parte del techo hacia abajo
	local segs = math.floor(dropLen / 0.8)
	for seg = 1, math.min(segs, 8) do
		if partCount >= CFG.MaxParts then break end
		local frac  = seg / segs
		local segPos = lerpC(Color3.new(ceilPos.X/255,ceilPos.Y/255,ceilPos.Z/255),
			Color3.new(pos.X/255,pos.Y/255,pos.Z/255), frac)  -- dummy, usamos lerp manual
		local p3 = ceilPos + (pos - ceilPos) * frac
		-- Pequeño blob/tendril colgante
		local hang = Instance.new("Part")
		hang.Anchored=true; hang.CanCollide=false; hang.CastShadow=false
		local w = 0.08 + math.random()*0.06 - frac*0.04
		hang.Size = Vector3.new(math.max(0.04,w), 0.8+math.random()*0.5, math.max(0.04,w))
		hang.CFrame = CFrame.new(p3 + Vector3.new((math.random()-0.5)*0.4, 0, (math.random()-0.5)*0.4))
		hang.Color = mycelColor(0.25 + frac*0.5)
		hang.Material = Enum.Material.Fabric
		hang.Transparency = 0.15 + frac*0.35
		hang.Parent = folder; partCount += 1

		-- Parpadeo ocasional
		if frac > 0.7 and math.random() < 0.15 then
			task.spawn(function()
				while hang and hang.Parent do
					task.wait(3 + math.random()*8)
					if not (hang and hang.Parent) then break end
					local oc = hang.Color
					hang.Color = rN(); hang.Material = Enum.Material.Neon
					task.wait(0.03)
					if hang and hang.Parent then hang.Color = oc; hang.Material = Enum.Material.Fabric end
				end
			end)
		end
	end
end

local function tickAerial(dt)
	aerialT += dt
	if aerialT < 0.8 then return end
	aerialT = 0
	if #blobReg == 0 then return end
	if math.random() > 0.12 then return end  -- Solo 12% de los ticks
	local b = blobReg[math.random(#blobReg)]
	if b then trySpawnAerial(b.pos) end
end

-- ════════════════════════════════════════════════════════════════════
--  INFECCIÓN: VENAS EN PANTALLA
--  Venas negras/moradas crecen desde los bordes según el stage
-- ════════════════════════════════════════════════════════════════════
local function buildVeinGui(player)
	if not (player and player.Parent) then return end
	if veinGuis[player] then return end

	local sg = Instance.new("ScreenGui"); sg.Name = "__PibbyVeins"
	sg.ResetOnSpawn = false; sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	sg.Parent = player:WaitForChild("PlayerGui")
	veinGuis[player] = sg

	-- Crea "venas" como frames estrechos y torcidos desde los 4 bordes
	local function makeVein(side)
		-- side: "top","bot","left","right"
		for _ = 1, math.random(3,7) do
			local f = Instance.new("Frame")
			f.BorderSizePixel = 0
			local isH = side=="top" or side=="bot"
			-- Posición base en el borde
			local bx = isH and math.random()*0.9 or (side=="left" and 0 or 0.92)
			local by = isH and (side=="top" and 0 or 0.92) or math.random()*0.9
			f.Position = UDim2.new(bx, 0, by, 0)
			-- Tamaño inicial: muy pequeño
			f.Size = UDim2.new(0, 2, 0, 2)
			-- Color: mezcla oscuro/morado
			f.BackgroundColor3 = math.random()<0.4 and Color3.fromRGB(80,0,140) or rD()
			f.BackgroundTransparency = 0.2
			f.Name = "vein_"..side.."_"..math.random(9999)
			f.Parent = sg
		end
	end
	makeVein("top"); makeVein("bot"); makeVein("left"); makeVein("right")

	-- Anima las venas expandiéndose según el stage
	task.spawn(function()
		while sg and sg.Parent and infected[player] do
			local stage = infected[player] and infected[player].stage or 0
			local spread = stage / 5  -- 0 → 1

			for _,f in ipairs(sg:GetChildren()) do
				if f:IsA("Frame") and f.Name:sub(1,5)=="vein_" then
					local side = f.Name:sub(6,8)
					local isH = side=="top" or side=="bot"
					-- Crece proporcionalmente al stage
					local len = spread * (0.25 + math.random()*0.35)
					local w   = 0.008 + spread*0.018 + math.random()*0.006

					local tw
					if isH then
						tw = TweenInfo.new(1.8 + math.random()*1.5)
						TweenService:Create(f, tw, {Size=UDim2.new(w, 0, len, 0)}):Play()
					else
						tw = TweenInfo.new(1.8 + math.random()*1.5)
						TweenService:Create(f, tw, {Size=UDim2.new(len, 0, w, 0)}):Play()
					end

					-- Parpadeo neon en stages altos
					if stage >= 3 and math.random() < 0.08 then
						task.spawn(function()
							task.wait(math.random()*2)
							if not (f and f.Parent) then return end
							f.BackgroundColor3 = rN()
							task.wait(0.05)
							if f and f.Parent then
								f.BackgroundColor3 = math.random()<0.4 and Color3.fromRGB(80,0,140) or rD()
							end
						end)
					end
				end
			end
			task.wait(2.2 + math.random()*1.8)
		end
		if sg then sg:Destroy() end
		veinGuis[player] = nil
	end)
end

-- ════════════════════════════════════════════════════════════════════
--  INFECCIÓN: HUD DE PROGRESO (% de corrupción visible)
-- ════════════════════════════════════════════════════════════════════
local function buildInfectionHud(player)
	if not (player and player.Parent) then return end
	if infectionHudGuis[player] then return end

	local sg = Instance.new("ScreenGui"); sg.Name = "__PibbyHud"
	sg.ResetOnSpawn = false; sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	sg.Parent = player:WaitForChild("PlayerGui")
	infectionHudGuis[player] = sg

	-- Barra de corrupción en esquina inferior izquierda
	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(0, 160, 0, 20)
	frame.Position = UDim2.new(0, 12, 1, -38)
	frame.BackgroundColor3 = Color3.fromRGB(8, 0, 18)
	frame.BackgroundTransparency = 0.3
	frame.BorderSizePixel = 0; frame.Parent = sg

	local corner = Instance.new("UICorner"); corner.CornerRadius = UDim.new(0,4); corner.Parent = frame

	local fill = Instance.new("Frame"); fill.Name = "fill"
	fill.Size = UDim2.new(0, 0, 1, 0)
	fill.Position = UDim2.new(0,0,0,0)
	fill.BackgroundColor3 = Color3.fromRGB(140,0,255)
	fill.BackgroundTransparency = 0; fill.BorderSizePixel = 0; fill.Parent = frame
	local fc = Instance.new("UICorner"); fc.CornerRadius = UDim.new(0,4); fc.Parent = fill

	local lbl = Instance.new("TextLabel"); lbl.Name = "lbl"
	lbl.Size = UDim2.new(1,0,1,0); lbl.Position = UDim2.new(0,0,0,0)
	lbl.BackgroundTransparency = 1
	lbl.Text = "CORRUPCIÓN 0%"
	lbl.TextColor3 = Color3.fromRGB(255,200,255)
	lbl.TextSize = 9; lbl.Font = Enum.Font.Code
	lbl.TextStrokeTransparency = 0.5; lbl.Parent = frame

	-- Label de stage
	local stLbl = Instance.new("TextLabel"); stLbl.Name = "stage"
	stLbl.Size = UDim2.new(0,160,0,14); stLbl.Position = UDim2.new(0,12,1,-56,0,0)
	stLbl.BackgroundTransparency = 1
	stLbl.Text = ""; stLbl.TextColor3 = rN()
	stLbl.TextSize = 9; stLbl.Font = Enum.Font.Code
	stLbl.TextStrokeTransparency = 0.4; stLbl.Parent = sg

	local STAGE_NAMES = {
		[0]="CONTACTO", [1]="COLONIZACIÓN", [2]="INVASIÓN",
		[3]="ABSORCIÓN", [4]="CONTROL", [5]="ASIMILACIÓN COMPLETA"
	}

	-- Update loop
	task.spawn(function()
		while sg and sg.Parent and infected[player] do
			local data = infected[player]
			if not data then break end
			local pct = math.clamp(infectionPct[player] or 0, 0, 100)
			local col = lerpC(Color3.fromRGB(140,0,255), Color3.fromRGB(255,0,0), pct/100)
			TweenService:Create(fill, TweenInfo.new(0.4), {Size=UDim2.new(pct/100,0,1,0), BackgroundColor3=col}):Play()
			lbl.Text = "CORRUPCIÓN "..math.floor(pct).."%"
			stLbl.Text = "◈ "..( STAGE_NAMES[data.stage] or "" )
			stLbl.TextColor3 = data.stage >= 4 and rN() or Color3.fromRGB(200,140,255)

			-- Parpadeo en porcentaje alto
			if pct > 75 and math.random() < 0.2 then
				lbl.TextColor3 = rN()
				task.wait(0.08)
				lbl.TextColor3 = Color3.fromRGB(255,200,255)
			end
			task.wait(0.35)
		end
		if sg then sg:Destroy() end
		infectionHudGuis[player] = nil
	end)
end

-- ════════════════════════════════════════════════════════════════════
--  INFECCIÓN: LATIDO CORRUPTO EN PANTALLA
--  Pulso rítmico que se acelera y distorsiona con el avance
-- ════════════════════════════════════════════════════════════════════
local function buildHeartbeatGui(player)
	if not (player and player.Parent) then return end
	if heartbeatGuis[player] then return end

	local sg = Instance.new("ScreenGui"); sg.Name = "__PibbyHB"
	sg.ResetOnSpawn = false; sg.Parent = player:WaitForChild("PlayerGui")
	heartbeatGuis[player] = sg

	local hb = Instance.new("Frame")
	hb.Size = UDim2.new(1,0,1,0); hb.BackgroundColor3 = Color3.fromRGB(80,0,130)
	hb.BackgroundTransparency = 1; hb.BorderSizePixel = 0; hb.Parent = sg

	task.spawn(function()
		while sg and sg.Parent and infected[player] do
			local data = infected[player]; if not data then break end
			local stage = data.stage
			-- Intervalo de latido depende del stage (más rápido = más infectado)
			local interval = math.max(0.25, 1.2 - stage*0.18)
			local intensity = stage * 0.04   -- transparencia mínima al pulsar

			-- Pulso: flash muy rápido en la pantalla
			TweenService:Create(hb, TweenInfo.new(0.06), {BackgroundTransparency = intensity}):Play()
			task.wait(0.07)
			TweenService:Create(hb, TweenInfo.new(0.18), {BackgroundTransparency = 1}):Play()

			-- En stage 4+: segundo pulso rápido (arritmia)
			if stage >= 4 and math.random() < 0.45 then
				task.wait(0.12)
				TweenService:Create(hb, TweenInfo.new(0.04), {BackgroundTransparency = intensity*0.6}):Play()
				task.wait(0.05)
				TweenService:Create(hb, TweenInfo.new(0.14), {BackgroundTransparency = 1}):Play()
			end

			-- En stage 5: color random del pulso
			if stage >= 5 then hb.BackgroundColor3 = rN() end

			task.wait(math.max(0.22, interval - 0.13))
		end
		if sg then sg:Destroy() end
		heartbeatGuis[player] = nil
	end)
end

-- ════════════════════════════════════════════════════════════════════
--  INFECCIÓN: PARÁSITO — CONTROL INVOLUNTARIO DEL MOVIMIENTO
--  En stage 4+, periódicamente toma el control del personaje
-- ════════════════════════════════════════════════════════════════════
local function startParasiteControl(player)
	if parasiteActive[player] then return end
	parasiteActive[player] = true

	task.spawn(function()
		local char = player.Character
		if not char then parasiteActive[player]=nil; return end
		local hrp  = char:FindFirstChild("HumanoidRootPart")
		local hum  = char:FindFirstChildOfClass("Humanoid")
		if not hrp or not hum then parasiteActive[player]=nil; return end

		while char and char.Parent and infected[player] and infected[player].stage >= 4 do
			task.wait(4 + math.random()*8)
			if not (char and char.Parent and infected[player]) then break end

			-- Episodio de control: 1-3 segundos de movimiento forzado
			local dur = 1.2 + math.random()*2.2
			local t0  = tick()
			local angle = math.random()*math.pi*2

			-- Mensaje en pantalla breve
			screenMsg(player, "[ CONTROL OVERRIDE ]", Color3.fromRGB(255,0,100), 1.5)

			while tick()-t0 < dur and char and char.Parent and infected[player] do
				-- Gira y mueve en dirección aleatoria cambiante
				angle += (math.random()-0.5)*1.2
				local moveDir = Vector3.new(math.cos(angle), 0, math.sin(angle))
				hum:Move(moveDir, false)

				-- Flash periódico en cabeza
				if math.random() < 0.12 then
					local head = char:FindFirstChild("Head")
					if head then
						local fl = Instance.new("PointLight"); fl.Color=rN()
						fl.Range=22; fl.Brightness=5; fl.Parent=head
						TweenService:Create(fl,TweenInfo.new(0.3),{Brightness=0}):Play()
						task.delay(0.35, function() if fl then fl:Destroy() end end)
					end
				end
				task.wait(0.08)
			end
			-- Detiene el movimiento forzado
			if hum and hum.Parent then hum:Move(Vector3.new(0,0,0), false) end
		end
		parasiteActive[player] = nil
	end)
end

-- ════════════════════════════════════════════════════════════════════
--  INFECCIÓN: ACTUALIZACIÓN DE PORCENTAJE
-- ════════════════════════════════════════════════════════════════════
local STAGE_PCT = {[0]=2, [1]=20, [2]=42, [3]=65, [4]=85, [5]=100}

local function updateInfectionPct(dt)
	for pl, data in pairs(infected) do
		local target = STAGE_PCT[data.stage] or 0
		local current = infectionPct[pl] or 0
		-- Sube gradualmente hacia el target
		local speed = 8 + data.stage*3  -- más rápido en stages altos
		infectionPct[pl] = math.min(target, current + speed*dt)
	end
end

-- ════════════════════════════════════════════════════════════════════
--  HOOK EN startInfection: AÑADE LOS NUEVOS EFECTOS
--  Wrappea la función original para agregar venas, HUD, heartbeat
-- ════════════════════════════════════════════════════════════════════
local _origStartInfection = startInfection
function startInfection(player)
	_origStartInfection(player)
	-- Inicia los nuevos sistemas con pequeño delay
	task.delay(0.1, function()
		if not infected[player] then return end
		infectionPct[player] = 0
		buildVeinGui(player)
		buildInfectionHud(player)
		buildHeartbeatGui(player)
	end)
	-- Inicia control parasitario cuando llega a stage 4
	task.spawn(function()
		while infected[player] do
			task.wait(0.5)
			if infected[player] and infected[player].stage >= 4 then
				startParasiteControl(player)
				break
			end
		end
	end)
end

-- ════════════════════════════════════════════════════════════════════
--  HOOK EN tickMycelium: REGISTRA TENDRILS Y ANASTOMOSIS
-- ════════════════════════════════════════════════════════════════════
local _origTickMycelium = tickMycelium
function tickMycelium()
	_origTickMycelium()
	-- La versión original ya no devuelve nada, todo va por side effects
end

-- Sobreescribe spawnTendril para registrar automáticamente
local _origSpawnTendril = spawnTendril
function spawnTendril(from, to, sn, age, isNeon, isRhizo)
	local p = _origSpawnTendril(from, to, sn, age, isNeon, isRhizo)
	if p and not isRhizo then
		registerTendril(p, (from+to)/2, age)
	end
	return p
end

-- ════════════════════════════════════════════════════════════════════
--  HOOK EN addNode: REGISTRA EXTREMOS PARA ANASTOMOSIS
-- ════════════════════════════════════════════════════════════════════
-- Cuando un nodo muere (life==0), su posición va a anastomosisReg
-- Esto se hace en tickMycelium pero necesitamos acceso...
-- Lo hacemos en el heartbeat

-- ════════════════════════════════════════════════════════════════════
--  HEARTBEAT EXTENDIDO (reemplaza el anterior)
-- ════════════════════════════════════════════════════════════════════
-- Desconectamos el viejo heartbeat no es posible directamente,
-- así que usamos una variable de control
local v32Active = true

-- Variables de timer para v3.2
local v32_timer    = 0
local expandSpeed  = CFG.TickRate  -- se actualiza dinámicamente

RunService.Heartbeat:Connect(function(dt)
	if not v32Active then return end

	-- Sistemas de expansión mejorados
	tickNetworkPulse(dt)
	tickClusterScan(dt)
	tickAerial(dt)
	updateInfectionPct(dt)

	-- Anastomosis: cuando hay nodos muertos, los registra
	v32_timer += dt
	if v32_timer >= 2.5 then
		v32_timer = 0
		-- Recoge posiciones de blobs recientes como candidatos
		if #blobReg > 5 then
			local sample = blobReg[math.random(#blobReg)]
			if sample then table.insert(anastomosisReg, sample.pos) end
		end
		-- Intenta anastomosis
		if #anastomosisReg >= 2 then tryAnastomosis() end
		anastomosisT += 2.5
	end

	-- Actualiza velocidad de expansión según fase
	expandSpeed = getExpansionSpeed()
end)

-- ════════════════════════════════════════════════════════════════════

-- ════════════════════════════════════════════════════════════════════
--  v3.3 — SISTEMA DE PRESIÓN Y CONCIENCIA ESPACIAL
--  El micelio detecta si está atrapado, acumula presión y la libera
--  por el primer hueco que encuentre (pared, suelo, techo, grieta)
-- ════════════════════════════════════════════════════════════════════

-- ── NUEVAS VARIABLES DE PRESIÓN ──────────────────────────────────────
local pressureMap    = {}   -- clave gKey → {pressure, pos, normal, dir}
local pressureTimer  = 0
local PRESSURE_MAX   = 28   -- presión para detonar una explosión
local PRESSURE_DECAY = 0.08 -- cuánto cae la presión por tick si hay salida
local pressureFlashT = 0

-- Direcciones de sondeo para detectar huecos (6 caras + diagonales)
local PROBE_DIRS = {
	Vector3.new( 1, 0, 0), Vector3.new(-1, 0, 0),
	Vector3.new( 0, 1, 0), Vector3.new( 0,-1, 0),
	Vector3.new( 0, 0, 1), Vector3.new( 0, 0,-1),
	Vector3.new( 1, 0, 1).Unit, Vector3.new(-1, 0, 1).Unit,
	Vector3.new( 1, 0,-1).Unit, Vector3.new(-1, 0,-1).Unit,
	Vector3.new( 1, 1, 0).Unit, Vector3.new(-1, 1, 0).Unit,
	Vector3.new( 0, 1, 1).Unit, Vector3.new( 0,-1, 1).Unit,
	Vector3.new( 1,-1, 0).Unit, Vector3.new(-1,-1, 0).Unit,
}

-- Sondea en una dirección buscando una superficie o hueco
-- Devuelve: "surface" + pos+normal, "gap" (vacío largo), o nil
local function probeDirection(from, dir, maxLen)
	maxLen = maxLen or 24
	-- Raycast principal
	local rMain = workspace:Raycast(from, dir * maxLen, rpMain)
	if rMain then
		-- Hay algo sólido
		local dist = (rMain.Position - from).Magnitude
		return "surface", rMain.Position + rMain.Normal * CFG.SurfaceOff, rMain.Normal, dist
	end
	-- No hay nada → hueco / espacio abierto
	return "gap", from + dir * maxLen, dir, maxLen
end

-- Analiza el entorno de una posición y clasifica la zona
-- Devuelve una tabla con: trapped (bool), exits (lista de dirs libres),
-- surfaces (lista de {pos,normal,dir,dist}), openSpace (bool)
local function analyzeSurroundings(pos, searchRadius)
	searchRadius = searchRadius or 18
	local surfaces = {}
	local exits    = {}
	local wallCount = 0
	local openCount = 0

	for _, dir in ipairs(PROBE_DIRS) do
		local kind, spos, snorm, dist = probeDirection(pos, dir, searchRadius)
		if kind == "surface" then
			wallCount += 1
			table.insert(surfaces, {pos=spos, normal=snorm, dir=dir, dist=dist})
		else
			openCount += 1
			table.insert(exits, {dir=dir, pos=spos, dist=dist})
		end
	end

	local trapped  = wallCount >= 12 and openCount <= 2  -- muy rodeado, pocas salidas
	local openSpace = openCount >= 10                     -- espacio muy abierto

	return {
		trapped   = trapped,
		exits     = exits,
		surfaces  = surfaces,
		wallCount = wallCount,
		openCount = openCount,
		openSpace = openSpace,
	}
end

-- ════════════════════════════════════════════════════════════════════
--  NODO CONSCIENTE (reemplaza el tick de nodo normal)
--  Cada nodo ahora sabe si está atrapado y actúa en consecuencia
-- ════════════════════════════════════════════════════════════════════

-- Convierte un nodo atrapado en presión en el grid
local function addPressure(pos, dir, normal, amount)
	local k = gKey(pos)
	if not pressureMap[k] then
		pressureMap[k] = {pressure=0, pos=pos, normal=normal, dir=dir, exits={}, analyzed=false}
	end
	pressureMap[k].pressure = math.min(pressureMap[k].pressure + amount, PRESSURE_MAX * 2)
	pressureMap[k].pos    = pos
	pressureMap[k].normal = normal
	pressureMap[k].dir    = dir
end

-- Cuando la presión supera el umbral, busca el mejor hueco y explota
local function releasePressure(k, data)
	local pressure = data.pressure
	if pressure < PRESSURE_MAX then return end
	pressureMap[k] = nil  -- consume la presión

	-- Re-analiza el entorno para encontrar la mejor salida
	local env = analyzeSurroundings(data.pos, 28)

	-- Flash visible de acumulación
	local flashScale = math.min(4, 0.8 + pressure / PRESSURE_MAX * 2.5)
	spawnFlash(data.pos, data.normal or Vector3.new(0,1,0), flashScale)
	task.spawn(function()
		for _ = 1, 3 do
			task.wait(0.04)
			spawnFlash(data.pos, data.normal or Vector3.new(0,1,0), flashScale * 0.6)
		end
	end)

	if #env.exits == 0 then
		-- Completamente atrapado: fuerza expansión hacia la superficie más lejana
		-- (intenta romper por la pared más débil = la más lejana)
		local best = nil; local bd = 0
		for _,s in ipairs(env.surfaces) do
			if s.dist > bd then best=s; bd=s.dist end
		end
		if best then
			-- Lanza oleada forzada en esa dirección
			local life = math.random(CFG.LifeMin, CFG.LifeMax) + math.floor(pressure/3)
			for i = 1, math.random(4, 8) do
				local spread = (math.random()-0.5)*0.8
				local fd = rotXZ(best.dir, spread)
				table.insert(nodes, {
					pos=data.pos, dir=fd, normal=best.normal,
					life=life, maxLife=life, depth=0, age=0.3,
					nodeType="pressure_burst"
				})
			end
		end
		return
	end

	-- Ordena salidas por mayor apertura (prefiere el hueco más grande)
	table.sort(env.exits, function(a,b) return a.dist > b.dist end)

	-- Elige las 2-3 mejores salidas
	local numExits = math.min(math.ceil(pressure / PRESSURE_MAX), #env.exits, 3)
	for i = 1, numExits do
		local exit = env.exits[i]
		-- Proyecta la salida a una superficie real
		local gp, gn = castSurf(exit.pos + exit.dir*2, -exit.dir, 8)
		if not gp then
			-- No hay suelo en esa dirección, intenta bajar
			gp, gn = castSurf(exit.pos, Vector3.new(0,-1,0), CFG.RayDown)
		end
		if not gp then gp = exit.pos; gn = Vector3.new(0,1,0) end

		-- Oleada proporcional a la presión
		local burstLife = math.random(CFG.LifeMin+8, CFG.LifeMax+20) + math.floor(pressure/4)
		local burstCount = math.random(5, 10 + math.floor(pressure/3))

		for j = 1, burstCount do
			if #nodes >= CFG.MaxNodes or partCount >= CFG.MaxParts then break end
			local jitter = (math.random()-0.5)*math.pi*0.55
			local bdir = rotXZ(exit.dir, jitter)
			table.insert(nodes, {
				pos=gp, dir=bdir, normal=gn,
				life=burstLife, maxLife=burstLife,
				depth=0, age=0.1, nodeType="pressure_burst"
			})
		end

		-- Blob en el punto de irrupción
		spawnBlob(gp, gn, 3.5 + math.random()*3 + pressure*0.08, 0.25)
		markOcc(gp)
		spawnFlash(gp, gn, 1.2 + pressure*0.04)
		print("[Pibby] 💥 Presión liberada en hueco! ("..math.floor(pressure).." → "..burstCount.." nodos)")
	end
end

-- ════════════════════════════════════════════════════════════════════
--  TICK DE PRESIÓN
-- ════════════════════════════════════════════════════════════════════
local function tickPressure(dt)
	pressureTimer += dt
	if pressureTimer < 0.35 then return end
	pressureTimer = 0

	local toRelease = {}
	for k, data in pairs(pressureMap) do
		-- Decae si tiene salidas
		if data.openCount and data.openCount > 3 then
			data.pressure = math.max(0, data.pressure - PRESSURE_DECAY * 10)
		end
		if data.pressure <= 0 then
			pressureMap[k] = nil
		elseif data.pressure >= PRESSURE_MAX then
			table.insert(toRelease, k)
		end
	end
	for _, k in ipairs(toRelease) do
		if pressureMap[k] then
			releasePressure(k, pressureMap[k])
		end
	end

	-- Flash sutil en zonas de alta presión (visual feedback)
	pressureFlashT += dt
	if pressureFlashT > 1.2 then
		pressureFlashT = 0
		for _, data in pairs(pressureMap) do
			if data.pressure > PRESSURE_MAX * 0.6 and partCount < CFG.MaxParts then
				local intensity = data.pressure / (PRESSURE_MAX * 2)
				-- Luz pulsante morada en la zona de presión
				local pfl = Instance.new("Part")
				pfl.Anchored=true; pfl.CanCollide=false; pfl.CastShadow=false
				pfl.Shape=Enum.PartType.Ball
				pfl.Size=Vector3.new(0.2,0.2,0.2)
				pfl.Position=data.pos+Vector3.new(0,0.4,0)
				pfl.Color=lerpC(Color3.fromRGB(120,0,200), Color3.fromRGB(255,0,255), intensity)
				pfl.Material=Enum.Material.Neon; pfl.Transparency=0.3
				pfl.Parent=folder; partCount+=1
				local pli=Instance.new("PointLight"); pli.Color=pfl.Color
				pli.Range=8+intensity*12; pli.Brightness=1.5+intensity*2; pli.Parent=pfl
				TweenService:Create(pfl,TweenInfo.new(0.6),{Size=Vector3.new(intensity*3,intensity*3,intensity*3),Transparency=1}):Play()
				TweenService:Create(pli,TweenInfo.new(0.6),{Brightness=0}):Play()
				task.delay(0.65,function() if pfl then pfl:Destroy(); partCount=math.max(0,partCount-1) end end)
			end
		end
	end
end

-- ════════════════════════════════════════════════════════════════════
--  NODO CONSCIENTE DEL ENTORNO
--  Envuelve el proceso de un nodo para que detecte si está atrapado
-- ════════════════════════════════════════════════════════════════════

-- Intervalo de análisis espacial (no cada tick para no matar perf)
local nodeAnalysisCounter = 0
local NODE_ANALYSIS_FREQ  = 12  -- analiza 1 de cada N nodos por tick

-- Sobreescribe tickMycelium para añadir conciencia espacial
local _v32TickMycelium = tickMycelium
function tickMycelium()
	-- Antes del tick normal, pre-procesa nodos de pressure_burst
	-- (tienen mayor vida y no necesitan análisis espacial)
	local burstNodes = {}
	local normalNodes = {}
	for _, node in ipairs(nodes) do
		if node.nodeType == "pressure_burst" then
			table.insert(burstNodes, node)
		else
			table.insert(normalNodes, node)
		end
	end

	-- Procesa nodos burst con menos overhead (sin anti-solapamiento)
	local burstNext = {}
	for _, node in ipairs(burstNodes) do
		if node.life <= 0 then
			local gp,gn = castSurf(node.pos+node.normal,-node.normal,4)
			if gp then spawnBlob(gp,gn,CFG.BlobRadMin+math.random()*1.2,0.55) end
			continue
		end
		local af = 1-(node.life/node.maxLife)
		local newDir = rotXZ(node.dir,(math.random()-0.5)*math.pi*0.35)
		local np,nn,ud = nextSurf(node.pos,newDir,node.normal,CFG.StepSize*1.4)
		if not np then
			-- Nodo burst bloqueado: añade presión
			addPressure(node.pos, node.dir, node.normal, 3.5)
			continue
		end
		-- Burst nodes ignoran anti-solapamiento para expandirse más agresivamente
		spawnTendril(node.pos,np,nn,af,math.random()<0.15,false)
		if math.random()<0.22 then
			spawnBlob(np,nn,CFG.BlobRadMin+math.random()*(CFG.BlobRadMax-CFG.BlobRadMin)*0.7,af)
		end
		if math.random()<0.12 then spawnFlash(np,nn,0.5) end
		table.insert(burstNext,{
			pos=np,dir=ud or newDir,normal=nn,
			life=node.life-1,maxLife=node.maxLife,
			depth=node.depth,age=node.age+1,nodeType="pressure_burst"
		})
		-- Bifurcación más agresiva en burst
		if math.random()<0.45 and node.depth<CFG.MaxDepth then
			local bs=math.random()>0.5 and 1 or -1
			local bLife=math.max(5,math.floor(node.life*0.7))
			addNode(np,rotXZ(ud or newDir,bs*(math.pi*0.3+math.random()*0.4)),nn,bLife,node.depth+1,node.age,"pressure_burst")
		end
		-- Detección de jugadores
		for _,pl in ipairs(Players:GetPlayers()) do
			if not infected[pl] then
				local ch=pl.Character; if ch then
					local h=ch:FindFirstChild("HumanoidRootPart")
					if h and (h.Position-np).Magnitude<CFG.PlayerRadius then startInfection(pl) end
				end
			end
		end
	end

	-- Restaura nodos para el tick normal
	nodes = normalNodes
	_v32TickMycelium()

	-- Añade los nodos burst procesados de vuelta
	for _, bn in ipairs(burstNext) do table.insert(nodes, bn) end

	-- ── Detección de nodos atrapados (muestreo cada N nodos) ──────────
	nodeAnalysisCounter += 1
	if nodeAnalysisCounter < NODE_ANALYSIS_FREQ then return end
	nodeAnalysisCounter = 0

	-- Selecciona un subset de nodos para analizar (no todos, es costoso)
	local sampleSize = math.min(6, #nodes)
	for _ = 1, sampleSize do
		if #nodes == 0 then break end
		local idx = math.random(#nodes)
		local node = nodes[idx]
		if not node then continue end

		-- Solo analiza nodos que llevan tiempo sin avanzar (life alto)
		if node.life < node.maxLife * 0.85 then continue end

		-- Sondeo rápido: solo 4 direcciones principales
		local blockedCount = 0
		local bestExit = nil
		local bestExitDist = 0

		for _, dir in ipairs({
			Vector3.new(1,0,0), Vector3.new(-1,0,0),
			Vector3.new(0,0,1), Vector3.new(0,0,-1),
			node.dir,           -- dirección de avance del nodo
			}) do
			local kind, spos, snorm, dist = probeDirection(node.pos, dir, 20)
			if kind == "surface" then
				blockedCount += 1
			else
				if dist > bestExitDist then
					bestExitDist = dist
					bestExit = {dir=dir, pos=spos, dist=dist}
				end
			end
		end

		local isTrapped = blockedCount >= 4  -- 4 de 5 direcciones bloqueadas

		if isTrapped then
			-- Nodo atrapado: acumula presión en su posición
			addPressure(node.pos, node.dir, node.normal, 4)
		elseif bestExit and bestExitDist > 12 then
			-- Nodo con espacio libre: potencia su expansión en esa dirección
			-- Añade un nodo extra con sesgo hacia el hueco
			if #nodes < CFG.MaxNodes and partCount < CFG.MaxParts then
				local bLife = math.random(CFG.LifeMin, CFG.LifeMax)
				table.insert(nodes, {
					pos=node.pos, dir=bestExit.dir, normal=node.normal,
					life=bLife, maxLife=bLife, depth=node.depth,
					age=node.age, nodeType="gap_seeker"
				})
			end
		end
	end
end

-- ════════════════════════════════════════════════════════════════════
--  NODOS GAP_SEEKER (nodos que buscan activamente huecos)
--  Se mueven más rápido y con más persistencia que los normales
-- ════════════════════════════════════════════════════════════════════
-- El tipo gap_seeker ya es manejado por el tick normal pero con
-- características especiales inyectadas vía el paso de step:
-- necesitamos interceptar en el tickMycelium original

-- Hack: marca nodos gap_seeker con stepOverride
local _origNextSurf = nextSurf
function nextSurf(from, move, sn, stepOvr)
	return _origNextSurf(from, move, sn, stepOvr)
end

-- ════════════════════════════════════════════════════════════════════
--  VISUALIZACIÓN DE ZONAS DE PRESIÓN (billboard opcional)
-- ════════════════════════════════════════════════════════════════════
local pressureBillboards = {}

local function updatePressureVisuals()
	-- Limpia billboards de zonas sin presión
	for k, bb in pairs(pressureBillboards) do
		if not pressureMap[k] or pressureMap[k].pressure < PRESSURE_MAX * 0.4 then
			if bb and bb.Parent then bb:Destroy() end
			pressureBillboards[k] = nil
		end
	end

	-- Crea/actualiza billboards de zonas de alta presión
	for k, data in pairs(pressureMap) do
		if data.pressure >= PRESSURE_MAX * 0.6 then
			if not pressureBillboards[k] then
				-- Crea una Part invisible con billboard
				local anchor = Instance.new("Part")
				anchor.Anchored=true; anchor.CanCollide=false; anchor.Transparency=1
				anchor.Size=Vector3.new(0.1,0.1,0.1); anchor.Position=data.pos+Vector3.new(0,2,0)
				anchor.Parent=folder; partCount+=1

				local bb=Instance.new("BillboardGui"); bb.Size=UDim2.new(0,80,0,20)
				bb.StudsOffset=Vector3.new(0,2,0); bb.AlwaysOnTop=false; bb.Parent=anchor
				local lbl=Instance.new("TextLabel"); lbl.Size=UDim2.new(1,0,1,0)
				lbl.BackgroundTransparency=1
				lbl.TextColor3=Color3.fromRGB(255,80,0); lbl.TextSize=9
				lbl.Font=Enum.Font.Code; lbl.TextStrokeTransparency=0.4
				lbl.Parent=bb
				pressureBillboards[k] = {gui=bb, lbl=lbl, anchor=anchor}

				-- Auto-cleanup si no hay presión
				task.delay(8, function()
					if not pressureMap[k] or pressureMap[k].pressure < 1 then
						if anchor then anchor:Destroy(); partCount=math.max(0,partCount-1) end
						pressureBillboards[k]=nil
					end
				end)
			end
			local bd = pressureBillboards[k]
			if bd and bd.lbl then
				local pct = math.floor(data.pressure/PRESSURE_MAX*100)
				bd.lbl.Text = "⚡"..pct.."%"
				bd.lbl.TextColor3 = pct>100 and Color3.fromRGB(255,0,0) or Color3.fromRGB(255,150,0)
			end
		end
	end
end

-- ════════════════════════════════════════════════════════════════════
--  DETECCIÓN DE HABITACIONES / CAVIDADES CERRADAS
--  Cuando MUCHOS nodos acumulan presión en la misma zona → habitación
-- ════════════════════════════════════════════════════════════════════
local roomDetections = {}  -- lista de {pos, radius, time} habitaciones detectadas

local function detectRoom(pos)
	-- Cuenta cuántas celdas de presión hay cerca
	local nearCount = 0
	local totalPressure = 0
	local centerSum = Vector3.new(0,0,0)

	for _, data in pairs(pressureMap) do
		local d = (data.pos - pos).Magnitude
		if d < 20 then
			nearCount += 1
			totalPressure += data.pressure
			centerSum += data.pos
		end
	end

	if nearCount < 4 then return nil end  -- no suficiente presión concentrada

	local center = centerSum / nearCount
	local avgPressure = totalPressure / nearCount

	-- Verifica que no sea una habitación ya detectada
	for _, r in ipairs(roomDetections) do
		if (r.pos - center).Magnitude < r.radius then return nil end
	end

	return {pos=center, radius=22, avgPressure=avgPressure, nodeCount=nearCount}
end

local roomScanTimer = 0

local function tickRoomDetection(dt)
	roomScanTimer += dt
	if roomScanTimer < 5 then return end
	roomScanTimer = 0

	-- Limpia habitaciones viejas
	local t = tick(); local fresh = {}
	for _, r in ipairs(roomDetections) do
		if t - r.time < 90 then table.insert(fresh, r) end
	end
	roomDetections = fresh

	-- Busca nueva habitación
	if next(pressureMap) == nil then return end

	-- Toma una celda de presión alta al azar
	local candidates = {}
	for _, data in pairs(pressureMap) do
		if data.pressure >= PRESSURE_MAX * 0.8 then
			table.insert(candidates, data)
		end
	end
	if #candidates == 0 then return end

	local sample = candidates[math.random(#candidates)]
	local room = detectRoom(sample.pos)
	if not room then return end

	room.time = tick()
	table.insert(roomDetections, room)
	print("[Pibby] 🏠 Habitación detectada en "..
		string.format("(%.0f,%.0f,%.0f)", room.pos.X,room.pos.Y,room.pos.Z)..
		" — presión media: "..math.floor(room.avgPressure)..
		" — nodos: "..room.nodeCount)

	-- Busca TODOS los huecos alrededor de la habitación (más exhaustivo)
	local env = analyzeSurroundings(room.pos, 35)

	if #env.exits >= 1 then
		-- ¡Hay salidas! Concentra toda la presión acumulada por ahí
		-- Ordena por apertura
		table.sort(env.exits, function(a,b) return a.dist > b.dist end)

		local mainExit = env.exits[1]
		local gp,gn = castSurf(mainExit.pos + mainExit.dir*3, -mainExit.dir, CFG.RayDown)
		if not gp then
			gp,gn = castSurf(mainExit.pos, Vector3.new(0,-1,0), CFG.RayDown)
		end
		if not gp then gp=mainExit.pos; gn=Vector3.new(0,1,0) end

		-- Efecto visual: pulso desde el centro de la habitación
		task.spawn(function()
			for _ = 1, 8 do
				spawnFlash(room.pos, Vector3.new(0,1,0), 1.8+math.random()*1.2)
				task.wait(0.05)
			end
		end)

		-- Explosión masiva por la salida
		local totalPres = room.avgPressure * room.nodeCount
		local burstCount = math.min(40, math.max(12, math.floor(totalPres/3)))
		print("[Pibby] 💣 Irrupción masiva por hueco! "..burstCount.." nodos liberados")

		for i = 1, burstCount do
			if #nodes >= CFG.MaxNodes or partCount >= CFG.MaxParts then break end
			local jitter = (math.random()-0.5)*math.pi*0.7
			local bdir = rotXZ(mainExit.dir, jitter)
			local bLife = math.random(CFG.LifeMin+12, CFG.LifeMax+25)
			table.insert(nodes, {
				pos=gp, dir=bdir, normal=gn,
				life=bLife, maxLife=bLife, depth=0, age=0.05,
				nodeType="pressure_burst"
			})
		end

		-- Si hay segunda salida, también envía nodos
		if #env.exits >= 2 then
			local exit2 = env.exits[2]
			local gp2,gn2 = castSurf(exit2.pos+exit2.dir*2, -exit2.dir, CFG.RayDown)
			if gp2 then
				for _ = 1, math.floor(burstCount*0.4) do
					if #nodes >= CFG.MaxNodes then break end
					local bLife = math.random(CFG.LifeMin+8, CFG.LifeMax+15)
					local jitter = (math.random()-0.5)*math.pi*0.5
					table.insert(nodes, {
						pos=gp2, dir=rotXZ(exit2.dir, jitter), normal=gn2,
						life=bLife, maxLife=bLife, depth=0, age=0.08,
						nodeType="pressure_burst"
					})
				end
			end
		end

		-- Libera la presión de todas las celdas de esa habitación
		for k, data in pairs(pressureMap) do
			if (data.pos - room.pos).Magnitude < room.radius then
				pressureMap[k] = nil
			end
		end

	else
		-- Completamente cerrada: la presión se convierte en micelio denso interno
		-- Llena la habitación con blobs densos
		print("[Pibby] 🔒 Habitación sellada — llenando con micelio interno")
		local fillCount = math.min(15, math.floor(room.avgPressure / 2))
		for _ = 1, fillCount do
			if partCount >= CFG.MaxParts then break end
			local offset = Vector3.new(
				(math.random()-0.5)*room.radius*0.8,
				(math.random()-0.5)*6,
				(math.random()-0.5)*room.radius*0.8
			)
			local tryPos = room.pos + offset
			local gp,gn = castSurf(tryPos+Vector3.new(0,4,0), Vector3.new(0,-1,0), 12)
			if gp then
				spawnBlob(gp, gn, 2+math.random()*3.5, 0.7+math.random()*0.3)
			end
		end
		-- También intenta escalar paredes hacia arriba buscando salida superior
		local upExit = nil; local upDist = 0
		for _, s in ipairs(env.surfaces) do
			if s.normal.Y > 0.5 and s.dist > upDist then
				upExit = s; upDist = s.dist
			end
		end
		if upExit then
			local l = math.random(CFG.LifeMin, CFG.LifeMax)
			addNode(room.pos, Vector3.new(0,1,0), upExit.normal, l, 0, 0.2, "pressure_burst")
		end
	end
end

-- ════════════════════════════════════════════════════════════════════
--  HEARTBEAT v3.3 (añade sistemas de presión al heartbeat v3.2)
-- ════════════════════════════════════════════════════════════════════
RunService.Heartbeat:Connect(function(dt)
	tickPressure(dt)
	tickRoomDetection(dt)

	-- Actualiza visuales de presión cada 2s aprox
	pressureFlashT += dt
	if pressureFlashT > 2.0 then
		pressureFlashT = 0
		updatePressureVisuals()
	end
end)

-- ════════════════════════════════════════════════════════════════════

-- ════════════════════════════════════════════════════════════════════
--  v3.4 — NAVEGACIÓN FÍSICA REAL + MEGA MEJORAS
--  El micelio ya NO atraviesa bloques: los rodea, sube, o los envuelve
-- ════════════════════════════════════════════════════════════════════

-- ────────────────────────────────────────────────────────────────────
--  SISTEMA DE NAVEGACIÓN LÓGICA
--  nextSurf ahora intenta múltiples alternativas cuando está bloqueado
-- ────────────────────────────────────────────────────────────────────

-- Cache de colisiones recientes (pos → blocked) para evitar re-calcular
local collisionCache = {}
local collisionCacheT = 0

local function isSolid(pos)
	-- Solo detecta si pos está literalmente DENTRO de geometría sólida
	-- (no en la superficie, sino adentro). Muy conservador para no
	-- bloquear tendrils válidos en superficies.
	local up = workspace:Raycast(pos, Vector3.new(0,1,0)*0.35, rpMain)
	local dn = workspace:Raycast(pos, Vector3.new(0,-1,0)*0.35, rpMain)
	-- Solo es sólido si hay geometría en AMBAS direcciones a <0.35 studs
	return (up ~= nil) and (dn ~= nil)
end

-- Busca superficie alternativa cuando el camino directo está bloqueado
-- Prueba 12 alternativas en orden de prioridad lógica
local function findAlternativeSurface(from, blockedDir, surfNormal, step)
	step = step or CFG.StepSize

	-- Genera variantes de dirección para rodear el obstáculo
	-- 1) Laterales (±90°) — rodear por los lados
	-- 2) Subir (escalar el bloque)
	-- 3) Bajar (pasar por debajo si hay espacio)
	-- 4) Diagonal combinado
	local alternatives = {}

	-- Laterales: gira 45°, 90°, 135° a cada lado
	for _, sign in ipairs({1, -1}) do
		for _, angle in ipairs({math.pi*0.25, math.pi*0.5, math.pi*0.75}) do
			table.insert(alternatives, rotXZ(blockedDir, sign*angle))
		end
	end

	-- Subir por el bloque (usar normal del bloque como nueva dirección)
	-- Lanza un ray lateral para encontrar la cara del bloque
	local wallRay = workspace:Raycast(from + surfNormal*0.3, blockedDir * (step*1.8), rpMain)
	if wallRay then
		-- La normal del bloque apunta hacia nosotros → trepar
		local wallNorm = wallRay.Normal
		if wallNorm.Y < 0.3 then  -- es una pared vertical
			-- Intenta escalar: muévete a la cara de la pared + sube
			local wallPos = wallRay.Position + wallNorm * CFG.SurfaceOff
			-- Punto arriba del borde del bloque
			local topCheck = workspace:Raycast(
				wallPos + Vector3.new(0, step*1.5, 0),
				blockedDir * step,
				rpMain
			)
			if not topCheck then
				-- Hay espacio encima del bloque: escalar
				local overTop = wallPos + Vector3.new(0, step*1.5, 0) + blockedDir*step
				local landRay = workspace:Raycast(overTop, Vector3.new(0,-1,0)*step*2, rpMain)
				if landRay then
					return landRay.Position + landRay.Normal*CFG.SurfaceOff, landRay.Normal, blockedDir, "climb"
				end
			end
		end
	end

	-- Prueba las alternativas laterales
	for _, altDir in ipairs(alternatives) do
		local sp, sn = castSurf(from + altDir*step + surfNormal*1.5, -surfNormal, CFG.RayDown)
		if sp then
			-- Verifica que el punto destino no esté dentro de un sólido
			if not isSolid(sp) then
				return sp, sn, altDir, "around"
			end
		end
		-- También prueba escalar en dirección alternativa
		if CFG.WallClimb then
			local wr = workspace:Raycast(from + surfNormal*0.5, altDir*CFG.SlopeRayLen, rpMain)
			if wr and wr.Normal.Y < 0.3 then
				return wr.Position + wr.Normal*CFG.SurfaceOff, wr.Normal, altDir, "wall"
			end
		end
	end

	return nil, nil, blockedDir, "stuck"
end

-- Versión mejorada de nextSurf que no atraviesa bloques
local _v33NextSurf = nextSurf
function nextSurf(from, move, sn, stepOvr)
	local step = stepOvr or CFG.StepSize
	local flat = (move - sn*move:Dot(sn))
	flat = flat.Magnitude < 0.001 and move or flat.Unit

	-- PRIMERO: intento normal (exactamente igual que antes — esto es lo que
	-- genera los tendrils bonitos). NO lo tocamos si funciona.
	local sp, sn2 = castSurf(from + flat*step + sn*1.5, -sn, CFG.RayDown)
	if sp then return sp, sn2, flat end

	if CFG.WallClimb then
		-- Pared lateral
		local wr = workspace:Raycast(from + sn*0.5, flat*CFG.SlopeRayLen, rpMain)
		if wr then return wr.Position + wr.Normal*CFG.SurfaceOff, wr.Normal, flat end
		-- Caída de borde
		local dr = workspace:Raycast(from + flat*step + sn*0.3, -sn*CFG.RayDown, rpMain)
		if dr then return dr.Position + dr.Normal*CFG.SurfaceOff, dr.Normal, flat end
	end

	-- SEGUNDO: solo si el camino normal falló, comprueba si hay una PARED
	-- perpendicular bloqueando (Y < 0.3 = pared vertical) e intenta escalarla.
	-- Este raycast va BAJO la superficie para no confundir suelo con obstáculo.
	local pathRay = workspace:Raycast(from + sn*(-0.1), flat*(step*0.9), rpMain)
	if pathRay then
		local wn = pathRay.Normal
		-- Solo actúa si es una pared real (normal casi horizontal)
		if math.abs(wn.Y) < 0.3 then
			local wallSurf = pathRay.Position + wn*CFG.SurfaceOff
			-- Comprueba si hay superficie encima de la pared (para trepar)
			local topRay = workspace:Raycast(
				wallSurf + Vector3.new(0, step*1.6, 0),
				flat * step, rpMain)
			if not topRay then
				-- Espacio libre encima → trepar
				local overPos  = wallSurf + Vector3.new(0, step*1.5, 0) + flat*step
				local landRay2 = workspace:Raycast(overPos, Vector3.new(0,-1,0)*step*2.5, rpMain)
				if landRay2 then
					return landRay2.Position + landRay2.Normal*CFG.SurfaceOff, landRay2.Normal, flat
				end
			end
			-- No puede trepar → rodea (alternativa lateral)
			local altPos, altNorm, altDir = findAlternativeSurface(from, flat, sn, step)
			if altPos then return altPos, altNorm, altDir end
		end
	end

	return nil, nil, flat
end

-- ────────────────────────────────────────────────────────────────────
--  SISTEMA DE ENVOLVIMIENTO DE BLOQUES
--  Cuando el micelio llega a un bloque, lo "envuelve" generando
--  tendrils en todas sus caras accesibles
-- ────────────────────────────────────────────────────────────────────
local wrappedObjects = {}  -- BasePart → true (ya envuelto)
local wrapQueue = {}       -- {part, time}

local function wrapBlock(part)
	if not (part and part.Parent) then return end
	if wrappedObjects[part] then return end
	if part:FindFirstAncestor("PibbyFolder") then return end
	if part.Name == "Baseplate" then return end
	if part.Locked then return end
	if partCount >= CFG.MaxParts - 12 then return end

	wrappedObjects[part] = true

	local s = part.Size
	local cf = part.CFrame
	local center = cf.Position

	-- Las 6 caras del bloque
	local faces = {
		{normal=cf.UpVector,    offset=Vector3.new(0, s.Y/2, 0)},
		{normal=-cf.UpVector,   offset=Vector3.new(0,-s.Y/2, 0)},
		{normal=cf.RightVector, offset=Vector3.new( s.X/2, 0, 0)},
		{normal=-cf.RightVector,offset=Vector3.new(-s.X/2, 0, 0)},
		{normal=cf.LookVector,  offset=Vector3.new(0, 0, s.Z/2)},
		{normal=-cf.LookVector, offset=Vector3.new(0, 0,-s.Z/2)},
	}

	for _, face in ipairs(faces) do
		if partCount >= CFG.MaxParts then break end

		local faceCenter = center + face.offset
		local faceNorm   = face.normal

		-- Comprueba que la cara esté accesible (no dentro de otro sólido)
		local accessCheck = workspace:Raycast(
			faceCenter + faceNorm*2,
			-faceNorm*3,
			rpMain
		)
		if not accessCheck then continue end

		local surfPos = accessCheck.Position + faceNorm*CFG.SurfaceOff

		-- Genera pequeños nodos de micelio en esta cara
		local numTendrils = math.random(2, 4)
		for _ = 1, numTendrils do
			if partCount >= CFG.MaxParts then break end

			-- Posición aleatoria en la cara
			local tanA = faceNorm:Cross(Vector3.new(0,1,0))
			if tanA.Magnitude < 0.01 then tanA = faceNorm:Cross(Vector3.new(1,0,0)) end
			tanA = tanA.Unit
			local tanB = faceNorm:Cross(tanA).Unit

			local u = (math.random()-0.5)
			local v = (math.random()-0.5)
			local faceW = (face.offset.X~=0 and s.Z or s.X) * 0.8
			local faceH = (face.offset.Y~=0 and s.X or s.Y) * 0.8

			local randomFacePos = surfPos + tanA*(u*faceW) + tanB*(v*faceH)
			local randomFaceRay = workspace:Raycast(randomFacePos + faceNorm*1.2, -faceNorm*2.5, rpMain)
			if randomFaceRay then
				local rp2 = randomFaceRay.Position + randomFaceRay.Normal*CFG.SurfaceOff
				if not isSolid(rp2 + faceNorm*0.3) then
					local l = math.random(6, 18)
					-- Dirección a lo largo de la superficie
					local expansionDir = rotXZ(tanA, math.random()*math.pi*2)
					table.insert(nodes, {
						pos=rp2, dir=expansionDir, normal=faceNorm,
						life=l, maxLife=l, depth=3, age=0.35,
						nodeType="block_wrapper"
					})
				end
			end
		end

		-- Blob pequeño en el centro de la cara
		spawnBlob(surfPos, faceNorm, 0.4 + math.random()*0.8, 0.5)
	end

	-- Efecto visual: flash al envolver
	task.spawn(function()
		task.wait(0.15)
		spawnFlash(center, Vector3.new(0,1,0), 0.6 + s.Magnitude*0.04)
	end)
end

-- Tick del sistema de envolvimiento
local wrapScanT = 0
local function tickWrapScan(dt)
	wrapScanT += dt
	if wrapScanT < 3.5 then return end
	wrapScanT = 0

	if partCount >= CFG.MaxParts - 15 then return end
	if #blobReg == 0 then return end

	-- Busca partes cercanas al micelio existente
	local sample = blobReg[math.random(#blobReg)]
	if not sample then return end

	-- Raycast en las 4 direcciones buscando bloques cercanos sin envolver
	for _, dir in ipairs({
		Vector3.new(1,0,0), Vector3.new(-1,0,0),
		Vector3.new(0,0,1), Vector3.new(0,0,-1),
		Vector3.new(0,1,0), Vector3.new(0,-1,0),
		}) do
		local r = workspace:Raycast(sample.pos, dir * 8, rpMain)
		if r and r.Instance then
			local inst = r.Instance
			if inst:IsA("BasePart") and not wrappedObjects[inst]
				and not inst:FindFirstAncestor("PibbyFolder")
				and inst.Name ~= "Baseplate"
				and not inst.Locked
				and inst.Anchored then
				if math.random() < 0.35 then
					table.insert(wrapQueue, {part=inst, time=tick()})
				end
			end
		end
	end

	-- Procesa la cola (máx 1 por tick para no matar performance)
	if #wrapQueue > 0 then
		local entry = table.remove(wrapQueue, 1)
		if entry and entry.part and entry.part.Parent then
			wrapBlock(entry.part)
		end
	end

	-- Limpia objetos destruidos del registro
	for part, _ in pairs(wrappedObjects) do
		if not (part and part.Parent) then wrappedObjects[part] = nil end
	end
end

-- ────────────────────────────────────────────────────────────────────
--  NODOS BLOCK_WRAPPER: expansión especial que sigue el contorno
--  del bloque y no sale de él hasta terminar la vida
-- ────────────────────────────────────────────────────────────────────
-- Los block_wrapper son manejados por el tick normal pero con
-- menor wander (más pegados a la superficie que envuelven)
-- El override de nextSurf ya los maneja correctamente

-- ────────────────────────────────────────────────────────────────────
--  MEJORA: DETECCIÓN DE ESQUINAS Y BORDES
--  El micelio ahora salta graciosamente de un bloque a otro
-- ────────────────────────────────────────────────────────────────────
local cornerBridgeT = 0

local function tryCornerBridge(pos, normal, dir)
	-- Cuando un tendril llega al borde de un bloque, busca el bloque adyacente
	-- y lanza un "puente" de micelio fino entre ambos
	if partCount >= CFG.MaxParts - 3 then return end
	if math.random() > 0.08 then return end  -- Solo 8% de veces

	-- Sondea si hay un bloque adyacente en esa dirección con un gap
	local gapRay = workspace:Raycast(pos + dir*CFG.StepSize, -normal*3, rpMain)
	if not gapRay then return end

	local gapDist = (gapRay.Position - (pos + normal*0.3)).Magnitude
	if gapDist < 0.5 or gapDist > CFG.StepSize*3 then return end

	local bridgeTarget = gapRay.Position + gapRay.Normal*CFG.SurfaceOff

	-- Crea tendril puente fino entre los dos bloques
	local bridgeLen = (bridgeTarget - pos).Magnitude
	if bridgeLen < 0.5 or bridgeLen > 10 then return end

	local p = Instance.new("Part")
	p.Anchored=true; p.CanCollide=false; p.CastShadow=false
	p.Size = Vector3.new(0.06, 0.06, bridgeLen)
	local look = (bridgeTarget-pos).Unit
	local right = normal:Cross(look); right = right.Magnitude<0.001 and Vector3.new(1,0,0) or right.Unit
	p.CFrame = CFrame.fromMatrix((pos+bridgeTarget)/2, right, look:Cross(right).Unit)
	p.Color = mycelColor(0.5); p.Material = Enum.Material.Fabric
	p.Transparency = 1; p.Parent = folder; partCount += 1
	TweenService:Create(p, TweenInfo.new(0.25), {Transparency=0.18}):Play()
end

-- ────────────────────────────────────────────────────────────────────
--  MEJORA: TENDRILS QUE BAJAN POR BORDES (gravedad simulada)
--  Cuando el micelio llega al borde de una plataforma, algunos
--  tendrils cuelgan y siguen el lado inferior del bloque
-- ────────────────────────────────────────────────────────────────────
local hangOverT = 0

local function tryHangOver(pos, normal, dir)
	if partCount >= CFG.MaxParts - 4 then return end
	if math.random() > 0.06 then return end

	-- Comprueba si hay un borde: no hay suelo directamente debajo del siguiente paso
	local nextPos = pos + dir*CFG.StepSize
	local floorCheck = workspace:Raycast(nextPos, Vector3.new(0,-1,0)*3, rpMain)
	if floorCheck then return end  -- hay suelo, no es un borde

	-- Es un borde: busca la cara inferior del bloque actual
	local underCheck = workspace:Raycast(pos, Vector3.new(0,-1,0)*4, rpMain)
	if not underCheck then return end

	local underNorm = underCheck.Normal
	if underNorm.Y < -0.5 then  -- superficie que mira hacia abajo (techo/fondo)
		local underPos = underCheck.Position + underNorm*CFG.SurfaceOff
		if not isSolid(underPos + underNorm*0.3) then
			-- Lanza nodo que crece por la parte inferior
			local l = math.random(8, 20)
			local underDir = rotXZ(dir, (math.random()-0.5)*0.6)
			table.insert(nodes, {
				pos=underPos, dir=underDir, normal=underNorm,
				life=l, maxLife=l, depth=4, age=0.4,
				nodeType="ceiling_crawler"
			})
		end
	end
end

-- ────────────────────────────────────────────────────────────────────
--  MEJORA: CEILING CRAWLER
--  Nodos que van por techos y superficies invertidas
-- ────────────────────────────────────────────────────────────────────
-- Los ceiling_crawler son procesados en el tick normal.
-- nextSurf mejorado ya maneja normales invertidas correctamente.

-- ────────────────────────────────────────────────────────────────────
--  OVERRIDE FINAL DE tickMycelium: AÑADE WRAPPING Y CORNER BRIDGES
-- ────────────────────────────────────────────────────────────────────
local _v33TickMyceliumFull = tickMycelium
function tickMycelium()
	_v33TickMyceliumFull()

	-- Post-proceso: corner bridges y hang-over en nodos activos
	cornerBridgeT += 1
	if cornerBridgeT >= 8 then  -- cada 8 ticks
		cornerBridgeT = 0
		local sample = math.min(4, #nodes)
		for _ = 1, sample do
			if #nodes == 0 then break end
			local n = nodes[math.random(#nodes)]
			if n then
				tryCornerBridge(n.pos, n.normal, n.dir)
				tryHangOver(n.pos, n.normal, n.dir)
			end
		end
	end
end

-- ────────────────────────────────────────────────────────────────────
--  MEJORA: MICELIO EN GRIETAS (tendrils ultrafinos que se meten
--  por espacios muy pequeños entre bloques)
-- ────────────────────────────────────────────────────────────────────
local crackTimer = 0

local function scanForCracks(dt)
	crackTimer += dt
	if crackTimer < 5 then return end
	crackTimer = 0
	if partCount >= CFG.MaxParts - 8 then return end
	if #blobReg == 0 then return end

	local sample = blobReg[math.random(#blobReg)]
	if not sample then return end

	-- Busca "grietas": dos superficies paralelas muy cercanas
	for _, dir in ipairs(PROBE_DIRS) do
		local r1 = workspace:Raycast(sample.pos, dir*15, rpMain)
		if not r1 then continue end

		-- Comprueba si hay otra superficie paralela cerca (grieta)
		local perpDirs = {}
		if math.abs(dir.Y) < 0.5 then
			table.insert(perpDirs, Vector3.new(0,1,0))
			table.insert(perpDirs, Vector3.new(0,-1,0))
		else
			table.insert(perpDirs, Vector3.new(1,0,0))
			table.insert(perpDirs, Vector3.new(0,0,1))
		end

		for _, perp in ipairs(perpDirs) do
			local r2 = workspace:Raycast(r1.Position + perp*0.3, -perp*3, rpMain)
			if r2 then
				local gapSize = (r2.Position - r1.Position).Magnitude
				if gapSize > 0.3 and gapSize < 2.2 then
					-- ¡Grieta encontrada! Mete un tendril finísimo
					local crackCenter = (r1.Position + r2.Position)/2
					local crackNorm   = (r1.Normal + r2.Normal).Unit

					local crack = Instance.new("Part")
					crack.Anchored=true; crack.CanCollide=false; crack.CastShadow=false
					crack.Size = Vector3.new(0.03, 0.03, math.min(gapSize*0.8, 1.8))
					crack.Color = mycelColor(0.7 + math.random()*0.3)
					crack.Material = Enum.Material.SmoothPlastic
					crack.CFrame = CFrame.new(crackCenter)
						* CFrame.fromMatrix(Vector3.new(0,0,0), perp, crackNorm, dir)
					crack.Transparency = 0.12
					crack.Parent = folder; partCount += 1

					-- Desde la grieta lanza nodos al otro lado
					local exitPos = r1.Position + dir*(gapSize*0.5)
					local gp,gn = castSurf(exitPos + Vector3.new(0,2,0), Vector3.new(0,-1,0))
					if gp then
						local l = math.random(CFG.LifeMin, CFG.LifeMax)
						table.insert(nodes,{pos=gp,dir=dir,normal=gn,life=l,maxLife=l,depth=0,age=0.1,nodeType="crack_exit"})
						spawnFlash(crackCenter, crackNorm, 0.35)
						print("[Pibby] 🔩 Grieta detectada — tendril infiltrado")
					end
					break
				end
			end
		end
	end
end

-- ────────────────────────────────────────────────────────────────────
--  MEJORA: EXPANSIÓN VERTICAL REAL
--  Cuando no hay suelo, el micelio cae hacia abajo buscando superficie
-- ────────────────────────────────────────────────────────────────────
local function tryVerticalFall(pos, normal, dir)
	if partCount >= CFG.MaxParts - 2 then return end
	if math.random() > 0.12 then return end

	-- Comprueba si hay un abismo debajo
	local fallRay = workspace:Raycast(pos, Vector3.new(0,-1,0)*CFG.RayDown, rpMain)
	if not fallRay then return end

	local fallDist = (fallRay.Position - pos).Magnitude
	if fallDist < 2 then return end  -- no es suficientemente profundo

	-- Genera tendrils que caen por el lado del bloque hacia abajo
	local fallSegs = math.min(math.floor(fallDist/1.8), 6)
	local lastPos = pos

	for seg = 1, fallSegs do
		if partCount >= CFG.MaxParts then break end
		local frac = seg/fallSegs
		local segPos = pos + Vector3.new(0,-1,0)*fallDist*frac
			+ Vector3.new((math.random()-0.5)*0.4, 0, (math.random()-0.5)*0.4)

		-- Verifica que esté pegado a la pared lateral
		local wallStick = workspace:Raycast(segPos, -dir*2, rpMain)
		if wallStick then
			segPos = wallStick.Position + wallStick.Normal*CFG.SurfaceOff
		end

		if not isSolid(segPos) then
			local vf = Instance.new("Part")
			vf.Anchored=true; vf.CanCollide=false; vf.CastShadow=false
			vf.Size = Vector3.new(0.07+math.random()*0.06, 1.6+math.random()*0.8, 0.07+math.random()*0.06)
			vf.CFrame = CFrame.new(segPos) * CFrame.Angles(math.random()*0.4-0.2, 0, math.random()*0.4-0.2)
			vf.Color = mycelColor(0.35 + frac*0.5)
			vf.Material = Enum.Material.Fabric
			vf.Transparency = 0.1 + frac*0.3
			vf.Parent = folder; partCount += 1
		end

		-- Nodo en el suelo al final de la caída
		if seg == fallSegs then
			local gp,gn = castSurf(segPos + Vector3.new(0,1,0), Vector3.new(0,-1,0), 5)
			if gp then
				spawnBlob(gp, gn, 0.8+math.random()*1.2, 0.3)
				local l = math.random(CFG.LifeMin, CFG.LifeMax)
				table.insert(nodes,{pos=gp,dir=dir,normal=gn,life=l,maxLife=l,depth=1,age=0.2,nodeType="normal"})
			end
		end

		lastPos = segPos
	end
end

-- ────────────────────────────────────────────────────────────────────
--  NUEVO SISTEMA DE INFECCIÓN v3.4
--  "Propagación por Contacto Físico": el micelio puede contagiar
--  objetos del workspace que toca, haciéndolos "parte" del micelio
-- ────────────────────────────────────────────────────────────────────
local assimilatedObjects = {}  -- Part → {time, lit}
local ASSIM_CHANCE = 0.003
local assimTimer = 0

local function assimilateObject(part, contactPos, contactNorm)
	if assimilatedObjects[part] then return end
	if not (part and part.Parent and part:IsA("BasePart")) then return end
	if part.Name == "Baseplate" or part:FindFirstAncestor("PibbyFolder") then return end
	if part.Locked or not part.Anchored then return end

	assimilatedObjects[part] = {time=tick(), lit=false}
	print("[Pibby] ⬛ Objeto asimilado: "..part.Name)

	task.spawn(function()
		local oc,om = part.Color, part.Material
		-- Fase 1: manchas de micelio se extienden por el objeto
		local steps = math.random(4,9)
		for i = 1, steps do
			task.wait(0.4 + math.random()*0.5)
			if not (part and part.Parent) then break end
			local frac = i/steps
			TweenService:Create(part, TweenInfo.new(0.45), {
				Color = lerpC(oc, rD(), frac*0.8)
			}):Play()
		end

		task.wait(1.5)
		if not (part and part.Parent) then assimilatedObjects[part]=nil; return end

		-- Fase 2: neon glitch intermitente
		part.Material = Enum.Material.SmoothPlastic
		TweenService:Create(part, TweenInfo.new(0.6), {Color=rD()}):Play()

		-- Luz muy sutil
		local li = Instance.new("PointLight")
		li.Color = Color3.fromRGB(70,0,140); li.Range = part.Size.Magnitude*1.2; li.Brightness = 0.4
		li.Parent = part
		assimilatedObjects[part].lit = true

		-- Glitch periódico
		task.spawn(function()
			while part and part.Parent and assimilatedObjects[part] do
				task.wait(4 + math.random()*9)
				if not (part and part.Parent) then break end
				if math.random() < 0.18 then
					local oc2 = part.Color
					part.Color = rN(); part.Material = Enum.Material.Neon
					task.wait(0.04 + math.random()*0.08)
					if part and part.Parent then
						part.Color = oc2; part.Material = Enum.Material.SmoothPlastic
					end
				end
			end
		end)

		-- Genera micelio desde la superficie del objeto asimilado
		task.wait(3 + math.random()*4)
		if part and part.Parent then
			local blobPos = contactPos or part.CFrame.Position
			local blobNorm = contactNorm or Vector3.new(0,1,0)
			spawnBlob(blobPos, blobNorm, 1.2+math.random()*1.8, 0.45)
			for _ = 1, math.random(2,4) do
				if #nodes < CFG.MaxNodes and partCount < CFG.MaxParts then
					local a = math.random()*math.pi*2
					local fd = Vector3.new(math.cos(a),0,math.sin(a))
					local l = math.random(CFG.LifeMin, CFG.LifeMax)
					table.insert(nodes,{pos=blobPos,dir=fd,normal=blobNorm,
						life=l,maxLife=l,depth=0,age=0.2,nodeType="normal"})
				end
			end
		end
	end)
end

local function tickAssimilation(dt)
	assimTimer += dt
	if assimTimer < 1.8 then return end
	assimTimer = 0

	if partCount >= CFG.MaxParts - 10 then return end
	if #blobReg == 0 then return end

	-- Muestra un blob aleatorio y comprueba si hay objetos cercanos sin asimilar
	local sample = blobReg[math.random(#blobReg)]
	if not sample then return end

	for _, dir in ipairs({
		Vector3.new(1,0,0),Vector3.new(-1,0,0),
		Vector3.new(0,1,0),Vector3.new(0,-1,0),
		Vector3.new(0,0,1),Vector3.new(0,0,-1),
		}) do
		local r = workspace:Raycast(sample.pos + dir*0.5, dir*3.5, rpMain)
		if r and r.Instance and r.Instance:IsA("BasePart") then
			if math.random() < ASSIM_CHANCE then
				assimilateObject(r.Instance, r.Position + r.Normal*CFG.SurfaceOff, r.Normal)
				break
			end
		end
	end
end

-- ────────────────────────────────────────────────────────────────────
--  MEJORA: MINI-EXPLOSIONES DE MICELIO EN ESQUINAS
--  Cuando dos frentes se acercan en un corner, generan una mini-explosión
-- ────────────────────────────────────────────────────────────────────
local cornerExplosionCooldown = 0

local function checkCornerExplosion(pos, normal)
	if cornerExplosionCooldown > 0 then return end
	if math.random() > 0.04 then return end

	-- Cuenta cuántos tendrils hay muy cerca
	local nearCount = 0
	for _, tr in ipairs(tendrilRegistry) do
		if (tr.pos - pos).Magnitude < 2.5 then nearCount += 1 end
	end

	if nearCount >= 8 then  -- muy denso → explosión
		cornerExplosionCooldown = 25
		spawnFlash(pos, normal, 1.2 + math.random())

		-- Rociado radial de nodos pequeños
		for i = 1, math.random(5,10) do
			if #nodes >= CFG.MaxNodes or partCount >= CFG.MaxParts then break end
			local angle = (i/10)*math.pi*2
			-- Proyecta en el plano de la superficie
			local tangent = normal:Cross(Vector3.new(math.cos(angle),0,math.sin(angle))).Unit
			local l = math.random(5, 14)
			table.insert(nodes, {pos=pos, dir=tangent, normal=normal,
				life=l, maxLife=l, depth=5, age=0.6, nodeType="normal"})
		end
	end
end

-- ────────────────────────────────────────────────────────────────────
--  HEARTBEAT v3.4 — Añade todos los nuevos sistemas
-- ────────────────────────────────────────────────────────────────────
RunService.Heartbeat:Connect(function(dt)
	tickWrapScan(dt)
	tickAssimilation(dt)
	scanForCracks(dt)

	if cornerExplosionCooldown > 0 then cornerExplosionCooldown -= 1 end
	if collisionCacheT > 0 then collisionCacheT -= dt end
	if collisionCacheT <= 0 then
		collisionCache = {}
		collisionCacheT = 5
	end

	-- Caídas verticales periódicas
	hangOverT += dt
	if hangOverT > 1.2 then
		hangOverT = 0
		if #nodes > 0 and math.random() < 0.18 then
			local n = nodes[math.random(#nodes)]
			if n then tryVerticalFall(n.pos, n.normal, n.dir) end
		end
	end

	-- Corner explosions
	if #tendrilRegistry > 0 and math.random() < 0.05 then
		local tr = tendrilRegistry[math.random(#tendrilRegistry)]
		if tr and tr.part and tr.part.Parent then
			checkCornerExplosion(tr.pos, tr.part.CFrame.UpVector)
		end
	end
end)

-- ════════════════════════════════════════════════════════════════════

-- ════════════════════════════════════════════════════════════════════
--  v3.5 — RAYCAST ROBUSTO + FASES MEJORADAS + ANIMACIÓN DE INICIO
-- ════════════════════════════════════════════════════════════════════

-- ────────────────────────────────────────────────────────────────────
--  FIX 1: RAYCAST ROBUSTO PARA UNIONS Y MESHES
--  Los Unions y MeshParts a veces fallan el raycast normal.
--  Solución: si el raycast falla en el punto esperado, hacemos
--  un segundo intento con offset y uno desde arriba.
-- ────────────────────────────────────────────────────────────────────

-- Sobreescribe castSurf con versión más robusta
local _v34CastSurf = castSurf
function castSurf(pos, dir, len, p)
	-- Intento 1: normal
	local sp, sn, si = _v34CastSurf(pos, dir, len, p)
	if sp then return sp, sn, si end

	-- Intento 2: offset lateral pequeño (para unions con geometría irregular)
	local offsets = {
		Vector3.new(0.12, 0, 0),
		Vector3.new(-0.12, 0, 0),
		Vector3.new(0, 0, 0.12),
		Vector3.new(0, 0, -0.12),
		Vector3.new(0, 0.08, 0),
	}
	for _, off in ipairs(offsets) do
		local r = workspace:Raycast((pos + off) - dir*1.2, dir*(len or CFG.RayDown), p or rpMain)
		if r then
			return r.Position + r.Normal*CFG.SurfaceOff, r.Normal, r.Instance
		end
	end

	return nil, nil, nil
end

-- Sobreescribe nextSurf para manejar meshes/unions mejor
local _v34NextSurf = nextSurf
function nextSurf(from, move, sn, stepOvr)
	local sp, sn2, flat = _v34NextSurf(from, move, sn, stepOvr)
	if sp then return sp, sn2, flat end

	-- Fallback para unions/meshes: barrido en abanico de 5 rayos descendentes
	local step = stepOvr or CFG.StepSize
	flat = flat or (move - sn*move:Dot(sn))
	flat = flat.Magnitude < 0.001 and move or flat.Unit

	local fanAngles = {-0.4, -0.2, 0, 0.2, 0.4}
	for _, ang in ipairs(fanAngles) do
		local testDir = rotXZ(flat, ang)
		local testPos = from + testDir*step
		-- Raycast desde más arriba para no perderse el mesh
		local r = workspace:Raycast(testPos + sn*2.5, -sn*6, p or rpMain)
		if r then
			local rp = r.Position + r.Normal*CFG.SurfaceOff
			-- Acepta si la normal apunta "hacia afuera" del sólido
			if r.Normal:Dot(sn) > -0.2 then
				return rp, r.Normal, testDir
			end
		end
	end

	-- Último recurso: busca desde el punto actual hacia abajo con más alcance
	local downR = workspace:Raycast(from + flat*step*0.5 + sn*3, -sn*CFG.RayDown*1.5, p or rpMain)
	if downR then
		return downR.Position + downR.Normal*CFG.SurfaceOff, downR.Normal, flat
	end

	return nil, nil, flat
end

-- ────────────────────────────────────────────────────────────────────
--  FIX 2: FASES MEJORADAS + INFECCIÓN MEJORADA
-- ────────────────────────────────────────────────────────────────────

-- FASES: ahora las fases también afectan la velocidad real del micelio
-- y añaden comportamientos nuevos por fase

-- Aplica velocidad de expansión por fase al timer principal
local _v35TimerAcc = 0
RunService.Heartbeat:Connect(function(dt)
	_v35TimerAcc += dt
	-- Ajuste dinámico del TickRate según la fase
	-- (se aplica además del v32 que calcula expandSpeed)
	if currentPhase >= 1 then
		local speedMult = PHASE_SPEED[math.clamp(currentPhase, 1, 5)]
		-- Adelanta el timer para que el micelio tick más rápido
		timer_acc += dt * (1 - speedMult) * 0.5
	end
end)

-- FASE 2+: partículas de "esporas ambientales" flotantes
local ambientSporeT = 0
local function tickAmbientSpores(dt)
	if currentPhase < 2 then return end
	ambientSporeT += dt
	if ambientSporeT < (5 - currentPhase*0.8) then return end
	ambientSporeT = 0

	if #blobReg == 0 or partCount >= CFG.MaxParts then return end
	local b = blobReg[math.random(#blobReg)]
	if not b then return end

	-- Espora ambiental flotante (no aterriza, solo visual)
	local p = Instance.new("Part")
	p.Anchored = true; p.CanCollide = false; p.CastShadow = false
	p.Shape = Enum.PartType.Ball
	local sz = 0.06 + math.random()*0.10
	p.Size = Vector3.new(sz,sz,sz)
	p.Position = b.pos + Vector3.new(
		(math.random()-0.5)*12,
		2 + math.random()*6,
		(math.random()-0.5)*12
	)
	p.Color = rN(); p.Material = Enum.Material.Neon; p.Transparency = 0.2
	p.Parent = folder; partCount += 1

	local li = Instance.new("PointLight"); li.Color=p.Color
	li.Range=3; li.Brightness=0.8; li.Parent=p

	-- Flota y desaparece
	local endPos = p.Position + Vector3.new((math.random()-0.5)*4, 3+math.random()*4, (math.random()-0.5)*4)
	TweenService:Create(p, TweenInfo.new(4+math.random()*3, Enum.EasingStyle.Sine), {Position=endPos, Transparency=1}):Play()
	TweenService:Create(li, TweenInfo.new(3), {Brightness=0}):Play()
	task.delay(7.5, function()
		if p then p:Destroy(); partCount=math.max(0,partCount-1) end
	end)
end

-- INFECCIÓN MEJORADA: síntomas visuales más graduales y distintivos

-- Parpadeo de ojos (efecto en pantalla al inicio del contacto)
local function eyeFlashEffect(player)
	task.spawn(function()
		if not (player and player.Parent) then return end
		local sg = Instance.new("ScreenGui"); sg.ResetOnSpawn=false; sg.Name="__PibbyEye"
		sg.Parent = player:WaitForChild("PlayerGui")

		-- Manchas moradas en las esquinas de la pantalla
		local corners = {
			{UDim2.new(0,0,0,0)},
			{UDim2.new(0.85,0,0,0)},
			{UDim2.new(0,0,0.85,0)},
			{UDim2.new(0.85,0,0.85,0)},
		}
		for _, c in ipairs(corners) do
			local f = Instance.new("Frame")
			f.Size = UDim2.new(0.15,0,0.15,0)
			f.Position = c[1]
			f.BackgroundColor3 = Color3.fromRGB(120,0,200)
			f.BackgroundTransparency = 1
			f.BorderSizePixel = 0
			f.Parent = sg
			TweenService:Create(f,TweenInfo.new(0.5),{BackgroundTransparency=0.55}):Play()
			task.delay(2.5,function()
				TweenService:Create(f,TweenInfo.new(1.5),{BackgroundTransparency=1}):Play()
			end)
		end
		task.delay(4.2,function() if sg then sg:Destroy() end end)
	end)
end

-- MEJORA: síntoma de "visión de micelio" — jugadores infectados ven
-- más esporas y efectos en la pantalla según su stage
local function tickInfectionSymptoms(dt)
	for pl, data in pairs(infected) do
		if data.stage >= 2 and math.random() < 0.002 * data.stage then
			-- Micro-flash de color en pantalla (latido de la red)
			screenMsg(pl, rG():format(math.random(10,99)), rN(), 0.4)
		end
	end
end

-- MEJORA: propagación de infección a través del suelo (rastro de micelio
-- entre dos jugadores infectados en stages altos)
local mycelTrailT = 0
local function tickMycelTrail(dt)
	mycelTrailT += dt
	if mycelTrailT < 3 then return end
	mycelTrailT = 0

	local infectedList = {}
	for pl, data in pairs(infected) do
		if data.stage >= 3 then
			local ch = pl.Character
			if ch then
				local hrp = ch:FindFirstChild("HumanoidRootPart")
				if hrp then table.insert(infectedList, hrp.Position) end
			end
		end
	end
	if #infectedList < 2 then return end

	-- Crea un trail de micelio entre dos jugadores infectados cercanos
	local p1, p2 = infectedList[1], infectedList[2]
	local dist = (p2-p1).Magnitude
	if dist < 4 or dist > 30 then return end

	local segs = math.floor(dist/3)
	for i = 1, segs do
		if partCount >= CFG.MaxParts then break end
		local frac = i/segs
		local segPos = p1 + (p2-p1)*frac
		local gp, gn = castSurf(segPos + Vector3.new(0,2,0), Vector3.new(0,-1,0), 8)
		if gp and not isOcc(gp) then
			spawnBlob(gp, gn, 0.3+math.random()*0.5, 0.6+frac*0.3)
			markOcc(gp)
		end
	end
end

-- Hook en startInfection para añadir el eye flash
local _v35StartInfection = startInfection
function startInfection(player)
	_v35StartInfection(player)
	eyeFlashEffect(player)
end

-- FASE 3+: el suelo "late" con el micelio (pulsos de color en el Baseplate)
local baseplateT = 0
local function tickBaseplatePulse(dt)
	if currentPhase < 3 then return end
	baseplateT += dt
	if baseplateT < 3.5 - currentPhase*0.4 then return end
	baseplateT = 0

	local bp = workspace:FindFirstChild("Baseplate")
	if not bp or not bp:IsA("BasePart") then return end

	local oc = bp.Color
	local nc = lerpC(oc, rD(), 0.35 + currentPhase*0.08)
	TweenService:Create(bp, TweenInfo.new(0.4), {Color=nc}):Play()
	task.delay(0.5, function()
		TweenService:Create(bp, TweenInfo.new(0.8), {Color=oc}):Play()
	end)
end

-- FASE 4+: "eco de micelio" — los tendrils existentes mandan señales
local ecoT = 0
local function tickMycelEcho(dt)
	if currentPhase < 4 then return end
	ecoT += dt
	if ecoT < 1.5 then return end
	ecoT = 0

	if #tendrilRegistry == 0 then return end
	-- Selecciona un tendril al azar y lo hace "brillar"
	local n = math.min(8 + currentPhase*3, #tendrilRegistry)
	for _ = 1, n do
		local tr = tendrilRegistry[math.random(#tendrilRegistry)]
		if tr and tr.part and tr.part.Parent then
			local p = tr.part
			task.spawn(function()
				local oc, om = p.Color, p.Material
				p.Color = lerpC(oc, rN(), 0.6+math.random()*0.4)
				p.Material = Enum.Material.Neon
				task.wait(0.04+math.random()*0.06)
				if p and p.Parent then
					TweenService:Create(p, TweenInfo.new(0.3), {Color=oc}):Play()
					p.Material = om
				end
			end)
		end
	end
end

-- HEARTBEAT v3.5 secundario
RunService.Heartbeat:Connect(function(dt)
	tickAmbientSpores(dt)
	tickInfectionSymptoms(dt)
	tickMycelTrail(dt)
	tickBaseplatePulse(dt)
	tickMycelEcho(dt)
end)

-- ────────────────────────────────────────────────────────────────────
--  FIX 3: ANIMACIÓN DE INICIO DE 10 SEGUNDOS
--  La Part "Infeccion" gira lento → muy rápido → materiales/colores
--  aleatorios → para en seco → empieza la infección
-- ────────────────────────────────────────────────────────────────────

-- Materiales para la animación
local ANIM_MATERIALS = {
	Enum.Material.Neon,
	Enum.Material.SmoothPlastic,
	Enum.Material.Metal,
	Enum.Material.DiamondPlate,
	Enum.Material.Foil,
	Enum.Material.Granite,
	Enum.Material.Neon,
	Enum.Material.Glass,
}

local function playIntroAnimation(part, onComplete)
	if not (part and part.Parent) then onComplete(); return end

	-- Guarda estado original
	local origColor    = part.Color
	local origMaterial = part.Material
	local origSize     = part.Size
	local origCFrame   = part.CFrame

	-- Efectos de sonido / luz iniciales
	local introLight = Instance.new("PointLight")
	introLight.Color = Color3.fromRGB(255,0,255)
	introLight.Range = 0; introLight.Brightness = 0
	introLight.Parent = part
	TweenService:Create(introLight, TweenInfo.new(1), {Range=35, Brightness=4}):Play()

	-- BillboardGui de cuenta atrás
	local bb = Instance.new("BillboardGui")
	bb.Size = UDim2.new(0,180,0,50); bb.StudsOffset=Vector3.new(0,4,0)
	bb.AlwaysOnTop=true; bb.Parent=part
	local countLbl = Instance.new("TextLabel")
	countLbl.Size=UDim2.new(1,0,1,0); countLbl.BackgroundTransparency=1
	countLbl.TextColor3=Color3.fromRGB(255,0,255); countLbl.TextSize=28
	countLbl.Font=Enum.Font.GothamBold; countLbl.Text="INICIANDO..."
	countLbl.TextStrokeTransparency=0.3; countLbl.Parent=bb

	local startT = tick()
	local spinConn

	-- FASE A (0-3s): rotación lenta + pulsos de color suaves
	spinConn = RunService.Heartbeat:Connect(function(dt)
		if not (part and part.Parent) then spinConn:Disconnect(); return end
		local elapsed = tick() - startT

		if elapsed < 3 then
			-- Giro lento
			local speed = elapsed * 0.8  -- acelera gradualmente
			part.CFrame = origCFrame * CFrame.Angles(0, elapsed*speed*0.2, 0)
			-- Color oscilante
			local t2 = (math.sin(elapsed*2)+1)*0.5
			part.Color = lerpC(Color3.fromRGB(100,0,180), Color3.fromRGB(255,0,255), t2)
			countLbl.Text = "◈ BIOMASA ACTIVANDO ◈"
			countLbl.TextColor3 = lerpC(Color3.fromRGB(180,0,255), rN(), t2)

		elseif elapsed < 7 then
			-- FASE B (3-7s): aceleración + cambio caótico de material y color
			local frac = (elapsed-3)/4
			local spinSpeed = 2 + frac*18  -- de 2 a 20 rad/s
			part.CFrame = origCFrame * CFrame.Angles(
				math.sin(elapsed*3)*0.5,
				elapsed*spinSpeed,
				math.cos(elapsed*2)*0.4
			)
			-- Cambio random de color cada ~0.05s
			if math.floor(elapsed*20) > math.floor((elapsed-dt)*20) then
				part.Color = rN()
				part.Material = ANIM_MATERIALS[math.random(#ANIM_MATERIALS)]
				introLight.Color = part.Color
				introLight.Range = 30 + frac*20
				introLight.Brightness = 4 + frac*5
			end
			-- Tamaño pulsa
			local pulse = 1 + math.sin(elapsed*15)*0.25*frac
			part.Size = origSize * pulse

			-- Contador de cuenta atrás
			local remaining = math.ceil(10 - elapsed)
			countLbl.Text = "⚡ "..remaining.." ⚡"
			countLbl.TextSize = 24 + frac*18
			countLbl.TextColor3 = rN()

			-- Flashes externos
			if math.random() < 0.12 and partCount < CFG.MaxParts then
				local fp, fn = castSurf(part.Position+Vector3.new(0,2,0), Vector3.new(0,-1,0))
				if fp then spawnFlash(fp, fn or Vector3.new(0,1,0), 0.8+frac*1.5) end
			end

		elseif elapsed < 9.5 then
			-- FASE C (7-9.5s): caos total, giro máximo, escala crece
			local frac = (elapsed-7)/2.5
			part.CFrame = origCFrame * CFrame.Angles(
				elapsed*12,
				elapsed*25,
				elapsed*8
			)
			part.Color = math.random()<0.5 and rN() or rD()
			part.Material = math.random()<0.6 and Enum.Material.Neon or Enum.Material.SmoothPlastic
			introLight.Color = part.Color
			introLight.Range = 55; introLight.Brightness = 8

			-- Crece antes de parar
			local grow = 1 + frac*0.8
			part.Size = origSize * grow

			countLbl.Text = "!!!"
			countLbl.TextSize = 42
			countLbl.TextColor3 = rN()

			-- Flash denso
			if math.random() < 0.3 and partCount < CFG.MaxParts then
				local fp2, fn2 = castSurf(part.Position+Vector3.new(0,2,0), Vector3.new(0,-1,0))
				if fp2 then spawnFlash(fp2, fn2 or Vector3.new(0,1,0), 1.5+frac*2) end
			end

		else
			-- FASE D (9.5s+): STOP EN SECO
			spinConn:Disconnect()

			-- Para bruscamente
			part.CFrame = origCFrame
			part.Size    = origSize
			part.Color   = Color3.fromRGB(5,0,15)  -- negro corrupto
			part.Material= Enum.Material.SmoothPlastic

			-- Luz explota y desaparece
			introLight.Range = 80; introLight.Brightness = 12
			TweenService:Create(introLight, TweenInfo.new(1.2), {Brightness=0, Range=0}):Play()
			task.delay(1.3, function() if introLight then introLight:Destroy() end end)

			-- Mega flash
			local fp3, fn3 = castSurf(part.Position+Vector3.new(0,2,0), Vector3.new(0,-1,0))
			task.spawn(function()
				for _ = 1, 5 do
					spawnFlash(part.Position, Vector3.new(0,1,0), 3.5)
					if fp3 then spawnFlash(fp3, fn3 or Vector3.new(0,1,0), 2.5) end
					task.wait(0.06)
				end
			end)

			-- Billboard desaparece
			countLbl.Text = "CORRUPCIÓN ACTIVA"
			countLbl.TextColor3 = Color3.fromRGB(255,0,255)
			countLbl.TextSize = 22
			TweenService:Create(countLbl, TweenInfo.new(2), {TextTransparency=1}):Play()
			task.delay(2.2, function() if bb then bb:Destroy() end end)

			-- Espera un frame y lanza la infección
			task.delay(0.5, onComplete)
		end
	end)
end

-- ════════════════════════════════════════════════════════════════════

-- ════════════════════════════════════════════════════════════════════
--  v3.6 — FASE 3: DESTRUCCIÓN DE BLOQUES + SABOTAJE DE SCRIPTS
-- ════════════════════════════════════════════════════════════════════

-- ────────────────────────────────────────────────────────────────────
--  SISTEMA DE DESTRUCCIÓN DIRIGIDA (Fase 3+)
--  El micelio encuentra bloques entre él y los jugadores,
--  los corroe rápidamente y los destruye para abrir paso
-- ────────────────────────────────────────────────────────────────────

local destroyedParts  = {}   -- Part → true  (ya siendo destruida)
local destroyQueue    = {}   -- {part, targetPlayer}
local destroyScanT    = 0

-- Corroe y destruye una Part del mapa para abrir paso hacia un jugador
local function destroyBlockForPath(part, targetPos)
	if not (part and part.Parent) then return end
	if destroyedParts[part] then return end
	if part.Name == "Baseplate" then return end
	if part:FindFirstAncestor("PibbyFolder") then return end
	if part.Locked then return end
	-- No destruye partes de personajes
	for _, pl in ipairs(Players:GetPlayers()) do
		if pl.Character and part:IsDescendantOf(pl.Character) then return end
	end

	destroyedParts[part] = true
	local oc, om, os = part.Color, part.Material, part.Size

	task.spawn(function()
		-- Flash de aviso: el bloque "sabe" que va a ser destruido
		spawnFlash(part.Position, Vector3.new(0,1,0),
			math.clamp(part.Size.Magnitude*0.12, 0.5, 2.5))

		-- Fase 1 (1.5s): el bloque se infecta visualmente
		TweenService:Create(part, TweenInfo.new(0.8), {
			Color    = rD(),
			Material = Enum.Material.Neon,
		}):Play()
		task.wait(0.9)
		if not (part and part.Parent) then destroyedParts[part]=nil; return end

		-- Fase 2 (0.8s): parpadeo neon agresivo
		for _ = 1, 4 do
			if not (part and part.Parent) then break end
			part.Color = rN()
			task.wait(0.08)
			if part and part.Parent then part.Color = rD() end
			task.wait(0.08)
		end
		if not (part and part.Parent) then destroyedParts[part]=nil; return end

		-- Fase 3: desintegración — se encoge y desaparece
		TweenService:Create(part, TweenInfo.new(0.55, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
			Size        = os * 0.04,
			Transparency= 1,
		}):Play()
		spawnFlash(part.Position, Vector3.new(0,1,0),
			math.clamp(part.Size.Magnitude*0.18, 0.6, 3))

		task.wait(0.6)
		if part and part.Parent then
			-- Genera micelio en el hueco que dejó el bloque destruido
			local gp, gn = castSurf(part.Position + Vector3.new(0,3,0), Vector3.new(0,-1,0), 12)
			if gp then
				spawnBlob(gp, gn, 1.8+math.random()*2, 0.4)
				-- Nodos que van DIRECTO hacia el jugador
				local dir = (targetPos - gp)
				local fd  = Vector3.new(dir.X, 0, dir.Z)
				if fd.Magnitude > 0.1 then
					fd = fd.Unit
					for _ = 1, math.random(4,7) do
						local jitter = (math.random()-0.5)*0.5
						local bdir = rotXZ(fd, jitter)
						local l = math.random(CFG.LifeMin+5, CFG.LifeMax+15)
						table.insert(nodes, {
							pos=gp, dir=bdir, normal=gn,
							life=l, maxLife=l, depth=0, age=0.1,
							nodeType="hunter"  -- nodo cazador: busca jugadores
						})
					end
				end
			end
			part:Destroy()
		end
		destroyedParts[part] = nil
	end)
end

-- Escanea bloques en el camino entre el micelio y los jugadores
local function tickDestroyPath(dt)
	if currentPhase < 3 then return end
	destroyScanT += dt
	if destroyScanT < 2.2 then return end
	destroyScanT = 0

	if #blobReg == 0 then return end

	-- Para cada jugador, busca bloques entre el micelio más cercano y él
	for _, pl in ipairs(Players:GetPlayers()) do
		local ch = pl.Character
		if not ch then continue end
		local hrp = ch:FindFirstChild("HumanoidRootPart")
		if not hrp then continue end

		local playerPos = hrp.Position

		-- Encuentra el blob más cercano al jugador
		local nearestBlob, nearestDist = nil, math.huge
		for _, b in ipairs(blobReg) do
			local d = (b.pos - playerPos).Magnitude
			if d < nearestDist then nearestBlob=b; nearestDist=d end
		end
		if not nearestBlob then continue end

		-- Lanza raycast desde el blob hacia el jugador
		local toPlayer = (playerPos - nearestBlob.pos)
		local dist     = toPlayer.Magnitude
		if dist < 3 then continue end

		local dirToPlayer = toPlayer.Unit

		-- Múltiples raycasts en el camino (cada ~3 studs)
		local steps = math.min(math.floor(dist/3), 8)
		for i = 1, steps do
			local checkPos = nearestBlob.pos + dirToPlayer * (i/steps * dist)
			local r = workspace:Raycast(checkPos, dirToPlayer*4, rpMain)
			if r and r.Instance then
				local inst = r.Instance
				if inst:IsA("BasePart")
					and not inst:FindFirstAncestor("PibbyFolder")
					and inst.Name ~= "Baseplate"
					and not inst.Locked
					and not destroyedParts[inst]
					and inst.Anchored then

					-- Fase 3: destruye cualquier bloque en el camino
					-- Fase 4+: también destruye bloques más grandes
					local sizeLimit = currentPhase >= 4 and 200 or 80
					if inst.Size.Magnitude < sizeLimit then
						table.insert(destroyQueue, {part=inst, targetPos=playerPos})
						break  -- solo 1 bloque por jugador por tick
					end
				end
			end
		end
	end

	-- Procesa la cola de destrucción (máx 2 por tick)
	local processed = 0
	while #destroyQueue > 0 and processed < 2 do
		local entry = table.remove(destroyQueue, 1)
		if entry and entry.part and entry.part.Parent then
			destroyBlockForPath(entry.part, entry.targetPos)
			processed += 1
		end
	end
end

-- ────────────────────────────────────────────────────────────────────
--  NODOS HUNTER: van directamente hacia el jugador más cercano
--  (generados en los huecos que dejan los bloques destruidos)
-- ────────────────────────────────────────────────────────────────────
-- Los nodos "hunter" son manejados por tickMycelium normal,
-- pero con memBiasDir siempre activo al 100%
-- Interceptamos la lógica de dirección en el tick

local _v35TickMyceliumHunter = tickMycelium
function tickMycelium()
	-- Pre-procesa nodos hunter: sesgo máximo hacia jugadores
	local hunterNodes  = {}
	local otherNodes   = {}
	for _, node in ipairs(nodes) do
		if node.nodeType == "hunter" then
			table.insert(hunterNodes, node)
		else
			table.insert(otherNodes, node)
		end
	end

	-- Procesa hunters con sesgo total hacia jugadores
	local hunterNext = {}
	for _, node in ipairs(hunterNodes) do
		if node.life <= 0 then
			local gp,gn = castSurf(node.pos+node.normal,-node.normal,4)
			if gp then spawnBlob(gp,gn,CFG.BlobRadMin+math.random()*0.8,0.7) end
			continue
		end

		-- Dirección: SIEMPRE hacia el jugador más cercano
		local bestDir = node.dir
		local bestDist = math.huge
		for _, pl in ipairs(Players:GetPlayers()) do
			local ch = pl.Character
			if ch then
				local h = ch:FindFirstChild("HumanoidRootPart")
				if h then
					local d = (h.Position - node.pos).Magnitude
					if d < bestDist then
						bestDist = d
						local toP = h.Position - node.pos
						bestDir = Vector3.new(toP.X, 0, toP.Z).Unit
					end
				end
			end
		end

		-- Pequeño jitter para que no sea perfectamente recto
		local huntDir = rotXZ(bestDir, (math.random()-0.5)*0.35)
		local np, nn, ud = nextSurf(node.pos, huntDir, node.normal, CFG.StepSize*1.2)
		if not np then
			-- Bloqueado: intenta destruir lo que hay en el camino
			local r = workspace:Raycast(node.pos, huntDir*4, rpMain)
			if r and r.Instance and r.Instance:IsA("BasePart")
				and not destroyedParts[r.Instance]
				and r.Instance.Name ~= "Baseplate"
				and not r.Instance:FindFirstAncestor("PibbyFolder")
				and r.Instance.Anchored then
				destroyBlockForPath(r.Instance, node.pos + huntDir*20)
			end
			continue
		end

		-- No usa anti-solapamiento (va a toda velocidad)
		spawnTendril(node.pos, np, nn, 1-(node.life/node.maxLife), math.random()<0.12, false)
		if math.random()<0.18 then
			spawnBlob(np, nn, CFG.BlobRadMin+math.random()*1.0, 0.65)
		end

		table.insert(hunterNext, {
			pos=np, dir=ud or huntDir, normal=nn,
			life=node.life-1, maxLife=node.maxLife,
			depth=node.depth, age=node.age+1, nodeType="hunter"
		})

		-- Infecta al tocar
		for _, pl in ipairs(Players:GetPlayers()) do
			if not infected[pl] then
				local ch = pl.Character
				if ch then
					local h = ch:FindFirstChild("HumanoidRootPart")
					if h and (h.Position-np).Magnitude < CFG.PlayerRadius then
						startInfection(pl)
					end
				end
			end
		end
	end

	-- Restaura nodos y ejecuta tick normal
	nodes = otherNodes
	_v35TickMyceliumHunter()
	for _, hn in ipairs(hunterNext) do table.insert(nodes, hn) end
end

-- ────────────────────────────────────────────────────────────────────
--  SABOTAJE DE SCRIPTS (Fase 3+)
--  Desactiva scripts existentes en el juego excepto el propio
-- ────────────────────────────────────────────────────────────────────

-- Referencia al script propio para no tocarlo nunca
local MY_SCRIPT = script  -- el script que contiene este código

local sabotageT   = 0
local sabotaged   = {}  -- Script → true
local SABOTAGE_FX = {   -- efectos visuales al sabotear
	"SCRIPT CORRUPTED", "PROCESS KILLED", "MEMORY LEAK",
	"STACK OVERFLOW", "NULL REFERENCE", "RUNTIME ERROR",
	"EXECUTION HALTED", "THREAD KILLED",
}

local function sabotageScript(s)
	if not (s and s.Parent) then return end
	if s == MY_SCRIPT then return end               -- nunca toca el propio
	if sabotaged[s] then return end
	if s:IsA("LocalScript") or s:IsA("Script") or s:IsA("ModuleScript") then
		sabotaged[s] = true

		task.spawn(function()
			-- Efecto visual: mensaje de error en pantalla de todos los jugadores
			local msg = SABOTAGE_FX[math.random(#SABOTAGE_FX)]
			for _, pl in ipairs(Players:GetPlayers()) do
				screenMsg(pl, "["..s.Name.."] "..msg, Color3.fromRGB(255,40,0), 2)
			end

			task.wait(0.3 + math.random()*0.5)
			if not (s and s.Parent) then return end

			-- Desactiva el script
			if s:IsA("Script") or s:IsA("LocalScript") then
				pcall(function() s.Disabled = true end)
			end

			-- Pequeño flash en la posición del objeto que contenía el script
			local parent = s.Parent
			if parent and parent:IsA("BasePart") then
				spawnFlash(parent.Position, Vector3.new(0,1,0), 0.8)
			end

			print("[Pibby] ☠ Script saboteado: "..s:GetFullName())
		end)
	end
end

local function tickScriptSabotage(dt)
	if currentPhase < 3 then return end
	sabotageT += dt
	-- Fase 3: cada 8s sabotea 1 script  |  Fase 4: cada 4s  |  Fase 5: cada 1.5s
	local interval = currentPhase >= 5 and 1.5 or (currentPhase >= 4 and 4 or 8)
	if sabotageT < interval then return end
	sabotageT = 0

	-- Recolecta scripts del juego (ServerScriptService, workspace, etc.)
	local candidates = {}
	local searchRoots = {
		game:GetService("ServerScriptService"),
		workspace,
		game:GetService("ReplicatedStorage"),
		game:GetService("StarterPack"),
		game:GetService("StarterPlayer"),
	}
	for _, root in ipairs(searchRoots) do
		pcall(function()
			for _, obj in ipairs(root:GetDescendants()) do
				if (obj:IsA("Script") or obj:IsA("LocalScript"))
					and obj ~= MY_SCRIPT
					and not obj.Disabled
					and not sabotaged[obj] then
					table.insert(candidates, obj)
				end
			end
		end)
	end

	if #candidates == 0 then return end

	-- Sabotea 1 script al azar (o más en fases avanzadas)
	local count = currentPhase >= 5 and math.random(2,4) or 1
	for _ = 1, count do
		if #candidates == 0 then break end
		local idx = math.random(#candidates)
		sabotageScript(table.remove(candidates, idx))
	end
end

-- ────────────────────────────────────────────────────────────────────
--  HEARTBEAT v3.6
-- ────────────────────────────────────────────────────────────────────
RunService.Heartbeat:Connect(function(dt)
	tickDestroyPath(dt)
	tickScriptSabotage(dt)
end)

-- ════════════════════════════════════════════════════════════════════
--  ARRANQUE v3.6 — Con animación de inicio
-- ════════════════════════════════════════════════════════════════════
task.wait(0.6)
local origin = getOrigin()
local infeccionPart = workspace:FindFirstChild("Infeccion")

if infeccionPart and infeccionPart:IsA("BasePart") then
	print("[Pibby] ◈ Animación de inicio — 10 segundos...")
	playIntroAnimation(infeccionPart, function()
		print("[Pibby] ◈ Animación completa — INICIANDO BIOMASA")
		infectionReady = true  -- desbloquea el heartbeat
		for i = 1, CFG.InitialWaves do
			task.delay(i*0.45, function()
				local off = i==1 and Vector3.new(0,0,0) or Vector3.new(math.random(-22,22),0,math.random(-22,22))
				spawnWave(origin + off)
			end)
		end
	end)
else
	infectionReady = true  -- sin animación, arranca directo
	for i = 1, CFG.InitialWaves do
		task.delay(i*0.45, function()
			local off = i==1 and Vector3.new(0,0,0) or Vector3.new(math.random(-22,22),0,math.random(-22,22))
			spawnWave(origin + off)
		end)
	end
end

