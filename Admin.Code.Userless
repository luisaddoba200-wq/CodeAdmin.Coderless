	local f=Instance.new("Folder"); f.Name="PibbyFolder"; f.Parent=workspace; return f
end)()
folder:ClearAllChildren()

local partCount=0; local sporeCount=0
local nodes={}; local spores={}; local fruitBodies={}
local blobReg={}   -- {pos, time}  ← NUNCA se modifica dentro de iteraciones
local consumed={}; local infected={}; local infectedNpcs={}
local playerMem={}; local bioLumReg={}
local timer_acc=0; local waveTimer=0; local fruitTimer=0
local bioTimer=0;  local memTimer=0;  local gridCleanT=0
local npcScanTimer=0
local currentPhase=0; local phaseFlags={}
local spatialGrid={}
local clashCooldown=0

local origGravity=workspace.Gravity
local origL={Ambient=Lighting.Ambient,OutdoorAmbient=Lighting.OutdoorAmbient,
	FogColor=Lighting.FogColor,FogEnd=Lighting.FogEnd,
	FogStart=Lighting.FogStart,Brightness=Lighting.Brightness}
