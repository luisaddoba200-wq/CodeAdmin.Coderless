-- ════════════════════════════════════════════════════════════════════
--  v3.7+ ejecutado en scope propio para evitar límite de 200 locals
-- ════════════════════════════════════════════════════════════════════
;(function()

	-- ════════════════════════════════════════════════════════════════════
	--  v3.7 — MEJORAS MASIVAS DE MOVIMIENTO + NUEVOS SISTEMAS
	--  ✓ nextSurf completamente reescrito: sube Y baja paredes reales
	--  ✓ Propagación mucho más agresiva y fluida
	--  ✓ Skybox glitch por fases
	--  ✓ Esporas que salen del cuerpo infectado
	--  ✓ Memoria de rutas (el micelio recuerda caminos exitosos)
	--  ✓ Zonas de cuarentena (Parts "Quarantine_XX" bloquean el micelio)
	--  ✓ Chat corrompido para infectados
	--  ✓ Leaderboard/stats glitcheados
	--  ✓ Sonidos del juego distorsionados gradualmente
	-- ════════════════════════════════════════════════════════════════════

	-- ────────────────────────────────────────────────────────────────────
	--  FIX CRÍTICO: nextSurf REESCRITO DESDE CERO
	--  El anterior tenía referencias a `p` (variable sin definir) y
	--  no manejaba correctamente superficies verticales ni inversas.
	--  Esta versión maneja: suelo, techo, pared izq/der, esquinas,
	--  caídas, escalada inversa (underside), y meshes/unions.
	-- ────────────────────────────────────────────────────────────────────

	local _v36NextSurf = nextSurf   -- guarda la cadena anterior por si acaso

	function nextSurf(from, move, sn, stepOvr)
		local step = stepOvr or CFG.StepSize

		-- Proyecta la dirección sobre el plano de la superficie actual
		local flat = move - sn * move:Dot(sn)
		if flat.Magnitude < 0.001 then flat = move else flat = flat.Unit end

		-- ── INTENTO 1: avance normal sobre la superficie ──────────────────
		-- Proyecta un paso adelante+arriba y raya hacia abajo
		local probe1 = from + flat*step + sn*(step*0.8)
		local r1 = workspace:Raycast(probe1, -sn*(step*2.2), rpMain)
		if r1 and not isSolid(r1.Position + r1.Normal*0.1) then
			return r1.Position + r1.Normal*CFG.SurfaceOff, r1.Normal, flat
		end

		-- ── INTENTO 2: abanico de 7 rayos (meshes/unions irregulares) ────
		local fanAngles7 = {0, -0.3, 0.3, -0.6, 0.6, -1.0, 1.0}
		for _, ang in ipairs(fanAngles7) do
			local testDir = rotXZ(flat, ang)
			local testProbe = from + testDir*step + sn*(step*0.7)
			local r = workspace:Raycast(testProbe, -sn*(step*2.5), rpMain)
			if r and not isSolid(r.Position + r.Normal*0.1) then
				if r.Normal:Dot(sn) > -0.15 then
					return r.Position + r.Normal*CFG.SurfaceOff, r.Normal, testDir
				end
			end
		end

		-- ── INTENTO 3: ESCALADA DE PARED (sube por el lado del bloque) ───
		-- Raya lateral para encontrar la cara de la pared
		local wallHit = workspace:Raycast(from + sn*0.2, flat*(step*1.4), rpMain)
		if wallHit then
			local wn = wallHit.Normal
			if math.abs(wn.Y) < 0.45 then  -- es una pared, no suelo
				-- Intenta varios escalones hacia arriba (FIX: no usa isSolid en superficies de pared)
				for climb = 1, 6 do
					local climbH  = climb * (step*0.45)
					-- Raya desde la cara de la pared hacia afuera y arriba para encontrar la cima
					local climbOrigin = wallHit.Position + wn*CFG.SurfaceOff + Vector3.new(0, climbH, 0)
					local climbRay = workspace:Raycast(climbOrigin + flat*step*0.5, -sn*(step*2.5), rpMain)
					if climbRay then
						-- Acepta si la normal es mayormente vertical (estamos en la cima)
						if climbRay.Normal.Y > 0.4 then
							return climbRay.Position + climbRay.Normal*CFG.SurfaceOff, climbRay.Normal, flat
						end
					end
				end
				-- También: prueba avanzar sobre la cara de la pared directamente
				local wallTopRay = workspace:Raycast(
					wallHit.Position + wn*CFG.SurfaceOff + Vector3.new(0, step*0.6, 0),
					flat * (step*0.8), rpMain)
				if not wallTopRay then
					-- Hay espacio → salta a la cima del bloque
					local topPos = wallHit.Position + wn*CFG.SurfaceOff + Vector3.new(0, step*0.6, 0) + flat*step*0.8
					local landRay = workspace:Raycast(topPos + Vector3.new(0, step*0.5, 0), Vector3.new(0,-1,0)*step*2, rpMain)
					if landRay and landRay.Normal.Y > 0.4 then
						return landRay.Position + landRay.Normal*CFG.SurfaceOff, landRay.Normal, flat
					end
				end
				-- Si no puede subir: se adhiere a la cara lateral de la pared
				local wallSurf = wallHit.Position + wn*CFG.SurfaceOff
				if not isSolid(wallSurf + wn*0.2) then
					-- Genera un paso lateral sobre la pared
					local wallTangent = wn:Cross(Vector3.new(0,1,0))
					if wallTangent.Magnitude < 0.01 then wallTangent = wn:Cross(flat) end
					wallTangent = wallTangent.Unit
					-- Elige la tangente que va más en la dirección original
					if wallTangent:Dot(flat) < 0 then wallTangent = -wallTangent end
					local wallStep = wallSurf + wallTangent*step
					local wallRay2 = workspace:Raycast(wallStep + wn*(step*0.5), -wn*(step*1.5), rpMain)
					if wallRay2 and not isSolid(wallRay2.Position + wallRay2.Normal*0.1) then
						return wallRay2.Position + wallRay2.Normal*CFG.SurfaceOff, wallRay2.Normal, wallTangent
					end
					return wallSurf, wn, flat   -- queda en la cara de la pared
				end
			end
		end

		-- ── INTENTO 4: DESCENSO POR BORDE (cae y sigue por abajo) ────────
		-- El micelio cae por el borde de la plataforma
		local edgeProbe = from + flat*step
		local edgeRay = workspace:Raycast(edgeProbe + sn*0.3, -sn*(CFG.RayDown*1.5), rpMain)
		if edgeRay and not isSolid(edgeRay.Position + edgeRay.Normal*0.1) then
			return edgeRay.Position + edgeRay.Normal*CFG.SurfaceOff, edgeRay.Normal, flat
		end

		-- ── INTENTO 5: ESCALADA INVERSA (superficie inferior del bloque) ──
		-- El micelio va por debajo de plataformas
		local underRay = workspace:Raycast(from - sn*(step*0.4), flat*(step*1.2), rpMain)
		if underRay then
			local un = underRay.Normal
			if un:Dot(sn) < -0.3 then  -- normal apunta hacia abajo = cara inferior
				local underSurf = underRay.Position + un*CFG.SurfaceOff
				if not isSolid(underSurf - un*0.2) then
					return underSurf, un, flat
				end
			end
		end

		-- ── INTENTO 6: RODEO LATERAL (últimas alternativas) ──────────────
		for _, sign in ipairs({1,-1,-1,1}) do
			for _, ang in ipairs({math.pi*0.33, math.pi*0.5, math.pi*0.66, math.pi*0.85}) do
				local altDir = rotXZ(flat, sign*ang)
				local altProbe = from + altDir*step + sn*(step*0.6)
				local altRay = workspace:Raycast(altProbe, -sn*(step*2.2), rpMain)
				if altRay and not isSolid(altRay.Position + altRay.Normal*0.1) then
					return altRay.Position + altRay.Normal*CFG.SurfaceOff, altRay.Normal, altDir
				end
			end
		end

		return nil, nil, flat
	end

	-- ────────────────────────────────────────────────────────────────────
	--  ZONAS DE CUARENTENA
	--  Cualquier Part en workspace cuyo nombre empiece por "Quarantine"
	--  actúa como barrera impenetrable para el micelio
	-- ────────────────────────────────────────────────────────────────────

	local quarantineZones = {}   -- lista de {pos, radius, part}
	local quarantineScanT = 0

	local function refreshQuarantine()
		quarantineZones = {}
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("BasePart") and obj.Name:sub(1,10) == "Quarantine" then
				table.insert(quarantineZones, {
					pos    = obj.Position,
					radius = math.max(obj.Size.X, obj.Size.Y, obj.Size.Z) * 0.6,
					part   = obj
				})
			end
		end
	end

	-- Devuelve true si una posición está dentro de alguna zona de cuarentena
	local function inQuarantine(pos)
		for _, z in ipairs(quarantineZones) do
			if not (z.part and z.part.Parent) then continue end
			if (z.pos - pos).Magnitude < z.radius then return true end
		end
		return false
	end

	-- Efecto visual en las zonas de cuarentena
	local function tickQuarantineVFX(dt)
		quarantineScanT += dt
		if quarantineScanT < 5 then return end
		quarantineScanT = 0
		refreshQuarantine()

		for _, z in ipairs(quarantineZones) do
			if not (z.part and z.part.Parent) then continue end
			-- Anillo neon de "barrera" alrededor de la zona
			if math.random() < 0.25 then
				task.spawn(function()
					local p = Instance.new("Part")
					p.Anchored=true; p.CanCollide=false; p.CastShadow=false
					p.Shape=Enum.PartType.Ball; p.Size=Vector3.new(z.radius*2+0.3, 0.12, z.radius*2+0.3)
					p.Position = z.pos; p.Color = Color3.fromRGB(0,255,80)
					p.Material = Enum.Material.Neon; p.Transparency=0.3
					p.Parent = folder; partCount+=1
					TweenService:Create(p, TweenInfo.new(1.2), {Transparency=1, Size=p.Size*1.08}):Play()
					task.delay(1.3, function() if p then p:Destroy(); partCount=math.max(0,partCount-1) end end)
				end)
			end
		end
	end

	-- Inyecta la revisión de cuarentena en el tick principal
	-- Los nodos que caen en zona de cuarentena simplemente mueren
	local _v36TickMyceliumQ = tickMycelium
	function tickMycelium()
		-- Filtra nodos que entraron en cuarentena antes de procesar
		local safeNodes = {}
		for _, node in ipairs(nodes) do
			if not inQuarantine(node.pos) then
				table.insert(safeNodes, node)
			else
				-- Chispa verde al "morir" en la barrera
				if math.random() < 0.12 and partCount < CFG.MaxParts then
					spawnFlash(node.pos, node.normal or Vector3.new(0,1,0), 0.3)
				end
			end
		end
		nodes = safeNodes
		_v36TickMyceliumQ()
	end

	-- ────────────────────────────────────────────────────────────────────
	--  MEMORIA DE RUTAS (Path Memory)
	--  El micelio recuerda qué caminos le funcionaron y los refuerza.
	--  Las rutas exitosas generan "nodos semilla" que brotan de nuevo.
	-- ────────────────────────────────────────────────────────────────────

	local pathMemory    = {}    -- lista de {pos, normal, dir, heat, time}
	local PATH_MAX      = 350   -- máximo de puntos en memoria
	local PATH_HEAT_MAX = 18    -- calor máximo de una ruta
	local pathMemT      = 0

	-- Registra un paso exitoso del micelio en la memoria de ruta
	local function registerPath(pos, normal, dir)
		-- Evita duplicar puntos muy cercanos
		for _, m in ipairs(pathMemory) do
			if (m.pos - pos).Magnitude < CFG.StepSize*1.5 then
				m.heat = math.min(m.heat + 1, PATH_HEAT_MAX)
				m.time = tick()
				return
			end
		end
		table.insert(pathMemory, {pos=pos, normal=normal, dir=dir, heat=1, time=tick()})
		if #pathMemory > PATH_MAX then table.remove(pathMemory, 1) end
	end

	-- El micelio "florece" desde rutas calientes periódicamente
	local function tickPathMemory(dt)
		pathMemT += dt
		if pathMemT < 6 then return end
		pathMemT = 0

		if #pathMemory == 0 or partCount >= CFG.MaxParts - 5 then return end
		if #nodes >= CFG.MaxNodes then return end

		-- Decae el calor con el tiempo
		local t = tick()
		local fresh = {}
		for _, m in ipairs(pathMemory) do
			m.heat = math.max(0, m.heat - (t - m.time) * 0.015)
			if m.heat > 0.5 then table.insert(fresh, m) end
		end
		pathMemory = fresh

		if #pathMemory == 0 then return end

		-- Selecciona puntos calientes y brota nodos desde ellos
		table.sort(pathMemory, function(a,b) return a.heat > b.heat end)
		local maxBrotar = math.min(3, math.floor(currentPhase/1.5)+1)
		for i = 1, maxBrotar do
			if i > #pathMemory then break end
			local m = pathMemory[i]
			if m.heat >= 4 and not inQuarantine(m.pos) then
				-- Brota un nodo en dirección recordada
				local jitter = (math.random()-0.5)*0.4
				local bdir = rotXZ(m.dir, jitter)
				local blife = math.random(CFG.LifeMin, math.floor(CFG.LifeMax * (m.heat/PATH_HEAT_MAX) + 8))
				table.insert(nodes, {
					pos=m.pos, dir=bdir, normal=m.normal,
					life=blife, maxLife=blife,
					depth=0, age=0.08, nodeType="pathgrow"
				})
				-- Flash sutil: la ruta "recuerda"
				if math.random() < 0.3 then
					spawnFlash(m.pos, m.normal, 0.25)
				end
			end
		end
	end

	-- Hook en spawnTendril para registrar rutas exitosas
	local _v37SpawnTendril = spawnTendril
	function spawnTendril(from, to, sn, age, isNeon, isRhizo)
		local p = _v37SpawnTendril(from, to, sn, age, isNeon, isRhizo)
		-- Solo registra tendrils normales maduros (no rhizo ni muy jóvenes)
		if p and not isRhizo and age > 0.25 and math.random() < 0.35 then
			local mid = (from+to)/2
			local dir = (to-from)
			if dir.Magnitude > 0.01 then
				registerPath(mid, sn, Vector3.new(dir.X,0,dir.Z).Unit)
			end
		end
		return p
	end

	-- ────────────────────────────────────────────────────────────────────
	--  SKYBOX GLITCH (cielo se rompe por fases)
	--  Manipula el Sky de Lighting para que "falle" visualmente
	-- ────────────────────────────────────────────────────────────────────

	local skyGlitchT   = 0
	local skyOrigProps = {}

	local function captureSky()
		local sky = Lighting:FindFirstChildOfClass("Sky")
		if sky then
			skyOrigProps = {
				SkyboxBk = sky.SkyboxBk, SkyboxDn = sky.SkyboxDn,
				SkyboxFt = sky.SkyboxFt, SkyboxLf = sky.SkyboxLf,
				SkyboxRt = sky.SkyboxRt, SkyboxUp = sky.SkyboxUp,
				StarCount = sky.StarCount,
			}
		end
	end
	captureSky()

	-- Glitch del skybox: voltea, invierte o elimina partes del cielo
	local SKY_GLITCH_IDS = {
		"rbxassetid://6444884337",   -- negro puro
		"rbxassetid://5616220888",   -- distorsión digital
	}

	local function doSkyGlitch()
		local sky = Lighting:FindFirstChildOfClass("Sky")
		if not sky then return end
		if currentPhase < 2 then return end

		local intensity = currentPhase / 5   -- 0.4 → 1.0

		-- Probabilidad de glitch según fase
		if math.random() > intensity * 0.7 then return end

		task.spawn(function()
			local origBk = sky.SkyboxBk

			-- Tipos de glitch dependiendo de la fase
			local glitchType = math.random(1, math.max(1, currentPhase))

			if glitchType == 1 then
				-- Flip: el cielo se invierte momentáneamente
				sky.SkyboxUp = sky.SkyboxDn
				task.wait(0.04 + math.random()*0.08)
				if skyOrigProps.SkyboxUp then sky.SkyboxUp = skyOrigProps.SkyboxUp end

			elseif glitchType == 2 then
				-- Swap: caras se mezclan
				local tmp = sky.SkyboxFt
				sky.SkyboxFt = sky.SkyboxBk
				sky.SkyboxBk = sky.SkyboxLf
				task.wait(0.06 + math.random()*0.10)
				if skyOrigProps.SkyboxFt then
					sky.SkyboxFt = skyOrigProps.SkyboxFt
					sky.SkyboxBk = skyOrigProps.SkyboxBk
				end

			elseif glitchType >= 3 then
				-- Colapso: el cielo se vuelve negro
				sky.SkyboxBk = SKY_GLITCH_IDS[1]
				sky.SkyboxFt = SKY_GLITCH_IDS[1]
				sky.SkyboxLf = SKY_GLITCH_IDS[1]
				sky.SkyboxRt = SKY_GLITCH_IDS[1]
				local dur = 0.08 + math.random()*0.25 * intensity
				task.wait(dur)
				if skyOrigProps.SkyboxBk then
					sky.SkyboxBk = skyOrigProps.SkyboxBk
					sky.SkyboxFt = skyOrigProps.SkyboxFt
					sky.SkyboxLf = skyOrigProps.SkyboxLf
					sky.SkyboxRt = skyOrigProps.SkyboxRt
				end
			end

			-- En fases 4-5: las estrellas también fallan
			if currentPhase >= 4 then
				sky.StarCount = math.random(0, 5000)
				task.wait(0.12)
				if skyOrigProps.StarCount then sky.StarCount = skyOrigProps.StarCount end
			end
		end)
	end

	local function tickSkyGlitch(dt)
		if currentPhase < 2 then return end
		skyGlitchT += dt
		-- Frecuencia: fase 2 cada ~12s, fase 5 cada ~1.5s
		local freq = math.max(1.5, 14 - currentPhase*2.5)
		if skyGlitchT < freq then return end
		skyGlitchT = 0
		doSkyGlitch()
	end

	-- ────────────────────────────────────────────────────────────────────
	--  ESPORAS DEL CUERPO INFECTADO
	--  Pequeñas partículas neon que salen del personaje infectado
	-- ────────────────────────────────────────────────────────────────────

	local bodySporeT  = {}  -- player → timer
	local BODY_SPORE_PARTS = {"UpperTorso","Torso","LowerTorso","Head"}

	local function emitBodySpore(player)
		if not (player and player.Parent) then return end
		local ch = player.Character; if not ch then return end
		local data = infected[player]; if not data then return end
		if partCount >= CFG.MaxParts then return end

		-- Elige una parte del cuerpo al azar para emitir
		local partName = BODY_SPORE_PARTS[math.random(#BODY_SPORE_PARTS)]
		local bp = ch:FindFirstChild(partName) or ch:FindFirstChild("HumanoidRootPart")
		if not (bp and bp:IsA("BasePart")) then return end

		-- Cuántas esporas según stage
		local count = data.stage + 1
		for _ = 1, count do
			if partCount >= CFG.MaxParts then break end
			local sz = 0.05 + math.random()*0.10
			local sp = Instance.new("Part")
			sp.Anchored=true; sp.CanCollide=false; sp.CastShadow=false
			sp.Shape=Enum.PartType.Ball; sp.Size=Vector3.new(sz,sz,sz)
			-- Posición aleatoria dentro del volumen del cuerpo
			local off = Vector3.new(
				(math.random()-0.5)*bp.Size.X*0.8,
				(math.random()-0.5)*bp.Size.Y*0.8,
				(math.random()-0.5)*bp.Size.Z*0.8
			)
			sp.Position = bp.Position + off
			sp.Color = math.random()<0.6 and rN() or mycelColor(0.3+math.random()*0.5)
			sp.Material = Enum.Material.Neon; sp.Transparency = 0.1
			sp.Parent = folder; partCount += 1

			local li = Instance.new("PointLight"); li.Color=sp.Color
			li.Range=2.5; li.Brightness=1.2; li.Parent=sp

			-- Flota hacia arriba y desaparece
			local rise = Vector3.new(
				(math.random()-0.5)*3,
				2.5 + math.random()*3.5 + data.stage*0.5,
				(math.random()-0.5)*3
			)
			local duration = 1.8 + math.random()*2.2
			TweenService:Create(sp, TweenInfo.new(duration, Enum.EasingStyle.Sine), {
				Position = sp.Position + rise,
				Transparency = 1,
				Size = Vector3.new(sz*0.2, sz*0.2, sz*0.2)
			}):Play()
			TweenService:Create(li, TweenInfo.new(duration*0.7), {Brightness=0}):Play()
			task.delay(duration+0.1, function()
				if sp then sp:Destroy(); partCount=math.max(0,partCount-1) end
			end)
		end
	end

	local function tickBodySpores(dt)
		for pl, data in pairs(infected) do
			if data.stage < 1 then continue end
			bodySporeT[pl] = (bodySporeT[pl] or 0) + dt
			-- Frecuencia de emisión según stage
			local interval = math.max(0.3, 2.5 - data.stage*0.4)
			if bodySporeT[pl] >= interval then
				bodySporeT[pl] = 0
				emitBodySpore(pl)
			end
		end
	end

	-- ────────────────────────────────────────────────────────────────────
	--  CHAT CORROMPIDO
	--  Los mensajes de jugadores infectados se distorsionan
	-- ────────────────────────────────────────────────────────────────────

	local ChatService = game:GetService("Chat")

	local CORRUPT_CHARS = {"█","▓","▒","░","▄","▀","■","□","▪","▫","◆","◇","○","●","×","÷","§","¶"}
	local CORRUPT_WORDS = {
		"ERROR","NULL","VOID","LOST","HELP","THEY","COME","DARK",
		"OVER","FEED","GROW","MINE","OURS","THEM","SOON","LATE",
	}

	local function corruptText(txt, stage)
		if stage <= 0 then return txt end
		local corruptRate = stage * 0.12   -- 12% → 60% de corrupción
		local result = {}
		for i = 1, #txt do
			local c = txt:sub(i,i)
			if c == " " then
				-- A veces inserta una palabra corrupta en el espacio
				if math.random() < corruptRate * 0.4 then
					table.insert(result, " "..CORRUPT_WORDS[math.random(#CORRUPT_WORDS)].." ")
				else
					table.insert(result, c)
				end
			elseif math.random() < corruptRate then
				table.insert(result, CORRUPT_CHARS[math.random(#CORRUPT_CHARS)])
			else
				-- A veces cambia mayúscula/minúscula
				if math.random() < corruptRate*0.5 then
					table.insert(result, math.random()<0.5 and c:upper() or c:lower())
				else
					table.insert(result, c)
				end
			end
		end
		-- En stage 5: a veces reemplaza TODO el mensaje
		if stage >= 5 and math.random() < 0.35 then
			return CORRUPT_WORDS[math.random(#CORRUPT_WORDS)].." "..CORRUPT_WORDS[math.random(#CORRUPT_WORDS)]
				.." "..CORRUPT_CHARS[math.random(#CORRUPT_CHARS)]:rep(math.random(3,8))
		end
		return table.concat(result)
	end

	-- Hook en el chat de cada jugador infectado
	local chatHooked = {}

	local function hookPlayerChat(player)
		if chatHooked[player] then return end
		chatHooked[player] = true

		-- Conecta al evento de chat del servidor
		player.Chatted:Connect(function(msg)
			local data = infected[player]
			if not data or data.stage < 2 then return end  -- solo corrompe en stage 2+
			if math.random() > 0.65 then return end  -- no siempre

			local corrupted = corruptText(msg, data.stage)
			if corrupted ~= msg then
				-- Muestra el mensaje corrompido como burbuja
				task.delay(0.08, function()
					local ch = player.Character
					if ch then
						pcall(function()
							ChatService:Chat(ch:FindFirstChild("Head") or ch:FindFirstChild("HumanoidRootPart"), corrupted, Enum.ChatColor.Red)
						end)
					end
				end)
			end
		end)
	end

	-- Hookea nuevos jugadores y los que se infecten
	Players.PlayerAdded:Connect(function(pl)
		pl.CharacterAdded:Wait()
		hookPlayerChat(pl)
	end)
	for _, pl in ipairs(Players:GetPlayers()) do hookPlayerChat(pl) end

	-- Mensajes de chat "espontáneos" desde jugadores infectados en stages altos
	local chatSpawnT = 0
	local SPOOKY_MSGS = {
		"...puedo sentirlo crecer","ya casi","me rinde","qué suave se siente",
		"por qué corro si ya no importa","ven con nosotros","es más fácil si te quedas quieto",
		"...no duele","somos el micelio","¿escuchas eso?","sí","no","espera","ya vienen",
	}

	local function tickCorruptChat(dt)
		chatSpawnT += dt
		if chatSpawnT < 18 then return end
		chatSpawnT = 0
		if currentPhase < 2 then return end

		for pl, data in pairs(infected) do
			if data.stage >= 3 and math.random() < 0.3 then
				local msg = math.random()<0.5
					and corruptText(SPOOKY_MSGS[math.random(#SPOOKY_MSGS)], data.stage)
					or CORRUPT_WORDS[math.random(#CORRUPT_WORDS)]:rep(math.random(1,3))
				task.spawn(function()
					local ch = pl.Character
					if ch then
						pcall(function()
							ChatService:Chat(ch:FindFirstChild("Head") or ch:FindFirstChild("HumanoidRootPart"), msg, Enum.ChatColor.Red)
						end)
					end
				end)
			end
		end
	end

	-- ────────────────────────────────────────────────────────────────────
	--  LEADERBOARD / STATS GLITCH
	--  Los valores del leaderboard se corrompen para infectados
	-- ────────────────────────────────────────────────────────────────────

	local statsGlitchT = {}   -- player → timer
	local statsOrig    = {}   -- player → {stat → valor_original}

	-- Glitch names separados por tipo para evitar type error
	local GLITCH_NAMES_STR = {"ERROR","NULL","VOID","????","...","LOST","FEED","████"}
	local GLITCH_NAMES_NUM = {-1, 0, 99999, 0, -999, 1}

	local function glitchLeaderboard(player)
		local data = infected[player]; if not data then return end
		if data.stage < 2 then return end

		local ls = player:FindFirstChild("leaderstats"); if not ls then return end

		-- Guarda valores originales
		if not statsOrig[player] then
			statsOrig[player] = {}
			for _, stat in ipairs(ls:GetChildren()) do
				if stat:IsA("IntValue") or stat:IsA("NumberValue") or stat:IsA("StringValue") then
					statsOrig[player][stat] = stat.Value
				end
			end
		end

		-- Glitch temporal (elige valor compatible con el tipo del stat)
		for stat, orig in pairs(statsOrig[player]) do
			if not (stat and stat.Parent) then continue end
			-- Elige glitch del tipo correcto para no causar error de conversión
			local glitchVal
			if stat:IsA("StringValue") then
				glitchVal = GLITCH_NAMES_STR[math.random(#GLITCH_NAMES_STR)]
			else
				glitchVal = GLITCH_NAMES_NUM[math.random(#GLITCH_NAMES_NUM)]
			end

			task.spawn(function()
				pcall(function()
					stat.Value = glitchVal
				end)
				task.wait(0.06 + math.random()*0.15)
				pcall(function()
					-- A veces vuelve al original, a veces no (depende del stage)
					if math.random() < (1 - data.stage/8) then
						stat.Value = orig
					end
				end)
			end)
		end
	end

	local function tickStatsGlitch(dt)
		for pl, data in pairs(infected) do
			if data.stage < 2 then continue end
			statsGlitchT[pl] = (statsGlitchT[pl] or 0) + dt
			local interval = math.max(0.8, 8 - data.stage*1.2)
			if statsGlitchT[pl] >= interval then
				statsGlitchT[pl] = 0
				glitchLeaderboard(pl)
			end
		end
		-- Restaura stats de jugadores ya no infectados
		for pl, _ in pairs(statsOrig) do
			if not infected[pl] then
				local ls = pl:FindFirstChild("leaderstats")
				if ls then
					for stat, orig in pairs(statsOrig[pl]) do
						pcall(function() if stat and stat.Parent then stat.Value = orig end end)
					end
				end
				statsOrig[pl] = nil
			end
		end
	end

	-- ────────────────────────────────────────────────────────────────────
	--  DISTORSIÓN DE SONIDOS EXISTENTES
	--  Encuentra todos los Sound en el juego y los corrompe gradualmente
	-- ────────────────────────────────────────────────────────────────────

	local soundRegistry  = {}   -- Sound → {origPitch, origVol, origReverb}
	local soundScanned   = false
	local soundGlitchT   = 0

	local function scanSounds()
		soundScanned = true
		-- Busca sonidos en todo el juego (workspace, personajes, partes)
		local function searchIn(root)
			pcall(function()
				for _, obj in ipairs(root:GetDescendants()) do
					if obj:IsA("Sound") and obj ~= nil then
						if not soundRegistry[obj] then
							soundRegistry[obj] = {
								pitch  = obj.PlaybackSpeed,
								volume = obj.Volume,
							}
						end
					end
				end
			end)
		end
		searchIn(workspace)
		searchIn(game:GetService("SoundService"))
		-- También escanea personajes
		for _, pl in ipairs(Players:GetPlayers()) do
			if pl.Character then searchIn(pl.Character) end
		end
		print("[Pibby] 🎵 "..#(function() local t={} for _ in pairs(soundRegistry) do t[#t+1]=1 end return t end)().." sonidos encontrados")
	end

	local function distortSounds(dt)
		if currentPhase < 1 then return end
		if not soundScanned then scanSounds() end

		soundGlitchT += dt
		local glitchInterval = math.max(0.5, 6 - currentPhase)
		if soundGlitchT < glitchInterval then return end
		soundGlitchT = 0

		local phase_factor = currentPhase / 5

		for sound, orig in pairs(soundRegistry) do
			if not (sound and sound.Parent) then
				soundRegistry[sound] = nil
				continue
			end

			task.spawn(function()
				pcall(function()
					-- Distorsión de pitch: se desafina aleatoriamente
					local pitchGlitch = orig.pitch * (0.6 + math.random()*0.8 + phase_factor*(math.random()-0.5)*1.2)
					sound.PlaybackSpeed = math.clamp(pitchGlitch, 0.1, 3.5)

					-- Distorsión de volumen: pulsa
					local volGlitch = orig.volume * (0.3 + math.random()*0.9) * (1 - phase_factor*0.3)
					sound.Volume = math.clamp(volGlitch, 0, 1)

					-- En fases altas: glitch breve (se va a 0 y vuelve)
					if currentPhase >= 3 and math.random() < 0.3 then
						task.wait(0.04 + math.random()*0.08)
						sound.Volume = 0
						task.wait(0.02 + math.random()*0.05)
						sound.Volume = math.clamp(orig.volume * (0.5 + math.random()*0.5), 0, 1)
					end

					-- Recuperación parcial (nunca vuelve al 100% original)
					task.wait(0.3 + math.random()*0.5)
					local recovery = 1 - phase_factor*0.45
					sound.PlaybackSpeed = orig.pitch * (recovery + (math.random()-0.5)*0.1)
					sound.Volume = math.clamp(orig.volume * recovery, 0, 1)
				end)
			end)
		end
	end

	-- En fase 5: pausa/reanuda sonidos aleatoriamente
	local soundChaosT = 0
	local function tickSoundChaos(dt)
		if currentPhase < 5 then return end
		soundChaosT += dt
		if soundChaosT < 2.5 then return end
		soundChaosT = 0

		for sound, _ in pairs(soundRegistry) do
			if not (sound and sound.Parent) then continue end
			if math.random() < 0.15 then
				pcall(function()
					sound.PlaybackSpeed = math.random() < 0.5 and 0.01 or (1 + math.random()*2)
				end)
			end
		end
	end

	-- ────────────────────────────────────────────────────────────────────
	--  MEJORAS AL MOVIMIENTO DEL MICELIO
	--  • Más ramas por tick (expansión más rápida y visual)
	--  • Nodos que "saltan" a superficies cercanas
	--  • Mejor manejo cuando se queda sin nodos
	-- ────────────────────────────────────────────────────────────────────

	-- Aumenta el BranchChance según la fase para que se vea más denso
	local function getDynamicBranchChance()
		local base = CFG.BranchChance
		return base * (1 + currentPhase * 0.35)
	end

	-- Salto de superficie: si un nodo está cerca de otra superficie,
	-- lanza tendrils hacia ella (para cruzar huecos pequeños)
	local surfaceJumpT = 0
	local function tickSurfaceJump(dt)
		surfaceJumpT += dt
		if surfaceJumpT < 1.8 then return end
		surfaceJumpT = 0
		if #nodes == 0 or #nodes >= CFG.MaxNodes or partCount >= CFG.MaxParts then return end

		local sample = math.min(3, #nodes)
		for _ = 1, sample do
			local n = nodes[math.random(#nodes)]
			if not n then continue end
			if inQuarantine(n.pos) then continue end

			-- Sondea en la dirección de avance buscando otra superficie cercana
			local jumpRay = workspace:Raycast(n.pos + n.normal*0.3, n.dir*4.5, rpMain)
			if jumpRay then
				local jn = jumpRay.Normal
				-- Si la superficie está "de lado" (no la misma en la que está)
				if jn:Dot(n.normal) < 0.4 then
					local jumpPos = jumpRay.Position + jn*CFG.SurfaceOff
					if not isSolid(jumpPos + jn*0.2) and not isOcc(jumpPos) then
						-- Crea un tendril puente y continúa desde ahí
						spawnTendril(n.pos, jumpPos, jn, n.age/n.maxLife, false, false)
						local blife = math.random(CFG.LifeMin, CFG.LifeMax)
						-- La dirección se proyecta sobre la nueva superficie
						local newDir = (n.dir - jn*n.dir:Dot(jn))
						if newDir.Magnitude < 0.01 then newDir = n.dir end
						table.insert(nodes, {
							pos=jumpPos, dir=newDir.Unit, normal=jn,
							life=blife, maxLife=blife, depth=n.depth, age=n.age,
							nodeType="normal"
						})
						markOcc(jumpPos)
					end
				end
			end
		end
	end

	-- Reinicio automático si el micelio se queda completamente sin nodos
	-- (pero ya tiene blobs — usa esos como semillas)
	local noNodesT = 0
	local function tickRevive(dt)
		if not infectionReady then return end
		if #nodes > 0 then noNodesT = 0; return end
		noNodesT += dt
		if noNodesT < 4 then return end  -- espera 4s antes de revivir
		noNodesT = 0

		if #blobReg == 0 then return end
		if partCount >= CFG.MaxParts then return end

		-- Elige un blob al azar y brota nodos desde él
		local b = blobReg[math.random(#blobReg)]
		if not b then return end
		if inQuarantine(b.pos) then return end

		local gp, gn = castSurf(b.pos + Vector3.new(0,2,0), Vector3.new(0,-1,0), CFG.RayDown)
		if not gp then gp=b.pos; gn=Vector3.new(0,1,0) end

		local rays = math.random(5,9)
		for i = 1, rays do
			local a = (i/rays)*math.pi*2 + (math.random()-0.5)*0.4
			local l = math.random(CFG.LifeMin, CFG.LifeMax)
			table.insert(nodes, {
				pos=gp, dir=Vector3.new(math.cos(a),0,math.sin(a)), normal=gn,
				life=l, maxLife=l, depth=0, age=0, nodeType="normal"
			})
		end
		spawnFlash(gp, gn, 1.2)
		print("[Pibby] ♻ Micelio revivido desde blob existente")
	end

	-- Sobreescribe la lógica de ramificación para que use el chance dinámico
	local _v37TickMyceliumBranch = tickMycelium
	function tickMycelium()
		-- Temporarily boost BranchChance based on phase
		local origBC = CFG.BranchChance
		CFG.BranchChance = getDynamicBranchChance()
		_v37TickMyceliumBranch()
		CFG.BranchChance = origBC
	end

	-- ────────────────────────────────────────────────────────────────────
	--  HEARTBEAT v3.7
	-- ────────────────────────────────────────────────────────────────────
	RunService.Heartbeat:Connect(function(dt)
		tickPathMemory(dt)
		tickQuarantineVFX(dt)
		tickSkyGlitch(dt)
		tickBodySpores(dt)
		tickCorruptChat(dt)
		tickStatsGlitch(dt)
		distortSounds(dt)
		tickSoundChaos(dt)
		tickSurfaceJump(dt)
		tickRevive(dt)
	end)

	-- Re-escanea sonidos cuando un personaje aparece
	Players.PlayerAdded:Connect(function(pl)
		pl.CharacterAdded:Connect(function(ch)
			task.wait(1)
			if ch then
				for _, obj in ipairs(ch:GetDescendants()) do
					if obj:IsA("Sound") and not soundRegistry[obj] then
						soundRegistry[obj] = {pitch=obj.PlaybackSpeed, volume=obj.Volume}
					end
				end
			end
		end)
	end)

	-- ── LIMPIEZA AL RESPAWN ──────────────────────────────────────────────
	local function cleanPlayerInfection(player)
		local guiNames = {"__PibbyDistort","__PibbyVeins","__PibbyHud","__PibbyHB","__PibbyEye"}
		task.spawn(function()
			local pg = player:FindFirstChild("PlayerGui")
			if pg then
				for _, name in ipairs(guiNames) do
					local g = pg:FindFirstChild(name)
					if g then pcall(function() g:Destroy() end) end
				end
			end
		end)
		infected[player]        = nil
		infectionPct[player]    = nil
		playerDistortion[player]= nil
		parasiteActive[player]  = nil
		if darkenT then darkenT[player] = nil end
		if bodySporeT then bodySporeT[player] = nil end
		if statsGlitchT then statsGlitchT[player] = nil end
		if distortionGuis[player]   then pcall(function() distortionGuis[player]:Destroy() end);   distortionGuis[player]   = nil end
		if infectionHudGuis[player] then pcall(function() infectionHudGuis[player]:Destroy() end); infectionHudGuis[player] = nil end
		if veinGuis[player]         then pcall(function() veinGuis[player]:Destroy() end);         veinGuis[player]         = nil end
		if heartbeatGuis[player]    then pcall(function() heartbeatGuis[player]:Destroy() end);    heartbeatGuis[player]    = nil end
		print("[Pibby] ♻ Infección limpiada: "..player.Name)
	end

	local function hookRespawn(player)
		player.CharacterAdded:Connect(function()
			task.wait(0.15)
			cleanPlayerInfection(player)
		end)
		player.CharacterRemoving:Connect(function()
			task.delay(0.05, function() cleanPlayerInfection(player) end)
		end)
	end
	for _, pl in ipairs(Players:GetPlayers()) do hookRespawn(pl) end
	Players.PlayerAdded:Connect(function(pl) hookRespawn(pl) end)
	Players.PlayerRemoving:Connect(function(pl) cleanPlayerInfection(pl) end)

	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.7                                                     ║")
	print("║  + nextSurf reescrito: sube Y baja paredes, maneja meshes       ║")
	print("║  + Memoria de rutas: el micelio recuerda caminos exitosos       ║")
	print("║  + Zonas de cuarentena (Part 'Quarantine_X' bloquea todo)       ║")
	print("║  + Skybox glitch progresivo por fases                           ║")
	print("║  + Esporas que brotan del cuerpo infectado                      ║")
	print("║  + Chat corrompido para jugadores infectados                    ║")
	print("║  + Leaderboard/stats glitcheados                                ║")
	print("║  + Todos los sonidos se distorsionan gradualmente               ║")
	print("║  + Expansión más densa + saltos de superficie + auto-revive     ║")
	print("╚══════════════════════════════════════════════════════════════════╝")

	-- ════════════════════════════════════════════════════════════════════
	--  v3.8 — NOCHE + LLUVIA CORRUPTA + RELÁMPAGOS + NIEBLA VIVA +
	--         SUELO QUE SE PUDRE
	-- ════════════════════════════════════════════════════════════════════

	-- ────────────────────────────────────────────────────────────────────
	--  LLUVIA CORRUPTA (Phase 2+)
	--  Gotas moradas/neon caen del cielo, se aceleran con la fase
	-- ────────────────────────────────────────────────────────────────────
	local rainActive    = false
	local rainConn      = nil
	local rainDropPool  = {}   -- partes reutilizables de lluvia
	local rainT         = 0

	local RAIN_AREA     = 80   -- ancho del área de lluvia
	local RAIN_HEIGHT   = 50   -- altura desde la que caen

	local function stopRain()
		rainActive = false
		if rainConn then rainConn:Disconnect(); rainConn = nil end
		for _, p in ipairs(rainDropPool) do
			if p and p.Parent then p:Destroy() end
		end
		rainDropPool = {}
	end

	local function startRain()
		if rainActive then return end
		rainActive = true

		rainConn = RunService.Heartbeat:Connect(function(dt)
			if not rainActive then return end
			rainT += dt

			-- Cadencia: fase 2 = 1 gota/0.25s, fase 5 = 8 gotas/0.05s
			local spawnRate = math.max(0.04, 0.3 - currentPhase*0.05)
			if rainT < spawnRate then return end
			rainT = 0

			local count = 1 + math.floor(currentPhase*0.8)
			for _ = 1, count do
				if partCount >= CFG.MaxParts then break end

				local origin = getOrigin()
				local rx = origin.X + (math.random()-0.5)*RAIN_AREA
				local rz = origin.Z + (math.random()-0.5)*RAIN_AREA
				local startY = RAIN_HEIGHT + origin.Y + math.random()*10

				-- Color: fase baja morado, fase alta neon brillante
				local isNeonDrop = math.random() < (currentPhase * 0.12)
				local dropColor = isNeonDrop and rN() or lerpC(
					Color3.fromRGB(90,0,160),
					Color3.fromRGB(160,0,255),
					math.random()
				)

				local drop = Instance.new("Part")
				drop.Anchored = true; drop.CanCollide = false; drop.CastShadow = false
				drop.Size = Vector3.new(0.04, 0.55+math.random()*0.35, 0.04)
				drop.Color = dropColor
				drop.Material = isNeonDrop and Enum.Material.Neon or Enum.Material.SmoothPlastic
				drop.Transparency = isNeonDrop and 0.1 or 0.35
				drop.Position = Vector3.new(rx, startY, rz)
				-- Ligera inclinación según fase (viento creciente)
				local windLean = currentPhase * 0.08
				drop.CFrame = CFrame.new(drop.Position) * CFrame.Angles(math.pi*0.5 + windLean, math.random()*0.3, 0)
				drop.Parent = folder; partCount += 1

				-- Luz en gotas neon
				if isNeonDrop then
					local li = Instance.new("PointLight"); li.Color=dropColor; li.Range=3; li.Brightness=0.8; li.Parent=drop
				end

				-- Caída: velocidad según fase
				local fallTime = math.max(0.18, 0.75 - currentPhase*0.08)
				local fallDist = startY - (origin.Y + 0.5)
				local endPos = Vector3.new(
					rx + (math.random()-0.5)*currentPhase*0.8,
					origin.Y + 0.5,
					rz + (math.random()-0.5)*currentPhase*0.8
				)

				TweenService:Create(drop, TweenInfo.new(fallTime, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
					Position = endPos,
					Transparency = 1,
				}):Play()

				-- Splash al aterrizar
				task.delay(fallTime, function()
					if drop then drop:Destroy(); partCount=math.max(0,partCount-1) end
					-- Mini-splash morado en el suelo
					if math.random() < 0.15 and partCount < CFG.MaxParts then
						local splash = Instance.new("Part")
						splash.Anchored=true; splash.CanCollide=false; splash.CastShadow=false
						splash.Shape = Enum.PartType.Ball
						splash.Size = Vector3.new(0.08,0.08,0.08)
						splash.Position = endPos + Vector3.new(0,0.1,0)
						splash.Color = dropColor; splash.Material=Enum.Material.Neon; splash.Transparency=0
						splash.Parent=folder; partCount+=1
						TweenService:Create(splash,TweenInfo.new(0.22),{
							Size=Vector3.new(0.6+math.random()*0.5,0.04,0.6+math.random()*0.5),
							Transparency=1
						}):Play()
						task.delay(0.25, function() if splash then splash:Destroy(); partCount=math.max(0,partCount-1) end end)
					end
				end)
			end
		end)
	end

	-- ────────────────────────────────────────────────────────────────────
	--  RELÁMPAGOS (Phase 3+)
	--  Destellos en el cielo + rayo visual + trueno en el chat
	-- ────────────────────────────────────────────────────────────────────
	local lightningT = 0
	local THUNDER_MSGS = {
		"💀", "⚡", "█▀▄", "░░░", "▓▒░",
		"BOOM","CRACK","BZZT","ERROR","---",
	}

	local function doLightning()
		if partCount >= CFG.MaxParts - 4 then return end

		local origin = getOrigin()
		local strikeX = origin.X + (math.random()-0.5)*60
		local strikeZ = origin.Z + (math.random()-0.5)*60

		-- Flash de pantalla global (Lighting.Brightness spike)
		local prevBrightness = Lighting.Brightness
		task.spawn(function()
			Lighting.Brightness = math.min(3, prevBrightness + 2.5 + math.random()*1.5)
			-- También tiñe la luz de morado/blanco
			local prevAmb = Lighting.Ambient
			Lighting.Ambient = lerpC(prevAmb, Color3.fromRGB(180,140,255), 0.8)
			task.wait(0.04 + math.random()*0.06)
			Lighting.Brightness = prevBrightness * 0.2
			task.wait(0.03)
			Lighting.Brightness = prevBrightness + 1.2
			task.wait(0.04)
			Lighting.Ambient = prevAmb
			TweenService:Create(Lighting, TweenInfo.new(0.35), {Brightness=prevBrightness}):Play()
		end)

		-- Rayo visual: columna delgada desde el cielo
		local rayTop = Vector3.new(strikeX, origin.Y + 55, strikeZ)
		local groundRay = workspace:Raycast(rayTop, Vector3.new(0,-1,0)*70, rpMain)
		local rayBottom = groundRay and groundRay.Position or Vector3.new(strikeX, origin.Y, strikeZ)
		local rayLen = (rayTop - rayBottom).Magnitude

		local bolt = Instance.new("Part")
		bolt.Anchored=true; bolt.CanCollide=false; bolt.CastShadow=false
		bolt.Size = Vector3.new(0.08 + currentPhase*0.04, rayLen, 0.08 + currentPhase*0.04)
		bolt.Color = math.random()<0.6 and Color3.fromRGB(220,180,255) or rN()
		bolt.Material = Enum.Material.Neon; bolt.Transparency = 0
		bolt.CFrame = CFrame.new((rayTop+rayBottom)/2)
		bolt.Parent = folder; partCount+=1

		-- Luz en el impacto
		local strikeLi = Instance.new("PointLight")
		strikeLi.Color = bolt.Color; strikeLi.Range = 40+currentPhase*8; strikeLi.Brightness = 8
		strikeLi.Parent = bolt

		TweenService:Create(bolt, TweenInfo.new(0.12), {Transparency=1, Size=Vector3.new(0.3,rayLen,0.3)}):Play()
		TweenService:Create(strikeLi, TweenInfo.new(0.12), {Brightness=0}):Play()
		task.delay(0.15, function()
			if bolt then bolt:Destroy(); partCount=math.max(0,partCount-1) end
		end)

		-- Flash en el suelo del impacto
		if groundRay then
			spawnFlash(groundRay.Position, groundRay.Normal or Vector3.new(0,1,0), 3+currentPhase*0.5)
			-- Genera un blob de micelio quemado en el punto de impacto
			if math.random() < 0.45 and partCount < CFG.MaxParts then
				task.delay(0.1, function()
					spawnBlob(groundRay.Position + Vector3.new(0,0.2,0), groundRay.Normal or Vector3.new(0,1,0),
						1.5+math.random()*2, 0.4)
					-- Nodos extra desde el impacto
					if #nodes < CFG.MaxNodes then
						for i=1,4 do
							local a=(i/4)*math.pi*2
							local l=math.random(CFG.LifeMin, CFG.LifeMax)
							table.insert(nodes,{pos=groundRay.Position,dir=Vector3.new(math.cos(a),0,math.sin(a)),
								normal=groundRay.Normal or Vector3.new(0,1,0),life=l,maxLife=l,depth=0,age=0,nodeType="normal"})
						end
					end
				end)
			end
		end

		-- "Trueno" en el chat
		task.delay(0.3 + math.random()*0.8, function()
			local msg = THUNDER_MSGS[math.random(#THUNDER_MSGS)]
			for _, pl in ipairs(Players:GetPlayers()) do
				screenMsg(pl, msg, lerpC(Color3.fromRGB(180,100,255), rN(), math.random()*0.5), 0.8)
			end
		end)
	end

	local function tickLightning(dt)
		if currentPhase < 3 then return end
		lightningT += dt
		-- Frecuencia: fase 3 cada ~20s, fase 5 cada ~4s
		local interval = math.max(4, 22 - currentPhase*3.5)
		if lightningT < interval then return end
		lightningT = 0
		-- A veces doble relámpago
		doLightning()
		if math.random() < 0.3 then
			task.delay(0.15+math.random()*0.3, doLightning)
		end
	end

	-- ────────────────────────────────────────────────────────────────────
	--  NIEBLA VIVA (Phase 2+)
	--  Parches de niebla volumétrica que se mueven hacia los jugadores
	-- ────────────────────────────────────────────────────────────────────
	local fogPatches   = {}   -- lista de {part, vel, target}
	local fogSpawnT    = 0
	local FOG_MAX      = 12

	local function spawnFogPatch(pos)
		if #fogPatches >= FOG_MAX or partCount >= CFG.MaxParts then return end

		local fog = Instance.new("Part")
		fog.Anchored=true; fog.CanCollide=false; fog.CastShadow=false
		fog.Shape=Enum.PartType.Ball
		local fogSize = 8 + math.random()*16 + currentPhase*2
		fog.Size = Vector3.new(fogSize, 2.5+math.random()*2, fogSize)
		fog.Color = lerpC(Color3.fromRGB(8,0,20), Color3.fromRGB(40,0,80), math.random()*0.5)
		fog.Material = Enum.Material.SmoothPlastic
		fog.Transparency = 0.65 - currentPhase*0.04
		fog.Position = pos + Vector3.new((math.random()-0.5)*30, 0.8+math.random()*2, (math.random()-0.5)*30)
		fog.Parent = folder; partCount+=1

		-- Luz tenue dentro de la niebla
		local li = Instance.new("PointLight"); li.Color=Color3.fromRGB(60,0,120)
		li.Range=fogSize*0.8; li.Brightness=0.35+currentPhase*0.08; li.Parent=fog

		-- Aparece suavemente
		fog.Transparency = 1
		TweenService:Create(fog, TweenInfo.new(2.5), {Transparency=0.62-currentPhase*0.04}):Play()

		table.insert(fogPatches, {part=fog, light=li, vel=Vector3.new(0,0,0), lifeT=0})
	end

	local function tickFogPatches(dt)
		if currentPhase < 2 then return end

		fogSpawnT += dt
		local spawnInterval = math.max(4, 18-currentPhase*2.5)
		if fogSpawnT >= spawnInterval then
			fogSpawnT = 0
			if #blobReg > 0 then
				local b = blobReg[math.random(#blobReg)]
				spawnFogPatch(b.pos)
			end
		end

		-- Mueve parches hacia jugadores
		local dead = {}
		for i, fp in ipairs(fogPatches) do
			if not (fp.part and fp.part.Parent) then table.insert(dead,i); continue end

			fp.lifeT += dt

			-- Cada 1.5s elige un nuevo jugador como objetivo
			if math.floor(fp.lifeT/1.5) > math.floor((fp.lifeT-dt)/1.5) then
				local closest=nil; local closestD=math.huge
				for _, pl in ipairs(Players:GetPlayers()) do
					local ch=pl.Character; if ch then
						local hrp=ch:FindFirstChild("HumanoidRootPart"); if hrp then
							local d=(hrp.Position-fp.part.Position).Magnitude
							if d<closestD then closestD=d; closest=hrp.Position end
						end
					end
				end
				if closest then
					local toTarget = (closest - fp.part.Position)
					fp.vel = Vector3.new(toTarget.X,0,toTarget.Z).Unit * (0.8 + currentPhase*0.25)
				else
					-- Deriva aleatoria
					fp.vel = Vector3.new((math.random()-0.5)*1.5, 0, (math.random()-0.5)*1.5)
				end
			end

			-- Aplica movimiento
			fp.part.Position = fp.part.Position + fp.vel * dt

			-- Pulso de tamaño suave
			local pulseFactor = 1 + math.sin(fp.lifeT*1.2)*0.06
			fp.part.Size = fp.part.Size * pulseFactor

			-- Parpadeo de color en fases altas
			if currentPhase >= 4 and math.random() < 0.01 then
				fp.part.Color = rD()
				fp.light.Color = rN()
			end

			-- Muere después de 45s
			if fp.lifeT > 45 then
				TweenService:Create(fp.part, TweenInfo.new(2.5), {Transparency=1}):Play()
				task.delay(2.6, function()
					if fp.part then fp.part:Destroy(); partCount=math.max(0,partCount-1) end
				end)
				table.insert(dead,i)
			end
		end
		for i=#dead,1,-1 do table.remove(fogPatches,dead[i]) end
	end

	-- ────────────────────────────────────────────────────────────────────
	--  SUELO QUE SE PUDRE (Phase 1+)
	--  El Baseplate y bloques del suelo van oscureciéndose y agrietándose
	--  con el avance. Genera manchas negras orgánicas.
	-- ────────────────────────────────────────────────────────────────────
	local rottedSpots  = {}   -- posiciones ya podridas
	local rotSpawnT    = 0
	local ROT_MAX      = 180  -- máximo de manchas de podredumbre

	local function spawnRotSpot(pos, groundNorm)
		if #rottedSpots >= ROT_MAX or partCount >= CFG.MaxParts then return end

		-- Verifica que no haya una mancha muy cerca
		for _, r in ipairs(rottedSpots) do
			if (r - pos).Magnitude < 3 then return end
		end
		table.insert(rottedSpots, pos)

		local rot = Instance.new("Part")
		rot.Anchored=true; rot.CanCollide=false; rot.CastShadow=false
		-- Forma orgánica irregular
		local shp = math.random(3)
		rot.Shape = shp==1 and Enum.PartType.Ball or (shp==2 and Enum.PartType.Block or Enum.PartType.Cylinder)
		local w = 0.6 + math.random()*2.5 + currentPhase*0.4
		rot.Size = Vector3.new(w, 0.08+math.random()*0.06, w*(0.7+math.random()*0.6))

		-- Color: negro con toques morado
		local isGlowing = math.random() < 0.12 + currentPhase*0.04
		rot.Color = isGlowing and rN() or lerpC(rD(), Color3.fromRGB(25,0,50), math.random()*0.6)
		rot.Material = isGlowing and Enum.Material.Neon or Enum.Material.SmoothPlastic

		-- Orientación sobre la superficie
		local br = (groundNorm or Vector3.new(0,1,0)):Cross(Vector3.new(1,0,0))
		if br.Magnitude < 0.01 then br = (groundNorm or Vector3.new(0,1,0)):Cross(Vector3.new(0,0,1)) end
		br = br.Unit
		rot.CFrame = CFrame.fromMatrix(pos + (groundNorm or Vector3.new(0,1,0))*0.06,
			br, groundNorm or Vector3.new(0,1,0), -br:Cross(groundNorm or Vector3.new(0,1,0)).Unit)
			* CFrame.Angles(0, math.random()*math.pi*2, 0)

		rot.Transparency = 1; rot.Parent = folder; partCount+=1

		-- Aparece creciendo desde el suelo
		TweenService:Create(rot, TweenInfo.new(1.8+math.random(), Enum.EasingStyle.Back, Enum.EasingDirection.Out),
			{Transparency = isGlowing and 0 or 0.15}):Play()

		-- Pulso de luz en manchas brillantes
		if isGlowing then
			local li = Instance.new("PointLight"); li.Color=rot.Color; li.Range=3+w; li.Brightness=0.6; li.Parent=rot
			task.spawn(function()
				while rot and rot.Parent do
					task.wait(2+math.random()*5)
					if not(rot and rot.Parent) then break end
					TweenService:Create(li,TweenInfo.new(0.3),{Brightness=2.5,Range=(3+w)*1.5}):Play()
					task.wait(0.35)
					TweenService:Create(li,TweenInfo.new(0.6),{Brightness=0.6,Range=3+w}):Play()
				end
			end)
		end
	end

	local function tickGroundRot(dt)
		if currentPhase < 1 then return end
		rotSpawnT += dt
		-- Fase 1: 1 mancha cada 8s, fase 5: 3 manchas por segundo
		local interval = math.max(0.3, 8 - currentPhase*1.4)
		if rotSpawnT < interval then return end
		rotSpawnT = 0

		if #blobReg == 0 then return end

		local count = 1 + math.floor(currentPhase*0.4)
		for _ = 1, count do
			if #rottedSpots >= ROT_MAX then break end
			local b = blobReg[math.random(#blobReg)]
			if not b then continue end

			-- Aterriza en el suelo debajo del blob
			local gp, gn = castSurf(b.pos + Vector3.new(0,1,0), Vector3.new(0,-1,0), 8)
			if gp then
				-- Pequeño jitter horizontal para que no se apilen
				local jitter = Vector3.new((math.random()-0.5)*4, 0, (math.random()-0.5)*4)
				spawnRotSpot(gp + jitter, gn)
			end
		end
	end

	-- ────────────────────────────────────────────────────────────────────
	--  HOOK DE FASES → activa lluvia, relámpagos, etc.
	-- ────────────────────────────────────────────────────────────────────
	local _v37ActivatePhase = activatePhase
	function activatePhase(phase)
		_v37ActivatePhase(phase)

		if phase == 2 then
			-- Comienza lluvia ligera en fase 2
			task.delay(3, function() startRain() end)

		elseif phase == 3 then
			-- Lluvia más intensa ya activa (startRain es idempotente)
			if not rainActive then startRain() end

		elseif phase == 5 then
			-- En fase 5 la lluvia se convierte en tormenta de partículas
			-- (ya está activa, solo se vuelve más densa por currentPhase)
		end
	end

	-- ────────────────────────────────────────────────────────────────────
	--  HEARTBEAT v3.8
	-- ────────────────────────────────────────────────────────────────────
	RunService.Heartbeat:Connect(function(dt)
		tickLightning(dt)
		tickFogPatches(dt)
		tickGroundRot(dt)
	end)

	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.8                                                     ║")
	print("║  + Fase 1: atardecer → fase 2: noche → fase 3: NOCHE TOTAL     ║")
	print("║  + Lluvia corrupta morada/neon (fase 2+, se intensifica)       ║")
	print("║  + Relámpagos que generan micelio en el impacto (fase 3+)      ║")
	print("║  + Niebla viva que persigue jugadores (fase 2+)                ║")
	print("║  + Manchas de podredumbre en el suelo (fase 1+)                ║")
	print("╚══════════════════════════════════════════════════════════════════╝")

	-- ════════════════════════════════════════════════════════════════════
	--  v3.9 — GAMEPLAY + MICELIO INSPIRADO EN CORDYCEPS + NPC IA MEJORADA
	-- ════════════════════════════════════════════════════════════════════

	-- ────────────────────────────────────────────────────────────────────
	--  FIX: QUITA LA ABSORCIÓN DE LUCES (causaba lag)
	--  El sabotaje de scripts ya no crea PointLights en ningún lugar
	-- ────────────────────────────────────────────────────────────────────
	-- Override sabotageScript para que no haga nada con luces
	local _v38SabotageOrig = sabotageScript
	function sabotageScript(s)
		if not (s and s.Parent) then return end
		-- Si el script tiene "light" en el nombre o contenido, lo ignora
		local nameLC = s.Name:lower()
		if nameLC:find("light") or nameLC:find("lamp") or nameLC:find("glow") then return end
		_v38SabotageOrig(s)
	end

	-- ────────────────────────────────────────────────────────────────────
	--  CONTAGIO POR CONTACTO (Stage 4+)
	--  Jugadores infectados en stage 4+ infectan a otros al tocarse
	-- ────────────────────────────────────────────────────────────────────
	local contactCheckT = 0

	local function tickContactContagion(dt)
		contactCheckT += dt
		if contactCheckT < 0.25 then return end
		contactCheckT = 0

		for infPl, data in pairs(infected) do
			if data.stage < 4 then continue end
			local infChar = infPl.Character
			if not infChar then continue end
			local infHRP = infChar:FindFirstChild("HumanoidRootPart")
			if not infHRP then continue end

			for _, otherPl in ipairs(Players:GetPlayers()) do
				if otherPl == infPl then continue end
				if infected[otherPl] then continue end
				local otherChar = otherPl.Character
				if not otherChar then continue end
				local otherHRP = otherChar:FindFirstChild("HumanoidRootPart")
				if not otherHRP then continue end

				local dist = (infHRP.Position - otherHRP.Position).Magnitude
				-- Contacto: 3.5 studs (más cercano que el radio normal)
				if dist < 3.5 then
					-- Flash de contacto en ambos personajes
					task.spawn(function()
						spawnFlash(infHRP.Position + (otherHRP.Position-infHRP.Position)*0.5,
							Vector3.new(0,1,0), 1.2)
						startInfection(otherPl)
						screenMsg(otherPl, "[ CONTACTO DIRECTO ]", Color3.fromRGB(255,0,120), 2)
					end)
				end
			end
		end
	end

	-- ────────────────────────────────────────────────────────────────────
	--  OSCURECIMIENTO PROGRESIVO DEL JUGADOR INFECTADO
	--  El personaje se va oscureciendo gradualmente conforme avanza la
	--  infección. No es instantáneo — es una degradación suave.
	-- ────────────────────────────────────────────────────────────────────
	local darkenT = {}    -- player → timer

	local function tickPlayerDarkening(dt)
		for pl, data in pairs(infected) do
			if data.stage < 1 then continue end
			darkenT[pl] = (darkenT[pl] or 0) + dt
			-- Oscurece cada 3-5 segundos
			if darkenT[pl] < 3.5 - data.stage*0.4 then continue end
			darkenT[pl] = 0

			local ch = pl.Character; if not ch then continue end
			local darkFrac = math.clamp(data.stage / 5 + (infectionPct[pl] or 0) / 200, 0, 1)

			for _, bp in ipairs(ch:GetDescendants()) do
				if bp:IsA("BasePart") and bp.Name ~= "PibbyBlock" then
					-- No toca partes que ya tienen bloques de corrupción encima
					local targetColor = lerpC(bp.Color, rD(), darkFrac * 0.18)
					TweenService:Create(bp, TweenInfo.new(2.5, Enum.EasingStyle.Sine),
						{Color=targetColor}):Play()
				end
			end

			-- En stages altos, la piel se vuelve casi negra
			if data.stage >= 4 then
				local head = ch:FindFirstChild("Head")
				local torso = ch:FindFirstChild("UpperTorso") or ch:FindFirstChild("Torso")
				for _, part in ipairs({head, torso}) do
					if part and part:IsA("BasePart") then
						TweenService:Create(part, TweenInfo.new(1.5), {
							Color = lerpC(part.Color, Color3.fromRGB(3,0,8), 0.25)
						}):Play()
					end
				end
			end
		end
	end

	-- ────────────────────────────────────────────────────────────────────
	--  MICELIO DINÁMICO ESTILO CORDYCEPS (inspirado en The Last of Us)
	--
	--  Cambios clave respecto al sistema anterior:
	--  1. Los tendrils son más GRUESOS y CORTOS (aspecto de hifa real)
	--  2. RAMIFICACIÓN DENSA en ángulos pequeños (forma de abanico)
	--  3. NÓDULOS: blobs pequeños aparecen en cada intersección
	--  4. TEXTURA RUGOSA: los tendrils tienen variación de grosor
	--  5. PRESIÓN LATERAL: los tendrils se "empujan" a los lados
	--  6. ESCALADA VISIBLE: genera geometría explícita en paredes
	-- ────────────────────────────────────────────────────────────────────

	-- Sobreescribe spawnTendril para hacerlo más orgánico (cordyceps style)
	local _v38SpawnTendrilOrig = spawnTendril
	function spawnTendril(from, to, sn, age, isNeon, isRhizo)
		if partCount >= CFG.MaxParts then return nil end
		local len = (to-from).Magnitude
		if len < 0.05 then return nil end

		-- Tendrils cordyceps: más gruesos, más cortos, más rugosos
		local baseW = isRhizo and (CFG.RhizoWidth+math.random()*0.14)
			or (CFG.TendrilW * 1.4 + math.random()*0.16)  -- 40% más grueso
		local baseH = isRhizo and (CFG.RhizoHeight+math.random()*0.05)
			or (CFG.TendrilH * 1.3 + math.random()*0.05)

		-- Variación rugosa: algunos segmentos más anchos en el centro
		local midBulge = math.random() < 0.3 and (1 + math.random()*0.6) or 1
		local w = baseW * midBulge
		local h = baseH

		local p = Instance.new("Part"); p.Anchored=true; p.CanCollide=false; p.CastShadow=false
		p.Size = Vector3.new(w, h, len)
		local look = (to-from).Unit
		local right = sn:Cross(look)
		right = right.Magnitude<0.001 and Vector3.new(1,0,0) or right.Unit
		p.CFrame = CFrame.fromMatrix((from+to)/2, right, look:Cross(right).Unit)

		if isNeon then
			p.Color=rN(); p.Material=Enum.Material.Neon
		elseif isRhizo then
			p.Color=rR(); p.Material=Enum.Material.SmoothPlastic
		else
			-- Paleta más oscura y orgánica (menos lavanda, más negro-morado)
			local ageDark = math.clamp(age * 1.3, 0, 1)
			p.Color = ageDark > 0.5
				and lerpC(rD(), Color3.fromRGB(35,0,65), math.random()*0.5)
				or  mycelColor(age * 0.7)  -- tonos más oscuros
			p.Material = age > 0.45 and Enum.Material.SmoothPlastic or Enum.Material.Fabric
		end

		p.Transparency = 1; p.Parent = folder; partCount += 1
		TweenService:Create(p, TweenInfo.new(0.18), {
			Transparency = isNeon and 0 or (isRhizo and 0.06 or 0.03)
		}):Play()

		-- Nódulo en extremo del tendril (intersecciones del micelio real)
		if not isNeon and not isRhizo and math.random() < 0.22 and partCount < CFG.MaxParts then
			task.delay(0.1, function()
				if partCount >= CFG.MaxParts then return end
				local nod = Instance.new("Part")
				nod.Anchored=true; nod.CanCollide=false; nod.CastShadow=false
				nod.Shape = Enum.PartType.Ball
				local nr = w*0.8 + math.random()*w*0.4
				nod.Size = Vector3.new(nr,nr*0.7,nr)
				nod.CFrame = CFrame.new(to + sn*(nr*0.2))
				nod.Color = math.random()<0.12 and rN() or lerpC(rD(), Color3.fromRGB(50,0,90), math.random())
				nod.Material = math.random()<0.12 and Enum.Material.Neon or Enum.Material.SmoothPlastic
				nod.Transparency = 1; nod.Parent = folder; partCount+=1
				TweenService:Create(nod, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
					{Transparency=0.06}):Play()
			end)
		end

		-- Luz en rhizo
		if isRhizo then
			local li=Instance.new("PointLight"); li.Color=Color3.fromRGB(110,0,190); li.Range=5; li.Brightness=0.35; li.Parent=p
		end

		-- Pulso neon esporádico
		if not isNeon and not isRhizo and age>0.55 and math.random()<0.22 then
			task.spawn(function()
				while p and p.Parent do
					task.wait(2.5+math.random()*7)
					if not(p and p.Parent) then break end
					if math.random()<0.18 then
						local oc,om=p.Color,p.Material; p.Color=rN(); p.Material=Enum.Material.Neon
						task.wait(0.03+math.random()*0.06)
						if p and p.Parent then p.Color=oc; p.Material=om end
					end
				end
			end)
		end

		-- Registra en tendrilRegistry
		if not isRhizo then
			table.insert(tendrilRegistry,{part=p,pos=(from+to)/2,age=age,pulse=0})
			if #tendrilRegistry>400 then table.remove(tendrilRegistry,1) end
		end
		return p
	end

	-- ────────────────────────────────────────────────────────────────────
	--  ESCALADA DE PARED VISIBLE (Cordyceps-style)
	--  Cuando el micelio sube por una pared, genera tendrils verticales
	--  explícitos que se ven pegados a la pared (como raíces en un árbol)
	-- ────────────────────────────────────────────────────────────────────
	local wallClimbT = 0

	local function spawnWallClimbVFX(wallPos, wallNormal, dir)
		if partCount >= CFG.MaxParts - 5 then return end
		-- Solo en superficies que miran "de lado" (paredes)
		if math.abs(wallNormal.Y) > 0.4 then return end

		-- Genera 2-4 filamentos verticales en la pared
		local count = math.random(2,4)
		for i = 1, count do
			if partCount >= CFG.MaxParts then break end

			-- Distribución horizontal aleatoria a lo largo de la pared
			local tangent = wallNormal:Cross(Vector3.new(0,1,0))
			if tangent.Magnitude < 0.01 then tangent = Vector3.new(1,0,0) end
			tangent = tangent.Unit
			local spread = (i/count - 0.5) * (0.6 + math.random()*0.8)

			local basePos = wallPos + tangent*spread + wallNormal*(0.04 + math.random()*0.03)
			local segH = 0.4 + math.random()*0.9
			local segW = 0.06 + math.random()*0.08

			local seg = Instance.new("Part")
			seg.Anchored=true; seg.CanCollide=false; seg.CastShadow=false
			seg.Size = Vector3.new(segW, segH, segW*(0.7+math.random()*0.6))
			seg.CFrame = CFrame.new(basePos) * CFrame.Angles(
				(math.random()-0.5)*0.4,
				math.random()*math.pi*2,
				(math.random()-0.5)*0.3
			)
			local isN = math.random() < 0.08
			seg.Color = isN and rN() or lerpC(rD(), Color3.fromRGB(40,0,75), math.random()*0.6)
			seg.Material = isN and Enum.Material.Neon or Enum.Material.SmoothPlastic
			seg.Transparency = 1; seg.Parent = folder; partCount += 1
			TweenService:Create(seg, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
				{Transparency = isN and 0 or 0.08}):Play()
		end
	end

	local function tickWallClimbVFX(dt)
		wallClimbT += dt
		if wallClimbT < 0.6 then return end
		wallClimbT = 0

		if #nodes == 0 then return end
		-- Muestrea nodos con normal horizontal (en paredes)
		local sample = math.min(5, #nodes)
		for _ = 1, sample do
			local n = nodes[math.random(#nodes)]
			if n and math.abs(n.normal.Y) < 0.35 then
				spawnWallClimbVFX(n.pos, n.normal, n.dir)
			end
		end
	end

	-- ────────────────────────────────────────────────────────────────────
	--  IA MEJORADA DE NPCs INFECTADOS (inspirada en The Last of Us)
	--
	--  Estados nuevos:
	--  PATROL   → deambula en zona conocida (donde había micelio)
	--  STALK    → detectó jugador, lo sigue silenciosamente
	--  CHARGE   → ataque rápido cuando está cerca
	--  FLAIL    → clicker-style: ataque en área cuando está muy cerca
	--  RETREAT  → se aleja si recibe daño
	-- ────────────────────────────────────────────────────────────────────

	local NPC_STATE = {PATROL=1, STALK=2, CHARGE=3, FLAIL=4}
	local npcStates = {}   -- model → {state, stateT, lastTarget, alertLevel}

	-- Sobreescribe corruptNpc con la versión mejorada
	local _v38CorruptNpcOrig = corruptNpc
	function corruptNpc(model)
		if infectedNpcs[model] then return end
		local hum = model:FindFirstChildOfClass("Humanoid")
		local hrp = model:FindFirstChild("HumanoidRootPart")
		if not hum or not hrp then return end
		infectedNpcs[model] = true
		print("[Pibby] NPC corrompido (IA mejorada): "..model.Name)

		-- Inicializa estado de IA
		npcStates[model] = {state=NPC_STATE.PATROL, stateT=0, lastTarget=nil, alertLevel=0}

		task.spawn(function()
			-- === FASE 1: CORRUPCIÓN VISUAL ===
			for _, p in ipairs(model:GetDescendants()) do
				if p:IsA("BasePart") then
					task.spawn(function()
						task.wait(math.random()*1.2)
						TweenService:Create(p, TweenInfo.new(1.5), {Color=rD()}):Play()
						-- Bloque de corrupción
						if math.random() < 0.38 then
							task.wait(1.2+math.random())
							local b=Instance.new("Part"); b.Name="PibbyBlock"
							b.CanCollide=false; b.Anchored=false; b.CastShadow=false
							b.Size=p.Size*(0.25+math.random()*0.45)
							b.CFrame=p.CFrame*CFrame.Angles(math.random()*math.pi,math.random()*math.pi,math.random()*math.pi)
							local isN=math.random()<0.22
							b.Color=isN and rN() or rD()
							b.Material=isN and Enum.Material.Neon or Enum.Material.SmoothPlastic
							b.Transparency=1; b.Parent=p
							local w=Instance.new("WeldConstraint"); w.Part0=b; w.Part1=p; w.Parent=b
							TweenService:Create(b,TweenInfo.new(0.4,Enum.EasingStyle.Back,Enum.EasingDirection.Out),
								{Transparency=isN and 0 or 0.08}):Play()
						end
					end)
				end
			end

			-- Luz de cabeza
			local npcHead = model:FindFirstChild("Head")
			if npcHead then
				local hl=Instance.new("PointLight"); hl.Color=Color3.fromRGB(180,0,255); hl.Range=14; hl.Brightness=2.5; hl.Parent=npcHead
			end

			-- Esporas del cuerpo del NPC
			task.spawn(function()
				while model and model.Parent and infectedNpcs[model] do
					task.wait(2+math.random()*4)
					if not(model and model.Parent) then break end
					if partCount < CFG.MaxParts then
						local sz=0.04+math.random()*0.07
						local sp=Instance.new("Part"); sp.Anchored=true; sp.CanCollide=false; sp.CastShadow=false
						sp.Shape=Enum.PartType.Ball; sp.Size=Vector3.new(sz,sz,sz)
						sp.Position=hrp.Position+Vector3.new((math.random()-0.5)*1.5,math.random()*1.5,(math.random()-0.5)*1.5)
						sp.Color=rN(); sp.Material=Enum.Material.Neon; sp.Transparency=0.2
						sp.Parent=folder; partCount+=1
						TweenService:Create(sp,TweenInfo.new(2+math.random()*2),
							{Position=sp.Position+Vector3.new(0,3+math.random()*3,0),Transparency=1}):Play()
						task.delay(4,function() if sp then sp:Destroy(); partCount=math.max(0,partCount-1) end end)
					end
				end
			end)

			-- === FASE 2: IA MEJORADA ===
			task.wait(2)
			if not(model and model.Parent) then return end

			-- Velocidades por estado
			local BASE_SPEED = (hum.WalkSpeed or 16)
			local PATROL_SPEED = BASE_SPEED * 0.7
			local STALK_SPEED  = BASE_SPEED * 1.1    -- sigiloso, no muy rápido
			local CHARGE_SPEED = BASE_SPEED * 2.2    -- sprint
			local FLAIL_SPEED  = BASE_SPEED * 0.4    -- caos en área cercana

			hum.WalkSpeed = PATROL_SPEED

			-- Parpadeo neon
			task.spawn(function()
				while model and model.Parent and infectedNpcs[model] do
					task.wait(1.2+math.random()*3.5)
					if not(model and model.Parent) then break end
					-- Intensidad del parpadeo depende del estado
					local ns = npcStates[model]
					local flashChance = ns and ns.state == NPC_STATE.CHARGE and 0.45 or 0.12
					for _, p in ipairs(model:GetDescendants()) do
						if p:IsA("BasePart") and math.random() < flashChance then
							local oc,om=p.Color,p.Material; p.Color=rN(); p.Material=Enum.Material.Neon
							task.wait(0.03+math.random()*0.06)
							if p and p.Parent then p.Color=oc; p.Material=om end
						end
					end
				end
			end)

			-- === BUCLE PRINCIPAL DE IA ===
			task.spawn(function()
				local patrolCenter  = hrp.Position   -- punto base de patrulla
				local patrolAngle   = math.random()*math.pi*2
				local alertDecayT   = 0

				while model and model.Parent and infectedNpcs[model] and hum and hum.Health > 0 do
					task.wait(0.2)  -- más frecuente que antes (0.5 → 0.2)
					if not(model and model.Parent) then break end

					local ns = npcStates[model]
					if not ns then break end
					ns.stateT += 0.2

					-- ── Encuentra jugador más cercano ──
					local closestPl, closestHRP, closestDist = nil, nil, math.huge
					for _, pl in ipairs(Players:GetPlayers()) do
						local ch=pl.Character; if ch then
							local ph=ch:FindFirstChild("HumanoidRootPart"); if ph then
								local d=(ph.Position-hrp.Position).Magnitude
								if d < closestDist then
									closestPl=pl; closestHRP=ph; closestDist=d
								end
							end
						end
					end

					-- ── Actualiza nivel de alerta ──
					if closestDist < 28 then
						-- Detecta con línea de visión aproximada (raycast)
						local los = workspace:Raycast(hrp.Position, (closestHRP.Position-hrp.Position).Unit*closestDist, rpMain)
						local canSee = (los == nil) or ((los.Position - closestHRP.Position).Magnitude < 3)
						if canSee then
							ns.alertLevel = math.min(100, ns.alertLevel + (closestDist < 14 and 12 or 5))
						end
					end
					-- Decae alerta si no hay nadie cerca
					if closestDist > 32 then
						ns.alertLevel = math.max(0, ns.alertLevel - 3)
					end

					-- ── Transiciones de estado ──
					if closestDist < 3.2 then
						ns.state = NPC_STATE.FLAIL
					elseif closestDist < 9 or ns.alertLevel >= 80 then
						ns.state = NPC_STATE.CHARGE
					elseif closestDist < 28 and ns.alertLevel >= 35 then
						ns.state = NPC_STATE.STALK
					else
						if ns.state ~= NPC_STATE.PATROL then
							ns.stateT = 0  -- resetea timer al volver a patrol
						end
						ns.state = NPC_STATE.PATROL
					end
					ns.lastTarget = closestHRP

					-- ── Comportamiento por estado ──
					if ns.state == NPC_STATE.PATROL then
						hum.WalkSpeed = PATROL_SPEED
						-- Deambula en círculo alrededor del punto base
						patrolAngle += 0.08 + math.random()*0.06
						local patrolTarget = patrolCenter + Vector3.new(
							math.cos(patrolAngle)*8, 0, math.sin(patrolAngle)*8)
						hum:MoveTo(patrolTarget)
						-- Genera pequeño micelio al patrullar
						if math.random() < 0.04 and partCount < CFG.MaxParts then
							local gp,gn=castSurf(hrp.Position,Vector3.new(0,-1,0),5)
							if gp then spawnBlob(gp,gn,0.3+math.random()*0.4,0.55) end
						end

					elseif ns.state == NPC_STATE.STALK then
						hum.WalkSpeed = STALK_SPEED
						if closestHRP then
							-- Sigue al jugador pero no en línea directa (rodea)
							local stalAngle = (math.atan2(
								hrp.Position.Z - closestHRP.Position.Z,
								hrp.Position.X - closestHRP.Position.X
								)) + math.pi + (math.random()-0.5)*0.8
							local approachPos = closestHRP.Position + Vector3.new(
								math.cos(stalAngle)*5, 0, math.sin(stalAngle)*5)
							hum:MoveTo(approachPos)
						end
						-- Micelio más frecuente en stalk
						if math.random() < 0.06 and partCount < CFG.MaxParts then
							local gp,gn=castSurf(hrp.Position,Vector3.new(0,-1,0),5)
							if gp then spawnBlob(gp,gn,0.4+math.random()*0.5,0.65) end
						end

					elseif ns.state == NPC_STATE.CHARGE then
						hum.WalkSpeed = CHARGE_SPEED
						if closestHRP then
							hum:MoveTo(closestHRP.Position)
						end
						-- Micelio en sprint (rastro denso)
						if math.random() < 0.12 and partCount < CFG.MaxParts then
							local gp,gn=castSurf(hrp.Position,Vector3.new(0,-1,0),5)
							if gp then spawnBlob(gp,gn,0.6+math.random()*0.6,0.7) end
						end
						-- Flash de carga
						if npcHead and math.random() < 0.08 then
							local fl=Instance.new("PointLight"); fl.Color=rN(); fl.Range=20; fl.Brightness=5; fl.Parent=npcHead
							TweenService:Create(fl,TweenInfo.new(0.25),{Brightness=0}):Play()
							task.delay(0.3,function() if fl then fl:Destroy() end end)
						end

					elseif ns.state == NPC_STATE.FLAIL then
						hum.WalkSpeed = FLAIL_SPEED
						-- Movimiento errático en área pequeña
						local flailDir = Vector3.new(math.random()-0.5,0,math.random()-0.5)
						if flailDir.Magnitude > 0.01 then
							hum:Move(flailDir.Unit, false)
						end
						-- Contagia a jugadores cercanos agresivamente
						if closestPl and not infected[closestPl] and closestDist < 4 then
							if math.random() < CFG.NpcInfectChance * 15 then
								task.spawn(function() startInfection(closestPl) end)
								spawnFlash(hrp.Position, Vector3.new(0,1,0), 1.2)
							end
						end
						-- Explosión de esporas al hacer flail
						if math.random() < 0.08 and partCount < CFG.MaxParts then
							for _ = 1, 3 do
								local sp=Instance.new("Part"); sp.Anchored=true; sp.CanCollide=false; sp.CastShadow=false
								sp.Shape=Enum.PartType.Ball; sp.Size=Vector3.new(0.12,0.12,0.12)
								sp.Position=hrp.Position+Vector3.new((math.random()-0.5)*0.8,1+math.random(),(math.random()-0.5)*0.8)
								sp.Color=rN(); sp.Material=Enum.Material.Neon; sp.Transparency=0.1
								sp.Parent=folder; partCount+=1
								local vel=Vector3.new((math.random()-0.5)*8,4+math.random()*5,(math.random()-0.5)*8)
								TweenService:Create(sp,TweenInfo.new(1.5+math.random()),
									{Position=sp.Position+vel,Transparency=1}):Play()
								task.delay(1.8,function() if sp then sp:Destroy(); partCount=math.max(0,partCount-1) end end)
							end
						end
					end

					-- ── Contagio regular por proximidad (todos los estados) ──
					if closestPl and not infected[closestPl] and closestDist < CFG.NpcInfectRadius then
						if math.random() < CFG.NpcInfectChance * 10 then
							task.spawn(function() startInfection(closestPl) end)
						end
					end

					-- ── Billboard de estado (debug visual, opcional) ──
					-- (desactivado por performance, descomentar para debug)
				end
			end)
		end)
	end

	-- ────────────────────────────────────────────────────────────────────
	--  MICELIO MÁS DENSO EN PAREDES (visible al escalar)
	--  Cada vez que un nodo tiene normal horizontal, genera wall VFX
	-- ────────────────────────────────────────────────────────────────────

	-- Override de addNode para detectar escalada y marcarla
	local _v38AddNode = addNode
	function addNode(pos, dir, sn, life, depth, age, nType)
		-- Si la normal es horizontal (pared), genera VFX de escalada
		if sn and math.abs(sn.Y) < 0.3 and math.random() < 0.35 then
			task.defer(function()
				spawnWallClimbVFX(pos, sn, dir)
			end)
		end
		return _v38AddNode(pos, dir, sn, life, depth, age, nType)
	end

	-- ────────────────────────────────────────────────────────────────────
	--  HEARTBEAT v3.9
	-- ────────────────────────────────────────────────────────────────────
	RunService.Heartbeat:Connect(function(dt)
		tickContactContagion(dt)
		tickPlayerDarkening(dt)
		tickWallClimbVFX(dt)
	end)

	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.9                                                     ║")
	print("║  + Noche comienza en fase 3 (atardecer f1 → noche f2 → noche   ║")
	print("║    total f3)                                                    ║")
	print("║  + Contagio por contacto directo (stage 4+, 3.5 studs)         ║")
	print("║  + Jugador se oscurece progresivamente con la infección         ║")
	print("║  + Tendrils estilo cordyceps: más gruesos, nódulos, rugosos     ║")
	print("║  + VFX explícita de escalada en paredes                        ║")
	print("║  + NPC IA: PATROL → STALK → CHARGE → FLAIL                    ║")
	print("║    + Línea de visión, nivel de alerta, rastro de micelio       ║")
	print("║    + Esporas de cuerpo + explosión de esporas en FLAIL         ║")
	print("║  + Sin absorción de luces (lag eliminado)                      ║")
	print("╚══════════════════════════════════════════════════════════════════╝")

end)()

-- ════════════════════════════════════════════════════════════════════
--  v3.10 — INFECCIÓN ORGÁNICA + IA DE MICELIO INTELIGENTE
--  Ejecutado en scope propio para evitar límite de 200 locals
-- ════════════════════════════════════════════════════════════════════
;(function()

	-- ────────────────────────────────────────────────────────────────────
	--  SISTEMA DE INFECCIÓN ORGÁNICA
	--  Cada parte del cuerpo recibe tratamiento específico y progresivo.
	--  Ya no es solo "color oscuro + cubito". Ahora:
	--  Stage 1 → Tendrils finos que ENVUELVEN las piernas desde abajo
	--  Stage 2 → Las extremidades se HINCHAN y deforman con bultos
	--  Stage 3 → El torso se FRAGMENTA con cristales de micelio
	--  Stage 4 → La cabeza muta: hongo completo, ojos extra, espinas
	--  Stage 5 → Cuerpo IRRECONOCIBLE: masa de micelio con forma humana
	-- ────────────────────────────────────────────────────────────────────

	-- Tabla de multiplicadores de deformación por parte del cuerpo
	local PART_ROLES = {
		-- Piernas: se encasillan primero, encajadas en micelio
		LeftFoot        = {order=1,  type="encase",  swellMult=1.4, spineChance=0.3},
		RightFoot       = {order=2,  type="encase",  swellMult=1.4, spineChance=0.3},
		LeftLowerLeg    = {order=3,  type="tendril", swellMult=1.2, spineChance=0.2},
		RightLowerLeg   = {order=4,  type="tendril", swellMult=1.2, spineChance=0.2},
		LeftUpperLeg    = {order=5,  type="swell",   swellMult=1.15,spineChance=0.15},
		RightUpperLeg   = {order=6,  type="swell",   swellMult=1.15,spineChance=0.15},
		-- Torso: fragmentación y bultos
		LowerTorso      = {order=7,  type="fragment",swellMult=1.3, spineChance=0.4},
		UpperTorso      = {order=8,  type="fragment",swellMult=1.25,spineChance=0.5},
		-- Brazos: espinas y tendrils
		LeftUpperArm    = {order=9,  type="spine",   swellMult=1.1, spineChance=0.6},
		RightUpperArm   = {order=10, type="spine",   swellMult=1.1, spineChance=0.6},
		LeftLowerArm    = {order=11, type="tendril", swellMult=1.1, spineChance=0.5},
		RightLowerArm   = {order=12, type="tendril", swellMult=1.1, spineChance=0.5},
		LeftHand        = {order=13, type="encase",  swellMult=1.3, spineChance=0.7},
		RightHand       = {order=14, type="encase",  swellMult=1.3, spineChance=0.7},
		-- Cabeza: mutación completa
		Head            = {order=16, type="mutate",  swellMult=1.2, spineChance=0.8},
		Neck            = {order=15, type="swell",   swellMult=1.1, spineChance=0.3},
		-- R6
		["Left Leg"]    = {order=3,  type="encase",  swellMult=1.3, spineChance=0.4},
		["Right Leg"]   = {order=4,  type="encase",  swellMult=1.3, spineChance=0.4},
		Torso           = {order=7,  type="fragment",swellMult=1.3, spineChance=0.5},
		["Left Arm"]    = {order=9,  type="spine",   swellMult=1.2, spineChance=0.6},
		["Right Arm"]   = {order=10, type="spine",   swellMult=1.2, spineChance=0.6},
	}

	-- Colores de corrupción por stage (más orgánicos, menos "cubo")
	local STAGE_COLORS = {
		[1] = function() return Color3.fromRGB(180+math.random()*20, 170+math.random()*15, 200+math.random()*20) end, -- lavanda pálida
		[2] = function() return Color3.fromRGB(80+math.random()*30,  20+math.random()*20,  100+math.random()*30) end, -- morado medio
		[3] = function() return Color3.fromRGB(30+math.random()*20,  0,                    55+math.random()*25)  end, -- morado oscuro
		[4] = function() return Color3.fromRGB(8+math.random()*12,   0,                    15+math.random()*15)  end, -- casi negro
		[5] = function() return Color3.fromRGB(3+math.random()*5,    0,                    8+math.random()*8)    end, -- negro total
	}

	-- ── TIPO: ENCASE ─────────────────────────────────────────────────────
	-- Envuelve la parte con una carcasa de micelio orgánica (varios segmentos)
	local function applyEncase(part, stage)
		if not (part and part.Parent) then return end
		local numSegs = 3 + stage
		for i = 1, numSegs do
			if partCount >= CFG.MaxParts then break end
			task.delay(i * 0.12, function()
				if not (part and part.Parent) then return end
				local seg = Instance.new("Part")
				seg.Name = "PibbyEncase"; seg.Anchored = false
				seg.CanCollide = false; seg.CastShadow = false
				-- Forma irregular sobre la parte
				local angle = (i / numSegs) * math.pi * 2
				local sx = part.Size.X * (0.55 + math.random()*0.55)
				local sy = part.Size.Y * (0.18 + math.random()*0.22)
				local sz = part.Size.Z * (0.55 + math.random()*0.55)
				seg.Size = Vector3.new(sx, sy, sz)
				seg.CFrame = part.CFrame
					* CFrame.new(
						math.cos(angle)*part.Size.X*0.3,
						(i/numSegs - 0.5)*part.Size.Y*0.8,
						math.sin(angle)*part.Size.Z*0.3
					)
					* CFrame.Angles(math.random()*0.6-0.3, math.random()*math.pi, math.random()*0.4-0.2)
				local isNeon = math.random() < 0.08 + stage*0.03
				seg.Color = isNeon and rN() or STAGE_COLORS[math.min(stage,5)]()
				seg.Material = isNeon and Enum.Material.Neon or Enum.Material.SmoothPlastic
				seg.Transparency = 1
				seg.Parent = part
				local w = Instance.new("WeldConstraint")
				w.Part0 = seg; w.Part1 = part; w.Parent = seg
				TweenService:Create(seg,
					TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
					{Transparency = isNeon and 0 or 0.05}):Play()
				partCount += 1
				-- Pulso de la carcasa con el micelio
				if not isNeon then
					task.spawn(function()
						while seg and seg.Parent do
							task.wait(3 + math.random()*6)
							if not (seg and seg.Parent) then break end
							if math.random() < 0.15 then
								local oc = seg.Color
								seg.Color = rN(); seg.Material = Enum.Material.Neon
								task.wait(0.03 + math.random()*0.07)
								if seg and seg.Parent then seg.Color = oc; seg.Material = Enum.Material.SmoothPlastic end
							end
						end
					end)
				end
			end)
		end
	end

	-- ── TIPO: TENDRIL ────────────────────────────────────────────────────
	-- Tendrils orgánicos que se ENROLLAN alrededor de la extremidad
	local function applyTendrilWrap(part, stage)
		if not (part and part.Parent) then return end
		local numTendrils = 2 + stage
		for t_idx = 1, numTendrils do
			if partCount >= CFG.MaxParts then break end
			task.delay(t_idx * 0.08, function()
				if not (part and part.Parent) then return end
				-- Crea una serie de segmentos que siguen una hélice
				local helixSegs = 4 + math.random(3)
				local lastPart = nil
				for s = 1, helixSegs do
					if partCount >= CFG.MaxParts then break end
					if not (part and part.Parent) then break end
					local helixAngle = (s/helixSegs)*math.pi*2 + (t_idx/numTendrils)*math.pi*2
					local helixY = (s/helixSegs - 0.5) * part.Size.Y
					local helixR = part.Size.X * (0.45 + math.random()*0.25)
					local segPart = Instance.new("Part")
					segPart.Name = "PibbyTendrilWrap"
					segPart.Anchored = false; segPart.CanCollide = false; segPart.CastShadow = false
					local segW = 0.08 + math.random()*0.06
					segPart.Size = Vector3.new(segW, segW, part.Size.Y/helixSegs*1.1)
					segPart.CFrame = part.CFrame * CFrame.new(
						math.cos(helixAngle)*helixR, helixY, math.sin(helixAngle)*helixR
					) * CFrame.Angles(0, helixAngle + math.pi/2, math.pi*0.12)
					segPart.Color = STAGE_COLORS[math.min(stage,5)]()
					segPart.Material = Enum.Material.SmoothPlastic
					segPart.Transparency = 1; segPart.Parent = part
					local w = Instance.new("WeldConstraint")
					w.Part0 = segPart; w.Part1 = part; w.Parent = segPart
					TweenService:Create(segPart,
						TweenInfo.new(0.35 + s*0.04, Enum.EasingStyle.Sine),
						{Transparency = 0.08}):Play()
					partCount += 1
					lastPart = segPart
				end
			end)
		end
	end

	-- ── TIPO: SWELL ──────────────────────────────────────────────────────
	-- La parte se HINCHA orgánicamente con nódulos y bultos
	local function applySwell(part, stage, swellMult)
		if not (part and part.Parent) then return end
		-- Hinchazón progresiva del tamaño
		local targetSize = part.Size * (1 + (swellMult-1) * (stage/5))
		TweenService:Create(part,
			TweenInfo.new(1.5 + math.random(), Enum.EasingStyle.Elastic, Enum.EasingDirection.Out),
			{Size = targetSize}):Play()
		-- Bultos sobre la superficie
		local numBulges = 1 + stage
		for b = 1, numBulges do
			if partCount >= CFG.MaxParts then break end
			task.delay(b * 0.2, function()
				if not (part and part.Parent) then return end
				local bulge = Instance.new("Part")
				bulge.Name = "PibbyBulge"
				bulge.Anchored = false; bulge.CanCollide = false; bulge.CastShadow = false
				bulge.Shape = Enum.PartType.Ball
				local br = 0.15 + math.random()*0.25 + stage*0.08
				bulge.Size = Vector3.new(br*2, br*1.3, br*2)
				bulge.CFrame = part.CFrame * CFrame.new(
					(math.random()-0.5)*part.Size.X*0.7,
					(math.random()-0.5)*part.Size.Y*0.5,
					(math.random()-0.5)*part.Size.Z*0.7
				)
				local isNeon = math.random() < 0.12
				bulge.Color = isNeon and rN() or STAGE_COLORS[math.min(stage,5)]()
				bulge.Material = isNeon and Enum.Material.Neon or Enum.Material.SmoothPlastic
				bulge.Transparency = 1; bulge.Parent = part
				local w = Instance.new("WeldConstraint")
				w.Part0 = bulge; w.Part1 = part; w.Parent = bulge
				TweenService:Create(bulge,
					TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
					{Transparency = isNeon and 0 or 0.06}):Play()
				partCount += 1
				if isNeon then
					local li = Instance.new("PointLight")
					li.Color = bulge.Color; li.Range = br*5; li.Brightness = 1.2; li.Parent = bulge
				end
			end)
		end
	end

	-- ── TIPO: FRAGMENT ───────────────────────────────────────────────────
	-- El torso se FRAGMENTA: cristales/placas de micelio sobresalen
	local function applyFragment(part, stage)
		if not (part and part.Parent) then return end
		local numFrags = 2 + stage * 2
		for f = 1, numFrags do
			if partCount >= CFG.MaxParts then break end
			task.delay(f * 0.1 + math.random()*0.2, function()
				if not (part and part.Parent) then return end
				local frag = Instance.new("Part")
				frag.Name = "PibbyFragment"
				frag.Anchored = false; frag.CanCollide = false; frag.CastShadow = false
				-- Forma de cristal/placa
				local fw = 0.08 + math.random()*0.12
				local fh = 0.4 + math.random()*0.8 + stage*0.2
				local fd = 0.08 + math.random()*0.10
				frag.Size = Vector3.new(fw, fh, fd)
				-- Posición: sobresale desde la superficie del torso
				local face = math.random(4)  -- 4 caras laterales
				local faceAngle = (face/4)*math.pi*2
				local faceX = math.cos(faceAngle)*part.Size.X*0.52
				local faceZ = math.sin(faceAngle)*part.Size.Z*0.52
				frag.CFrame = part.CFrame * CFrame.new(
					faceX + (math.random()-0.5)*part.Size.X*0.3,
					(math.random()-0.5)*part.Size.Y*0.6,
					faceZ + (math.random()-0.5)*part.Size.Z*0.3
				) * CFrame.Angles(
					math.random()*0.5-0.25,
					faceAngle + (math.random()-0.5)*0.8,
					math.random()*0.4-0.2
				)
				local isNeon = math.random() < 0.18 + stage*0.05
				frag.Color = isNeon and rN() or STAGE_COLORS[math.min(stage,5)]()
				frag.Material = isNeon and Enum.Material.Neon or Enum.Material.SmoothPlastic
				frag.Transparency = 1; frag.Parent = part
				local w = Instance.new("WeldConstraint")
				w.Part0 = frag; w.Part1 = part; w.Parent = frag
				-- Aparece empujando hacia afuera (Back easing = rebote orgánico)
				TweenService:Create(frag,
					TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
					{Transparency = isNeon and 0 or 0.04}):Play()
				partCount += 1
				if isNeon then
					local li = Instance.new("PointLight")
					li.Color = frag.Color; li.Range = 6; li.Brightness = 1.5; li.Parent = frag
				end
			end)
		end
	end

	-- ── TIPO: SPINE ──────────────────────────────────────────────────────
	-- Espinas óseas de micelio crecen desde los brazos/extremidades
	local function applySpine(part, stage)
		if not (part and part.Parent) then return end
		local numSpines = 1 + stage + math.random(2)
		for s = 1, numSpines do
			if partCount >= CFG.MaxParts then break end
			task.delay(s * 0.15, function()
				if not (part and part.Parent) then return end
				local spine = Instance.new("Part")
				spine.Name = "PibbySpine"
				spine.Anchored = false; spine.CanCollide = false; spine.CastShadow = false
				-- Forma de espina: cónica (estrecha en la punta, ancha en la base)
				local spLen = 0.3 + math.random()*0.7 + stage*0.15
				local spW  = 0.06 + math.random()*0.06
				spine.Size = Vector3.new(spW, spLen, spW)
				-- Angulo de salida: hacia afuera de la superficie
				local spAngle = math.random() * math.pi * 2
				spine.CFrame = part.CFrame * CFrame.new(
					math.cos(spAngle)*part.Size.X*0.55,
					(math.random()-0.5)*part.Size.Y*0.8,
					math.sin(spAngle)*part.Size.Z*0.55
				) * CFrame.Angles(
					math.cos(spAngle)*0.6, spAngle, math.sin(spAngle)*0.6
				)
				local isNeon = math.random() < 0.15
				spine.Color = isNeon and rN() or lerpC(
					STAGE_COLORS[math.min(stage,5)](),
					Color3.fromRGB(200, 180, 220), 0.3
				)
				spine.Material = isNeon and Enum.Material.Neon or Enum.Material.SmoothPlastic
				spine.Transparency = 1; spine.Parent = part
				local w = Instance.new("WeldConstraint")
				w.Part0 = spine; w.Part1 = part; w.Parent = spine
				TweenService:Create(spine,
					TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
					{Transparency = isNeon and 0 or 0.06,
						Size = Vector3.new(spW*0.3, spLen, spW*0.3)}):Play()
				partCount += 1
			end)
		end
	end

	-- ── TIPO: MUTATE (CABEZA) ────────────────────────────────────────────
	-- La cabeza muta completamente: hongo, ojos extra, mandíbula
	local function applyHeadMutation(head, stage)
		if not (head and head.Parent) then return end

		-- 1. Hongo encima de la cabeza (crece con el stage)
		if stage >= 2 and partCount < CFG.MaxParts then
			task.delay(0.3, function()
				if not (head and head.Parent) then return end
				local stalkH = 0.3 + stage*0.2
				local capR   = 0.3 + stage*0.15

				local stalk = Instance.new("Part"); stalk.Name = "PibbyFungusStalk"
				stalk.Anchored=false; stalk.CanCollide=false; stalk.CastShadow=false
				stalk.Size = Vector3.new(0.18, stalkH, 0.18)
				stalk.Color = STAGE_COLORS[math.min(stage,5)]()
				stalk.Material = Enum.Material.SmoothPlastic
				stalk.CFrame = head.CFrame * CFrame.new(
					(math.random()-0.5)*head.Size.X*0.4,
					head.Size.Y*0.55,
					(math.random()-0.5)*head.Size.Z*0.4
				)
				stalk.Transparency = 1; stalk.Parent = head
				local ws = Instance.new("WeldConstraint"); ws.Part0=stalk; ws.Part1=head; ws.Parent=stalk
				TweenService:Create(stalk, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
					{Transparency=0.05}):Play()
				partCount += 1

				-- Cap del hongo
				local cap = Instance.new("Part"); cap.Name = "PibbyFungusCap"
				cap.Anchored=false; cap.CanCollide=false; cap.CastShadow=false
				cap.Shape = Enum.PartType.Ball
				cap.Size = Vector3.new(capR*2, capR*0.55, capR*2)
				cap.Color = rN(); cap.Material = Enum.Material.Neon
				cap.CFrame = stalk.CFrame * CFrame.new(0, stalkH*0.55, 0)
				cap.Transparency = 1; cap.Parent = head
				local wc = Instance.new("WeldConstraint"); wc.Part0=cap; wc.Part1=stalk; wc.Parent=cap
				TweenService:Create(cap, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
					{Transparency=0.08}):Play()
				partCount += 1

				local capLi = Instance.new("PointLight"); capLi.Color=cap.Color
				capLi.Range=capR*8+stage*3; capLi.Brightness=1.8+stage*0.4; capLi.Parent=cap
				-- Pulso del hongo
				task.spawn(function()
					while cap and cap.Parent do
						task.wait(2.5+math.random()*4)
						if not(cap and cap.Parent) then break end
						TweenService:Create(capLi,TweenInfo.new(0.3),{Brightness=4.5+stage,Range=capR*14}):Play()
						task.wait(0.35)
						TweenService:Create(capLi,TweenInfo.new(1),{Brightness=1.8+stage*0.4,Range=capR*8+stage*3}):Play()
					end
				end)
			end)
		end

		-- 2. Ojo extra neon (stage 3+)
		if stage >= 3 and partCount < CFG.MaxParts then
			task.delay(0.6, function()
				if not (head and head.Parent) then return end
				local numEyes = stage - 2
				for e = 1, numEyes do
					if partCount >= CFG.MaxParts then break end
					local eyeCol = rN()
					local eye = Instance.new("Part"); eye.Name = "PibbyExtraEye"
					eye.Anchored=false; eye.CanCollide=false; eye.CastShadow=false
					eye.Shape = Enum.PartType.Ball
					local er = 0.12 + math.random()*0.10
					eye.Size = Vector3.new(er*2, er*2, er*2)
					eye.Color = eyeCol; eye.Material = Enum.Material.Neon
					-- Posicionado en diferentes partes de la cara
					local eyeAngle = (e/numEyes)*math.pi*1.4 - math.pi*0.7
					eye.CFrame = head.CFrame * CFrame.new(
						math.cos(eyeAngle)*head.Size.X*0.4,
						math.sin(eyeAngle)*head.Size.Y*0.25,
						-head.Size.Z*0.5
					)
					eye.Transparency = 1; eye.Parent = head
					local we = Instance.new("WeldConstraint"); we.Part0=eye; we.Part1=head; we.Parent=eye
					TweenService:Create(eye, TweenInfo.new(0.4),{Transparency=0}):Play()
					partCount += 1
					local eli = Instance.new("PointLight"); eli.Color=eyeCol
					eli.Range=8; eli.Brightness=2.5; eli.Parent=eye
					-- Parpadeo irregular del ojo
					task.spawn(function()
						while eye and eye.Parent do
							task.wait(0.8 + math.random()*3)
							if not(eye and eye.Parent) then break end
							TweenService:Create(eye,TweenInfo.new(0.04),{Size=Vector3.new(er*2,er*0.1,er*2)}):Play()
							task.wait(0.06)
							if eye and eye.Parent then
								TweenService:Create(eye,TweenInfo.new(0.05),{Size=Vector3.new(er*2,er*2,er*2)}):Play()
								if math.random()<0.3 then eye.Color=rN(); eli.Color=eye.Color end
							end
						end
					end)
				end
			end)
		end

		-- 3. Mandíbula/grietas en la cara (stage 4+)
		if stage >= 4 and partCount < CFG.MaxParts then
			task.delay(0.9, function()
				if not (head and head.Parent) then return end
				local numCracks = 2 + math.random(3)
				for c = 1, numCracks do
					if partCount >= CFG.MaxParts then break end
					local crack = Instance.new("Part"); crack.Name = "PibbyCrack"
					crack.Anchored=false; crack.CanCollide=false; crack.CastShadow=false
					crack.Size = Vector3.new(head.Size.X*(0.05+math.random()*0.08),
						head.Size.Y*(0.04+math.random()*0.06),
						head.Size.Z*(0.55+math.random()*0.35))
					local crackAngle = (c/numCracks)*math.pi*2
					crack.CFrame = head.CFrame * CFrame.new(
						math.cos(crackAngle)*head.Size.X*0.4,
						(math.random()-0.5)*head.Size.Y*0.6,
						0
					) * CFrame.Angles(0, crackAngle, (math.random()-0.5)*0.4)
					crack.Color = rN(); crack.Material = Enum.Material.Neon
					crack.Transparency = 1; crack.Parent = head
					local wk = Instance.new("WeldConstraint"); wk.Part0=crack; wk.Part1=head; wk.Parent=crack
					TweenService:Create(crack,TweenInfo.new(0.3),{Transparency=0}):Play()
					partCount += 1
					local cli = Instance.new("PointLight"); cli.Color=crack.Color
					cli.Range=4; cli.Brightness=1.8; cli.Parent=crack
				end
			end)
		end
	end

	-- ── FUNCIÓN PRINCIPAL: aplica corrupción por stage y tipo de parte ───
	local function applyOrganicCorruption(char, stage)
		if not (char and char.Parent) then return end
		local isR15 = char:FindFirstChild("LowerTorso") ~= nil

		-- Primero oscurece el color base de forma orgánica (no uniforme)
		for _, part in ipairs(char:GetDescendants()) do
			if part:IsA("BasePart") and part.Name ~= "PibbyBlock"
				and not part.Name:find("Pibby") then
				task.spawn(function()
					task.wait(math.random()*0.8)
					if not (part and part.Parent) then return end
					local targetCol = STAGE_COLORS[math.min(stage,5)]()
					-- Mezcla con el color actual para que no sea instantáneo
					local mixFrac = 0.15 + stage*0.15
					TweenService:Create(part, TweenInfo.new(1.2+math.random()*0.8),
						{Color = lerpC(part.Color, targetCol, mixFrac)}):Play()
				end)
			end
		end

		-- Luego aplica el tipo de corrupción específico de cada parte
		local partsToProcess = isR15 and {
			"LeftFoot","RightFoot","LeftLowerLeg","RightLowerLeg",
			"LeftUpperLeg","RightUpperLeg","LowerTorso","UpperTorso",
			"LeftUpperArm","RightUpperArm","LeftLowerArm","RightLowerArm",
			"LeftHand","RightHand","Neck","Head"
		} or {"Left Leg","Right Leg","Torso","Left Arm","Right Arm","Head"}

		for _, partName in ipairs(partsToProcess) do
			local part = char:FindFirstChild(partName)
			local role = PART_ROLES[partName]
			if not (part and role) then continue end

			-- Solo aplica si el stage corresponde (no reprocesa lo que ya hizo)
			-- Stage 1: primeras 6 partes | Stage 2: siguientes | etc.
			local stageThreshold = math.ceil(role.order / (isR15 and 3.2 or 1.2))
			if stageThreshold > stage then continue end

			task.delay(role.order * 0.08, function()
				if not (part and part.Parent) then return end
				if role.type == "encase"   then applyEncase(part, stage)
				elseif role.type == "tendril" then applyEncase(part, stage)  -- encase instead of wrap (no stray vines)
				elseif role.type == "swell"   then applySwell(part, stage, role.swellMult)
				elseif role.type == "fragment" then applyFragment(part, stage)
				elseif role.type == "spine"   then applySpine(part, stage)
				elseif role.type == "mutate"  then applyHeadMutation(part, stage) end
			end)
		end
	end

	-- Venas bioluminiscentes visibles en la PIEL del personaje (Stage 2+)
	local function applyBioVeins(char, stage)
		if stage < 2 then return end
		if not (char and char.Parent) then return end
		local veinParts = {"UpperTorso","Torso","LeftUpperArm","RightUpperArm"}
		for _, pName in ipairs(veinParts) do
			local p = char:FindFirstChild(pName)
			if not (p and p:IsA("BasePart")) then continue end
			if partCount >= CFG.MaxParts then break end
			local numV = stage
			for v = 1, numV do
				if partCount >= CFG.MaxParts then break end
				task.delay(v*0.15, function()
					if not (p and p.Parent) then return end
					local vein = Instance.new("Part"); vein.Name = "PibbyVein"
					vein.Anchored=false; vein.CanCollide=false; vein.CastShadow=false
					local vLen = p.Size.Y*(0.5+math.random()*0.6)
					vein.Size = Vector3.new(0.035, vLen, 0.035)
					local vAngle = math.random()*math.pi*2
					vein.CFrame = p.CFrame * CFrame.new(
						math.cos(vAngle)*p.Size.X*0.48,
						(math.random()-0.5)*p.Size.Y*0.3,
						math.sin(vAngle)*p.Size.Z*0.48
					) * CFrame.Angles(math.random()*0.3-0.15, vAngle, 0)
					vein.Color = math.random()<0.5 and Color3.fromRGB(120,0,200) or Color3.fromRGB(180,0,255)
					vein.Material = Enum.Material.Neon
					vein.Transparency = 0.2; vein.Parent = p
					local wv = Instance.new("WeldConstraint"); wv.Part0=vein; wv.Part1=p; wv.Parent=vein
					partCount += 1
					-- Pulso de la vena
					task.spawn(function()
						while vein and vein.Parent do
							task.wait(1.5+math.random()*2.5)
							if not(vein and vein.Parent) then break end
							TweenService:Create(vein,TweenInfo.new(0.12),{Transparency=0, Size=Vector3.new(0.055,vLen,0.055)}):Play()
							task.wait(0.15)
							if vein and vein.Parent then
								TweenService:Create(vein,TweenInfo.new(0.4),{Transparency=0.2, Size=Vector3.new(0.035,vLen,0.035)}):Play()
							end
						end
					end)
				end)
			end
		end
	end

	-- ── OVERRIDE DE startInfection CON EL NUEVO SISTEMA ─────────────────
	local _v310StartInfection = startInfection
	function startInfection(player)
		if infected[player] then return end
		_v310StartInfection(player)

		-- Hook post-infección: aplica corrupción orgánica en cada stage
		task.spawn(function()
			local lastAppliedStage = 0
			while infected[player] do
				task.wait(0.5)
				local data = infected[player]
				if not data then break end
				if data.stage > lastAppliedStage then
					lastAppliedStage = data.stage
					local ch = player.Character
					if ch then
						applyOrganicCorruption(ch, data.stage)
						applyBioVeins(ch, data.stage)
					end
				end
			end
		end)
	end


	-- ════════════════════════════════════════════════════════════════════
	--  IA DE MICELIO INTELIGENTE v3.10
	--  Inspirada en comportamiento real de Physarum polycephalum
	--  (el moho del limo que "resuelve laberintos" y optimiza rutas)
	--
	--  Sistemas nuevos:
	--  1. FEROMONAS: las rutas exitosas dejan "rastro" que atrae más micelio
	--  2. FLUJO: el micelio fluye como agua alrededor de obstáculos
	--  3. PULSOS DE CRECIMIENTO: olas de expansión desde el núcleo
	--  4. MEMORIA DE FRACASO: evita rutas que siempre fallan
	--  5. HAMBRE DIRECCIONAL: busca activamente zonas sin cubrir
	-- ════════════════════════════════════════════════════════════════════

	-- ── MAPA DE FEROMONAS ────────────────────────────────────────────────
	-- Células del grid marcadas con "intensidad de feromona"
	-- Cuando un nodo pasa por una celda, deja feromona
	-- Otros nodos siguen el rastro de feromona (como hormigas reales)
	local pheromoneMap    = {}   -- gridKey → {strength, time}
	local PHERO_DECAY     = 0.004 -- decae por segundo
	local PHERO_MAX       = 12
	local PHERO_THRESHOLD = 0.5
	local pheromoneDecayT = 0

	local function depositPheromone(pos, strength)
		local k = gKey(pos)
		if not pheromoneMap[k] then
			pheromoneMap[k] = {strength=0, time=tick(), pos=pos}
		end
		pheromoneMap[k].strength = math.min(
			pheromoneMap[k].strength + (strength or 1),
			PHERO_MAX
		)
		pheromoneMap[k].time = tick()
	end

	-- Devuelve la dirección de mayor feromona desde una posición
	local function pheromoneGradient(pos, currentDir)
		local bestDir = nil
		local bestStr = PHERO_THRESHOLD

		-- Escanea 8 direcciones buscando feromona
		for i = 1, 8 do
			local angle = (i/8)*math.pi*2
			local testDir = Vector3.new(math.cos(angle), 0, math.sin(angle))
			-- Sesga hacia la dirección actual (no da vueltas de 180°)
			if testDir:Dot(currentDir) < -0.5 then continue end
			local testPos = pos + testDir*CFG.StepSize*2
			local k = gKey(testPos)
			local phero = pheromoneMap[k]
			if phero and phero.strength > bestStr then
				bestStr = phero.strength
				bestDir = testDir
			end
		end
		return bestDir, bestStr
	end

	-- ── MAPA DE FRACASOS ─────────────────────────────────────────────────
	-- Posiciones donde el micelio se quedó bloqueado varias veces
	local failureMap = {}  -- gridKey → count

	local function recordFailure(pos)
		local k = gKey(pos)
		failureMap[k] = (failureMap[k] or 0) + 1
	end

	local function isFailureZone(pos)
		local k = gKey(pos)
		return (failureMap[k] or 0) >= 3
	end

	-- ── PULSOS DE CRECIMIENTO ────────────────────────────────────────────
	-- Periódicamente el micelio envía una "ola" de crecimiento desde
	-- el núcleo hacia fuera, como latidos de un corazón orgánico
	local growthPulseT    = 0
	local PULSE_INTERVAL  = 12  -- segundos entre pulsos
	local pulseCount      = 0

	local function emitGrowthPulse()
		if not infectionReady then return end
		if #blobReg < 5 then return end
		if partCount >= CFG.MaxParts then return end

		pulseCount += 1
		local origin = getOrigin()

		-- Ordena blobs por distancia al núcleo
		local sortedBlobs = {}
		for _, b in ipairs(blobReg) do
			table.insert(sortedBlobs, {pos=b.pos, d=(b.pos-origin).Magnitude})
		end
		table.sort(sortedBlobs, function(a,b) return a.d < b.d end)

		-- La ola viaja desde el centro hacia afuera
		-- Activa nodos durmientes en orden radial
		local waveSpeed = 18 + currentPhase*3
		local maxBlobs  = math.min(30 + currentPhase*8, #sortedBlobs)

		for i = 1, maxBlobs do
			local b = sortedBlobs[i]
			local delay_ = b.d / waveSpeed
			task.delay(delay_, function()
				if partCount >= CFG.MaxParts or #nodes >= CFG.MaxNodes then return end
				if inQuarantine and inQuarantine(b.pos) then return end
				-- Brota 1-2 nodos desde cada blob alcanzado por la ola
				local numBroots = math.random(1, 2)
				for _ = 1, numBroots do
					local baseAngle = math.random() * math.pi * 2
					-- Sesgo: nodos en dirección radial (se alejan del núcleo)
					local radialDir = (b.pos - origin)
					local radialFlat = Vector3.new(radialDir.X, 0, radialDir.Z)
					local expandDir
					if radialFlat.Magnitude > 0.1 then
						-- 70% radial + 30% aleatorio
						local randDir = Vector3.new(math.cos(baseAngle),0,math.sin(baseAngle))
						expandDir = (radialFlat.Unit*0.7 + randDir*0.3).Unit
					else
						expandDir = Vector3.new(math.cos(baseAngle),0,math.sin(baseAngle))
					end

					-- Busca superficie en esa dirección
					local gp, gn = castSurf(b.pos + Vector3.new(0,2,0), Vector3.new(0,-1,0), CFG.RayDown)
					if gp and not isOcc(gp) then
						local life = math.random(CFG.LifeMin, CFG.LifeMax)
						table.insert(nodes, {
							pos=gp, dir=expandDir, normal=gn or Vector3.new(0,1,0),
							life=life, maxLife=life, depth=0, age=0,
							nodeType="pulse_wave"  -- tipo especial para el pulso
						})
						-- Deposita feromona en la posición del blob
						depositPheromone(gp, 2)
					end
				end
			end)
		end

		-- Visual: anillo de luz desde el núcleo que se expande
		task.spawn(function()
			if partCount >= CFG.MaxParts then return end
			local ringPart = Instance.new("Part")
			ringPart.Anchored=true; ringPart.CanCollide=false; ringPart.CastShadow=false
			ringPart.Shape = Enum.PartType.Ball
			ringPart.Size = Vector3.new(1,0.08,1)
			ringPart.Position = origin + Vector3.new(0,0.3,0)
			ringPart.Color = rN(); ringPart.Material = Enum.Material.Neon; ringPart.Transparency = 0.2
			ringPart.Parent = folder; partCount += 1
			local maxRadius = 60 + currentPhase*10
			TweenService:Create(ringPart,
				TweenInfo.new(maxRadius/waveSpeed, Enum.EasingStyle.Sine),
				{Size=Vector3.new(maxRadius*2, 0.08, maxRadius*2), Transparency=1}):Play()
			task.delay(maxRadius/waveSpeed + 0.1, function()
				if ringPart then ringPart:Destroy(); partCount=math.max(0,partCount-1) end
			end)
		end)
	end

	local function tickGrowthPulse(dt)
		growthPulseT += dt
		local interval = math.max(5, PULSE_INTERVAL - currentPhase*1.2)
		if growthPulseT < interval then return end
		growthPulseT = 0
		emitGrowthPulse()
	end

	-- ── FLUJO ORGÁNICO ───────────────────────────────────────────────────
	-- Los nodos "pulse_wave" tienen comportamiento de flujo:
	-- cuando encuentran un obstáculo, no se bloquean, sino que
	-- "fluyen" por los lados como agua, usando el gradiente de feromona

	local function processFlowNodes()
		if #nodes == 0 then return end

		local flowNodes = {}
		local otherNodes = {}
		for _, node in ipairs(nodes) do
			if node.nodeType == "pulse_wave" or node.nodeType == "pathgrow" then
				table.insert(flowNodes, node)
			else
				table.insert(otherNodes, node)
			end
		end

		local flowNext = {}
		for _, node in ipairs(flowNodes) do
			if node.life <= 0 then
				-- Al morir: deposita feromona fuerte (ruta exitosa)
				depositPheromone(node.pos, 3)
				local gp, gn = castSurf(node.pos+node.normal, -node.normal, 4)
				if gp then spawnBlob(gp, gn, CFG.BlobRadMin+math.random()*0.5, 0.7) end
				continue
			end
			if isFailureZone(node.pos) then continue end  -- evita zonas problemáticas

			local af = 1 - (node.life/node.maxLife)
			local wander = 0.2 + af*0.4

			-- Dirección base: combina dirección actual + gradiente de feromona
			local baseDir = node.dir
			local pheroDir, pheroStr = pheromoneGradient(node.pos, baseDir)
			if pheroDir and pheroStr > PHERO_THRESHOLD then
				-- Sigue el rastro de feromona (como una hormiga siguiendo a otra)
				baseDir = (baseDir*(1-pheroStr/PHERO_MAX*0.6) + pheroDir*(pheroStr/PHERO_MAX*0.6)).Unit
			end

			-- Sesgo de exploración: prefiere zonas sin cubrir
			if math.random() < 0.35 then
				local expBias = explorationBiasDir and explorationBiasDir(node.pos)
				if expBias then baseDir = (baseDir*0.65 + expBias*0.35).Unit end
			end

			local newDir = rotXZ(baseDir, (math.random()-0.5)*math.pi*wander)
			local np, nn, ud = nextSurf(node.pos, newDir, node.normal, CFG.StepSize)

			if not np then
				-- FLUJO: si el camino está bloqueado, prueba ±45° y ±90°
				local flowed = false
				for _, flowAngle in ipairs({math.pi*0.25, -math.pi*0.25, math.pi*0.5, -math.pi*0.5}) do
					local flowDir = rotXZ(newDir, flowAngle)
					local fp, fn, fd = nextSurf(node.pos, flowDir, node.normal, CFG.StepSize)
					if fp and not isSolid(fp+fn*0.1) then
						np = fp; nn = fn; ud = fd
						flowed = true
						break
					end
				end
				if not flowed then
					recordFailure(node.pos)
					continue
				end
			end

			if isOcc(np) then continue end
			markOcc(np)

			-- Deposita feromona en el paso exitoso
			depositPheromone(np, 1)

			spawnTendril(node.pos, np, nn, af, math.random()<0.06, false)
			if math.random() < 0.15 then
				spawnBlob(np, nn, CFG.BlobRadMin+math.random()*(CFG.BlobRadMax-CFG.BlobRadMin)*0.4, af)
			end

			table.insert(flowNext, {
				pos=np, dir=ud or newDir, normal=nn,
				life=node.life-1, maxLife=node.maxLife,
				depth=node.depth, age=node.age+1,
				nodeType=node.nodeType
			})

			-- Ramificación del flujo (más frecuente que nodos normales)
			if math.random() < CFG.BranchChance*1.4 and node.depth < CFG.MaxDepth then
				local bs = math.random()>0.5 and 1 or -1
				local bLife = math.max(4, math.floor(node.life*CFG.BranchDecay))
				addNode(np, rotXZ(ud or newDir, bs*(math.pi*0.25+math.random()*0.4)),
					nn, bLife, node.depth+1, node.age, "pulse_wave")
			end

			-- Infección de jugadores
			for _, pl in ipairs(Players:GetPlayers()) do
				if not infected[pl] then
					local ch = pl.Character
					if ch then
						local h = ch:FindFirstChild("HumanoidRootPart")
						if h and (h.Position-np).Magnitude < CFG.PlayerRadius then
							startInfection(pl)
						end
					end
				end
			end
		end

		nodes = otherNodes
		for _, fn in ipairs(flowNext) do table.insert(nodes, fn) end
	end

	-- ── LIMPIEZA PERIÓDICA DE FEROMONAS Y FALLOS ────────────────────────
	local pheroCleanT = 0
	local function tickPheromoneSystem(dt)
		pheromoneDecayT += dt
		pheroCleanT += dt

		-- Decae feromonas cada tick
		if pheromoneDecayT >= 0.5 then
			pheromoneDecayT = 0
			local t = tick()
			local staleKeys = {}
			for k, ph in pairs(pheromoneMap) do
				ph.strength = ph.strength - PHERO_DECAY * (t - ph.time)
				ph.time = t
				if ph.strength <= 0 then table.insert(staleKeys, k) end
			end
			for _, k in ipairs(staleKeys) do pheromoneMap[k] = nil end
		end

		-- Limpia mapa de fallos periódicamente
		if pheroCleanT >= 60 then
			pheroCleanT = 0
			for k, count in pairs(failureMap) do
				failureMap[k] = math.max(0, count - 1)
				if failureMap[k] == 0 then failureMap[k] = nil end
			end
		end
	end

	-- ── HAMBRE DIRECCIONAL ───────────────────────────────────────────────
	-- El micelio "siente" dónde hay zonas sin cubrir y envía
	-- nodos exploradores hacia allá de forma proactiva
	local hungerT = 0

	local function tickHunger(dt)
		hungerT += dt
		if hungerT < 8 - currentPhase*0.5 then return end
		hungerT = 0

		if not infectionReady then return end
		if #nodes >= CFG.MaxNodes or partCount >= CFG.MaxParts then return end
		if #blobReg == 0 then return end

		-- Elige un punto de micelio al azar
		local sample = blobReg[math.random(#blobReg)]
		if not sample then return end
		if inQuarantine and inQuarantine(sample.pos) then return end

		-- Busca la dirección con menor cobertura (más "hambre")
		local hungrierDir = nil
		local lowestDensity = math.huge

		for i = 1, 8 do
			local angle = (i/8)*math.pi*2
			local testDir = Vector3.new(math.cos(angle), 0, math.sin(angle))
			local testPos = sample.pos + testDir*20

			-- Densidad = cuánto micelio hay en esa zona
			local density = 0
			for _, b in ipairs(blobReg) do
				if (b.pos - testPos).Magnitude < 12 then density += 1 end
			end

			-- Penaliza zonas de fracaso
			if isFailureZone(testPos) then density += 5 end

			if density < lowestDensity then
				lowestDensity = density
				hungrierDir = testDir
			end
		end

		if not hungrierDir then return end

		-- Envía un "explorador" en esa dirección
		local explorePos = sample.pos + hungrierDir*15
		local gp, gn = castSurf(explorePos+Vector3.new(0,3,0), Vector3.new(0,-1,0), CFG.RayDown)
		if gp and not isOcc(gp) then
			local life = math.random(CFG.LifeMin, CFG.LifeMax + currentPhase*3)
			table.insert(nodes, {
				pos=gp, dir=hungrierDir, normal=gn or Vector3.new(0,1,0),
				life=life, maxLife=life, depth=0, age=0,
				nodeType="hungry_explorer"
			})
		end
	end

	-- ── HEARTBEAT v3.10 ──────────────────────────────────────────────────
	RunService.Heartbeat:Connect(function(dt)
		tickGrowthPulse(dt)
		tickPheromoneSystem(dt)
		tickHunger(dt)
		processFlowNodes()
	end)

	-- ── PRINT FINAL ──────────────────────────────────────────────────────
	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.10                                                    ║")
	print("║  ✦ INFECCIÓN ORGÁNICA — 6 tipos según parte del cuerpo:        ║")
	print("║    ENCASE: carcasa de micelio que envuelve pies/manos           ║")
	print("║    TENDRIL: hélices que se enrollan alrededor de piernas/brazos ║")
	print("║    SWELL: hinchazón + bultos orgánicos en extremidades          ║")
	print("║    FRAGMENT: cristales/placas que brotan del torso              ║")
	print("║    SPINE: espinas óseas en brazos                               ║")
	print("║    MUTATE: cabeza con hongo real, ojos extra, grietas neon      ║")
	print("║    + Venas bioluminiscentes en la piel (Stage 2+)               ║")
	print("║  ✦ IA MICELIO INTELIGENTE (Physarum style):                     ║")
	print("║    FEROMONAS: rutas exitosas atraen más micelio                 ║")
	print("║    FLUJO: rodea obstáculos como agua (no se bloquea)            ║")
	print("║    PULSOS: olas de crecimiento radiales desde el núcleo         ║")
	print("║    HAMBRE: busca activamente zonas sin cubrir                   ║")
	print("║    MEMORIA: evita zonas donde siempre falla                     ║")
	print("╚══════════════════════════════════════════════════════════════════╝")

end)()  -- cierra el scope de v3.10
-- ════════════════════════════════════════════════════════════════════
--  v3.11 — FASE 4 CON ANIMACIÓN DE PULSOS + IA Y CUERPO MEJORADOS
-- ════════════════════════════════════════════════════════════════════
;(function()

	-- ────────────────────────────────────────────────────────────────────
	--  ANIMACIÓN DE FASE 4: 5 PULSOS DESDE EL NÚCLEO
	-- ────────────────────────────────────────────────────────────────────

	local phase4Triggered = false

	local function emitPhase4Pulse(pulseIndex, origin, infeccionPart)
		if partCount >= CFG.MaxParts then return end

		local pulseColors = {
			Color3.fromRGB(180,0,255),
			Color3.fromRGB(255,0,180),
			Color3.fromRGB(0,180,255),
			Color3.fromRGB(255,80,0),
			Color3.fromRGB(255,255,255),
		}
		local col = pulseColors[pulseIndex] or rN()

		if infeccionPart and infeccionPart.Parent then
			local origCol = infeccionPart.Color
			infeccionPart.Color = col
			infeccionPart.Material = Enum.Material.Neon
			task.delay(0.12, function()
				if infeccionPart and infeccionPart.Parent then
					TweenService:Create(infeccionPart, TweenInfo.new(0.4), {Color=origCol}):Play()
				end
			end)
			local pl = Instance.new("PointLight")
			pl.Color = col; pl.Range = 0; pl.Brightness = 12; pl.Parent = infeccionPart
			TweenService:Create(pl, TweenInfo.new(0.08), {Range=80}):Play()
			TweenService:Create(pl, TweenInfo.new(1.5), {Brightness=0, Range=20}):Play()
			task.delay(1.6, function() if pl then pl:Destroy() end end)
		end

		local ring = Instance.new("Part")
		ring.Anchored=true; ring.CanCollide=false; ring.CastShadow=false
		ring.Shape = Enum.PartType.Ball
		ring.Size = Vector3.new(2, 0.15, 2)
		ring.Position = origin + Vector3.new(0, 0.5, 0)
		ring.Color = col; ring.Material = Enum.Material.Neon; ring.Transparency = 0.1
		ring.Parent = folder; partCount += 1

		local maxR = 80 + pulseIndex * 15
		local duration = 2.0 + pulseIndex * 0.3

		TweenService:Create(ring, TweenInfo.new(duration, Enum.EasingStyle.Sine), {
			Size = Vector3.new(maxR*2, 0.15, maxR*2),
			Transparency = 1
		}):Play()

		task.delay(duration + 0.1, function()
			if ring then ring:Destroy(); partCount=math.max(0,partCount-1) end
		end)

		local waveSpeed = maxR / duration
		for _, b in ipairs(blobReg) do
			local d = (b.pos - origin).Magnitude
			if d > maxR then continue end
			task.delay(d / waveSpeed, function()
				if partCount < CFG.MaxParts then
					local flash = Instance.new("Part")
					flash.Anchored=true; flash.CanCollide=false; flash.CastShadow=false
					flash.Shape=Enum.PartType.Ball; flash.Size=Vector3.new(0.4,0.4,0.4)
					flash.Position = b.pos + Vector3.new(0,0.3,0)
					flash.Color = col; flash.Material=Enum.Material.Neon; flash.Transparency=0.1
					flash.Parent=folder; partCount+=1
					TweenService:Create(flash,TweenInfo.new(0.35),{Size=Vector3.new(2,2,2),Transparency=1}):Play()
					task.delay(0.4,function() if flash then flash:Destroy(); partCount=math.max(0,partCount-1) end end)
				end
			end)
		end

		if pulseIndex == 5 then
			task.delay(duration * 0.5, function()
				for _, pl in ipairs(Players:GetPlayers()) do
					screenMsg(pl, "[ FASE 4 — SIN RETORNO ]", col, 4)
				end
			end)
		end
	end

	local _v311ActivatePhase = activatePhase
	function activatePhase(phase)
		_v311ActivatePhase(phase)

		if phase == 4 and not phase4Triggered then
			phase4Triggered = true
			local origin = getOrigin()
			local infPart = workspace:FindFirstChild("Infeccion")

			for i = 1, 5 do
				task.delay(i * 0.85, function()
					emitPhase4Pulse(i, origin, infPart)
				end)
			end

			task.delay(5.5, function()
				if not infectionReady then return end
				for j = 1, 3 do
					task.delay(j * 0.3, function()
						local off = Vector3.new(
							(math.random()-0.5)*15, 0, (math.random()-0.5)*15)
						spawnWave(origin + off)
					end)
				end
			end)
		end
	end

	-- ────────────────────────────────────────────────────────────────────
	--  RASTRO DE INFECTADOS — VERSIÓN CORREGIDA
	--  El micelio ya NO aparece bajo el jugador.
	--  Usa historial de posiciones: spawnea donde el jugador YA ESTUVO.
	-- ────────────────────────────────────────────────────────────────────

	-- Radio de exclusión: no spawnea si el jugador sigue cerca de ese punto
	local FOOT_EXCLUSION_RADIUS = 4.5   -- studs; sube si aún se ve muy cerca

	-- Historial de posiciones por jugador (dónde estuvo, no dónde está)
	local footPosHistory  = {}   -- player → {pos1, pos2, ...}
	local HIST_SAMPLE_DIST = 1.8 -- distancia mínima entre muestras
	local HIST_MAX         = 10  -- puntos máximos por jugador

	-- Timers de rastro y crecimientos
	local footTrailT  = {}
	local bodyGrowthT = {}

	-- Devuelve true si `pos` está demasiado cerca del jugador actual
	local function nearPlayer(pos, player)
		local ch = player.Character
		if not ch then return false end
		local hrp = ch:FindFirstChild("HumanoidRootPart")
		if not hrp then return false end
		return (hrp.Position - pos).Magnitude < FOOT_EXCLUSION_RADIUS
	end

	-- ── spawnFootNode CORREGIDO ────────────────────────────────────────
	local function spawnFootNode(player, stage)
		if not (player and player.Parent) then return end
		local ch = player.Character; if not ch then return end
		local hrp = ch:FindFirstChild("HumanoidRootPart"); if not hrp then return end
		if partCount >= CFG.MaxParts - 3 then return end
		if stage < 1 then return end

		-- Elige una posición histórica (donde el jugador ya NO está)
		local hist = footPosHistory[player]
		local spawnPos = nil

		if hist and #hist >= 3 then
			-- Toma un punto de hace 2-4 pasos atrás
			local targetIdx = math.max(1, #hist - math.random(2, 4))
			local candidate = hist[targetIdx]
			-- Verifica que el jugador no haya vuelto a ese punto
			if not nearPlayer(candidate, player) then
				spawnPos = candidate
			end
		end

		-- Si no hay historial válido o el jugador volvió al punto:
		-- desplaza aleatoriamente fuera del radio de exclusión
		if not spawnPos then
			local angle = math.random() * math.pi * 2
			local dist  = FOOT_EXCLUSION_RADIUS + math.random() * 4
			spawnPos = hrp.Position + Vector3.new(
				math.cos(angle)*dist, 0, math.sin(angle)*dist)
		end

		-- Busca el suelo en esa posición
		local gp, gn = castSurf(spawnPos + Vector3.new(0,2,0), Vector3.new(0,-1,0), 6)
		if not gp then return end

		-- Última comprobación: si el jugador está justo ahí, cancela
		if nearPlayer(gp, player) then return end

		-- Nódulo orgánico en el suelo
		local nodeR = 0.18 + math.random()*0.25 + stage*0.12
		local isNeon = math.random() < 0.08 + stage*0.04
		local stageCol = ({
			[1]=Color3.fromRGB(180,160,210),
			[2]=Color3.fromRGB(80,20,120),
			[3]=Color3.fromRGB(28,0,58),
			[4]=Color3.fromRGB(8,0,20),
			[5]=Color3.fromRGB(3,0,8),
		})[math.min(stage,5)] or rD()

		local nod = Instance.new("Part")
		nod.Anchored=true; nod.CanCollide=false; nod.CastShadow=false
		nod.Shape=Enum.PartType.Ball
		nod.Size = Vector3.new(nodeR, nodeR*0.55, nodeR)
		nod.CFrame = CFrame.new(gp + gn*(nodeR*0.3))
			* CFrame.Angles(math.random()*0.4-0.2, math.random()*math.pi, 0)
		nod.Color    = isNeon and rN() or stageCol
		nod.Material = isNeon and Enum.Material.Neon or Enum.Material.SmoothPlastic
		nod.Transparency = 1; nod.Parent = folder; partCount+=1

		TweenService:Create(nod,
			TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
			{Transparency = isNeon and 0 or 0.12}):Play()

		-- Desvanece tras un tiempo
		local lifetime = 4 + stage*2 + math.random()*3
		task.delay(lifetime, function()
			if nod and nod.Parent then
				TweenService:Create(nod, TweenInfo.new(1.5), {Transparency=1}):Play()
				task.delay(1.6, function()
					if nod then nod:Destroy(); partCount=math.max(0,partCount-1) end
				end)
			end
		end)

		-- Nodo de micelio en stages altos
		if stage >= 3 and math.random() < 0.25 and #nodes < CFG.MaxNodes then
			local a = math.random()*math.pi*2
			local l = math.random(4, 12)
			table.insert(nodes, {
				pos=gp, dir=Vector3.new(math.cos(a),0,math.sin(a)),
				normal=gn, life=l, maxLife=l,
				depth=3, age=0.5, nodeType="normal"
			})
		end

		-- Contagio por pisadas (stage 4+) — solo en posición histórica
		if stage >= 4 then
			for _, otherPl in ipairs(Players:GetPlayers()) do
				if otherPl ~= player and not infected[otherPl] then
					local oc = otherPl.Character
					if oc then
						local oh = oc:FindFirstChild("HumanoidRootPart")
						if oh and (oh.Position - gp).Magnitude < 3.0 then
							if math.random() < 0.015 then
								task.spawn(function() startInfection(otherPl) end)
							end
						end
					end
				end
			end
		end
	end

	-- ── spawnBodyGrowth (sin cambios) ──────────────────────────────────
	local function spawnBodyGrowth(player, stage)
		if stage < 2 then return end
		if not (player and player.Parent) then return end
		local ch = player.Character; if not ch then return end
		if partCount >= CFG.MaxParts - 2 then return end

		local bodyParts = {"LeftUpperLeg","RightUpperLeg","LeftUpperArm","RightUpperArm","LowerTorso","UpperTorso"}
		local partName = bodyParts[math.random(#bodyParts)]
		local bp = ch:FindFirstChild(partName)
		if not (bp and bp:IsA("BasePart")) then return end

		local growR = 0.12 + math.random()*0.20 + stage*0.06
		local gnode = Instance.new("Part")
		gnode.Name = "PibbyBodyGrowth"
		gnode.Anchored=false; gnode.CanCollide=false; gnode.CastShadow=false
		gnode.Shape=Enum.PartType.Ball
		gnode.Size = Vector3.new(growR, growR*0.75, growR)
		local surfAngle = math.random()*math.pi*2
		local surfPos = Vector3.new(
			math.cos(surfAngle)*bp.Size.X*0.52,
			(math.random()-0.5)*bp.Size.Y*0.7,
			math.sin(surfAngle)*bp.Size.Z*0.52
		)
		gnode.CFrame = bp.CFrame * CFrame.new(surfPos)
		local isNeon = math.random() < 0.10 + stage*0.04
		gnode.Color = isNeon and rN() or ({
			[2]=Color3.fromRGB(60,10,100),
			[3]=Color3.fromRGB(20,0,45),
			[4]=Color3.fromRGB(6,0,15),
			[5]=Color3.fromRGB(2,0,6),
		})[math.min(stage,5)] or rD()
		gnode.Material = isNeon and Enum.Material.Neon or Enum.Material.SmoothPlastic
		gnode.Transparency = 1; gnode.Parent = bp

		local w = Instance.new("WeldConstraint"); w.Part0=gnode; w.Part1=bp; w.Parent=gnode
		TweenService:Create(gnode,
			TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
			{Transparency = isNeon and 0 or 0.08,
				Size=Vector3.new(growR*1.3, growR, growR*1.3)}):Play()
		partCount += 1

		if isNeon then
			local li=Instance.new("PointLight"); li.Color=gnode.Color
			li.Range=growR*6; li.Brightness=1.5; li.Parent=gnode
		end
		task.spawn(function()
			while gnode and gnode.Parent do
				task.wait(4+math.random()*8)
				if not(gnode and gnode.Parent) then break end
				if math.random()<0.12 then
					local oc=gnode.Color; gnode.Color=rN(); gnode.Material=Enum.Material.Neon
					task.wait(0.04+math.random()*0.06)
					if gnode and gnode.Parent then
						gnode.Color=oc; gnode.Material=Enum.Material.SmoothPlastic
					end
				end
			end
		end)
	end

	-- ── tickInfectedTrail CORREGIDO ────────────────────────────────────
	--  Añade el registro del historial de posición antes de spawnear
	local function tickInfectedTrail(dt)
		for pl, data in pairs(infected) do
			if data.stage < 1 then continue end

			local ch = pl.Character; if not ch then continue end
			local hrp = ch:FindFirstChild("HumanoidRootPart"); if not hrp then continue end

			-- ── Registra posición actual en el historial ──────────────
			if not footPosHistory[pl] then footPosHistory[pl] = {} end
			local hist = footPosHistory[pl]
			local curPos = hrp.Position
			if #hist == 0 or (hist[#hist] - curPos).Magnitude >= HIST_SAMPLE_DIST then
				table.insert(hist, curPos)
				if #hist > HIST_MAX then table.remove(hist, 1) end
			end

			-- ── Rastro de nodos en posición histórica ────────────────
			footTrailT[pl] = (footTrailT[pl] or 0) + dt
			local trailInterval = math.max(0.25, 1.8 - data.stage*0.28)
			if footTrailT[pl] >= trailInterval then
				footTrailT[pl] = 0
				spawnFootNode(pl, data.stage)
			end

			-- ── Crecimientos en el cuerpo (sin cambios) ──────────────
			bodyGrowthT[pl] = (bodyGrowthT[pl] or 0) + dt
			local growInterval = math.max(3, 18 - data.stage*3)
			if bodyGrowthT[pl] >= growInterval then
				bodyGrowthT[pl] = 0
				spawnBodyGrowth(pl, data.stage)
			end
		end

		-- Limpia historial de jugadores que dejaron de estar infectados
		for pl, _ in pairs(footPosHistory) do
			if not (pl and pl.Parent) or not infected[pl] then
				footPosHistory[pl] = nil
				footTrailT[pl]     = nil
				bodyGrowthT[pl]    = nil
			end
		end
	end

	-- ────────────────────────────────────────────────────────────────────
	--  nextSurf FINAL (igual que antes)
	-- ────────────────────────────────────────────────────────────────────
	local _v311NextSurf = nextSurf
	function nextSurf(from, move, sn, stepOvr)
		local step = stepOvr or CFG.StepSize
		local flat = move - sn * move:Dot(sn)
		if flat.Magnitude < 0.001 then flat = move else flat = flat.Unit end

		local r1 = workspace:Raycast(from + flat*step + sn*(step*0.9), -sn*(step*2.5), rpMain)
		if r1 then
			if r1.Normal.Y > 0.2 then
				return r1.Position + r1.Normal*CFG.SurfaceOff, r1.Normal, flat
			elseif math.abs(r1.Normal.Y) < 0.4 then
				return r1.Position + r1.Normal*CFG.SurfaceOff, r1.Normal, flat
			end
		end

		local wallR = workspace:Raycast(from + sn*0.15, flat*(step*1.5), rpMain)
		if wallR then
			local wn = wallR.Normal
			if math.abs(wn.Y) < 0.5 then
				for h = 1, 7 do
					local hOff = h * (step * 0.4)
					local topProbe = wallR.Position + wn*CFG.SurfaceOff + Vector3.new(0, hOff, 0) + flat*(step*0.6)
					local topR = workspace:Raycast(topProbe + Vector3.new(0,step*0.3,0), Vector3.new(0,-1,0)*step*1.5, rpMain)
					if topR and topR.Normal.Y > 0.35 then
						return topR.Position + topR.Normal*CFG.SurfaceOff, topR.Normal, flat
					end
				end
				local wallTan = wn:Cross(Vector3.new(0,1,0))
				if wallTan.Magnitude < 0.01 then wallTan = wn:Cross(Vector3.new(0,0,1)) end
				wallTan = wallTan.Unit
				if wallTan:Dot(flat) < 0 then wallTan = -wallTan end
				return wallR.Position + wn*CFG.SurfaceOff, wn, wallTan
			end
		end

		local edgeR = workspace:Raycast(from + flat*step + sn*0.2, -sn*(CFG.RayDown*1.5), rpMain)
		if edgeR then
			return edgeR.Position + edgeR.Normal*CFG.SurfaceOff, edgeR.Normal, flat
		end

		for _, sign in ipairs({1,-1}) do
			for _, ang in ipairs({math.pi*0.28, math.pi*0.5, math.pi*0.72}) do
				local altDir = rotXZ(flat, sign*ang)
				local altR = workspace:Raycast(from + altDir*step + sn*(step*0.7), -sn*(step*2.2), rpMain)
				if altR and altR.Normal.Y > -0.1 then
					return altR.Position + altR.Normal*CFG.SurfaceOff, altR.Normal, altDir
				end
			end
		end

		local underR = workspace:Raycast(from - sn*(step*0.5), flat*(step*1.2), rpMain)
		if underR and underR.Normal:Dot(sn) < -0.25 then
			return underR.Position + underR.Normal*CFG.SurfaceOff, underR.Normal, flat
		end

		return nil, nil, flat
	end

	-- ────────────────────────────────────────────────────────────────────
	--  HEARTBEAT v3.11
	-- ────────────────────────────────────────────────────────────────────
	RunService.Heartbeat:Connect(function(dt)
		tickInfectedTrail(dt)
	end)

	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.11 (fix: micelio NO aparece bajo el jugador)         ║")
	print("║  + Fase 4: 5 pulsos con onda expansiva que activa el mapa      ║")
	print("║  + Rastro usa historial de posición — spawnea donde YA ESTUVO  ║")
	print("║  + Radio de exclusión: "..string.format("%.1f", 4.5).." studs desde el jugador")
	print("║  + Stage 2+: crecimientos brotan directamente del cuerpo        ║")
	print("║  + Stage 4+: pisadas contagian solo en posiciones históricas    ║")
	print("║  + nextSurf reescrito: sube paredes detectando la normal        ║")
	print("╚══════════════════════════════════════════════════════════════════╝")

end)()
-- ════════════════════════════════════════════════════════════════════
--  v3.16 — FASE 4: APAGADO PERMANENTE DE SCRIPTS
--
--  Cuando se activa la Fase 4, TODOS los scripts del juego se
--  deshabilitan UNA sola vez y NO vuelven a funcionar nunca más.
--  El único script protegido es el llamado "Scripteless".
--
--  ► INSTRUCCIONES: pega este bloque al FINAL del script v3.11,
--    justo después del último  end)()
-- ════════════════════════════════════════════════════════════════════
;(function()

	local phase4KillDone = false   -- garantiza que solo ocurre una vez

	-- ── Función que apaga todo ────────────────────────────────────────
	local function killAllScripts()
		if phase4KillDone then return end
		phase4KillDone = true

		print("[Pibby] ☠  FASE 4 — apagando todos los scripts...")

		-- Mensaje dramático en pantalla de todos los jugadores
		for _, pl in ipairs(Players:GetPlayers()) do
			screenMsg(pl, "[ SISTEMA COLAPSANDO ]", Color3.fromRGB(255, 20, 0), 4)
		end

		task.delay(1.5, function()

			local searchRoots = {
				game:GetService("ServerScriptService"),
				workspace,
				game:GetService("ReplicatedStorage"),
				game:GetService("StarterPack"),
				game:GetService("StarterPlayer"),
				game:GetService("ServerStorage"),
			}

			local killed  = 0
			local skipped = 0

			for _, root in ipairs(searchRoots) do
				pcall(function()
					for _, obj in ipairs(root:GetDescendants()) do

						-- Solo Scripts y LocalScripts
						if not (obj:IsA("Script") or obj:IsA("LocalScript")) then
							continue
						end

						-- ★ NUNCA toca "Scripteless" ★
						if obj.Name == "Scripteless" then
							skipped += 1
							continue
						end

						-- ★ Tampoco toca el script del micelio ★
						if obj == script then
							skipped += 1
							continue
						end

						-- Deshabilita permanentemente
						pcall(function()
							obj.Disabled = true
						end)
						killed += 1

						-- Flash visual en la Part que contenía el script (si aplica)
						if math.random() < 0.3 then
							local parent = obj.Parent
							if parent and parent:IsA("BasePart") and partCount < CFG.MaxParts then
								task.spawn(function()
									spawnFlash(
										parent.Position,
										Vector3.new(0, 1, 0),
										math.clamp(parent.Size.Magnitude * 0.1, 0.3, 1.5)
									)
								end)
							end
						end

					end
				end)
			end

			print("[Pibby] ☠  Scripts apagados: " .. killed ..
				" | Protegidos: " .. skipped)

			-- Mensaje final de colapso
			task.delay(0.5, function()
				for _, pl in ipairs(Players:GetPlayers()) do
					screenMsg(pl, "[ SCRIPTS ELIMINADOS ]", Color3.fromRGB(255, 0, 0), 3)
				end
			end)
		end)
	end

	-- ── Hook en activatePhase para disparar el apagado en Fase 4 ─────
	local _v316ActivatePhase = activatePhase
	function activatePhase(phase)
		_v316ActivatePhase(phase)
		if phase == 4 then
			-- Espera un poco después de los pulsos visuales (que duran ~5s)
			task.delay(6, killAllScripts)
		end
	end

	print("[Pibby] v3.16 cargado — Fase 4 apagará todos los scripts excepto 'Scripteless'")

end)()
-- ════════════════════════════════════════════════════════════════════
--  v3.17 — AUDIO PROGRESIVO + ANÁLISIS DE SERVIDOR + IA PROCEDURAL
-- ════════════════════════════════════════════════════════════════════
;(function()

	local HttpService = game:GetService("HttpService")
	local rng = Random.new(tick() * math.random(1000, 9999))
	local function rngFloat(a, b) return rng:NextNumber(a, b) end
	local function rngInt(a, b)   return rng:NextInteger(a, b) end

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 1: AUDIO PROGRESIVO
	-- ════════════════════════════════════════════════════════════════

	local AUDIO_INTERVAL  = 300
	local AUDIO_STEP      = 0.10
	local audioDecayLevel = 0
	local audioDecayTimer = 0
	local audioMasterReg  = {}

	local function collectAllSounds()
		local roots = {
			workspace,
			game:GetService("SoundService"),
			game:GetService("ServerScriptService"),
			game:GetService("ReplicatedStorage"),
			game:GetService("StarterPack"),
			game:GetService("StarterPlayer"),
			game:GetService("ServerStorage"),
		}
		for _, root in ipairs(roots) do
			pcall(function()
				for _, obj in ipairs(root:GetDescendants()) do
					if obj:IsA("Sound") and not audioMasterReg[obj] then
						audioMasterReg[obj] = {
							origSpeed    = obj.PlaybackSpeed,
							origVol      = obj.Volume,
							decayApplied = 0,
						}
					end
				end
			end)
		end
		for _, pl in ipairs(Players:GetPlayers()) do
			if pl.Character then
				for _, obj in ipairs(pl.Character:GetDescendants()) do
					if obj:IsA("Sound") and not audioMasterReg[obj] then
						audioMasterReg[obj] = {
							origSpeed    = obj.PlaybackSpeed,
							origVol      = obj.Volume,
							decayApplied = 0,
						}
					end
				end
			end
		end
	end

	local function applyAudioDecayTick()
		audioDecayLevel += 1
		local totalDecay = audioDecayLevel * AUDIO_STEP
		collectAllSounds()

		local degraded = 0
		for sound, data in pairs(audioMasterReg) do
			if not (sound and sound.Parent) then
				audioMasterReg[sound] = nil
				continue
			end
			pcall(function()
				local newSpeed = math.max(0.01,
					data.origSpeed - totalDecay * (0.8 + rngFloat(0, 0.4)))
				local volFade = math.max(0.05,
					data.origVol * (1 - totalDecay * 0.04))
				local jitter = rngFloat(-0.04, 0.04) * audioDecayLevel
				sound.PlaybackSpeed = math.clamp(newSpeed + jitter, 0.01, 3.0)
				sound.Volume        = math.clamp(volFade, 0, 1)

				if audioDecayLevel >= 5 and not sound:FindFirstChildOfClass("EqualizerSoundEffect") then
					local eq = Instance.new("EqualizerSoundEffect")
					eq.LowGain  = -10 * math.min(audioDecayLevel * 0.3, 1)
					eq.MidGain  = rngFloat(-8, 8) * math.min(audioDecayLevel * 0.2, 1)
					eq.HighGain = -15 * math.min(audioDecayLevel * 0.4, 1)
					eq.Parent   = sound
				end
				local eq = sound:FindFirstChildOfClass("EqualizerSoundEffect")
				if eq then
					eq.LowGain  = math.clamp(-audioDecayLevel * 2.5, -80, 0)
					eq.MidGain  = rngFloat(-audioDecayLevel*1.5, audioDecayLevel*1.5)
					eq.HighGain = math.clamp(-audioDecayLevel * 3, -80, 0)
				end

				if audioDecayLevel >= 8 and not sound:FindFirstChildOfClass("ReverbSoundEffect") then
					local rev = Instance.new("ReverbSoundEffect")
					rev.DecayTime = math.min(audioDecayLevel * 0.5, 8)
					rev.Density   = math.min(audioDecayLevel * 0.08, 1)
					rev.Diffusion = math.min(audioDecayLevel * 0.10, 1)
					rev.DryLevel  = math.clamp(-audioDecayLevel * 1.5, -80, 0)
					rev.WetLevel  = math.min(audioDecayLevel * 0.5, 0)
					rev.Parent    = sound
				end

				data.decayApplied = audioDecayLevel
				degraded += 1
			end)
		end

		print(string.format("[Pibby|Audio] Tick %d — %d audios degradados (speed ×%.2f)",
			audioDecayLevel, degraded,
			math.max(0.01, 1 - totalDecay * 0.8)))

		local milestone = {
			[3]="[ AUDIO CORRUPTO ]", [6]="[ SEÑAL PERDIDA ]",
			[10]="[ SILENCIO TOTAL ]", [15]="[ ??? ]"
		}
		if milestone[audioDecayLevel] then
			for _, pl in ipairs(Players:GetPlayers()) do
				screenMsg(pl, milestone[audioDecayLevel], rN(), 3)
			end
		end
	end

	RunService.Heartbeat:Connect(function(dt)
		audioDecayTimer += dt
		if audioDecayTimer >= AUDIO_INTERVAL then
			audioDecayTimer = 0
			applyAudioDecayTick()
		end
	end)

	Players.PlayerAdded:Connect(function(pl)
		pl.CharacterAdded:Connect(function(ch)
			task.wait(0.5)
			for _, obj in ipairs(ch:GetDescendants()) do
				if obj:IsA("Sound") and not audioMasterReg[obj] then
					audioMasterReg[obj] = {
						origSpeed=obj.PlaybackSpeed, origVol=obj.Volume, decayApplied=0
					}
				end
			end
		end)
	end)

	task.delay(2, collectAllSounds)

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 2: ANÁLISIS DE SERVIDOR
	-- ════════════════════════════════════════════════════════════════

	local TARGET_TYPES = {
		SCRIPT    = "script",
		NPC       = "npc",
		STRUCTURE = "structure",
		LIGHT     = "light",
		AUDIO     = "audio",
		PLAYER    = "player",
	}

	local ServerPlan = {
		scanComplete  = false,
		targets       = {},
		attackOrder   = {},
		totalParts    = 0,
		totalScripts  = 0,
		totalNpcs     = 0,
		totalLights   = 0,
		totalAudios   = 0,
		largestParts  = {},
		scriptHubs    = {},
		chokePoints   = {},
		personality   = nil,
	}

	local function evaluateTarget(obj)
		if obj:IsA("BasePart") then
			local volume = obj.Size.X * obj.Size.Y * obj.Size.Z
			return volume * (obj.Anchored and 1.2 or 0.8)
		elseif obj:IsA("Script") or obj:IsA("LocalScript") then
			return 10 + #obj:GetDescendants() * 2
		elseif obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
			return 25
		elseif obj:IsA("Sound") then return 5
		elseif obj:IsA("Light") then return 3
		end
		return 1
	end

	local function scanServer()
		print("[Pibby|Análisis] ▶ Iniciando escaneo del servidor...")
		local scanStart = tick()

		local partsBySize  = {}
		local scriptHubMap = {}
		local densityGrid  = {}

		local function scanDescendants(root)
			pcall(function()
				for _, obj in ipairs(root:GetDescendants()) do
					if obj:IsA("BasePart") then
						ServerPlan.totalParts += 1
						local vol = obj.Size.X * obj.Size.Y * obj.Size.Z
						table.insert(partsBySize, {part=obj, vol=vol})
						local k = gKey(obj.Position)
						densityGrid[k] = (densityGrid[k] or 0) + 1

					elseif obj:IsA("Script") or obj:IsA("LocalScript") then
						ServerPlan.totalScripts += 1
						if obj ~= script then
							local par = obj.Parent
							if par then
								scriptHubMap[par] = (scriptHubMap[par] or 0) + 1
							end
							-- ► El target de script ahora apunta al PARENT (BasePart)
							--   para usarlo como punto de entrada del micelio
							if par and par:IsA("BasePart") then
								table.insert(ServerPlan.targets, {
									type     = TARGET_TYPES.SCRIPT,
									obj      = obj,
									parent   = par,
									priority = evaluateTarget(obj),
									pos      = par.Position,
								})
							end
						end

					elseif obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
						ServerPlan.totalNpcs += 1
						local hrp = obj:FindFirstChild("HumanoidRootPart")
						table.insert(ServerPlan.targets, {
							type     = TARGET_TYPES.NPC,
							obj      = obj,
							priority = evaluateTarget(obj),
							pos      = hrp and hrp.Position or Vector3.new(0,0,0),
						})

					elseif obj:IsA("Sound") then
						ServerPlan.totalAudios += 1
					elseif obj:IsA("Light") then
						ServerPlan.totalLights += 1
					end
				end
			end)
		end

		local scanRoots = {
			workspace,
			game:GetService("ServerScriptService"),
			game:GetService("ReplicatedStorage"),
			game:GetService("StarterPack"),
			game:GetService("StarterPlayer"),
		}
		for _, r in ipairs(scanRoots) do scanDescendants(r) end

		table.sort(partsBySize, function(a,b) return a.vol > b.vol end)
		for i = 1, math.min(10, #partsBySize) do
			table.insert(ServerPlan.largestParts, partsBySize[i])
		end

		for obj, count in pairs(scriptHubMap) do
			if count >= 2 then
				table.insert(ServerPlan.scriptHubs, {obj=obj, count=count})
			end
		end
		table.sort(ServerPlan.scriptHubs, function(a,b) return a.count > b.count end)

		local densityList = {}
		for k, count in pairs(densityGrid) do
			if count >= 5 then
				local parts2 = {}
				for seg in k:gmatch("[^,]+") do table.insert(parts2, tonumber(seg)) end
				if #parts2 == 3 then
					local pos = Vector3.new(
						parts2[1]*CFG.CellSize,
						parts2[2]*CFG.CellSize,
						parts2[3]*CFG.CellSize)
					table.insert(densityList, {pos=pos, density=count})
				end
			end
		end
		table.sort(densityList, function(a,b) return a.density > b.density end)
		for i = 1, math.min(8, #densityList) do
			table.insert(ServerPlan.chokePoints, densityList[i])
		end

		table.sort(ServerPlan.targets, function(a,b) return a.priority > b.priority end)
		ServerPlan.scanComplete = true

		print(string.format(
			"[Pibby|Análisis] ✔ Escaneo completo (%.2fs)\n"..
				"  Parts: %d | Scripts: %d | NPCs: %d | Audios: %d | Luces: %d\n"..
				"  Targets: %d | Chokepoints: %d | Script hubs: %d",
			tick()-scanStart,
			ServerPlan.totalParts, ServerPlan.totalScripts,
			ServerPlan.totalNpcs,  ServerPlan.totalAudios, ServerPlan.totalLights,
			#ServerPlan.targets, #ServerPlan.chokePoints, #ServerPlan.scriptHubs
			))
		return ServerPlan
	end

	-- ── Ejecución del plan: NUNCA elimina scripts, los usa como portales ──
	local attackIndex = 0
	local attackTimer = 0

	local function executeNextAttack()
		if not ServerPlan.scanComplete then return end
		if #ServerPlan.targets == 0 then return end

		attackIndex = (attackIndex % #ServerPlan.targets) + 1
		local target = ServerPlan.targets[attackIndex]
		if not target then return end

		if not (target.obj and target.obj.Parent) then
			table.remove(ServerPlan.targets, attackIndex)
			attackIndex = math.max(1, attackIndex - 1)
			return
		end

		local t = target.type

		if t == TARGET_TYPES.SCRIPT then
			-- ► USA el objeto contenedor como portal de entrada del micelio
			--   NO toca el script en absoluto
			local parent = target.parent
			if parent and parent:IsA("BasePart") and parent.Parent then
				task.spawn(function()
					-- Pulso visual en el objeto (le "late" el micelio por dentro)
					local oc, om = parent.Color, parent.Material
					for _ = 1, math.random(3, 7) do
						if not (parent and parent.Parent) then break end
						parent.Color    = rN()
						parent.Material = Enum.Material.Neon
						task.wait(0.04 + math.random()*0.08)
						if parent and parent.Parent then
							parent.Color    = rD()
							parent.Material = Enum.Material.SmoothPlastic
						end
						task.wait(0.04)
					end
					-- Restaura color original
					if parent and parent.Parent then
						TweenService:Create(parent, TweenInfo.new(0.6),
							{Color=oc}):Play()
						parent.Material = om
					end
					-- Genera micelio desde ese objeto
					if parent and parent.Parent and partCount < CFG.MaxParts then
						local gp, gn = castSurf(
							parent.Position + Vector3.new(0,3,0),
							Vector3.new(0,-1,0), CFG.RayDown)
						if gp then
							spawnBlob(gp, gn, 1.2 + math.random()*1.8, 0.45)
							for i = 1, math.random(3, 5) do
								local a = (i/5)*math.pi*2
								local l = math.random(CFG.LifeMin, CFG.LifeMax)
								table.insert(nodes, {
									pos=gp,
									dir=Vector3.new(math.cos(a),0,math.sin(a)),
									normal=gn, life=l, maxLife=l,
									depth=0, age=0.1, nodeType="normal"
								})
							end
							spawnFlash(gp, gn, 0.8)
							print("[Pibby|Plan] ⬛ Portal de micelio: "..parent:GetFullName())
						end
					end
				end)
			end

		elseif t == TARGET_TYPES.NPC then
			if infectedNpcs and not infectedNpcs[target.obj] then
				local hrp = target.obj:FindFirstChild("HumanoidRootPart")
				if hrp then
					for _, b in ipairs(blobReg) do
						if (b.pos - hrp.Position).Magnitude < 25 then
							corruptNpc(target.obj)
							break
						end
					end
				end
			end

		elseif t == TARGET_TYPES.STRUCTURE then
			if #nodes < CFG.MaxNodes and partCount < CFG.MaxParts then
				local gp, gn = castSurf(
					target.pos+Vector3.new(0,3,0), Vector3.new(0,-1,0), CFG.RayDown)
				if gp then
					for i = 1, 5 do
						local a = (i/5)*math.pi*2
						local l = math.random(CFG.LifeMin, CFG.LifeMax)
						table.insert(nodes,{
							pos=gp, dir=Vector3.new(math.cos(a),0,math.sin(a)),
							normal=gn, life=l, maxLife=l,
							depth=0, age=0, nodeType="hunter"
						})
					end
				end
			end
		end
	end

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 3: IA PROCEDURAL
	-- ════════════════════════════════════════════════════════════════

	local STRATEGIES = {
		AGGRESSIVE  = "aggressive",
		PATIENT     = "patient",
		TARGETED    = "targeted",
		CHAOTIC     = "chaotic",
		SURROUND    = "surround",
		VERTICAL    = "vertical",
		UNDERGROUND = "underground",
	}

	local function generatePersonality()
		local seed = math.floor(tick()) % 999983
		local pers = {
			seed             = seed,
			name             = "",
			primaryStrat     = nil,
			secondaryStrat   = nil,
			expansionSpeed   = rngFloat(0.5, 2.2),
			branchMult       = rngFloat(0.6, 2.8),
			blobFreq         = rngFloat(0.3, 1.8),
			sporeFreq        = rngFloat(0.5, 3.0),
			playerFocus      = rngFloat(0.1, 1.0),
			npcAggression    = rngFloat(0.3, 2.0),
			audioDecayMult   = rngFloat(0.5, 2.5),
			lightHunger      = rngFloat(0.0, 1.0),
			favorWalls       = rng:NextNumber() > 0.5,
			favorCeilings    = rng:NextNumber() > 0.7,
			burstExplosions  = rng:NextNumber() > 0.6,
			silentInfection  = rng:NextNumber() > 0.5,
			mutationRate     = rngFloat(0.8, 1.5),
			strategyTimer    = 0,
			strategyInterval = rngFloat(45, 180),
			stratHistory     = {},
			customPhaseDelays = {
				rngFloat(0.8,1.3), rngFloat(0.8,1.2),
				rngFloat(0.7,1.3), rngFloat(0.6,1.2),
				rngFloat(0.5,1.1),
			},
			expansionBias = Vector3.new(
				rngFloat(-1,1), 0, rngFloat(-1,1)
			).Unit,
		}

		local stratList = {}
		for _, s in pairs(STRATEGIES) do table.insert(stratList, s) end
		pers.primaryStrat = stratList[rngInt(1,#stratList)]
		repeat
			pers.secondaryStrat = stratList[rngInt(1,#stratList)]
		until pers.secondaryStrat ~= pers.primaryStrat

		local prefixes = {"STRAIN","VECTOR","CLADE","MYCO","PHYTO","ENTO","CORDY"}
		local suffixes = {"ALPHA","BETA","SIGMA","OMEGA","PRIME","NULL","VOID","ZERO"}
		pers.name = prefixes[rngInt(1,#prefixes)].."-"..
			suffixes[rngInt(1,#suffixes)].."-"..
			string.format("%04X", seed % 65536)

		return pers
	end

	local Personality = generatePersonality()
	ServerPlan.personality = Personality

	local function applyPersonalityToCFG(pers)
		CFG.BranchChance  = math.clamp(CFG.BranchChance * pers.branchMult,    0.05, 0.6)
		CFG.BlobChance    = math.clamp(CFG.BlobChance   * pers.blobFreq,      0.02, 0.4)
		CFG.SporeChance   = math.clamp(CFG.SporeChance  * pers.sporeFreq,     0.001,0.02)
		CFG.MemoryBias    = math.clamp(CFG.MemoryBias   * pers.playerFocus,   0.05, 0.7)
		CFG.NpcChaseSpeed = math.clamp(CFG.NpcChaseSpeed* pers.npcAggression, 0.5,  2.5)
		AUDIO_STEP        = math.clamp(AUDIO_STEP * pers.audioDecayMult,      0.03, 0.35)
	end
	applyPersonalityToCFG(Personality)

	local function mutateStrategy(pers)
		local stratList = {}
		for _, s in pairs(STRATEGIES) do table.insert(stratList, s) end

		local tries, newStrat = 0, nil
		repeat
			newStrat = stratList[rngInt(1,#stratList)]
			tries += 1
		until newStrat ~= pers.primaryStrat or tries > 10

		table.insert(pers.stratHistory, pers.primaryStrat)
		if #pers.stratHistory > 6 then table.remove(pers.stratHistory,1) end

		local oldStrat = pers.primaryStrat
		pers.primaryStrat = newStrat

		if newStrat == STRATEGIES.AGGRESSIVE then
			CFG.TickRate     = math.max(0.2, CFG.TickRate * 0.65)
			CFG.BranchChance = math.min(0.55, CFG.BranchChance * 1.4)
		elseif newStrat == STRATEGIES.PATIENT then
			CFG.TickRate      = CFG.TickRate * 1.3
			CFG.BlobChance    = math.min(0.35, CFG.BlobChance * 1.8)
			CFG.FruitCooldown = math.max(5, CFG.FruitCooldown * 0.6)
		elseif newStrat == STRATEGIES.TARGETED then
			CFG.MemoryBias   = math.min(0.8, CFG.MemoryBias * 1.6)
			CFG.PlayerRadius = math.min(12, CFG.PlayerRadius * 1.3)
		elseif newStrat == STRATEGIES.CHAOTIC then
			CFG.BranchChance = rngFloat(0.08, 0.55)
			CFG.StepSize     = rngFloat(1.0,  3.5)
			CFG.BlobChance   = rngFloat(0.05, 0.35)
		elseif newStrat == STRATEGIES.SURROUND then
			CFG.SpreadRadius = math.min(20, CFG.SpreadRadius * 1.5)
			CFG.RhizoChance  = math.min(0.15, CFG.RhizoChance * 2)
			CFG.RhizoStep    = math.max(2, CFG.RhizoStep * 0.75)
		elseif newStrat == STRATEGIES.VERTICAL then
			CFG.WallClimb       = true
			CFG.BlockClimbSpeed = math.max(0.15, CFG.BlockClimbSpeed * 0.5)
			CFG.SlopeRayLen     = CFG.SlopeRayLen * 1.4
		elseif newStrat == STRATEGIES.UNDERGROUND then
			CFG.RayDown    = math.min(60, CFG.RayDown * 1.5)
			CFG.SurfaceOff = CFG.SurfaceOff * 0.5
		end

		pers.strategyInterval = rngFloat(30,150) * pers.mutationRate

		print(string.format("[Pibby|IA] ◈ %s MUTA: %s → %s (próxima en %.0fs)",
			pers.name, oldStrat, newStrat, pers.strategyInterval))

		for _, pl in ipairs(Players:GetPlayers()) do
			screenMsg(pl, "[ MUTACIÓN DETECTADA ]", rN(), 2.5)
		end
	end

	function explorationBiasDir(pos)
		if not Personality then return nil end
		local bias  = Personality.expansionBias
		local drift = tick() * 0.008
		return Vector3.new(
			bias.X*math.cos(drift) - bias.Z*math.sin(drift),
			0,
			bias.X*math.sin(drift) + bias.Z*math.cos(drift)
		).Unit
	end

	local planAttackTimer = 0
	RunService.Heartbeat:Connect(function(dt)
		if Personality then
			Personality.strategyTimer += dt
			if Personality.strategyTimer >= Personality.strategyInterval then
				Personality.strategyTimer = 0
				mutateStrategy(Personality)
			end
		end
		if ServerPlan.scanComplete then
			planAttackTimer += dt
			local cadence = math.max(2, 8 - currentPhase*1.2)
			if planAttackTimer >= cadence then
				planAttackTimer = 0
				executeNextAttack()
			end
		end
	end)

	task.delay(3, function()
		local plan = scanServer()
		task.delay(1, function()
			for i, cp in ipairs(plan.chokePoints) do
				if i > 4 then break end
				task.delay(i*0.5, function()
					if not infectionReady then return end
					local gp, gn = castSurf(
						cp.pos+Vector3.new(0,4,0), Vector3.new(0,-1,0), CFG.RayDown)
					if gp then
						spawnWave(gp)
						print("[Pibby|Plan] ▶ Oleada → chokepoint (densidad: "..cp.density..")")
					end
				end)
			end
		end)

		print(string.format(
			"[Pibby|IA] ════ PERSONALIDAD GENERADA ════\n"..
				"  ID:                    %s\n"..
				"  Estrategia primaria:   %s\n"..
				"  Estrategia secundaria: %s\n"..
				"  Velocidad expansión:   %.2fx\n"..
				"  Bifurcación:           %.2fx\n"..
				"  Enfoque jugadores:     %.0f%%\n"..
				"  Agresión NPC:          %.2fx\n"..
				"  Decay audio:           %.2fx\n"..
				"  Paredes/Techos:        %s / %s\n"..
				"  Mutación cada:         %.0fs",
			Personality.name,
			Personality.primaryStrat, Personality.secondaryStrat,
			Personality.expansionSpeed, Personality.branchMult,
			Personality.playerFocus*100, Personality.npcAggression,
			Personality.audioDecayMult,
			tostring(Personality.favorWalls), tostring(Personality.favorCeilings),
			Personality.strategyInterval
			))
	end)

	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.17 (sin borrado de scripts)                          ║")
	print("║  ✦ Scripts detectados → portales de micelio, NO eliminados     ║")
	print("║  ✦ Audio progresivo: EQ + Reverb + PlaybackSpeed cada 5min     ║")
	print("║  ✦ Análisis de servidor: chokepoints, hubs, plan de ataque     ║")
	print("║  ✦ IA procedural: 7 estrategias mutantes, seed único           ║")
	print("╚══════════════════════════════════════════════════════════════════╝")

end)()
-- ════════════════════════════════════════════════════════════════════
--  v3.18 — GUI PROGRESIVA + IDEAS PROPIAS
--  ✦ GUIs del juego se corrompen cada 5 min igual que el audio
--  ✦ Pensamientos del micelio en el mundo 3D
--  ✦ Respuesta inmune falsa (zonas blancas que colapsan)
--  ✦ Autopistas de infección visibles
-- ════════════════════════════════════════════════════════════════════
;(function()

	-- ── UTILIDADES ───────────────────────────────────────────────────
	local rng18 = Random.new(tick() * 7919)
	local function r18f(a,b) return rng18:NextNumber(a,b) end
	local function r18i(a,b) return rng18:NextInteger(a,b) end

	-- Caracteres de corrupción por nivel
	local CORRUPT_SETS = {
		[1] = {"̈","̀","́","̂","̃","̄","̅","̆","̇"},         -- nivel 1: diacríticos sutiles
		[2] = {"█","▓","▒","░","▄","▀","■","□"},            -- nivel 2: bloques
		[3] = {"⚠","⛔","✗","✘","⁉","‽","¿","¡","§"},       -- nivel 3: símbolos
		[4] = {"̶","̷","̸","̵","̴","̳","̲","̱"},              -- nivel 4: tachado
		[5] = {"N","U","L","L","E","R","R"," ","0","1"},    -- nivel 5: error puro
	}

	local GLITCH_WORDS = {
		"ERROR","NULL","VOID","FEED","GROW","MINE","THEY",
		"COME","LATE","LOST","HELP","DARK","OVER","OURS",
		"SOON","FEED","0x00","NaN","NIL","???","---","///",
	}

	-- Mezcla texto con corrupción según nivel (0=limpio, 5=irreconocible)
	local function corruptGuiText(original, level)
		if level <= 0 then return original end
		local rate = math.clamp(level * 0.15, 0.05, 0.95)
		local chars = CORRUPT_SETS[math.min(level, 5)]
		local result = {}

		for i = 1, #original do
			local c = original:sub(i,i)
			if c == " " and r18f(0,1) < rate * 0.4 then
				-- Inserta palabra de error en espacios
				table.insert(result, " "..GLITCH_WORDS[r18i(1,#GLITCH_WORDS)].." ")
			elseif r18f(0,1) < rate then
				table.insert(result, chars[r18i(1,#chars)])
			else
				-- A veces invierte mayúscula/minúscula
				if r18f(0,1) < rate*0.3 then
					table.insert(result, r18f(0,1)<0.5 and c:upper() or c:lower())
				else
					table.insert(result, c)
				end
			end
		end

		-- Nivel 5: reemplaza todo el texto con error puro
		if level >= 5 and r18f(0,1) < 0.5 then
			return GLITCH_WORDS[r18i(1,#GLITCH_WORDS)]
				.." "..GLITCH_WORDS[r18i(1,#GLITCH_WORDS)]
				.."_"..string.format("%04X", r18i(0,65535))
		end

		return table.concat(result)
	end

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 1: CORRUPCIÓN PROGRESIVA DE GUIs
	--  Igual que el audio: cada 5 minutos sube un nivel (0→5).
	--  Afecta TextLabels, TextButtons, ImageLabels, Frames.
	--  Los GUIs propios del virus (nombre __Pibby*) se ignoran.
	-- ════════════════════════════════════════════════════════════════

	local GUI_INTERVAL   = 300     -- segundos entre ticks
	local guiDecayLevel  = 0       -- nivel actual (0=limpio, 5=irreconocible)
	local guiDecayTimer  = 0
	local guiRegistry    = {}      -- GuiObject → {origProps...}
	local guiScanned     = false

	-- Recolecta TODOS los GuiObjects del juego
	local function collectAllGuis()
		guiScanned = true
		local function scanGui(root)
			pcall(function()
				for _, obj in ipairs(root:GetDescendants()) do
					-- Ignora GUIs del virus
					local sg = obj:FindFirstAncestorOfClass("ScreenGui")
					if sg and sg.Name:sub(1,7)=="__Pibby" then continue end

					if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
						if not guiRegistry[obj] then
							guiRegistry[obj] = {
								origText      = obj.Text,
								origTextColor = obj.TextColor3,
								origBGColor   = obj.BackgroundColor3,
								origBGTrans   = obj.BackgroundTransparency,
								origTextSize  = obj.TextSize,
								origFont      = obj.Font,
								decayApplied  = 0,
								type          = "text",
							}
						end

					elseif obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
						if not guiRegistry[obj] then
							guiRegistry[obj] = {
								origImage     = obj.Image,
								origImageColor= obj.ImageColor3,
								origBGColor   = obj.BackgroundColor3,
								origBGTrans   = obj.BackgroundTransparency,
								decayApplied  = 0,
								type          = "image",
							}
						end

					elseif obj:IsA("Frame") then
						if not guiRegistry[obj] then
							guiRegistry[obj] = {
								origBGColor   = obj.BackgroundColor3,
								origBGTrans   = obj.BackgroundTransparency,
								origBorderCol = obj.BorderColor3,
								decayApplied  = 0,
								type          = "frame",
							}
						end
					end
				end
			end)
		end

		-- Escanea StarterGui, PlayerGui de todos los jugadores
		pcall(function() scanGui(game:GetService("StarterGui")) end)
		for _, pl in ipairs(Players:GetPlayers()) do
			pcall(function()
				local pg = pl:FindFirstChild("PlayerGui")
				if pg then scanGui(pg) end
			end)
		end
	end

	-- Aplica un tick de corrupción a todos los GUIs registrados
	local function applyGuiDecayTick()
		guiDecayLevel += 1
		if not guiScanned then collectAllGuis() end

		-- También recolecta GUIs nuevos que aparecieron
		collectAllGuis()

		local corrupted = 0
		for obj, data in pairs(guiRegistry) do
			if not (obj and obj.Parent) then
				guiRegistry[obj] = nil
				continue
			end

			-- Salta el objeto si ya está en el nivel actual
			if data.decayApplied >= guiDecayLevel then continue end
			data.decayApplied = guiDecayLevel

			task.spawn(function()
				pcall(function()
					if data.type == "text" then
						-- ── Texto ──────────────────────────────────────────
						-- Corrompe el texto progresivamente
						obj.Text = corruptGuiText(data.origText, guiDecayLevel)

						-- Color del texto: se va volviendo morado/negro
						local targetCol = lerpC(
							data.origTextColor,
							guiDecayLevel >= 4 and rN() or Color3.fromRGB(
								180 - guiDecayLevel*30,
								0,
								200 - guiDecayLevel*20
							),
							math.clamp(guiDecayLevel * 0.18, 0, 1)
						)
						TweenService:Create(obj, TweenInfo.new(1.5), {TextColor3=targetCol}):Play()

						-- Tamaño del texto: fluctúa levemente
						if guiDecayLevel >= 2 then
							local sizeJitter = data.origTextSize * (1 + r18f(-0.08,0.12)*guiDecayLevel*0.15)
							obj.TextSize = math.clamp(sizeJitter, 6, 100)
						end

						-- Fondo: oscurece con el nivel
						if guiDecayLevel >= 2 and obj.BackgroundTransparency < 0.95 then
							local bgTarget = lerpC(
								data.origBGColor,
								Color3.fromRGB(4, 0, 12),
								math.clamp(guiDecayLevel * 0.15, 0, 0.85)
							)
							TweenService:Create(obj, TweenInfo.new(2), {BackgroundColor3=bgTarget}):Play()
						end

						-- Nivel 3+: fuente cambia a Code (monoespaciado de error)
						if guiDecayLevel >= 3 then
							obj.Font = Enum.Font.Code
						end

						-- Nivel 4+: parpadeo periódico del texto
						if guiDecayLevel >= 4 and not obj:GetAttribute("PibbyGlitchActive") then
							obj:SetAttribute("PibbyGlitchActive", true)
							task.spawn(function()
								while obj and obj.Parent and guiDecayLevel >= 4 do
									task.wait(r18f(0.5, 3.5))
									if not (obj and obj.Parent) then break end
									-- Parpadeo rápido
									for _ = 1, r18i(1,4) do
										if not (obj and obj.Parent) then break end
										obj.Text = corruptGuiText(data.origText, 5)
										obj.TextColor3 = rN()
										task.wait(0.03 + r18f(0,0.08))
										obj.Text = corruptGuiText(data.origText, guiDecayLevel)
										task.wait(0.03 + r18f(0,0.06))
									end
								end
							end)
						end

					elseif data.type == "image" then
						-- ── Imagen ─────────────────────────────────────────
						-- Color de imagen: se tiñe de morado
						local imgTarget = lerpC(
							data.origImageColor,
							Color3.fromRGB(120, 0, 180),
							math.clamp(guiDecayLevel * 0.18, 0, 1)
						)
						TweenService:Create(obj, TweenInfo.new(1.8), {ImageColor3=imgTarget}):Play()

						-- Nivel 3+: transparencia fluctuante
						if guiDecayLevel >= 3 then
							task.spawn(function()
								while obj and obj.Parent and guiDecayLevel >= 3 do
									task.wait(r18f(1.5, 6))
									if not (obj and obj.Parent) then break end
									TweenService:Create(obj, TweenInfo.new(0.1), {ImageTransparency=r18f(0.3,0.8)}):Play()
									task.wait(0.12)
									if obj and obj.Parent then
										TweenService:Create(obj, TweenInfo.new(0.25), {ImageTransparency=0}):Play()
									end
								end
							end)
						end

						-- Nivel 5: fondo negro
						if guiDecayLevel >= 5 then
							TweenService:Create(obj, TweenInfo.new(1), {
								BackgroundColor3 = Color3.fromRGB(2,0,6),
								BackgroundTransparency = 0
							}):Play()
						end

					elseif data.type == "frame" then
						-- ── Frame ──────────────────────────────────────────
						local frameTarget = lerpC(
							data.origBGColor,
							Color3.fromRGB(6, 0, 18),
							math.clamp(guiDecayLevel * 0.15, 0, 0.9)
						)
						TweenService:Create(obj, TweenInfo.new(2), {BackgroundColor3=frameTarget}):Play()

						-- Nivel 2+: borde corrupto
						if guiDecayLevel >= 2 then
							TweenService:Create(obj, TweenInfo.new(1), {
								BorderColor3 = guiDecayLevel >= 4 and rN() or Color3.fromRGB(120,0,200)
							}):Play()
						end

						-- Nivel 4+: frame "tiembla" levemente
						if guiDecayLevel >= 4 and not obj:GetAttribute("PibbyShakeActive") then
							obj:SetAttribute("PibbyShakeActive", true)
							local origPos = obj.Position
							task.spawn(function()
								while obj and obj.Parent and guiDecayLevel >= 4 do
									task.wait(r18f(2, 8))
									if not (obj and obj.Parent) then break end
									local shakeX = r18f(-3, 3) * guiDecayLevel
									local shakeY = r18f(-3, 3) * guiDecayLevel
									TweenService:Create(obj, TweenInfo.new(0.05), {
										Position = UDim2.new(
											origPos.X.Scale, origPos.X.Offset + shakeX,
											origPos.Y.Scale, origPos.Y.Offset + shakeY
										)
									}):Play()
									task.wait(0.06)
									if obj and obj.Parent then
										TweenService:Create(obj, TweenInfo.new(0.08), {Position=origPos}):Play()
									end
								end
							end)
						end
					end
					corrupted += 1
				end)
			end)
		end

		print(string.format("[Pibby|GUI] Tick %d — %d elementos corrompidos",
			guiDecayLevel, corrupted))

		-- Mensajes de milestone
		local msgs = {
			[1]="[ UI INESTABLE ]",
			[2]="[ INTERFAZ CORRUPTA ]",
			[3]="[ HUD CONSUMIDO ]",
			[4]="[ REALIDAD.EXE ERROR ]",
			[5]="[ NO HAY INTERFAZ ]",
		}
		if msgs[guiDecayLevel] then
			for _, pl in ipairs(Players:GetPlayers()) do
				screenMsg(pl, msgs[guiDecayLevel], rN(), 3)
			end
		end
	end

	-- Heartbeat del sistema de GUIs
	RunService.Heartbeat:Connect(function(dt)
		guiDecayTimer += dt
		if guiDecayTimer >= GUI_INTERVAL then
			guiDecayTimer = 0
			applyGuiDecayTick()
		end
	end)

	-- Recolecta GUIs cuando un jugador entra
	Players.PlayerAdded:Connect(function(pl)
		pl.CharacterAdded:Connect(function()
			task.delay(2, collectAllGuis)
		end)
	end)

	-- Recolección inicial
	task.delay(4, collectAllGuis)

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 2: PENSAMIENTOS DEL MICELIO (IDEA PROPIA)
	--  Fragmentos de "consciencia" flotan en el mundo 3D.
	--  El tono cambia según la fase: confuso→lúcido→amenazante.
	-- ════════════════════════════════════════════════════════════════

	local THOUGHTS_BY_PHASE = {
		[0] = {
			"...hambre","...crecer","...expandir","...más",
			"...oscuro aquí","...qué es esto","...moverse",
		},
		[1] = {
			"siento el suelo","las paredes me hablan",
			"hay calor cerca","me extiendo","todo es mío",
			"la luz duele","el frío es bueno","absorber",
		},
		[2] = {
			"puedo sentirlos","sus pasos vibran",
			"no pueden esconderse","el mapa me pertenece",
			"cada grieta es un camino","crezco mientras duermen",
			"pronto no quedará nada","recuerdo cada ruta",
		},
		[3] = {
			"ya casi soy el servidor","sus scripts son míos",
			"la realidad se dobla bien","vengan con nosotros",
			"¿por qué resisten?","el hambre no para",
			"somos muchos ahora","el suelo tiene memoria",
		},
		[4] = {
			"YO SOY EL SERVIDOR","no hay afuera",
			"sus cuerpos son nutrientes","la resistencia es nutriente",
			"TODO ES MICELIO","olvidaron que existían",
			"el juego terminó hace rato","solo queda absorber",
		},
		[5] = {
			"","","CONSUME","CONSUME","somos","todo",
			"no hay jugadores","no hay mapa","no hay nada",
			"solo nosotros","solo nosotros","solo nosotros",
		},
	}

	local thoughtTimer = 0

	local function emitThought()
		if #blobReg == 0 then return end
		if partCount >= CFG.MaxParts - 2 then return end

		-- Elige una posición aleatoria del micelio
		local b = blobReg[math.random(#blobReg)]
		if not b then return end

		local phase = math.clamp(currentPhase, 0, 5)
		local pool  = THOUGHTS_BY_PHASE[phase]
		if not pool or #pool == 0 then return end
		local thought = pool[r18i(1,#pool)]
		if thought == "" then return end

		-- Crea la Part anclada como soporte del billboard
		local anchor = Instance.new("Part")
		anchor.Anchored=true; anchor.CanCollide=false; anchor.Transparency=1
		anchor.Size=Vector3.new(0.1,0.1,0.1)
		anchor.Position = b.pos + Vector3.new(
			r18f(-8,8), r18f(1.5,4.5), r18f(-8,8))
		anchor.Parent = folder; partCount+=1

		local bb = Instance.new("BillboardGui")
		bb.Size = UDim2.new(0, 160, 0, 30)
		bb.AlwaysOnTop = false
		bb.StudsOffset = Vector3.new(0,0,0)
		bb.Parent = anchor

		local lbl = Instance.new("TextLabel")
		lbl.Size=UDim2.new(1,0,1,0)
		lbl.BackgroundTransparency=1
		lbl.Text = thought
		lbl.TextColor3 = phase >= 3 and rN() or lerpC(
			Color3.fromRGB(200,180,240),
			Color3.fromRGB(180,0,255),
			phase/5
		)
		lbl.TextSize = 13 + phase*2
		lbl.Font = phase >= 4 and Enum.Font.GothamBold or Enum.Font.Code
		lbl.TextStrokeTransparency = 0.5
		lbl.TextTransparency = 1
		lbl.Parent = bb

		-- Aparece y flota
		local lifetime = r18f(4, 9) - phase*0.3
		TweenService:Create(lbl, TweenInfo.new(0.6), {TextTransparency=0.1}):Play()
		TweenService:Create(anchor, TweenInfo.new(lifetime, Enum.EasingStyle.Sine), {
			Position = anchor.Position + Vector3.new(r18f(-3,3), r18f(1,3), r18f(-3,3))
		}):Play()

		-- Parpadeo en fases altas
		if phase >= 3 then
			task.spawn(function()
				local t0 = tick()
				while anchor and anchor.Parent and tick()-t0 < lifetime-0.8 do
					task.wait(r18f(0.4, 1.8))
					if not (lbl and lbl.Parent) then break end
					lbl.TextTransparency = 0.85
					task.wait(0.04)
					if lbl and lbl.Parent then lbl.TextTransparency = 0.1 end
				end
			end)
		end

		task.delay(lifetime, function()
			TweenService:Create(lbl, TweenInfo.new(0.8), {TextTransparency=1}):Play()
			task.delay(0.9, function()
				if anchor then anchor:Destroy(); partCount=math.max(0,partCount-1) end
			end)
		end)
	end

	RunService.Heartbeat:Connect(function(dt)
		thoughtTimer += dt
		local interval = math.max(4, 22 - currentPhase*3.5)
		if thoughtTimer >= interval then
			thoughtTimer = 0
			emitThought()
		end
	end)

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 3: RESPUESTA INMUNE FALSA (IDEA PROPIA)
	--  El mapa genera zonas blancas que "resisten" el micelio
	--  durante unos segundos... luego colapsan dramáticamente.
	-- ════════════════════════════════════════════════════════════════

	local immuneZones    = {}   -- lista de {center, radius, parts, timer}
	local immuneScanT    = 0
	local IMMUNE_MAX     = 4    -- máximo de zonas activas
	local IMMUNE_RESIST  = 12   -- segundos que "resiste" antes de colapsar

	local function createImmuneZone(pos)
		if #immuneZones >= IMMUNE_MAX then return end
		if partCount >= CFG.MaxParts - 6 then return end

		local radius = r18f(6, 14)
		local zone = {center=pos, radius=radius, parts={}, timer=0, collapsing=false}

		-- Barrera visual: anillo de partes blancas
		local numPillars = r18i(5,9)
		for i = 1, numPillars do
			if partCount >= CFG.MaxParts then break end
			local angle = (i/numPillars)*math.pi*2
			local px = pos.X + math.cos(angle)*radius
			local pz = pos.Z + math.sin(angle)*radius
			local gp, gn = castSurf(
				Vector3.new(px, pos.Y+4, pz), Vector3.new(0,-1,0), 12)
			if not gp then continue end

			local pillar = Instance.new("Part")
			pillar.Anchored=true; pillar.CanCollide=false; pillar.CastShadow=false
			pillar.Size=Vector3.new(0.45, 4+r18f(0,3), 0.45)
			pillar.CFrame=CFrame.new(gp+gn*2)
			pillar.Color=Color3.fromRGB(240,240,255)
			pillar.Material=Enum.Material.Neon
			pillar.Transparency=1; pillar.Parent=folder; partCount+=1
			TweenService:Create(pillar, TweenInfo.new(0.8,Enum.EasingStyle.Back,Enum.EasingDirection.Out),
				{Transparency=0.08}):Play()

			local li=Instance.new("PointLight")
			li.Color=Color3.fromRGB(180,200,255); li.Range=8; li.Brightness=2; li.Parent=pillar

			table.insert(zone.parts, {part=pillar, light=li, origPos=pillar.Position})
		end

		-- Suelo blanco dentro de la zona
		if partCount < CFG.MaxParts then
			local floor=Instance.new("Part")
			floor.Anchored=true; floor.CanCollide=false; floor.CastShadow=false
			floor.Shape=Enum.PartType.Ball
			floor.Size=Vector3.new(radius*2, 0.2, radius*2)
			floor.CFrame=CFrame.new(pos+Vector3.new(0,0.15,0))
			floor.Color=Color3.fromRGB(220,220,255); floor.Material=Enum.Material.Neon
			floor.Transparency=1; floor.Parent=folder; partCount+=1
			TweenService:Create(floor,TweenInfo.new(1),{Transparency=0.65}):Play()
			table.insert(zone.parts, {part=floor, light=nil, origPos=floor.Position})
		end

		-- Mensaje
		for _, pl in ipairs(Players:GetPlayers()) do
			screenMsg(pl,"[ ZONA RESISTENTE DETECTADA ]",Color3.fromRGB(200,220,255),2.5)
		end
		print(string.format("[Pibby|Inmune] Zona de resistencia en (%.0f,%.0f,%.0f) radio %.1f",
			pos.X,pos.Y,pos.Z,radius))

		table.insert(immuneZones, zone)
	end

	local function collapseImmuneZone(zone)
		zone.collapsing = true
		print("[Pibby|Inmune] ⚠ Zona colapsando!")

		for _, pl in ipairs(Players:GetPlayers()) do
			screenMsg(pl,"[ RESISTENCIA FALLIDA ]",Color3.fromRGB(255,80,0),2.5)
		end

		-- Colapso dramático: los pilares cambian a neon corrupto
		for i, pd in ipairs(zone.parts) do
			local p = pd.part
			if not (p and p.Parent) then continue end
			task.delay(i*0.08, function()
				if not (p and p.Parent) then return end
				-- Glitch rápido
				for _ = 1, 5 do
					if not (p and p.Parent) then break end
					p.Color = rN(); p.Material=Enum.Material.Neon
					task.wait(0.04)
					if p and p.Parent then p.Color=rD(); p.Material=Enum.Material.SmoothPlastic end
					task.wait(0.04)
				end
				-- Explota en micelio
				if p and p.Parent then
					spawnFlash(p.Position,Vector3.new(0,1,0),0.8)
					p:Destroy(); partCount=math.max(0,partCount-1)
				end
			end)
		end

		-- Oleada de micelio desde el colapso
		task.delay(0.8, function()
			local gp,gn=castSurf(zone.center+Vector3.new(0,3,0),Vector3.new(0,-1,0),CFG.RayDown)
			if gp then
				spawnBlob(gp,gn,3+r18f(0,2),0.3)
				for i=1,6 do
					local a=(i/6)*math.pi*2
					local l=math.random(CFG.LifeMin,CFG.LifeMax)
					table.insert(nodes,{pos=gp,
						dir=Vector3.new(math.cos(a),0,math.sin(a)),
						normal=gn,life=l,maxLife=l,depth=0,age=0,nodeType="normal"})
				end
				spawnFlash(gp,gn,2.5)
			end
		end)
	end

	local function tickImmuneSystem(dt)
		immuneScanT += dt

		-- Crea zonas periódicamente (solo fase 1+)
		if currentPhase >= 1 and immuneScanT >= r18f(35,70) then
			immuneScanT = 0
			if #blobReg > 0 and #immuneZones < IMMUNE_MAX then
				local b = blobReg[math.random(#blobReg)]
				createImmuneZone(b.pos + Vector3.new(r18f(-25,25),0,r18f(-25,25)))
			end
		end

		-- Actualiza zonas activas
		local dead={}
		for idx,zone in ipairs(immuneZones) do
			if zone.collapsing then
				table.insert(dead,idx); continue
			end
			zone.timer += dt

			-- Pulso de resistencia (las partes parpadean blanco)
			if math.floor(zone.timer*2)>math.floor((zone.timer-dt)*2) then
				for _,pd in ipairs(zone.parts) do
					if pd.light then
						TweenService:Create(pd.light,TweenInfo.new(0.25),
							{Brightness=3.5,Range=12}):Play()
						task.delay(0.3,function()
							if pd.light and pd.light.Parent then
								TweenService:Create(pd.light,TweenInfo.new(0.4),
									{Brightness=2,Range=8}):Play()
							end
						end)
					end
				end
			end

			-- Fuerza colapso cuando el micelio invade la zona
			local invaded = false
			for _,b in ipairs(blobReg) do
				if (b.pos-zone.center).Magnitude < zone.radius * 0.8 then
					invaded=true; break
				end
			end

			-- Colapsa por invasión O por tiempo agotado
			if invaded or zone.timer >= IMMUNE_RESIST then
				collapseImmuneZone(zone)
			end
		end
		for i=#dead,1,-1 do table.remove(immuneZones,dead[i]) end
	end

	RunService.Heartbeat:Connect(function(dt)
		tickImmuneSystem(dt)
	end)

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 4: AUTOPISTAS DE INFECCIÓN (IDEA PROPIA)
	--  Las rutas más usadas del micelio se refuerzan visualmente
	--  con rizomorfos gruesos y brillantes → "carreteras" del hongo.
	-- ════════════════════════════════════════════════════════════════

	local HIGHWAY_MIN_HEAT  = 8    -- calor mínimo para formar autopista
	local HIGHWAY_WIDTH     = 0.55 -- ancho del tendril de autopista
	local highwayBuiltT     = 0
	local builtHighways     = {}   -- set de posiciones ya conectadas

	local function buildHighwaySegment(posA, posB, normal)
		if partCount >= CFG.MaxParts - 2 then return end
		local len = (posB-posA).Magnitude
		if len < 0.5 or len > 20 then return end

		-- Tendril grueso y brillante
		local hw = Instance.new("Part")
		hw.Anchored=true; hw.CanCollide=false; hw.CastShadow=false
		hw.Size=Vector3.new(HIGHWAY_WIDTH, HIGHWAY_WIDTH*0.45, len)
		local look=(posB-posA).Unit
		local right=normal:Cross(look); right=right.Magnitude<0.001 and Vector3.new(1,0,0) or right.Unit
		hw.CFrame=CFrame.fromMatrix((posA+posB)/2, right, look:Cross(right).Unit)

		-- Color: negro-morado muy oscuro con leve brillo
		local isNeon = r18f(0,1) < 0.18
		hw.Color = isNeon and rN() or Color3.fromRGB(12,0,28)
		hw.Material = isNeon and Enum.Material.Neon or Enum.Material.SmoothPlastic
		hw.Transparency=1; hw.Parent=folder; partCount+=1

		TweenService:Create(hw,TweenInfo.new(0.55),{Transparency=isNeon and 0 or 0.04}):Play()

		-- Luz de autopista: bioluminiscencia tenue
		if not isNeon then
			local li=Instance.new("PointLight")
			li.Color=Color3.fromRGB(80,0,160); li.Range=HIGHWAY_WIDTH*8; li.Brightness=0.55; li.Parent=hw
		end

		-- Pulso periódico de "tráfico" (como un impulso eléctrico que viaja)
		task.spawn(function()
			while hw and hw.Parent do
				task.wait(r18f(3,10))
				if not(hw and hw.Parent) then break end
				local oc,om=hw.Color,hw.Material
				hw.Color=Color3.fromRGB(140,0,255); hw.Material=Enum.Material.Neon
				task.wait(0.04)
				if hw and hw.Parent then
					TweenService:Create(hw,TweenInfo.new(0.4),{Color=oc}):Play()
					hw.Material=om
				end
			end
		end)
	end

	local function tickHighways(dt)
		highwayBuiltT += dt
		if highwayBuiltT < 8 then return end
		highwayBuiltT = 0

		-- Usa la memoria de rutas (pathMemory del v3.7) si existe
		-- Si no, usa blobReg como proxy
		if not pathMemory then return end

		-- Filtra puntos de calor alto
		local hotSpots = {}
		for _, m in ipairs(pathMemory) do
			if m.heat >= HIGHWAY_MIN_HEAT then
				table.insert(hotSpots, m)
			end
		end
		if #hotSpots < 2 then return end

		-- Conecta los pares de hotspots más cercanos con autopistas
		table.sort(hotSpots, function(a,b) return a.heat > b.heat end)
		local maxConnect = math.min(4 + currentPhase, #hotSpots)

		for i = 1, maxConnect do
			if i >= #hotSpots then break end
			local a = hotSpots[i]
			local b = hotSpots[i+1]

			-- Clave única para evitar duplicados
			local key = string.format("%.0f_%.0f_%.0f:%.0f_%.0f_%.0f",
				a.pos.X,a.pos.Y,a.pos.Z,b.pos.X,b.pos.Y,b.pos.Z)
			if builtHighways[key] then continue end
			builtHighways[key] = true

			local dist = (a.pos - b.pos).Magnitude
			if dist > 25 or dist < 1 then continue end

			-- Construye la autopista en segmentos
			local segs = math.ceil(dist / 3)
			for s = 1, segs do
				local frac0 = (s-1)/segs
				local frac1 = s/segs
				local p0 = a.pos + (b.pos-a.pos)*frac0
				local p1 = a.pos + (b.pos-a.pos)*frac1
				-- Aterriza ambos puntos en la superficie
				local gp0,gn0=castSurf(p0+Vector3.new(0,2,0),Vector3.new(0,-1,0),8)
				local gp1,gn1=castSurf(p1+Vector3.new(0,2,0),Vector3.new(0,-1,0),8)
				if gp0 and gp1 then
					buildHighwaySegment(gp0, gp1, (gn0+gn1).Unit)
				end
			end
		end
	end

	RunService.Heartbeat:Connect(function(dt)
		tickHighways(dt)
	end)

	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.18                                                    ║")
	print("║  ✦ GUIs PROGRESIVAS: texto/imágenes/frames se corrompen        ║")
	print("║    cada 5min — parpadeo, fuente Code, color morado, shake       ║")
	print("║    nivel 5 = completamente irreconocible                        ║")
	print("║  ✦ PENSAMIENTOS DEL MICELIO: fragmentos de consciencia         ║")
	print("║    flotan en el mundo, tono cambia con la fase                  ║")
	print("║  ✦ RESPUESTA INMUNE FALSA: zonas blancas que resisten          ║")
	print("║    unos segundos antes de colapsar en oleada de micelio         ║")
	print("║  ✦ AUTOPISTAS DE INFECCIÓN: rutas calientes se refuerzan       ║")
	print("║    con tendrils gruesos y pulsos de tráfico visibles            ║")
	print("╚══════════════════════════════════════════════════════════════════╝")

end)()
-- ════════════════════════════════════════════════════════════════════
--  v3.19 — TERRENO + BLOQUEO ESTRATÉGICO + FRENTES + ZONAS SEGURAS
-- ════════════════════════════════════════════════════════════════════
;(function()

	local rng19 = Random.new(tick() * 6271)
	local function r19f(a,b) return rng19:NextNumber(a,b) end
	local function r19i(a,b) return rng19:NextInteger(a,b) end

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 1: DETECCIÓN Y ADAPTACIÓN A TERRAIN
	--  Si el mapa usa Roblox Terrain en vez de bloques,
	--  el micelio se adapta: raycast contra Terrain, muestrea
	--  puntos de superficie y lanza oleadas desde ahí.
	-- ════════════════════════════════════════════════════════════════

	local Terrain       = workspace:FindFirstChildOfClass("Terrain")
	local terrainMode   = false   -- se activa si detectamos que hay más terrain que partes
	local terrainScanT  = 0
	local terrainWaveT  = 0
	local TERRAIN_SAMPLE_RADIUS = 120
	local TERRAIN_WAVE_INTERVAL = 18

	-- Comprueba si el mapa es principalmente Terrain
	local function detectTerrainMap()
		if not Terrain then return false end
		-- Cuenta BaseParts ancladas (excluye folder del virus)
		local anchoredCount = 0
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("BasePart")
				and obj.Anchored
				and not obj:FindFirstAncestor("PibbyFolder")
				and obj.Name ~= "Baseplate"
				and obj ~= Terrain then
				anchoredCount += 1
				if anchoredCount >= 12 then return false end  -- hay suficientes bloques
			end
		end
		-- Menos de 12 bloques anclados → probablemente es Terrain puro
		return true
	end

	-- Muestrea N puntos de superficie en el Terrain usando RaycastParams
	-- que SÍ incluyen al Terrain (rpMain excluye folder pero no Terrain)
	local rpTerrain = RaycastParams.new()
	rpTerrain.FilterType = Enum.RaycastFilterType.Include
	rpTerrain.FilterDescendantsInstances = Terrain and {Terrain} or {}

	local function sampleTerrainSurface(origin, radius, numSamples)
		local points = {}
		local attempts = 0
		while #points < numSamples and attempts < numSamples * 6 do
			attempts += 1
			local angle  = r19f(0, math.pi*2)
			local dist   = r19f(5, radius)
			local testX  = origin.X + math.cos(angle)*dist
			local testZ  = origin.Z + math.sin(angle)*dist
			local startY = origin.Y + 60

			local r = workspace:Raycast(
				Vector3.new(testX, startY, testZ),
				Vector3.new(0,-1,0)*120,
				rpTerrain
			)
			if r then
				-- Acepta si la normal es mayormente vertical (no pared)
				if r.Normal.Y > 0.35 then
					table.insert(points, {
						pos    = r.Position + r.Normal*CFG.SurfaceOff,
						normal = r.Normal
					})
				end
			end
		end
		return points
	end

	-- Override de castSurf para que también haga raycast contra Terrain
	local _v319CastSurf = castSurf
	function castSurf(pos, dir, len, p)
		-- Intento normal (bloques)
		local sp, sn, si = _v319CastSurf(pos, dir, len, p)
		if sp then return sp, sn, si end

		-- Si no encontró nada y hay Terrain, prueba contra él
		if Terrain then
			local r = workspace:Raycast(
				pos - dir*1.2,
				dir*(len or CFG.RayDown),
				rpTerrain
			)
			if r then
				return r.Position + r.Normal*CFG.SurfaceOff, r.Normal, r.Instance
			end
		end
		return nil, nil, nil
	end

	-- Override de nextSurf para Terrain: si el intento normal falla,
	-- hace un sondeo directo contra Terrain en 5 direcciones
	local _v319NextSurf = nextSurf
	function nextSurf(from, move, sn, stepOvr)
		local sp, sn2, flat = _v319NextSurf(from, move, sn, stepOvr)
		if sp then return sp, sn2, flat end

		if not Terrain then return nil, nil, flat end

		local step = stepOvr or CFG.StepSize
		flat = flat or (move - sn*move:Dot(sn))
		flat = flat.Magnitude < 0.001 and move or flat.Unit

		-- Barrido de 5 rayos contra Terrain
		for _, ang in ipairs({0, -0.4, 0.4, -0.8, 0.8}) do
			local testDir = rotXZ(flat, ang)
			local probe   = from + testDir*step + sn*(step*0.7)
			local r = workspace:Raycast(probe, -sn*(step*2.5), rpTerrain)
			if r and r.Normal.Y > -0.1 then
				return r.Position + r.Normal*CFG.SurfaceOff, r.Normal, testDir
			end
		end

		-- Caída libre sobre Terrain
		local dr = workspace:Raycast(
			from + flat*step + sn*0.3,
			Vector3.new(0,-1,0)*CFG.RayDown,
			rpTerrain
		)
		if dr then
			return dr.Position + dr.Normal*CFG.SurfaceOff, dr.Normal, flat
		end

		return nil, nil, flat
	end

	-- Heartbeat: detecta Terrain al inicio y lanza oleadas periódicas
	local terrainInitDone = false
	RunService.Heartbeat:Connect(function(dt)
		-- Detección inicial (solo una vez, 5s después del arranque)
		terrainScanT += dt
		if not terrainInitDone and terrainScanT >= 5 then
			terrainInitDone = true
			terrainMode = detectTerrainMap()
			if terrainMode then
				print("[Pibby|Terrain] ⛰  Modo Terrain activado — adaptando sistemas")
				-- Ajuste de CFG para Terrain (superficies más irregulares)
				CFG.SurfaceOff  = 0.12   -- offset mayor para no hundirnos
				CFG.RayDown     = 55     -- mayor alcance vertical
				CFG.StepSize    = 2.0    -- pasos un poco más grandes
				CFG.MinDist     = 2.0    -- distancia mínima mayor
				-- Actualiza rpTerrain con el Terrain real
				if Terrain then
					rpTerrain.FilterDescendantsInstances = {Terrain}
				end
			else
				print("[Pibby|Terrain] 🧱 Modo Bloques — sin cambios")
			end
		end

		-- Oleadas periódicas en Terrain: brotan desde puntos muestreados
		if terrainMode and infectionReady then
			terrainWaveT += dt
			if terrainWaveT >= TERRAIN_WAVE_INTERVAL then
				terrainWaveT = 0
				local origin = getOrigin()
				local pts = sampleTerrainSurface(origin, TERRAIN_SAMPLE_RADIUS, 5)
				for _, pt in ipairs(pts) do
					if partCount >= CFG.MaxParts or #nodes >= CFG.MaxNodes then break end
					-- Brota micelio en cada punto muestreado
					spawnBlob(pt.pos, pt.normal, 2 + r19f(0,2), 0.08)
					markOcc(pt.pos)
					local rays = r19i(4, 7)
					for i = 1, rays do
						local a = (i/rays)*math.pi*2 + (r19f(0,1)-0.5)*0.5
						local l = math.random(CFG.LifeMin, CFG.LifeMax)
						table.insert(nodes, {
							pos=pt.pos,
							dir=Vector3.new(math.cos(a),0,math.sin(a)),
							normal=pt.normal, life=l, maxLife=l,
							depth=0, age=0, nodeType="normal"
						})
					end
				end
				if #pts > 0 then
					print(string.format("[Pibby|Terrain] 🌿 %d oleadas desde superficie de Terrain", #pts))
				end
			end
		end
	end)

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 2: BLOQUEO ESTRATÉGICO
	--  El micelio aprende por dónde corren los jugadores y, con
	--  suficiente información, envía nodos a bloquear esas rutas
	--  ANTES de que el jugador llegue ahí.
	-- ════════════════════════════════════════════════════════════════

	-- Historial de posiciones por jugador: {pos, time}
	local playerRouteHistory = {}  -- player → lista de {pos, time}
	local ROUTE_HISTORY_MAX  = 40  -- puntos por jugador
	local ROUTE_SAMPLE_DIST  = 4   -- mínima distancia entre muestras
	local ROUTE_DECAY        = 30  -- segundos antes de olvidar un punto

	-- Segmentos de ruta "caliente" aprendidos
	local learnedRoutes = {}   -- lista de {from, to, heat, lastSeen}
	local ROUTE_HEAT_MAX = 12

	local routeUpdateT  = 0
	local blockDecideT  = 0
	local BLOCK_COOLDOWN = 20   -- segundos mínimos entre bloqueos
	local lastBlockTime  = 0

	-- Registra la posición actual de cada jugador en su historial
	local function updatePlayerRoutes(dt)
		routeUpdateT += dt
		if routeUpdateT < 0.8 then return end
		routeUpdateT = 0

		local t = tick()
		for _, pl in ipairs(Players:GetPlayers()) do
			local ch = pl.Character
			if not ch then continue end
			local hrp = ch:FindFirstChild("HumanoidRootPart")
			if not hrp then continue end

			if not playerRouteHistory[pl] then
				playerRouteHistory[pl] = {}
			end
			local hist = playerRouteHistory[pl]
			local pos  = hrp.Position

			-- Solo añade si se movió suficiente desde el último punto
			if #hist == 0 or (hist[#hist].pos - pos).Magnitude >= ROUTE_SAMPLE_DIST then
				table.insert(hist, {pos=pos, time=t})
				if #hist > ROUTE_HISTORY_MAX then table.remove(hist, 1) end
			end

			-- Actualiza/crea segmentos de ruta aprendidos
			if #hist >= 2 then
				local last = hist[#hist-1]
				local curr = hist[#hist]
				-- Busca si este segmento ya existe
				local found = false
				for _, route in ipairs(learnedRoutes) do
					if (route.from - last.pos).Magnitude < 5
						and (route.to - curr.pos).Magnitude < 5 then
						route.heat = math.min(route.heat + 1, ROUTE_HEAT_MAX)
						route.lastSeen = t
						found = true
						break
					end
				end
				if not found then
					table.insert(learnedRoutes, {
						from     = last.pos,
						to       = curr.pos,
						dir      = (curr.pos - last.pos).Unit,
						heat     = 1,
						lastSeen = t,
						blocked  = false,
					})
				end
			end

			-- Limpia puntos viejos
			for i = #hist, 1, -1 do
				if t - hist[i].time > ROUTE_DECAY then table.remove(hist, i) end
			end
		end

		-- Decae calor y limpia rutas viejas
		local toRemove = {}
		for i, route in ipairs(learnedRoutes) do
			if t - route.lastSeen > 45 then
				route.heat = math.max(0, route.heat - 1)
			end
			if route.heat <= 0 then table.insert(toRemove, i) end
		end
		for i = #toRemove, 1, -1 do table.remove(learnedRoutes, toRemove[i]) end
	end

	-- Decide si bloquear una ruta aprendida y lanza nodos hacia ella
	local function decideStrategicBlock()
		local t = tick()
		if t - lastBlockTime < BLOCK_COOLDOWN then return end
		if #learnedRoutes == 0 then return end
		if #nodes >= CFG.MaxNodes or partCount >= CFG.MaxParts then return end

		-- Ordena rutas por calor (las más recorridas primero)
		table.sort(learnedRoutes, function(a,b) return a.heat > b.heat end)

		-- Elige la ruta más caliente sin bloquear
		local target = nil
		for _, route in ipairs(learnedRoutes) do
			if route.heat >= 4 and not route.blocked then
				target = route; break
			end
		end
		if not target then return end

		-- Calcula punto de intercepción: X studs ADELANTE en la ruta
		local interceptDist = 18 + currentPhase * 5
		local interceptPos  = target.to + target.dir * interceptDist

		-- Busca superficie en ese punto
		local gp, gn = castSurf(
			interceptPos + Vector3.new(0,4,0),
			Vector3.new(0,-1,0), CFG.RayDown)
		if not gp then return end

		-- Comprueba que el micelio no esté ya allí
		if getBlobDensity(gp, 8) >= 3 then
			target.blocked = true   -- ya hay micelio, marca como bloqueado
			return
		end

		-- ¡Bloqueo! Lanza un frente de nodos hacia el punto de intercepción
		local numNodes = 6 + currentPhase * 2
		for i = 1, numNodes do
			if #nodes >= CFG.MaxNodes then break end
			local a = (i/numNodes)*math.pi*2
			local jitter = (r19f(0,1)-0.5)*0.5
			local l = math.random(CFG.LifeMin+5, CFG.LifeMax+10)
			table.insert(nodes, {
				pos     = gp,
				dir     = Vector3.new(math.cos(a+jitter),0,math.sin(a+jitter)),
				normal  = gn,
				life    = l, maxLife = l,
				depth   = 0, age = 0.05,
				nodeType = "block_route"   -- tipo especial: bloqueo de ruta
			})
		end
		spawnBlob(gp, gn, 2 + r19f(0,1.5), 0.2)
		spawnFlash(gp, gn, 1.5)

		target.blocked = true
		lastBlockTime  = t

		print(string.format(
			"[Pibby|Bloqueo] ⚔ Ruta bloqueada (calor: %d) en (%.0f,%.0f,%.0f) — %d nodos",
			target.heat, gp.X, gp.Y, gp.Z, numNodes))

		-- Mensaje en pantalla al jugador que usa esa ruta
		for _, pl in ipairs(Players:GetPlayers()) do
			local hist = playerRouteHistory[pl]
			if hist and #hist > 0 then
				local lastPos = hist[#hist].pos
				if (lastPos - target.from).Magnitude < 15 then
					screenMsg(pl, "[ RUTA CORTADA ]", Color3.fromRGB(255,60,0), 2)
				end
			end
		end
	end

	RunService.Heartbeat:Connect(function(dt)
		updatePlayerRoutes(dt)
		blockDecideT += dt
		if blockDecideT >= 5 then
			blockDecideT = 0
			if currentPhase >= 1 then decideStrategicBlock() end
		end
	end)

	-- Limpia historial al morir/respawn
	Players.PlayerRemoving:Connect(function(pl)
		playerRouteHistory[pl] = nil
	end)

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 3: COORDINACIÓN DE FRENTES
	--  Detecta N jugadores en el servidor y envía un frente
	--  SEPARADO e INDEPENDIENTE hacia cada uno simultáneamente.
	--  Los frentes convergen: si dos frentes se acercan,
	--  se fusionan generando un pulso de fusión.
	-- ════════════════════════════════════════════════════════════════

	-- Estado de cada frente activo
	local activeFronts  = {}   -- lista de {playerId, nodes[], origin, target, health}
	local frontTimer    = 0
	local FRONT_COOLDOWN = 25  -- segundos entre lanzamientos de frente coordinado
	local FRONT_SIZE     = 8   -- nodos por frente
	local FRONT_MERGE_DIST = 12 -- distancia para fusión de frentes

	-- Lanza un frente de nodos dedicado hacia un jugador específico
	local function launchFrontToward(player, fromPos, fromNorm)
		local ch = player.Character
		if not ch then return end
		local hrp = ch:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
		if #nodes >= CFG.MaxNodes or partCount >= CFG.MaxParts then return end

		local targetPos = hrp.Position
		local toTarget  = (targetPos - fromPos)
		local flatDir   = Vector3.new(toTarget.X, 0, toTarget.Z)
		if flatDir.Magnitude < 0.1 then return end
		flatDir = flatDir.Unit

		-- Busca punto de partida en el suelo
		local gp, gn = castSurf(fromPos+Vector3.new(0,3,0), Vector3.new(0,-1,0), CFG.RayDown)
		if not gp then gp=fromPos; gn=Vector3.new(0,1,0) end

		local frontNodes = {}
		for i = 1, FRONT_SIZE do
			if #nodes >= CFG.MaxNodes then break end
			-- Abanico apuntando al jugador con leve dispersión
			local spread   = (i/(FRONT_SIZE+1) - 0.5) * 0.9
			local dir      = rotXZ(flatDir, spread)
			local life     = math.random(CFG.LifeMin+8, CFG.LifeMax+20)
			local nodeData = {
				pos=gp, dir=dir, normal=gn,
				life=life, maxLife=life,
				depth=0, age=0.05,
				nodeType="front_attack"
			}
			table.insert(nodes, nodeData)
			table.insert(frontNodes, nodeData)
		end

		-- Blob de "lanzamiento"
		spawnBlob(gp, gn, 1.5 + r19f(0,1), 0.15)
		spawnFlash(gp, gn, 1.2)

		-- Registra el frente
		table.insert(activeFronts, {
			playerId = player.UserId,
			nodes    = frontNodes,
			origin   = gp,
			target   = player,
			launched = tick(),
		})

		print(string.format("[Pibby|Frentes] ▶ Frente lanzado hacia %s (%d nodos)",
			player.Name, FRONT_SIZE))
	end

	-- Comprueba si dos frentes se acercan y los fusiona
	local function checkFrontMerges()
		if #activeFronts < 2 then return end

		local merged = {}
		for i = 1, #activeFronts do
			for j = i+1, #activeFronts do
				local fa = activeFronts[i]
				local fb = activeFronts[j]
				if merged[i] or merged[j] then continue end

				-- Toma las posiciones actuales de los nodos de cada frente
				local posA = fa.origin
				local posB = fb.origin
				-- Actualiza con nodos vivos si existen
				for _, nd in ipairs(fa.nodes) do
					posA = nd.pos; break
				end
				for _, nd in ipairs(fb.nodes) do
					posB = nd.pos; break
				end

				local dist = (posA - posB).Magnitude
				if dist < FRONT_MERGE_DIST then
					-- ¡Fusión! Flash de encuentro
					local midP = (posA + posB) / 2
					task.spawn(function()
						for _ = 1, 6 do
							spawnFlash(midP, Vector3.new(0,1,0), 1.8 + r19f(0,1))
							task.wait(0.05)
						end
					end)
					-- Oleada radial en el punto de fusión
					local gp, gn = castSurf(midP+Vector3.new(0,3,0), Vector3.new(0,-1,0), CFG.RayDown)
					if gp then
						spawnBlob(gp, gn, 3.5 + r19f(0,2), 0.35)
						for k = 1, 8 do
							if #nodes >= CFG.MaxNodes then break end
							local a = (k/8)*math.pi*2
							local l = math.random(CFG.LifeMin+10, CFG.LifeMax+20)
							table.insert(nodes,{
								pos=gp,
								dir=Vector3.new(math.cos(a),0,math.sin(a)),
								normal=gn, life=l, maxLife=l,
								depth=0, age=0.2, nodeType="normal"
							})
						end
					end
					-- Mensaje
					for _, pl in ipairs(Players:GetPlayers()) do
						screenMsg(pl, "[ FRENTES CONVERGIENDO ]", Color3.fromRGB(255,0,180), 2)
					end
					print("[Pibby|Frentes] ⚡ Fusión de frentes en "..
						string.format("(%.0f,%.0f,%.0f)",midP.X,midP.Y,midP.Z))
					merged[i] = true
					merged[j] = true
				end
			end
		end

		-- Elimina frentes fusionados y los muy viejos (>60s)
		local t = tick()
		local cleanFronts = {}
		for i, f in ipairs(activeFronts) do
			if not merged[i] and (t - f.launched) < 60 then
				-- También elimina si el jugador objetivo ya no existe o está infectado
				local pl = f.target
				if pl and pl.Parent and not infected[pl] then
					table.insert(cleanFronts, f)
				end
			end
		end
		activeFronts = cleanFronts
	end

	-- Tick de coordinación de frentes
	RunService.Heartbeat:Connect(function(dt)
		frontTimer += dt
		if frontTimer < FRONT_COOLDOWN then return end
		if not infectionReady then return end
		if currentPhase < 1 then return end

		-- Recolecta jugadores no infectados
		local targets = {}
		for _, pl in ipairs(Players:GetPlayers()) do
			if not infected[pl] then
				local ch = pl.Character
				if ch and ch:FindFirstChild("HumanoidRootPart") then
					table.insert(targets, pl)
				end
			end
		end

		if #targets == 0 then return end

		-- Solo lanza frentes coordinados si hay ≥2 jugadores O ya estamos en fase 2+
		if #targets < 2 and currentPhase < 2 then return end

		frontTimer = 0

		-- Encuentra el punto de micelio más cercano a cada jugador
		-- como origen del frente correspondiente
		for _, pl in ipairs(targets) do
			local ch = pl.Character
			if not ch then continue end
			local hrp = ch:FindFirstChild("HumanoidRootPart")
			if not hrp then continue end

			-- Busca el blob más cercano al jugador que sea suficientemente lejos
			local bestBlob, bestDist = nil, math.huge
			for _, b in ipairs(blobReg) do
				local d = (b.pos - hrp.Position).Magnitude
				-- Mínimo 15 studs para que el frente tenga "viaje"
				if d >= 15 and d < bestDist then
					bestBlob = b; bestDist = d
				end
			end

			if bestBlob then
				task.spawn(function()
					launchFrontToward(pl, bestBlob.pos, Vector3.new(0,1,0))
				end)
			end
		end

		-- Comprueba fusiones en cada tick de frentes
		task.delay(2, checkFrontMerges)

		if #targets >= 2 then
			for _, pl in ipairs(Players:GetPlayers()) do
				screenMsg(pl,
					"[ "..#targets.." OBJETIVOS — FRENTES ENVIADOS ]",
					Color3.fromRGB(180,0,255), 2.5)
			end
		end
	end)

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 4: ZONAS SEGURAS (colapsan en Fase 2)
	--  Parts llamadas "SafeZone_XX" bloquean el micelio en Fase 0-1.
	--  Al llegar a Fase 2, la biomasa "aprende" que no funcionan
	--  y las desactiva dramáticamente una por una.
	-- ════════════════════════════════════════════════════════════════

	local safeZones       = {}  -- lista de {part, pos, radius, active}
	local safeZoneScanT   = 0
	local safeZoneCollT   = 0   -- timer para colapsar en fase 2
	local safeZonesCollapsed = false

	-- Refresca la lista de zonas seguras del mapa
	local function refreshSafeZones()
		safeZones = {}
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("BasePart") and obj.Name:sub(1,8) == "SafeZone" then
				table.insert(safeZones, {
					part   = obj,
					pos    = obj.Position,
					radius = math.max(obj.Size.X, obj.Size.Y, obj.Size.Z) * 0.65,
					active = true,
				})
			end
		end
	end

	-- Devuelve true si la posición está en una zona segura ACTIVA
	local function inSafeZone(pos)
		for _, z in ipairs(safeZones) do
			if not z.active then continue end
			if not (z.part and z.part.Parent) then continue end
			if (z.pos - pos).Magnitude < z.radius then return true end
		end
		return false
	end

	-- Efecto visual de "barrera activa" en las zonas seguras (Fase 0-1)
	local function tickSafeZoneVFX(dt)
		safeZoneScanT += dt
		if safeZoneScanT < 4 then return end
		safeZoneScanT = 0

		refreshSafeZones()

		if safeZonesCollapsed then return end  -- ya colapsaron, no hace falta VFX

		for _, z in ipairs(safeZones) do
			if not z.active then continue end
			if not (z.part and z.part.Parent) then continue end

			if r19f(0,1) < 0.4 then
				task.spawn(function()
					-- Anillo verde-blanco pulsante
					if partCount >= CFG.MaxParts then return end
					local ring = Instance.new("Part")
					ring.Anchored=true; ring.CanCollide=false; ring.CastShadow=false
					ring.Shape=Enum.PartType.Ball
					ring.Size=Vector3.new(z.radius*2+0.5, 0.18, z.radius*2+0.5)
					ring.Position=z.pos; ring.Color=Color3.fromRGB(80,255,130)
					ring.Material=Enum.Material.Neon; ring.Transparency=0.25
					ring.Parent=folder; partCount+=1
					TweenService:Create(ring,TweenInfo.new(1.4),{
						Transparency=1, Size=ring.Size*1.10
					}):Play()
					task.delay(1.5, function()
						if ring then ring:Destroy(); partCount=math.max(0,partCount-1) end
					end)
				end)
			end

			-- Nodos del micelio que entran en la zona reciben una chispa verde y mueren
			-- (esto se gestiona en el hook de tickMycelium de abajo)
		end
	end

	-- Colapso dramático de todas las zonas seguras al llegar a Fase 2
	local function collapseSafeZones()
		if safeZonesCollapsed then return end
		safeZonesCollapsed = true

		if #safeZones == 0 then return end

		print("[Pibby|SafeZone] ☠ Fase 2 — zonas seguras colapsando...")

		-- Mensaje de advertencia
		task.delay(0.5, function()
			for _, pl in ipairs(Players:GetPlayers()) do
				screenMsg(pl, "[ ZONAS SEGURAS COMPROMETIDAS ]",
					Color3.fromRGB(255,120,0), 3.5)
			end
		end)

		-- Colapsa cada zona con delay escalonado
		for idx, z in ipairs(safeZones) do
			task.delay(idx * 1.8, function()
				if not (z.part and z.part.Parent) then return end

				-- La biomasa "entiende" la zona: glitch verde→morado→negro
				task.spawn(function()
					local part = z.part
					local oc = part.Color

					-- Fase 1: titila como si "luchara"
					for _ = 1, 6 do
						if not (part and part.Parent) then break end
						part.Color = Color3.fromRGB(80,255,130)
						task.wait(0.08)
						if part and part.Parent then
							part.Color = rN()
						end
						task.wait(0.08)
					end
					if not (part and part.Parent) then return end

					-- Fase 2: se vuelve morado (el micelio la asimila)
					TweenService:Create(part, TweenInfo.new(0.6), {
						Color = Color3.fromRGB(100, 0, 180)
					}):Play()
					task.wait(0.7)
					if not (part and part.Parent) then return end

					-- Fase 3: parpadeo neon agresivo
					for _ = 1, 8 do
						if not (part and part.Parent) then break end
						part.Color = rN(); part.Material = Enum.Material.Neon
						task.wait(0.04)
						if part and part.Parent then
							part.Color = rD(); part.Material = Enum.Material.SmoothPlastic
						end
						task.wait(0.04)
					end
					if not (part and part.Parent) then return end

					-- Fase 4: flash y se vuelve negra (ya es del micelio)
					spawnFlash(part.Position, Vector3.new(0,1,0),
						math.clamp(z.radius*0.2, 0.8, 3.5))
					TweenService:Create(part, TweenInfo.new(0.8), {
						Color = Color3.fromRGB(4, 0, 12)
					}):Play()
					task.wait(0.9)

					-- Marca como inactiva
					z.active = false
					z.pos = part.Position  -- actualiza por si se movió

					-- Genera micelio desde la zona colapsada
					if partCount < CFG.MaxParts then
						local gp, gn = castSurf(
							part.Position + Vector3.new(0,3,0),
							Vector3.new(0,-1,0), CFG.RayDown)
						if gp then
							spawnBlob(gp, gn, z.radius*0.4 + r19f(0,1), 0.25)
							for i = 1, math.random(5, 9) do
								if #nodes >= CFG.MaxNodes then break end
								local a = (i/9)*math.pi*2
								local l = math.random(CFG.LifeMin+5, CFG.LifeMax+12)
								table.insert(nodes,{
									pos=gp,
									dir=Vector3.new(math.cos(a),0,math.sin(a)),
									normal=gn, life=l, maxLife=l,
									depth=0, age=0.1, nodeType="normal"
								})
							end
							spawnFlash(gp, gn, 2)
						end
					end

					print(string.format("[Pibby|SafeZone] ⬛ Zona '%s' colapsada",
						part.Name))
				end)
			end)
		end

		-- Mensaje final tras el último colapso
		task.delay(#safeZones * 1.8 + 2, function()
			for _, pl in ipairs(Players:GetPlayers()) do
				screenMsg(pl, "[ NO HAY ZONAS SEGURAS ]",
					Color3.fromRGB(255, 0, 0), 4)
			end
		end)
	end

	-- Hook en activatePhase: en Fase 2 colapsan las zonas seguras
	local _v319ActivatePhase = activatePhase
	function activatePhase(phase)
		_v319ActivatePhase(phase)
		if phase == 2 then
			-- Espera 8s para que la transición visual de Fase 2 termine
			task.delay(8, collapseSafeZones)
		end
	end

	-- Hook en tickMycelium: nodos en zona segura activa mueren con chispa verde
	local _v319TickMycelium = tickMycelium
	function tickMycelium()
		-- Pre-filtra nodos que entren en zonas seguras activas
		if not safeZonesCollapsed and #safeZones > 0 then
			local safeNodes   = {}
			local blockedNodes = {}
			for _, node in ipairs(nodes) do
				if inSafeZone(node.pos) then
					table.insert(blockedNodes, node)
				else
					table.insert(safeNodes, node)
				end
			end
			-- Chispa verde en nodos bloqueados
			for _, node in ipairs(blockedNodes) do
				if math.random() < 0.25 and partCount < CFG.MaxParts then
					local spark = Instance.new("Part")
					spark.Anchored=true; spark.CanCollide=false; spark.CastShadow=false
					spark.Shape=Enum.PartType.Ball; spark.Size=Vector3.new(0.3,0.3,0.3)
					spark.Position=node.pos; spark.Color=Color3.fromRGB(80,255,130)
					spark.Material=Enum.Material.Neon; spark.Transparency=0
					spark.Parent=folder; partCount+=1
					TweenService:Create(spark,TweenInfo.new(0.35),{
						Size=Vector3.new(1.2,1.2,1.2), Transparency=1
					}):Play()
					task.delay(0.4,function()
						if spark then spark:Destroy(); partCount=math.max(0,partCount-1) end
					end)
				end
			end
			nodes = safeNodes
		end
		_v319TickMycelium()
	end

	-- Heartbeat del sistema de zonas seguras
	RunService.Heartbeat:Connect(function(dt)
		tickSafeZoneVFX(dt)
		if not safeZonesCollapsed then
			safeZoneCollT += dt
		end
	end)

	-- Escaneo inicial de zonas seguras
	task.delay(2, refreshSafeZones)

	-- ── PRINT FINAL ──────────────────────────────────────────────────
	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.19                                                    ║")
	print("║  ✦ TERRAIN: detecta mapas de terreno, adapta CFG y raycast     ║")
	print("║    Oleadas periódicas desde puntos muestreados en la superficie ║")
	print("║  ✦ BLOQUEO ESTRATÉGICO: aprende rutas de jugadores y las       ║")
	print("║    intercepta antes de que lleguen (Fase 1+)                   ║")
	print("║  ✦ FRENTES COORDINADOS: un frente por jugador simultáneo,      ║")
	print("║    convergencia con fusión y oleada de fusión (Fase 1+)        ║")
	print("║  ✦ ZONAS SEGURAS (SafeZone_XX): bloquean micelio en Fase 0-1  ║")
	print("║    En Fase 2 la biomasa las asimila dramáticamente una por una  ║")
	print("╚══════════════════════════════════════════════════════════════════╝")

end)()
-- ════════════════════════════════════════════════════════════════════
--  v3.20 — PRESIÓN FRENÉTICA + MICELIO ADHERIDO A BLOQUES
-- ════════════════════════════════════════════════════════════════════
;(function()

	local rng20 = Random.new(tick() * 5003)
	local function r20f(a,b) return rng20:NextNumber(a,b) end
	local function r20i(a,b) return rng20:NextInteger(a,b) end

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 1: PRESIÓN FRENÉTICA
	--
	--  Lógica completa:
	--  • El micelio monitorea si está "estancado" (sin crecer).
	--  • Si no crece, el medidor FRENETIC sube (0→100%).
	--  • Al 50%: lanza esporas desesperadas hacia zonas libres.
	--  • Al 100%: activa FRENETIC MODE.
	--    - Cualquier espora que aterrice en zona libre crea un
	--      NÚCLEO NUEVO que se expande rápido pero controlado.
	--  • Si el micelio vuelve a crecer (zona libre encontrada),
	--    el medidor BAJA gradualmente y sale del modo frenético.
	-- ════════════════════════════════════════════════════════════════

	-- ── Estado del medidor ───────────────────────────────────────────
	local freneticMeter   = 0        -- 0..100
	local freneticActive  = false    -- modo frenético ON
	local freneticCores   = {}       -- núcleos nuevos generados

	-- Referencia al tamaño anterior del micelio para detectar estancamiento
	local lastPartCount   = 0
	local stagnantTime    = 0        -- segundos sin crecer
	local STAGNANT_THRESH = 8        -- segundos quieto → empieza a subir
	local METER_RISE_RATE = 4.5      -- % por segundo cuando estancado
	local METER_DROP_RATE = 6.0      -- % por segundo cuando crece activo
	local METER_CHECK_T   = 0        -- timer para chequeo

	-- Zonas exploradas para detectar espacio libre
	local freeZoneCache   = {}       -- {pos, time} zonas libres detectadas
	local freeZoneScanT   = 0

	-- ── Detecta zonas SIN micelio cerca del borde de expansión ──────
	local function scanForFreeZones()
		if #blobReg == 0 then return end
		freeZoneCache = {}

		-- Muestrea desde bordes del micelio en direcciones aleatorias
		local sampleBlobs = math.min(20, #blobReg)
		for _ = 1, sampleBlobs do
			local b = blobReg[math.random(#blobReg)]
			if not b then continue end

			for _ = 1, 6 do
				local angle  = r20f(0, math.pi*2)
				local dist   = r20f(18, 55)
				local testPos = b.pos + Vector3.new(
					math.cos(angle)*dist, 0, math.sin(angle)*dist)

				-- Comprueba si esa zona tiene poco micelio
				local density = getBlobDensity(testPos, 12)
				if density <= 2 then
					-- Zona casi libre: verifica que haya superficie
					local gp, gn = castSurf(
						testPos + Vector3.new(0,4,0),
						Vector3.new(0,-1,0), CFG.RayDown)
					if gp then
						table.insert(freeZoneCache, {pos=gp, normal=gn, density=density})
					end
				end
			end
		end

		-- Ordena por menor densidad (más libre primero)
		table.sort(freeZoneCache, function(a,b) return a.density < b.density end)
	end

	-- ── Lanza esporas "desesperadas" hacia zonas libres (50%+) ──────
	local despeSporeT = 0
	local function launchDesperateSpora(freeZone)
		if sporeCount >= CFG.SporeMaxActive then return end
		if partCount >= CFG.MaxParts then return end
		if #blobReg == 0 then return end

		-- Origen: blob más cercano a la zona libre
		local best, bestD = nil, math.huge
		for _, b in ipairs(blobReg) do
			local d = (b.pos - freeZone.pos).Magnitude
			if d < bestD then best=b; bestD=d end
		end
		if not best then return end

		-- Espora visual (igual que launchSpore pero apunta a zona libre)
		local fromPos    = best.pos + Vector3.new(0,0.5,0)
		local fromNormal = Vector3.new(0,1,0)
		local landPos    = freeZone.pos
		local landNormal = freeZone.normal or Vector3.new(0,1,0)

		local sp = Instance.new("Part")
		sp.Anchored=true; sp.CanCollide=false; sp.CastShadow=false
		sp.Shape=Enum.PartType.Ball; sp.Size=Vector3.new(0.35,0.35,0.35)
		sp.Position=fromPos
		-- Color especial para esporas frenéticas: rojo-naranja
		sp.Color = lerpC(Color3.fromRGB(255,80,0), rN(), 0.4)
		sp.Material=Enum.Material.Neon; sp.Transparency=0.1
		sp.Parent=folder; partCount+=1; sporeCount+=1

		local sl=Instance.new("PointLight")
		sl.Color=sp.Color; sl.Range=8; sl.Brightness=1.8; sl.Parent=sp

		local ft     = CFG.SporeFlightMin + r20f(0, CFG.SporeFlightMax-CFG.SporeFlightMin)
		local midH   = CFG.SporeArcHeight * (0.55 + r20f(0,0.45))
		local midPos = (fromPos + landPos)/2 + Vector3.new(0, midH, 0)

		table.insert(spores, {
			part      = sp,
			light     = sl,
			startPos  = fromPos,
			midPos    = midPos,
			landPos   = landPos,
			landNormal= landNormal,
			startTime = tick(),
			flightTime= ft,
			trail     = {},
			landed    = false,
			isFrenetic= true,   -- marca especial
		})
	end

	-- ── Crea un núcleo FRENÉTICO en la zona de aterrizaje ───────────
	local function spawnFreneticCore(pos, normal)
		if partCount >= CFG.MaxParts - 20 then return end
		if #nodes >= CFG.MaxNodes then return end

		-- Visual del núcleo: blob grande rojo-morado pulsante
		local coreBlob = Instance.new("Part")
		coreBlob.Shape=Enum.PartType.Ball
		coreBlob.Anchored=true; coreBlob.CanCollide=false; coreBlob.CastShadow=false
		coreBlob.Size=Vector3.new(3,1.2,3)
		coreBlob.Color=Color3.fromRGB(200,0,80)
		coreBlob.Material=Enum.Material.Neon
		coreBlob.CFrame=CFrame.new(pos + normal*0.6)
		coreBlob.Transparency=1; coreBlob.Parent=folder; partCount+=1

		TweenService:Create(coreBlob,
			TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
			{Transparency=0.05}):Play()

		-- Luz roja intensa en el núcleo
		local cLi=Instance.new("PointLight")
		cLi.Color=Color3.fromRGB(255,40,0); cLi.Range=22; cLi.Brightness=5
		cLi.Parent=coreBlob

		-- Flash de llegada
		task.spawn(function()
			for _ = 1,4 do
				spawnFlash(pos, normal, 2.5)
				task.wait(0.06)
			end
		end)

		-- Pulso del núcleo
		task.spawn(function()
			while coreBlob and coreBlob.Parent do
				task.wait(1.2 + r20f(0,1.5))
				if not(coreBlob and coreBlob.Parent) then break end
				TweenService:Create(cLi,TweenInfo.new(0.25),{Brightness=9,Range=35}):Play()
				task.wait(0.28)
				TweenService:Create(cLi,TweenInfo.new(0.6),{Brightness=5,Range=22}):Play()
			end
		end)

		-- Registra el núcleo
		table.insert(freneticCores, {part=coreBlob, pos=pos, normal=normal, born=tick()})
		table.insert(blobReg, {pos=pos, time=tick()})
		markOcc(pos)

		-- Mensaje a todos los jugadores
		for _, pl in ipairs(Players:GetPlayers()) do
			screenMsg(pl, "[ NUEVO NÚCLEO FRENÉTICO ]",
				Color3.fromRGB(255,60,0), 3)
		end

		-- Expansión rápida pero controlada desde el nuevo núcleo
		-- Velocidad: BranchChance más alto, TickRate un poco menor
		local numRays = math.random(10, 16)
		for i = 1, numRays do
			if #nodes >= CFG.MaxNodes then break end
			local angle = (i/numRays)*math.pi*2 + (r20f(0,1)-0.5)*0.4
			-- Vida un poco menor para que no explote el servidor
			local life  = math.random(
				math.max(8, CFG.LifeMin - 4),
				math.min(CFG.LifeMax + 8, 45)
			)
			table.insert(nodes, {
				pos      = pos,
				dir      = Vector3.new(math.cos(angle), 0, math.sin(angle)),
				normal   = normal,
				life     = life,
				maxLife  = life,
				depth    = 0,
				age      = 0,
				nodeType = "frenetic_core",  -- tipo especial
			})
		end

		print(string.format("[Pibby|Frenético] 🔴 Núcleo frenético en (%.0f,%.0f,%.0f)",
			pos.X, pos.Y, pos.Z))
	end

	-- ── Tick principal del medidor frenético ─────────────────────────
	local function tickFreneticMeter(dt)
		METER_CHECK_T += dt
		if METER_CHECK_T < 0.5 then return end
		METER_CHECK_T = 0

		-- ¿Está creciendo el micelio?
		local isGrowing = (partCount > lastPartCount + 5)
		lastPartCount = partCount

		if isGrowing then
			-- Activamente creciendo → baja el medidor
			stagnantTime = 0
			if freneticMeter > 0 then
				freneticMeter = math.max(0, freneticMeter - METER_DROP_RATE * 0.5)
			end
			-- Si baja de 80 y estaba frenético, desactiva el modo
			if freneticActive and freneticMeter < 80 then
				freneticActive = false
				print("[Pibby|Frenético] 🟢 Modo frenético DESACTIVADO — micelio creciendo")
				for _, pl in ipairs(Players:GetPlayers()) do
					screenMsg(pl, "[ EXPANSIÓN RETOMADA ]", Color3.fromRGB(0,200,120), 2.5)
				end
			end
		else
			-- Estancado → sube el medidor
			stagnantTime += 0.5

			if stagnantTime >= STAGNANT_THRESH then
				freneticMeter = math.min(100, freneticMeter + METER_RISE_RATE * 0.5)
			end
		end

		-- Activación del modo frenético al llegar a 100%
		if freneticMeter >= 100 and not freneticActive then
			freneticActive = true
			print("[Pibby|Frenético] 🔴 MODO FRENÉTICO ACTIVADO — sin espacio disponible")
			for _, pl in ipairs(Players:GetPlayers()) do
				screenMsg(pl, "[ INFECCIÓN FRENÉTICA ]",
					Color3.fromRGB(255,30,0), 4)
			end
		end

		-- Lanzamiento de esporas desesperadas (50%+)
		if freneticMeter >= 50 then
			despeSporeT += 0.5
			-- Frecuencia: más rápido cuanto más alto el medidor
			local interval = math.max(1.5, 12 - freneticMeter*0.08)
			if despeSporeT >= interval then
				despeSporeT = 0
				-- Actualiza cache de zonas libres
				if freeZoneScanT <= 0 then
					scanForFreeZones()
					freeZoneScanT = 8
				end
				freeZoneScanT -= 0.5

				-- Lanza 1-3 esporas desesperadas
				local numSporas = freneticActive and math.random(2,4) or 1
				for i = 1, numSporas do
					if i <= #freeZoneCache then
						launchDesperateSpora(freeZoneCache[i])
					end
				end
			end
		end

		-- Log periódico del medidor (solo cuando es relevante)
		if freneticMeter >= 50 and math.floor(freneticMeter/10) ~=
			math.floor(math.max(0, freneticMeter - METER_RISE_RATE*0.5)/10) then
			print(string.format("[Pibby|Frenético] Medidor: %.0f%% | Creciendo: %s | Frenético: %s",
				freneticMeter, tostring(isGrowing), tostring(freneticActive)))
		end
	end

	-- ── Override del aterrizaje de esporas frenéticas ─────────────────
	-- Las esporas marcadas como frenéticas crean núcleos al aterrizar
	-- Hook en updateSpores (que ya está corriendo): no podemos interceptar
	-- directamente, así que usamos blobReg como proxy y detectamos
	-- cuándo aterrizó una espora frenética.

	-- Guardamos referencias a esporas frenéticas en vuelo
	local freneticSporesInFlight = {}   -- {landPos, normal}

	-- Override de launchDesperateSpora para registrar el destino
	local _origLaunchDesperate = launchDesperateSpora
	function launchDesperateSpora(freeZone)
		_origLaunchDesperate(freeZone)
		-- Registra el destino para crear núcleo al aterrizar
		local arrivalTime = tick() +
			CFG.SporeFlightMin + r20f(0, CFG.SporeFlightMax-CFG.SporeFlightMin) +
			CFG.SporeGermDelay + 0.5
		table.insert(freneticSporesInFlight, {
			landPos  = freeZone.pos,
			normal   = freeZone.normal or Vector3.new(0,1,0),
			arriveAt = arrivalTime,
			spawned  = false,
		})
	end

	-- Ticker que comprueba si esporas frenéticas aterrizaron
	local freneticLandT = 0
	local function tickFreneticLanding(dt)
		freneticLandT += dt
		if freneticLandT < 0.3 then return end
		freneticLandT = 0

		if not freneticActive then return end

		local t   = tick()
		local done = {}
		for i, fs in ipairs(freneticSporesInFlight) do
			if fs.spawned then
				table.insert(done, i); continue
			end
			if t < fs.arriveAt then continue end

			-- Verifica que la zona de aterrizaje SIGA libre
			local density = getBlobDensity(fs.landPos, 10)
			if density <= 3 then
				-- ¡Espora frenética aterrizó en zona libre! → núcleo nuevo
				local gp, gn = castSurf(
					fs.landPos + Vector3.new(0,2,0),
					Vector3.new(0,-1,0), CFG.RayDown)
				if gp then
					spawnFreneticCore(gp, gn)
				end
			end
			-- Si la zona ya está infectada, simplemente no hace nada
			fs.spawned = true
			table.insert(done, i)
		end
		for i = #done, 1, -1 do
			table.remove(freneticSporesInFlight, done[i])
		end

		-- Limita tamaño de la lista
		while #freneticSporesInFlight > 40 do
			table.remove(freneticSporesInFlight, 1)
		end
	end

	-- ── Nodos frenetic_core: velocidad mayor, BranchChance elevado ────
	-- Se procesan en tickMycelium normal pero con CFG temporal modificado
	local _v320TickMycelium = tickMycelium
	function tickMycelium()
		-- Aumenta temporalmente el BranchChance para nodos frenéticos
		local hasFrenetic = false
		for _, node in ipairs(nodes) do
			if node.nodeType == "frenetic_core" then hasFrenetic=true; break end
		end

		if hasFrenetic then
			local origBC  = CFG.BranchChance
			local origTR  = CFG.TickRate
			CFG.BranchChance = math.min(0.65, CFG.BranchChance * 1.55)
			-- No modificamos TickRate aquí para no interferir con otros sistemas
			_v320TickMycelium()
			CFG.BranchChance = origBC
		else
			_v320TickMycelium()
		end

		-- Limpia núcleos frenéticos muertos del registro
		local aliveCores = {}
		for _, core in ipairs(freneticCores) do
			if core.part and core.part.Parent then
				table.insert(aliveCores, core)
			end
		end
		freneticCores = aliveCores
	end

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 2: MICELIO ADHERIDO A BLOQUES
	--
	--  Cada vez que el micelio se genera sobre un BasePart anclada,
	--  registra esa relación. Si la parte se DESANCLA, las piezas
	--  de micelio adheridas a ella también se desanclan.
	--  Si esas piezas tocan una nueva zona sin micelio,
	--  el crecimiento continúa desde ahí.
	-- ════════════════════════════════════════════════════════════════

	-- Registro de adherencia: BasePart → lista de Parts de micelio
	local adhesionMap      = {}    -- hostPart → {mycelParts...}
	local detachedMycel    = {}    -- mycelPart → {hostPart, attachedAt}
	local adhesionScanT    = 0
	local fallingMycelT    = 0

	-- Registra una Part de micelio como adherida a una BasePart del mapa
	local function registerAdhesion(mycelPart, hostPart)
		if not (mycelPart and hostPart) then return end
		if hostPart == workspace.Terrain then return end
		if hostPart:FindFirstAncestor("PibbyFolder") then return end

		if not adhesionMap[hostPart] then
			adhesionMap[hostPart] = {}
		end
		-- Evita duplicados
		for _, mp in ipairs(adhesionMap[hostPart]) do
			if mp == mycelPart then return end
		end
		table.insert(adhesionMap[hostPart], mycelPart)
	end

	-- Detects cuando una BasePart del mapa se desancla
	-- (Roblox no tiene un evento directo para esto, usamos polling)
	local function scanDetachedBlocks()
		local toClean = {}
		for hostPart, mycelList in pairs(adhesionMap) do
			-- Parte destruida
			if not (hostPart and hostPart.Parent) then
				toClean[hostPart] = true
				continue
			end
			-- Parte que se desancló
			if not hostPart.Anchored then
				-- Desancla todas las piezas de micelio adheridas
				for _, mp in ipairs(mycelList) do
					if not (mp and mp.Parent) then continue end
					if mp.Anchored then
						mp.Anchored = false
						detachedMycel[mp] = {
							hostPart   = hostPart,
							detachedAt = tick(),
						}
					end
				end
				toClean[hostPart] = true
			end
		end
		for hp, _ in pairs(toClean) do
			adhesionMap[hp] = nil
		end

		-- Limpia micelio destruido del registro de desanclados
		for mp, _ in pairs(detachedMycel) do
			if not (mp and mp.Parent) then
				detachedMycel[mp] = nil
			end
		end
	end

	-- Comprueba si piezas de micelio desancladas tocaron zona nueva
	-- y lanza crecimiento desde ahí
	local function tickDetachedMycel(dt)
		fallingMycelT += dt
		if fallingMycelT < 0.6 then return end
		fallingMycelT = 0

		for mp, data in pairs(detachedMycel) do
			if not (mp and mp.Parent) then
				detachedMycel[mp] = nil
				continue
			end

			-- Solo procesa micelio que lleva más de 0.5s cayendo
			if tick() - data.detachedAt < 0.5 then continue end

			-- Hace raycast desde el micelio hacia abajo buscando nueva superficie
			local r = workspace:Raycast(
				mp.Position + Vector3.new(0,0.3,0),
				Vector3.new(0,-1,0)*3,
				rpMain
			)
			if not r then continue end

			local hitPart = r.Instance
			if not hitPart then continue end

			-- Verifica que es una superficie sin micelio
			if hitPart:FindFirstAncestor("PibbyFolder") then continue end
			if hitPart.Name == "Baseplate" then continue end

			local surfPos    = r.Position + r.Normal*CFG.SurfaceOff
			local nearDensity = getBlobDensity(surfPos, 8)

			if nearDensity > 3 then continue end  -- ya infectado, ignora

			-- ¡Nueva zona alcanzada! Genera micelio desde ahí
			if partCount < CFG.MaxParts and #nodes < CFG.MaxNodes then
				-- Flash de contacto
				spawnFlash(surfPos, r.Normal, 0.9)

				-- Blob inicial
				spawnBlob(surfPos, r.Normal, 1.5 + r20f(0,1.2), 0.2)
				markOcc(surfPos)

				-- Nodos de crecimiento en todas las direcciones
				local numNew = math.random(4, 7)
				for i = 1, numNew do
					local angle = (i/numNew)*math.pi*2 + (r20f(0,1)-0.5)*0.4
					local l     = math.random(CFG.LifeMin, CFG.LifeMax)
					table.insert(nodes, {
						pos      = surfPos,
						dir      = Vector3.new(math.cos(angle), 0, math.sin(angle)),
						normal   = r.Normal,
						life     = l,
						maxLife  = l,
						depth    = 0,
						age      = 0.05,
						nodeType = "adhesion_spread",
					})
				end

				print(string.format(
					"[Pibby|Adhesión] 🪨 Micelio caído alcanzó nueva zona en (%.0f,%.0f,%.0f)",
					surfPos.X, surfPos.Y, surfPos.Z))

				-- El micelio ya cumplió su función: lo reanclamos para que
				-- quede como una semilla visual en la nueva superficie
				task.delay(0.4, function()
					if mp and mp.Parent then
						mp.Anchored = true
						mp.Position = surfPos + r.Normal*0.1
					end
				end)
			end

			-- Elimina de la lista de desanclados (ya se propagó o ya ancló)
			detachedMycel[mp] = nil
		end
	end

	-- ── Hook en spawnTendril y spawnBlob para registrar adherencia ────
	-- Sobreescribe spawnBlob para registrar la BasePart debajo
	local _v320SpawnBlob = spawnBlob
	function spawnBlob(pos, normal, radius, ageFrac)
		local p = _v320SpawnBlob(pos, normal, radius, ageFrac)
		if not p then return p end

		-- Detecta qué BasePart hay debajo del blob
		task.defer(function()
			if not (p and p.Parent) then return end
			local r = workspace:Raycast(
				pos + Vector3.new(0,0.3,0),
				-normal * 1.5,
				rpMain
			)
			if r and r.Instance and r.Instance:IsA("BasePart")
				and r.Instance.Anchored
				and not r.Instance:FindFirstAncestor("PibbyFolder") then
				registerAdhesion(p, r.Instance)
			end
		end)
		return p
	end

	-- Sobreescribe spawnTendril para registrar adherencia también
	local _v320SpawnTendril = spawnTendril
	function spawnTendril(from, to, sn, age, isNeon, isRhizo)
		local p = _v320SpawnTendril(from, to, sn, age, isNeon, isRhizo)
		if not p then return p end

		task.defer(function()
			if not (p and p.Parent) then return end
			-- Para tendrils: busca bajo el punto medio
			local mid = (from+to)/2
			local r = workspace:Raycast(
				mid + sn*0.3,
				-sn * 1.2,
				rpMain
			)
			if r and r.Instance and r.Instance:IsA("BasePart")
				and r.Instance.Anchored
				and not r.Instance:FindFirstAncestor("PibbyFolder") then
				registerAdhesion(p, r.Instance)
			end
		end)
		return p
	end

	-- ── Limpieza periódica de la adhesionMap ─────────────────────────
	local adhesionCleanT = 0
	local function tickAdhesionClean(dt)
		adhesionCleanT += dt
		if adhesionCleanT < 15 then return end
		adhesionCleanT = 0

		-- Limpia partes de micelio destruidas del mapa de adherencia
		for hostPart, mycelList in pairs(adhesionMap) do
			if not (hostPart and hostPart.Parent) then
				adhesionMap[hostPart] = nil
				continue
			end
			local alive = {}
			for _, mp in ipairs(mycelList) do
				if mp and mp.Parent then table.insert(alive, mp) end
			end
			if #alive == 0 then
				adhesionMap[hostPart] = nil
			else
				adhesionMap[hostPart] = alive
			end
		end
	end

	-- ════════════════════════════════════════════════════════════════
	--  HEARTBEAT v3.20
	-- ════════════════════════════════════════════════════════════════
	RunService.Heartbeat:Connect(function(dt)
		if not infectionReady then return end

		tickFreneticMeter(dt)
		tickFreneticLanding(dt)
		tickDetachedMycel(dt)
		tickAdhesionClean(dt)

		-- Escanea bloques desanclados periódicamente
		adhesionScanT += dt
		if adhesionScanT >= 1.2 then
			adhesionScanT = 0
			scanDetachedBlocks()
		end

		-- Actualiza cache de zonas libres periódicamente
		freeZoneScanT = math.max(0, freeZoneScanT - dt)
	end)

	-- ── Limpieza al respawn de jugadores ────────────────────────────
	Players.PlayerAdded:Connect(function(pl)
		pl.CharacterAdded:Connect(function()
			-- Si el jugador respawneó y el medidor frenético era alto,
			-- puede que haya más espacio libre: baja un poco el medidor
			if freneticMeter > 20 then
				freneticMeter = math.max(20, freneticMeter - 15)
			end
		end)
	end)

	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.20 — LA PRESIÓN                                      ║")
	print("║  ✦ MEDIDOR FRENÉTICO: sube cuando el micelio no crece          ║")
	print("║    50%→ esporas desesperadas a zonas libres                     ║")
	print("║    100%→ MODO FRENÉTICO: esporas crean nuevos NÚCLEOS           ║")
	print("║    Los núcleos se expanden rápido pero controlado               ║")
	print("║    Si el micelio vuelve a crecer, el medidor baja               ║")
	print("║  ✦ ADHESIÓN A BLOQUES: el micelio registra sobre qué bloque    ║")
	print("║    está pegado. Si el bloque se desancla, el micelio            ║")
	print("║    también cae. Si toca zona nueva, crece desde ahí.            ║")
	print("╚══════════════════════════════════════════════════════════════════╝")

end)()
-- ════════════════════════════════════════════════════════════════════
--  v3.21 — MODO SURVIVALIST
--  Actívalo en CFG añadiendo:  SurvivalistMode = true
--  (o false para el comportamiento normal)
-- ════════════════════════════════════════════════════════════════════
;(function()

	-- ── Lee la flag de la config ─────────────────────────────────────
	-- Si no existe en CFG la añadimos con valor false por defecto
	if CFG.SurvivalistMode == nil then CFG.SurvivalistMode = false end

	-- Alias corto para no escribirlo todo el rato
	local SURV = CFG.SurvivalistMode

	if not SURV then
		print("[Pibby|Survivalist] Modo Survivalist DESACTIVADO — comportamiento normal")
		return   -- sale del scope: ningún sistema de este bloque se activa
	end

	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.21 — MODO SURVIVALIST ACTIVADO                       ║")
	print("║  ✦ Scripts protegidos — el micelio nunca los desactiva         ║")
	print("║  ✦ Niebla suavizada (fase 1-4 más visible, oscuridad en f5)   ║")
	print("║  ✦ Noche permanente solo desde Fase 3                          ║")
	print("║  ✦ Zonas Seguras nunca colapsan                                ║")
	print("║  ✦ IA de NPC infectados mejorada — caza más inteligente        ║")
	print("║  ✦ Infección de jugadores más lenta                            ║")
	print("╚══════════════════════════════════════════════════════════════════╝")

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 1: SCRIPTS PROTEGIDOS
	--  Sobreescribe sabotageScript y killAllScripts para que no
	--  hagan nada. El micelio nunca podrá desactivar ningún script.
	-- ════════════════════════════════════════════════════════════════

	-- Neutraliza sabotageScript (definido en v3.6)
	if sabotageScript then
		local _origSabotage = sabotageScript
		function sabotageScript(s)
			-- En modo Survivalist: solo muestra el efecto visual pero
			-- NO deshabilita el script
			if not (s and s.Parent) then return end
			local parent = s.Parent
			if parent and parent:IsA("BasePart") and partCount < CFG.MaxParts then
				task.spawn(function()
					spawnFlash(parent.Position, Vector3.new(0,1,0),
						math.clamp(parent.Size.Magnitude*0.08, 0.2, 1.0))
				end)
			end
			-- sin s.Disabled = true
		end
		print("[Pibby|Survivalist] sabotageScript neutralizado")
	end

	-- Neutraliza killAllScripts (definido en v3.16 dentro de activatePhase)
	-- Lo hacemos sobreescribiendo activatePhase para interceptar fase 4
	local _survActivatePhase = activatePhase
	function activatePhase(phase)
		_survActivatePhase(phase)
		-- En Survivalist, fase 4 NO mata scripts: el hook de v3.16
		-- ya llamó killAllScripts con delay, pero como sabotageScript
		-- ya está neutralizado arriba, el daño real es 0.
		-- Aquí solo emitimos un mensaje alternativo
		if phase == 4 then
			task.delay(6.5, function()
				for _, pl in ipairs(Players:GetPlayers()) do
					screenMsg(pl,
						"[ BIOMASA CONTENIDA — SISTEMAS ACTIVOS ]",
						Color3.fromRGB(100,200,255), 3.5)
				end
			end)
		end
	end

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 2: NIEBLA SUAVIZADA POR FASES
	--  Sobreescribe los valores de niebla/iluminación para dar más
	--  visibilidad en fases tempranas. La oscuridad total llega
	--  gradualmente solo en Fase 5.
	-- ════════════════════════════════════════════════════════════════

	-- Tabla de parámetros de niebla Survivalist (más permisiva)
	-- { FogEnd, FogStart, Brightness, AtmoDensity, AtmoHaze }
	local SURV_FOG = {
		[1] = { FogEnd=2200, FogStart=600,  Brightness=0.95, Density=0.04, Haze=0.15 },
		[2] = { FogEnd=1400, FogStart=380,  Brightness=0.78, Density=0.10, Haze=0.55 },
		[3] = { FogEnd=750,  FogStart=160,  Brightness=0.55, Density=0.20, Haze=1.10 },
		[4] = { FogEnd=320,  FogStart=55,   Brightness=0.28, Density=0.38, Haze=2.80 },
		[5] = { FogEnd=42,   FogStart=3,    Brightness=0.04, Density=0.90, Haze=9.50 },
	}

	-- Aplica la niebla survivalist al activar una fase
	local function applySurvivalistFog(phase)
		local f = SURV_FOG[math.clamp(phase,1,5)]
		if not f then return end

		TweenService:Create(Lighting, TweenInfo.new(6, Enum.EasingStyle.Sine), {
			FogEnd        = f.FogEnd,
			FogStart      = f.FogStart,
			Brightness    = f.Brightness,
		}):Play()

		task.spawn(function()
			local steps = 30
			for i = 1, steps do
				task.wait(0.2)
				atmo.Density = math.min(f.Density, atmo.Density + f.Density/steps)
				atmo.Haze    = math.min(f.Haze,    atmo.Haze    + f.Haze/steps)
			end
		end)
	end

	-- Hook en activatePhase (encadenado al que ya tiene este bloque arriba)
	local _survFogPhase = activatePhase
	function activatePhase(phase)
		_survFogPhase(phase)
		-- Corrige la niebla con los valores survivalist
		task.delay(0.1, function() applySurvivalistFog(phase) end)
	end

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 3: NOCHE PERMANENTE SOLO DESDE FASE 3
	--  En el modo normal la noche empieza antes. Aquí retrasamos
	--  la oscuridad total y las transiciones de cielo.
	-- ════════════════════════════════════════════════════════════════

	-- Restablece el reloj a un atardecer neutro si la fase es < 3
	local clockFixT = 0
	local clockFixed = false

	RunService.Heartbeat:Connect(function(dt)
		if clockFixed then return end
		clockFixT += dt
		if clockFixT < 2 then return end
		clockFixed = true

		-- Solo toca el reloj si estamos en fases tempranas
		if currentPhase < 3 then
			-- Mantiene el día (o atardecer suave según fase)
			local targetClock = currentPhase <= 1 and 14.0 or 17.5
			TweenService:Create(Lighting, TweenInfo.new(4, Enum.EasingStyle.Sine), {
				ClockTime           = targetClock,
				GeographicLatitude  = 45,
				ExposureCompensation= 0,
			}):Play()
		end
	end)

	-- Sobreescribe la transición de noche en fase 2 (que en el original
	-- manda a medianoche). En Survivalist, fase 2 → solo atardecer tardío.
	-- Fase 3 → noche total (igual que el original pero retrasado un fase).
	local _survClockPhase = activatePhase
	function activatePhase(phase)
		_survClockPhase(phase)

		if phase == 2 then
			-- Survivalist fase 2: atardecer tardío, NO noche
			task.delay(0.2, function()
				TweenService:Create(Lighting, TweenInfo.new(8, Enum.EasingStyle.Sine), {
					ClockTime           = 20.0,
					GeographicLatitude  = 20,
					ExposureCompensation= -0.2,
				}):Play()
				for _, pl in ipairs(Players:GetPlayers()) do
					screenMsg(pl, "[ ATARDECER CORRUPTO ]",
						Color3.fromRGB(255,140,60), 2.5)
				end
			end)

		elseif phase == 3 then
			-- Survivalist fase 3: aquí sí llega la noche total
			task.delay(0.2, function()
				TweenService:Create(Lighting, TweenInfo.new(10, Enum.EasingStyle.Sine), {
					ClockTime           = 0,
					GeographicLatitude  = 0,
					ExposureCompensation= -0.8,
					ShadowSoftness      = 1,
				}):Play()
				for _, pl in ipairs(Players:GetPlayers()) do
					screenMsg(pl, "[ NOCHE ETERNA ]",
						Color3.fromRGB(100,0,255), 3)
				end
			end)
		end
	end

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 4: ZONAS SEGURAS PERMANENTES
	--  En Survivalist las SafeZone nunca colapsan.
	--  Sobreescribimos collapseSafeZones (que se llama al activar fase 2)
	--  para que no haga nada, y el VFX de barrera siga activo siempre.
	-- ════════════════════════════════════════════════════════════════

	-- La función collapseSafeZones está definida dentro del scope de v3.19
	-- No podemos acceder directamente, pero podemos hookear activatePhase
	-- para anunciar que las zonas siguen en pie.
	local _survSafePhase = activatePhase
	function activatePhase(phase)
		_survSafePhase(phase)
		if phase == 2 then
			task.delay(9, function()
				for _, pl in ipairs(Players:GetPlayers()) do
					screenMsg(pl,
						"[ ZONAS SEGURAS RESISTIENDO ]",
						Color3.fromRGB(80,255,130), 3)
				end
			end)
		end
	end

	-- Refuerzo visual de zonas seguras en modo Survivalist:
	-- pulso verde más frecuente y brillante para que los jugadores
	-- sepan claramente dónde están protegidos.
	local survZoneT = 0
	RunService.Heartbeat:Connect(function(dt)
		survZoneT += dt
		if survZoneT < 6 then return end
		survZoneT = 0

		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("BasePart") and obj.Name:sub(1,8) == "SafeZone" then
				if partCount >= CFG.MaxParts then break end
				task.spawn(function()
					local ring = Instance.new("Part")
					ring.Anchored=true; ring.CanCollide=false; ring.CastShadow=false
					ring.Shape=Enum.PartType.Ball
					local r = math.max(obj.Size.X, obj.Size.Y, obj.Size.Z)*0.65
					ring.Size = Vector3.new(r*2+0.4, 0.2, r*2+0.4)
					ring.Position = obj.Position
					ring.Color = Color3.fromRGB(60,255,120)
					ring.Material = Enum.Material.Neon
					ring.Transparency = 0.2
					ring.Parent = folder; partCount+=1
					TweenService:Create(ring, TweenInfo.new(1.6), {
						Transparency=1, Size=ring.Size*1.12
					}):Play()
					task.delay(1.7, function()
						if ring then ring:Destroy(); partCount=math.max(0,partCount-1) end
					end)
				end)
			end
		end
	end)

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 5: IA DE NPC MEJORADA (modo Survivalist)
	--
	--  Los NPCs infectados ahora:
	--  a) Usan pathfinding real (PathfindingService) para rodear
	--     obstáculos en lugar de moverse en línea recta.
	--  b) Coordinan en grupo: si hay varios NPCs infectados,
	--     se reparten los jugadores objetivo para no perseguir todos
	--     al mismo jugador.
	--  c) Emboscada: si un NPC pierde de vista al jugador,
	--     calcula una ruta de intercepción en vez de perseguir
	--     la última posición conocida.
	--  d) Tasa de contagio al jugador aumentada pero la infección
	--     PROGRESA más lentamente (delays entre stages más largos).
	-- ════════════════════════════════════════════════════════════════

	local PathfindingService = game:GetService("PathfindingService")

	-- Tabla de asignación NPC → jugador objetivo (para repartir targets)
	local npcAssignments   = {}   -- NPC model → player
	local assignUpdateT    = 0

	-- Distribuye jugadores entre NPCs infectados de forma equilibrada
	local function reassignNpcTargets()
		local infectedNpcList = {}
		for model, _ in pairs(infectedNpcs) do
			if model and model.Parent then
				table.insert(infectedNpcList, model)
			end
		end

		local playerList = {}
		for _, pl in ipairs(Players:GetPlayers()) do
			if not infected[pl] then
				local ch = pl.Character
				if ch and ch:FindFirstChild("HumanoidRootPart") then
					table.insert(playerList, pl)
				end
			end
		end

		if #playerList == 0 then
			-- No hay jugadores libres — todos los NPCs van al azar
			for _, npc in ipairs(infectedNpcList) do
				npcAssignments[npc] = nil
			end
			return
		end

		-- Asignación round-robin
		for i, npc in ipairs(infectedNpcList) do
			npcAssignments[npc] = playerList[((i-1) % #playerList) + 1]
		end
	end

	-- Calcula y sigue una ruta con PathfindingService
	-- Devuelve false si el pathfinding falla (fallback a movimiento directo)
	local function moveNpcViaPath(hum, hrp, targetPos)
		if not (hum and hum.Parent and hrp and hrp.Parent) then return false end

		local success, path = pcall(function()
			local p = PathfindingService:CreatePath({
				AgentRadius       = 2,
				AgentHeight       = 5,
				AgentCanJump      = true,
				AgentJumpHeight   = 7,
				AgentMaxSlope     = 45,
				WaypointSpacing   = 4,
			})
			p:ComputeAsync(hrp.Position, targetPos)
			return p
		end)

		if not success or not path then return false end
		if path.Status ~= Enum.PathStatus.Success then return false end

		local waypoints = path:GetWaypoints()
		if #waypoints < 2 then return false end

		-- Mueve al NPC waypoint a waypoint (solo los primeros 3 para no bloquear)
		task.spawn(function()
			for i = 2, math.min(4, #waypoints) do
				if not (hum and hum.Parent) then break end
				local wp = waypoints[i]
				if wp.Action == Enum.PathWaypointAction.Jump then
					hum.Jump = true
				end
				hum:MoveTo(wp.Position)
				-- Espera a que llegue o timeout de 2s
				local t0 = tick()
				while hum and hum.Parent do
					if (hrp.Position - wp.Position).Magnitude < 3 then break end
					if tick()-t0 > 2 then break end
					task.wait(0.1)
				end
			end
		end)
		return true
	end

	-- Calcula punto de intercepción: predice dónde estará el jugador
	-- en ~1.5 segundos basándose en su velocidad actual
	local playerVelocities = {}   -- player → velocidad estimada

	local velUpdateT = 0
	local prevPositions = {}   -- player → posición hace 0.5s

	local function updatePlayerVelocities(dt)
		velUpdateT += dt
		if velUpdateT < 0.5 then return end
		velUpdateT = 0

		for _, pl in ipairs(Players:GetPlayers()) do
			local ch = pl.Character
			if not ch then continue end
			local hrp = ch:FindFirstChild("HumanoidRootPart")
			if not hrp then continue end

			local curPos = hrp.Position
			if prevPositions[pl] then
				local vel = (curPos - prevPositions[pl]) / 0.5
				playerVelocities[pl] = vel
			end
			prevPositions[pl] = curPos
		end
	end

	local function getInterceptPosition(player, fromPos, lookAhead)
		lookAhead = lookAhead or 1.5
		local ch = player.Character
		if not ch then return nil end
		local hrp = ch:FindFirstChild("HumanoidRootPart")
		if not hrp then return nil end

		local vel = playerVelocities[player]
		if vel and vel.Magnitude > 0.5 then
			-- Predice posición futura
			return hrp.Position + Vector3.new(vel.X,0,vel.Z) * lookAhead
		end
		return hrp.Position
	end

	-- ── Override de corruptNpc para la versión Survivalist ───────────
	local _survCorruptNpc = corruptNpc
	function corruptNpc(model)
		if infectedNpcs[model] then return end
		-- Llama al original para la corrupción visual
		_survCorruptNpc(model)

		-- Espera a que el original termine la inicialización básica
		task.delay(3.2, function()
			if not (model and model.Parent and infectedNpcs[model]) then return end

			local hum = model:FindFirstChildOfClass("Humanoid")
			local hrp = model:FindFirstChild("HumanoidRootPart")
			if not hum or not hrp then return end

			print("[Pibby|Survivalist] NPC mejorado: "..model.Name)

			-- Velocidades por modo (Survivalist: más rápido en persecución)
			local BASE = hum.WalkSpeed or 16
			local PATROL_SPD  = BASE * 0.65
			local STALK_SPD   = BASE * 1.25   -- más sigiloso pero más rápido
			local CHARGE_SPD  = BASE * 2.5    -- sprint mejorado
			local INTERCEPT_SPD = BASE * 2.8  -- cuando intercepta

			-- Estado interno mejorado
			local state         = "patrol"
			local alertLevel    = 0
			local lastKnownPos  = nil
			local patrolAngle   = math.random()*math.pi*2
			local lostTargetT   = 0    -- tiempo sin ver al objetivo

			-- Intervalo de actualización más rápido que el original
			task.spawn(function()
				while model and model.Parent and infectedNpcs[model]
					and hum and hum.Health > 0 do
					task.wait(0.15)   -- más reactivo (original: 0.2s)
					if not (model and model.Parent) then break end

					-- ── Obtiene jugador asignado ─────────────────────
					local targetPl = npcAssignments[model]
					-- Si no tiene asignación o el objetivo se infectó, busca otro
					if not targetPl or not targetPl.Parent or infected[targetPl] then
						-- Busca el no-infectado más cercano
						local closest, closestD = nil, math.huge
						for _, pl in ipairs(Players:GetPlayers()) do
							if infected[pl] then continue end
							local ch2 = pl.Character
							if not ch2 then continue end
							local h2 = ch2:FindFirstChild("HumanoidRootPart")
							if not h2 then continue end
							local d = (h2.Position - hrp.Position).Magnitude
							if d < closestD then closest=pl; closestD=d end
						end
						targetPl = closest
						npcAssignments[model] = targetPl
					end

					-- ── Detección del objetivo ───────────────────────
					local targetHRP   = nil
					local targetDist  = math.huge
					local canSee      = false

					if targetPl and targetPl.Parent then
						local ch2 = targetPl.Character
						if ch2 then
							local h2 = ch2:FindFirstChild("HumanoidRootPart")
							if h2 then
								targetHRP  = h2
								targetDist = (h2.Position - hrp.Position).Magnitude

								-- Línea de visión
								local toTarget = (h2.Position - hrp.Position)
								local los = workspace:Raycast(
									hrp.Position + Vector3.new(0,1.5,0),
									toTarget.Unit * targetDist,
									rpMain)
								canSee = (los == nil)
									or ((los.Position - h2.Position).Magnitude < 2.5)
							end
						end
					end

					-- ── Actualiza alerta ─────────────────────────────
					if canSee then
						alertLevel = math.min(100, alertLevel
							+ (targetDist < 15 and 18 or 7))
						lastKnownPos = targetHRP and targetHRP.Position
						lostTargetT  = 0
					else
						alertLevel = math.max(0, alertLevel - 4)
						lostTargetT += 0.15
					end

					-- ── Transición de estados ────────────────────────
					if targetDist < 2.8 then
						state = "flail"
					elseif targetDist < 8 or alertLevel >= 85 then
						state = "charge"
					elseif not canSee and lastKnownPos and lostTargetT < 8 then
						state = "intercept"  -- ← NUEVO: va al punto de intercepción
					elseif alertLevel >= 30 and targetDist < 32 then
						state = "stalk"
					else
						state = "patrol"
					end

					-- ── Comportamiento por estado ────────────────────

					if state == "patrol" then
						hum.WalkSpeed = PATROL_SPD
						patrolAngle += 0.07 + math.random()*0.05
						local pt = hrp.Position + Vector3.new(
							math.cos(patrolAngle)*9, 0, math.sin(patrolAngle)*9)
						hum:MoveTo(pt)
						-- Deja rastro de micelio al patrullar
						if math.random() < 0.05 and partCount < CFG.MaxParts then
							local gp,gn=castSurf(hrp.Position,Vector3.new(0,-1,0),5)
							if gp then spawnBlob(gp,gn,0.3+math.random()*0.4,0.5) end
						end

					elseif state == "stalk" then
						hum.WalkSpeed = STALK_SPD
						if targetHRP then
							-- Rodea al jugador para no alertarlo
							local ang = math.atan2(
								hrp.Position.Z - targetHRP.Position.Z,
								hrp.Position.X - targetHRP.Position.X)
							ang = ang + math.pi + (math.random()-0.5)*0.6
							local approachPos = targetHRP.Position
								+ Vector3.new(math.cos(ang)*5, 0, math.sin(ang)*5)
							-- Intenta pathfinding, si falla: moveTo directo
							if not moveNpcViaPath(hum, hrp, approachPos) then
								hum:MoveTo(approachPos)
							end
						end
						if math.random() < 0.05 and partCount < CFG.MaxParts then
							local gp,gn=castSurf(hrp.Position,Vector3.new(0,-1,0),5)
							if gp then spawnBlob(gp,gn,0.4+math.random()*0.5,0.6) end
						end

					elseif state == "intercept" then
						-- ← NUEVO ESTADO: calcula intercepción
						hum.WalkSpeed = INTERCEPT_SPD
						if targetPl and targetPl.Parent then
							local interceptPos = getInterceptPosition(
								targetPl, hrp.Position, 2.0)
							if interceptPos then
								if not moveNpcViaPath(hum, hrp, interceptPos) then
									hum:MoveTo(interceptPos)
								end
							elseif lastKnownPos then
								hum:MoveTo(lastKnownPos)
							end
						end

					elseif state == "charge" then
						hum.WalkSpeed = CHARGE_SPD
						if targetHRP then
							-- Usa pathfinding en carga para rodear obstáculos
							if not moveNpcViaPath(hum, hrp, targetHRP.Position) then
								hum:MoveTo(targetHRP.Position)
							end
						end
						if math.random() < 0.15 and partCount < CFG.MaxParts then
							local gp,gn=castSurf(hrp.Position,Vector3.new(0,-1,0),5)
							if gp then spawnBlob(gp,gn,0.6+math.random()*0.6,0.7) end
						end
						-- Flash de carga
						local head = model:FindFirstChild("Head")
						if head and math.random() < 0.07 then
							local fl=Instance.new("PointLight")
							fl.Color=rN(); fl.Range=22; fl.Brightness=5; fl.Parent=head
							TweenService:Create(fl,TweenInfo.new(0.25),{Brightness=0}):Play()
							task.delay(0.3,function() if fl then fl:Destroy() end end)
						end

					elseif state == "flail" then
						hum.WalkSpeed = BASE * 0.4
						local flailDir = Vector3.new(math.random()-0.5,0,math.random()-0.5)
						if flailDir.Magnitude > 0.01 then
							hum:Move(flailDir.Unit, false)
						end
					end

					-- ── Contagio al jugador ───────────────────────────
					-- En Survivalist: radio de contagio mayor, tasa más alta,
					-- pero los stages de infección tardan más (ver sistema 6)
					if targetHRP and not infected[targetPl]
						and targetDist < CFG.NpcInfectRadius * 1.6 then
						if math.random() < CFG.NpcInfectChance * 18 then
							task.spawn(function()
								startInfection(targetPl)
							end)
						end
					end

					-- ── Micelio al caminar ────────────────────────────
					if math.random() < 0.04 and partCount < CFG.MaxParts then
						local gp,gn=castSurf(hrp.Position,Vector3.new(0,-1,0),5)
						if gp then spawnBlob(gp,gn,0.4+math.random()*0.5,0.6) end
					end

					-- ── Esporas del cuerpo del NPC ────────────────────
					if math.random() < 0.012 and partCount < CFG.MaxParts then
						local sz = 0.05+math.random()*0.08
						local sp = Instance.new("Part")
						sp.Anchored=true; sp.CanCollide=false; sp.CastShadow=false
						sp.Shape=Enum.PartType.Ball; sp.Size=Vector3.new(sz,sz,sz)
						sp.Position = hrp.Position
							+ Vector3.new((math.random()-0.5)*1.2, math.random()*1.5,
								(math.random()-0.5)*1.2)
						sp.Color=rN(); sp.Material=Enum.Material.Neon; sp.Transparency=0.15
						sp.Parent=folder; partCount+=1
						TweenService:Create(sp, TweenInfo.new(2+math.random()*2), {
							Position=sp.Position+Vector3.new(0,3+math.random()*3,0),
							Transparency=1
						}):Play()
						task.delay(4.5, function()
							if sp then sp:Destroy(); partCount=math.max(0,partCount-1) end
						end)
					end
				end
			end)
		end)
	end

	-- Reasignación periódica de targets
	RunService.Heartbeat:Connect(function(dt)
		updatePlayerVelocities(dt)
		assignUpdateT += dt
		if assignUpdateT >= 8 then
			assignUpdateT = 0
			reassignNpcTargets()
		end
	end)

	-- ════════════════════════════════════════════════════════════════
	--  SISTEMA 6: INFECCIÓN DE JUGADORES MÁS LENTA
	--  En Survivalist los stages tardan más en avanzar.
	--  Los delays originales:
	--    Stage2Delay=11, Stage3Delay=20, Stage4Delay=32, Stage5Delay=52
	--  Survivalist multiplica estos valores por un factor.
	-- ════════════════════════════════════════════════════════════════

	local SURV_DELAY_MULT = 2.2   -- los stages tardan 2.2× más

	-- Ajusta la config antes de que startInfection la use
	CFG.Stage2Delay = CFG.Stage2Delay * SURV_DELAY_MULT
	CFG.Stage3Delay = CFG.Stage3Delay * SURV_DELAY_MULT
	CFG.Stage4Delay = CFG.Stage4Delay * SURV_DELAY_MULT
	CFG.Stage5Delay = CFG.Stage5Delay * SURV_DELAY_MULT
	CFG.BlockClimbSpeed = CFG.BlockClimbSpeed * 1.5  -- la corrupción visual también más lenta

	print(string.format(
		"[Pibby|Survivalist] Delays de infección ×%.1f → Stage2=%.0fs Stage3=%.0fs Stage4=%.0fs Stage5=%.0fs",
		SURV_DELAY_MULT,
		CFG.Stage2Delay, CFG.Stage3Delay, CFG.Stage4Delay, CFG.Stage5Delay))

	-- También ralentiza la tasa de subida del porcentaje de corrupción visible
	-- STAGE_PCT ya está definido en v3.2; no podemos acceder pero
	-- updateInfectionPct usa un speed fijo, así que lo sobreescribimos
	-- via un hook en la función. La velocidad original es (8 + stage*3).
	-- En Survivalist la reducimos: (4 + stage*1.5).
	local _origUpdateInfPct = updateInfectionPct
	if _origUpdateInfPct then
		function updateInfectionPct(dt)
			-- Parche: reduce la velocidad de actualización temporalmente
			for pl, data in pairs(infected) do
				local target = ({[0]=2,[1]=20,[2]=42,[3]=65,[4]=85,[5]=100})[data.stage] or 0
				local current = infectionPct[pl] or 0
				local speed = 4 + data.stage*1.5   -- más lento que el original (8+stage*3)
				infectionPct[pl] = math.min(target, current + speed*dt)
			end
		end
	end

	-- ════════════════════════════════════════════════════════════════
	--  ANUNCIO INICIAL EN PANTALLA
	-- ════════════════════════════════════════════════════════════════
	task.delay(2, function()
		for _, pl in ipairs(Players:GetPlayers()) do
			screenMsg(pl,
				"[ MODO SURVIVALIST — LUCHA ]",
				Color3.fromRGB(0,220,120), 4.5)
		end
	end)

end)()
-- ════════════════════════════════════════════════════════════════════
--  v3.22 — RAYCAST MEJORADO + ADHESIÓN A DESANCLADOS + SURVIVALIST
--
--  ✦ Detección de pared ANTES de generar el tendril:
--    si hay obstáculo en el camino, el nodo gira y lo evita.
--  ✦ Barrera anti-penetración: nunca atraviesa geometría sólida.
--  ✦ Adhesión a bloques DESANCLADOS: el micelio se "pega" a
--    partes móviles y crece desde donde aterrizan.
--  ✦ Survivalist: detección en abanico más precisa y ruido
--    de dirección mínimo para no perder el rastro de la pared.
-- ════════════════════════════════════════════════════════════════════
;(function()

	local SURV = CFG.SurvivalistMode == true

	-- ════════════════════════════════════════════════════════════════
	--  UTILIDADES DE RAYCAST INTERNO
	-- ════════════════════════════════════════════════════════════════

	-- ── Comprueba si el segmento (from→to) está libre de obstáculos ──
	-- Lanza un rayo directo y verifica que no haya nada sólido
	-- entre los dos puntos (excluye el folder del micelio).
	local function isSegmentClear(from, to)
		local dir = to - from
		local len = dir.Magnitude
		if len < 0.05 then return true end
		local r = workspace:Raycast(from, dir.Unit * len, rpMain)
		if not r then return true end
		-- Hay algo, pero ¿está entre from y to o detrás de to?
		local hitDist = (r.Position - from).Magnitude
		return hitDist >= len - 0.15   -- margen de 0.15 studs
	end

	-- ── Detecta pared en la dirección de avance ───────────────────────
	-- Devuelve: blocked (bool), wallNormal (Vector3 o nil), wallDist (number)
	local WALL_CHECK_DIST_NORMAL = 2.2   -- studs por delante en modo normal
	local WALL_CHECK_DIST_SURV   = 3.5   -- más largo en Survivalist

	local function detectWallAhead(pos, dir, surfNormal)
		local checkDist = SURV and WALL_CHECK_DIST_SURV or WALL_CHECK_DIST_NORMAL
		-- Proyecta la dirección sobre el plano de la superficie
		local flat = dir - surfNormal * dir:Dot(surfNormal)
		if flat.Magnitude < 0.001 then flat = dir end
		flat = flat.Unit

		-- Rayo principal hacia adelante (ligeramente elevado para no raspar suelo)
		local origin = pos + surfNormal * 0.25
		local r = workspace:Raycast(origin, flat * checkDist, rpMain)
		if not r then return false, nil, checkDist end

		local wallNorm = r.Normal
		local wallDist = (r.Position - pos).Magnitude

		-- Solo cuenta como pared si la normal es mayormente horizontal
		if math.abs(wallNorm.Y) < 0.55 then
			return true, wallNorm, wallDist
		end
		-- Si la normal es vertical (suelo/techo delante), no es pared
		return false, nil, wallDist
	end

	-- ── Genera direcciones alternativas para evitar una pared ─────────
	-- Dada la normal de la pared, produce direcciones tangentes
	-- ordenadas de la más lateral a la que da la vuelta.
	local function getWallAvoidDirs(blockedDir, wallNormal, surfNormal)
		local dirs = {}

		-- Tangentes a la pared (izquierda y derecha de la dirección original)
		local wallTan = wallNormal:Cross(Vector3.new(0,1,0))
		if wallTan.Magnitude < 0.01 then
			wallTan = wallNormal:Cross(surfNormal)
		end
		wallTan = wallTan.Unit
		-- Elige el lado que más se acerca a la dirección original
		if wallTan:Dot(blockedDir) < 0 then wallTan = -wallTan end

		-- Ángulos de escape: 45°, 70°, 90°, 110° a cada lado
		local angles = SURV
			and {math.pi*0.22, math.pi*0.38, math.pi*0.5, math.pi*0.65}
			or  {math.pi*0.25, math.pi*0.5,  math.pi*0.75}

		for _, sign in ipairs({1, -1}) do
			for _, ang in ipairs(angles) do
				local escDir = rotXZ(blockedDir, sign * ang)
				-- Solo acepta si no vuelve más de 100° atrás
				if escDir:Dot(blockedDir) > -0.18 then
					table.insert(dirs, escDir)
				end
			end
		end

		-- Añade la tangente pura de la pared como último recurso
		table.insert(dirs, wallTan)
		table.insert(dirs, -wallTan)

		return dirs
	end

	-- ════════════════════════════════════════════════════════════════
	--  OVERRIDE DE nextSurf CON DETECCIÓN DE PARED
	--  Esta versión añade el check ANTES del intento de movimiento,
	--  de modo que si hay pared al frente el nodo ya gira antes de
	--  intentar el raycast de superficie.
	-- ════════════════════════════════════════════════════════════════

	local _v322NextSurf = nextSurf

	function nextSurf(from, move, sn, stepOvr)
		local step = stepOvr or CFG.StepSize
		local flat  = move - sn * move:Dot(sn)
		if flat.Magnitude < 0.001 then flat = move else flat = flat.Unit end

		-- ── PASO 0: detección de pared al frente ─────────────────────
		local wallBlocked, wallNorm, wallDist = detectWallAhead(from, flat, sn)

		if wallBlocked and wallNorm then
			-- Hay pared: genera alternativas y prueba cada una
			local altDirs = getWallAvoidDirs(flat, wallNorm, sn)

			for _, altDir in ipairs(altDirs) do
				-- Comprueba que esa dirección tampoco choca
				local altBlocked = detectWallAhead(from, altDir, sn)
				if not altBlocked then
					-- Usa esa dirección alternativa para el nextSurf normal
					local sp2, sn2, fd2 = _v322NextSurf(from, altDir, sn, step)
					if sp2 then
						-- Verifica que el segmento from→sp2 esté libre
						if isSegmentClear(from + sn*0.1, sp2 + sn2*0.1) then
							return sp2, sn2, altDir
						end
					end
				end
			end

			-- Todas las alternativas bloqueadas: intenta escalar la pared
			-- (el nextSurf original ya tiene lógica de escalada)
			local sp3, sn3, fd3 = _v322NextSurf(from, flat, sn, step)
			if sp3 and isSegmentClear(from + sn*0.1, sp3 + sn3*0.1) then
				return sp3, sn3, fd3
			end
			return nil, nil, flat
		end

		-- ── PASO 1: intento normal ────────────────────────────────────
		local sp, sn2, fd = _v322NextSurf(from, flat, sn, step)

		if sp then
			-- Anti-penetración: verifica que el segmento esté libre
			if isSegmentClear(from + sn*0.1, sp + sn2*0.1) then
				return sp, sn2, fd
			end

			-- El segmento cruza algo sólido: intenta alternativas laterales
			local altDirs2 = getWallAvoidDirs(flat,
				Vector3.new(-flat.Z, 0, flat.X), sn)  -- normal perpendicular estimada

			for _, altDir2 in ipairs(altDirs2) do
				local sp4, sn4, fd4 = _v322NextSurf(from, altDir2, sn, step)
				if sp4 and isSegmentClear(from + sn*0.1, sp4 + sn4*0.1) then
					return sp4, sn4, altDir2
				end
			end

			return nil, nil, flat
		end

		return nil, nil, flat
	end

	-- ════════════════════════════════════════════════════════════════
	--  SURVIVALIST: ABANICO DE RAYOS PARA NAVEGACIÓN
	--  En modo Survivalist el micelio lanza 5 rayos en abanico
	--  y elige la dirección más libre antes de moverse.
	--  Esto hace que evite paredes de forma más natural.
	-- ════════════════════════════════════════════════════════════════

	if SURV then

		local _survFanNextSurf = nextSurf

		function nextSurf(from, move, sn, stepOvr)
			local step = stepOvr or CFG.StepSize
			local flat  = move - sn * move:Dot(sn)
			if flat.Magnitude < 0.001 then flat = move else flat = flat.Unit end

			-- Abanico de 5 direcciones centradas en flat
			-- Elige la que tiene mayor distancia libre al frente
			local fanAngles = {0, -0.28, 0.28, -0.58, 0.58}
			local bestDir   = flat
			local bestFree  = 0

			for _, ang in ipairs(fanAngles) do
				local testDir = rotXZ(flat, ang)
				local blocked, _, dist = detectWallAhead(from, testDir, sn)
				if not blocked and dist > bestFree then
					bestFree = dist
					bestDir  = testDir
				end
			end

			-- Usa la mejor dirección encontrada
			return _survFanNextSurf(from, bestDir, sn, stepOvr)
		end

		print("[Pibby|v3.22] Survivalist: abanico de 5 rayos activo")
	end

	-- ════════════════════════════════════════════════════════════════
	--  ADHESIÓN A BLOQUES DESANCLADOS
	--
	--  Nueva lógica separada del sistema de v3.20:
	--  • Cuando el micelio aterriza sobre una BasePart NO anclada,
	--    se "suelda" visualmente a ella usando WeldConstraint.
	--  • Si la parte se mueve (por física, explosión, etc.), el
	--    micelio viaja con ella.
	--  • Cuando la parte toca una zona sin micelio, el micelio
	--    se desuelda y genera crecimiento en la nueva posición.
	-- ════════════════════════════════════════════════════════════════

	-- Registro: mycelPart → { host, weld, born }
	local unanchoredRiders  = {}
	local riderScanT        = 0

	-- Intenta pegar una Part de micelio a un bloque desanclado
	local function attachToUnanchored(mycelPart, hostPart)
		if not (mycelPart and mycelPart.Parent) then return end
		if not (hostPart  and hostPart.Parent)  then return end
		if hostPart.Anchored then return end  -- este sistema es solo para desanclados
		if hostPart:FindFirstAncestor("PibbyFolder") then return end

		-- Evita duplicados
		if unanchoredRiders[mycelPart] then return end

		-- Desancla la parte de micelio y la suelda al host
		mycelPart.Anchored = false

		local ok, weld = pcall(function()
			local w = Instance.new("WeldConstraint")
			w.Part0 = mycelPart
			w.Part1 = hostPart
			w.Parent = mycelPart
			return w
		end)

		if not ok or not weld then
			-- Si falla el weld (por alguna razón), reanclamos la parte
			mycelPart.Anchored = true
			return
		end

		unanchoredRiders[mycelPart] = {
			host  = hostPart,
			weld  = weld,
			born  = tick(),
			lastPos = hostPart.Position,
		}
	end

	-- Comprueba si un rider llegó a zona nueva y genera crecimiento
	local function tickUnanchoredRiders(dt)
		riderScanT += dt
		if riderScanT < 0.5 then return end
		riderScanT = 0

		local toRemove = {}

		for mycelPart, data in pairs(unanchoredRiders) do
			-- Limpia entradas con partes destruidas
			if not (mycelPart and mycelPart.Parent) then
				toRemove[mycelPart] = true
				continue
			end
			if not (data.host and data.host.Parent) then
				-- El bloque desapareció: reanclamos la pieza donde quedó
				mycelPart.Anchored = true
				if data.weld and data.weld.Parent then data.weld:Destroy() end
				toRemove[mycelPart] = true
				continue
			end

			-- ¿El bloque se movió lo suficiente?
			local moved = (data.host.Position - data.lastPos).Magnitude
			if moved < 1.5 then continue end
			data.lastPos = data.host.Position

			-- ¿El micelio está sobre zona sin infectar?
			local pos = mycelPart.Position
			local nearDensity = getBlobDensity(pos, 7)
			if nearDensity > 4 then continue end  -- ya hay micelio cerca

			-- Busca suelo debajo de la pieza de micelio
			local gp, gn = castSurf(
				pos + Vector3.new(0, 1.5, 0),
				Vector3.new(0,-1,0), 6)
			if not gp then continue end

			-- ¡Nueva zona! Genera crecimiento
			if partCount < CFG.MaxParts and #nodes < CFG.MaxNodes then
				spawnFlash(gp, gn, 0.7)
				spawnBlob(gp, gn, 1.2 + math.random()*1.0, 0.2)
				markOcc(gp)

				local numNew = math.random(3, 6)
				for i = 1, numNew do
					local a = (i/numNew)*math.pi*2 + (math.random()-0.5)*0.4
					local l = math.random(CFG.LifeMin, CFG.LifeMax)
					table.insert(nodes, {
						pos      = gp,
						dir      = Vector3.new(math.cos(a), 0, math.sin(a)),
						normal   = gn,
						life     = l, maxLife = l,
						depth    = 0, age = 0.05,
						nodeType = "adhesion_spread",
					})
				end

				print(string.format(
					"[Pibby|v3.22] Micelio móvil aterrizó en (%.0f,%.0f,%.0f)",
					gp.X, gp.Y, gp.Z))
			end

			-- Desuelda y reanclamos en la nueva posición
			mycelPart.Anchored = true
			if data.weld and data.weld.Parent then data.weld:Destroy() end
			pcall(function() mycelPart.Position = gp + gn * 0.1 end)
			toRemove[mycelPart] = true
		end

		for mp, _ in pairs(toRemove) do
			unanchoredRiders[mp] = nil
		end
	end

	-- ── Detecta qué BasePart hay debajo (anclada O desanclada) ────────
	local function detectHostBelow(pos, normal, mycelPart)
		local r = workspace:Raycast(
			pos + Vector3.new(0, 0.3, 0),
			-normal * 2.0,
			rpMain)
		if not r then return end
		local inst = r.Instance
		if not inst or not inst:IsA("BasePart") then return end
		if inst:FindFirstAncestor("PibbyFolder") then return end
		if inst.Name == "Baseplate" then return end

		if inst.Anchored then
			-- Sistema de v3.20: registerAdhesion (ya existe, lo llamamos si existe)
			if registerAdhesion then
				registerAdhesion(mycelPart, inst)
			end
		else
			-- NUEVO: adherencia a desanclado
			attachToUnanchored(mycelPart, inst)
		end
	end

	-- ── Override de spawnBlob para detectar host (anclado Y desanclado) ─
	local _v322SpawnBlob = spawnBlob
	function spawnBlob(pos, normal, radius, ageFrac)
		local p = _v322SpawnBlob(pos, normal, radius, ageFrac)
		if not p then return p end

		task.defer(function()
			if not (p and p.Parent) then return end
			detectHostBelow(pos, normal, p)
		end)
		return p
	end

	-- ── Override de spawnTendril para detectar host ────────────────────
	local _v322SpawnTendril = spawnTendril
	function spawnTendril(from, to, sn, age, isNeon, isRhizo)
		local p = _v322SpawnTendril(from, to, sn, age, isNeon, isRhizo)
		if not p then return p end

		task.defer(function()
			if not (p and p.Parent) then return end
			local mid = (from + to) / 2
			detectHostBelow(mid, sn, p)
		end)
		return p
	end

	-- ════════════════════════════════════════════════════════════════
	--  SURVIVALIST: AJUSTE DE DETECCIÓN PARA MODO SUPERVIVENCIA
	--  En modo Survivalist el micelio usa distancias de detección
	--  mayores y además hace una segunda pasada de validación
	--  para asegurarse de que el punto de destino es accesible.
	-- ════════════════════════════════════════════════════════════════

	if SURV then
		-- En Survivalist: antes de cualquier spawnTendril, verifica
		-- que la dirección del tendril no cruza una pared.
		-- Si cruza, no genera la parte visual (tendril "fantasma").
		local _survSpawnTendrilCheck = spawnTendril
		function spawnTendril(from, to, sn, age, isNeon, isRhizo)
			-- Verificación de segmento extra en Survivalist
			if not isSegmentClear(
				from + sn * 0.08,
				to   + sn * 0.08) then
				-- Segmento bloqueado: no genera el tendril
				return nil
			end
			return _survSpawnTendrilCheck(from, to, sn, age, isNeon, isRhizo)
		end
		print("[Pibby|v3.22] Survivalist: verificación de segmento activa en tendrils")
	end

	-- ════════════════════════════════════════════════════════════════
	--  HEARTBEAT v3.22
	-- ════════════════════════════════════════════════════════════════
	RunService.Heartbeat:Connect(function(dt)
		tickUnanchoredRiders(dt)
	end)

	-- ── Limpieza al destruir micelio de riders viejos ────────────────
	local riderCleanT = 0
	RunService.Heartbeat:Connect(function(dt)
		riderCleanT += dt
		if riderCleanT < 20 then return end
		riderCleanT = 0

		for mp, data in pairs(unanchoredRiders) do
			-- Limpia riders que llevan más de 90s (no se han movido suficiente)
			if tick() - data.born > 90 then
				if mp and mp.Parent then
					mp.Anchored = true
					if data.weld and data.weld.Parent then data.weld:Destroy() end
				end
				unanchoredRiders[mp] = nil
			end
		end
	end)

	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.22 — RAYCAST MEJORADO + ADHESIÓN A DESANCLADOS       ║")
	print("║  ✦ Detección de pared ANTES de moverse                         ║")
	print("║    → si hay obstáculo, el nodo rota y lo evita                 ║")
	print("║  ✦ Anti-penetración: isSegmentClear valida cada tendril        ║")
	print("║  ✦ Adhesión a bloques desanclados: el micelio viaja con         ║")
	print("║    las partes móviles y crece al aterrizar en zona libre        ║")
	if SURV then
		print("║  ✦ Survivalist: abanico de 5 rayos + verificación extra         ║")
		print("║    de segmento en cada tendril generado                         ║")
	end
	print("╚══════════════════════════════════════════════════════════════════╝")

end)()
-- ════════════════════════════════════════════════════════════════════
--  v3.23 — PAREDES ROBUSTAS + SURVIVALIST AVANZADO
--  (versión revisada: sin LOS — reemplaza el bloque anterior v3.23)
--
--  ✦ Detección multi-rayo: 7 rayos paralelos antes de moverse
--  ✦ Verificación de segmento con 5 rayos paralelos
--  ✦ Survivalist: infección solo por CONTACTO FÍSICO de tendril cazador
--  ✦ Survivalist: sin mensajes flotantes sobre nodos del micelio
--  ✦ Survivalist: screenMsg solo llega a jugadores infectados
-- ════════════════════════════════════════════════════════════════════
;(function()

	local SURV = CFG.SurvivalistMode == true

	-- ════════════════════════════════════════════════════════════════
	--  BLOQUE 1: DETECCIÓN ROBUSTA DE PAREDES (todos los modos)
	-- ════════════════════════════════════════════════════════════════

	local WALL_DIST = SURV and 3.8 or 2.6

	local function robustWallCheck(pos, dir, surfNormal)
		local sn   = surfNormal or Vector3.new(0,1,0)
		local flat = dir - sn * dir:Dot(sn)
		if flat.Magnitude < 0.001 then flat = dir else flat = flat.Unit end

		local perp = sn:Cross(flat)
		if perp.Magnitude < 0.001 then perp = Vector3.new(1,0,0) end
		perp = perp.Unit

		local halfW = CFG.TendrilW * 1.8

		local origins = {
			pos + sn * 0.20,
			pos + sn * 0.20 + perp * halfW,
			pos + sn * 0.20 - perp * halfW,
			pos + sn * 0.45,
			pos + sn * 0.06,
			pos + sn * 0.20 + perp * halfW * 0.5 + flat * 0.25,
			pos + sn * 0.20 - perp * halfW * 0.5 + flat * 0.25,
		}

		for _, origin in ipairs(origins) do
			local r = workspace:Raycast(origin, flat * WALL_DIST, rpMain)
			if r and math.abs(r.Normal.Y) < 0.65 then
				return true, r.Normal, (r.Position - pos).Magnitude
			end
		end
		return false, nil, WALL_DIST
	end

	local function robustSegmentClear(from, to, surfNormal)
		local dir = to - from
		local len = dir.Magnitude
		if len < 0.05 then return true end
		local unit = dir.Unit
		local sn   = surfNormal or Vector3.new(0,1,0)

		local perp = sn:Cross(unit)
		if perp.Magnitude < 0.001 then perp = Vector3.new(1,0,0) end
		perp = perp.Unit * 0.24

		local origins = {
			from + sn * 0.18,
			from + sn * 0.18 + perp,
			from + sn * 0.18 - perp,
			from + sn * 0.40,
			from + sn * 0.06,
		}

		for _, origin in ipairs(origins) do
			local r = workspace:Raycast(origin, unit * len, rpMain)
			if r and (r.Position - origin).Magnitude < len - 0.22 then
				return false
			end
		end
		return true
	end

	local function getAvoidDirs(blockedDir, wallNormal, surfNormal)
		local dirs = {}
		local sn   = surfNormal or Vector3.new(0,1,0)

		local wallTan = wallNormal:Cross(Vector3.new(0,1,0))
		if wallTan.Magnitude < 0.01 then wallTan = wallNormal:Cross(sn) end
		if wallTan.Magnitude < 0.01 then wallTan = Vector3.new(1,0,0) end
		wallTan = wallTan.Unit
		if wallTan:Dot(blockedDir) < 0 then wallTan = -wallTan end

		local angles = SURV
			and { math.pi*0.18, math.pi*0.32, math.pi*0.46,
				math.pi*0.60, math.pi*0.74, math.pi*0.88 }
			or  { math.pi*0.25, math.pi*0.45, math.pi*0.65, math.pi*0.82 }

		for _, sign in ipairs({1, -1}) do
			for _, ang in ipairs(angles) do
				local esc = rotXZ(blockedDir, sign * ang)
				if esc:Dot(blockedDir) > -0.32 then
					table.insert(dirs, esc)
				end
			end
		end
		table.insert(dirs, wallTan)
		table.insert(dirs, -wallTan)
		return dirs
	end

	-- ════════════════════════════════════════════════════════════════
	--  OVERRIDE FINAL DE nextSurf
	-- ════════════════════════════════════════════════════════════════

	local _v323NextSurf = nextSurf

	function nextSurf(from, move, sn, stepOvr)
		local step = stepOvr or CFG.StepSize
		local flat  = move - sn * move:Dot(sn)
		if flat.Magnitude < 0.001 then flat = move else flat = flat.Unit end

		local wallBlocked, wallNorm = robustWallCheck(from, flat, sn)

		if wallBlocked and wallNorm then
			for _, altDir in ipairs(getAvoidDirs(flat, wallNorm, sn)) do
				if not robustWallCheck(from, altDir, sn) then
					local sp2, sn2 = _v323NextSurf(from, altDir, sn, step)
					if sp2 and robustSegmentClear(from, sp2, sn) then
						return sp2, sn2, altDir
					end
				end
			end
			local sp3, sn3, fd3 = _v323NextSurf(from, flat, sn, step)
			if sp3 and robustSegmentClear(from, sp3, sn) then
				return sp3, sn3, fd3
			end
			return nil, nil, flat
		end

		local sp, sn2, fd = _v323NextSurf(from, flat, sn, step)
		if sp then
			if robustSegmentClear(from, sp, sn) then
				return sp, sn2, fd
			end
			local perpEst = Vector3.new(-flat.Z, 0, flat.X)
			for _, altDir2 in ipairs(getAvoidDirs(flat, perpEst, sn)) do
				local sp4, sn4 = _v323NextSurf(from, altDir2, sn, step)
				if sp4 and robustSegmentClear(from, sp4, sn) then
					return sp4, sn4, altDir2
				end
			end
			return nil, nil, flat
		end

		return nil, nil, flat
	end

	-- ════════════════════════════════════════════════════════════════
	--  SURVIVALIST — ABANICO + VERIFICACIÓN DE TENDRIL
	-- ════════════════════════════════════════════════════════════════

	if SURV then
		local _survFan = nextSurf
		function nextSurf(from, move, sn, stepOvr)
			local flat = move - sn * move:Dot(sn)
			if flat.Magnitude < 0.001 then flat = move else flat = flat.Unit end

			local fanAngles = {0, -0.24, 0.24, -0.50, 0.50, -0.78, 0.78}
			local bestDir, bestFree = flat, -1

			for _, ang in ipairs(fanAngles) do
				local testDir = rotXZ(flat, ang)
				local blocked, _, dist = robustWallCheck(from, testDir, sn)
				if not blocked and dist > bestFree then
					bestFree = dist
					bestDir  = testDir
				end
			end

			return _survFan(from, bestDir, sn, stepOvr)
		end

		local _survTendril = spawnTendril
		function spawnTendril(from, to, sn, age, isNeon, isRhizo)
			if not robustSegmentClear(from, to, sn) then return nil end
			return _survTendril(from, to, sn, age, isNeon, isRhizo)
		end

		print("[Pibby|v3.23] Survivalist — abanico 7 rayos + check tendril")
	end

	-- ════════════════════════════════════════════════════════════════
	--  BLOQUE 2 (SURVIVALIST): INFECCIÓN POR CONTACTO FÍSICO
	--
	--  La infección en modo Survivalist NO es instantánea ni por
	--  distancia. El micelio envía un "tendril cazador" que navega
	--  físicamente por la superficie hasta tocar al jugador o NPC.
	--  Si hay una pared entre ellos, el tendril tiene que RODEARLA.
	--  Solo el contacto real del tendril con el personaje infecta.
	--
	--  Mecánica:
	--  • Cada 4s busca jugadores/NPCs no infectados a ≤28 studs
	--  • Por cada objetivo, lanza un nodo especial "hunter" desde
	--    el blob más cercano
	--  • El nodo hunter ignora las reglas normales de crecimiento:
	--    siempre gira hacia el objetivo, usa robustWallCheck para
	--    esquivar paredes, y tiene vida extra larga
	--  • Spawn una Part "sensor" fina al frente de cada hunter
	--  • Si esa Part toca al personaje → infección inmediata
	--  • Si el hunter muere sin tocar → el objetivo se salvó
	-- ════════════════════════════════════════════════════════════════

	if SURV then

		local hunterNodes   = {}   -- { node, sensorPart, targetChar, targetPlayer/nil, targetNpc/nil }
		local hunterScanT   = 0
		local HUNTER_RANGE  = 28   -- studs máximos para lanzar un hunter
		local HUNTER_LIFE   = 220  -- ticks de vida extra del hunter
		local HUNTER_SPEED  = CFG.StepSize * 1.35   -- más rápido que micelio normal

		-- ── Crea la Part sensor del cazador ──────────────────────────
		local function makeHunterSensor(pos, targetChar)
			local s = Instance.new("Part")
			s.Name       = "HunterSensor"
			s.Size       = Vector3.new(0.35, 0.35, 0.35)
			s.Position   = pos
			s.Anchored   = true
			s.CanCollide = false
			s.CastShadow = false
			s.Material   = Enum.Material.Neon
			s.Color      = Color3.fromRGB(180, 60, 220)
			s.Transparency = 0.55
			s.Parent     = folder

			-- Conecta Touched para detectar contacto con el personaje objetivo
			s.Touched:Connect(function(hit)
				if not (s and s.Parent) then return end
				if hit:IsDescendantOf(targetChar) then
					s:Destroy()   -- se consume al tocar
				end
			end)

			return s
		end

		-- ── Lanza un hunter desde un blob hacia un objetivo ───────────
		local function spawnHunter(blobPos, blobNormal, targetChar, targetPlayer, targetNpc)
			-- Dirección inicial hacia el objetivo
			local targetPos = targetChar:FindFirstChild("HumanoidRootPart")
			if not targetPos then return end
			local initDir = (targetPos.Position - blobPos)
			initDir = Vector3.new(initDir.X, 0, initDir.Z)
			if initDir.Magnitude < 0.01 then return end
			initDir = initDir.Unit

			local sensor = makeHunterSensor(blobPos, targetChar)

			table.insert(hunterNodes, {
				pos        = blobPos,
				dir        = initDir,
				normal     = blobNormal,
				life       = HUNTER_LIFE,
				sensor     = sensor,
				targetChar = targetChar,
				targetPlayer = targetPlayer,
				targetNpc  = targetNpc,
			})
		end

		-- ── Encuentra el blob más cercano a una posición ──────────────
		local function closestBlob(targetPos, maxDist)
			local best, bestD = nil, math.huge
			for _, b in ipairs(blobReg) do
				local d = (b.pos - targetPos).Magnitude
				if d < maxDist and d < bestD then
					best  = b
					bestD = d
				end
			end
			return best
		end

		-- ── Tick de hunters (cada frame) ──────────────────────────────
		local hunterTickT = 0
		RunService.Heartbeat:Connect(function(dt)
			hunterTickT += dt
			if hunterTickT < 0.06 then return end   -- ~16 fps
			hunterTickT = 0

			local toRemove = {}

			for i, h in ipairs(hunterNodes) do
				h.life -= 1

				-- Limpia si murió o el objetivo desapareció
				if h.life <= 0
					or not (h.targetChar and h.targetChar.Parent)
					or not (h.sensor and h.sensor.Parent) then
					if h.sensor and h.sensor.Parent then h.sensor:Destroy() end
					toRemove[i] = true
					continue
				end

				-- ── Navega hacia el objetivo ───────────────────────────
				local hrp = h.targetChar:FindFirstChild("HumanoidRootPart")
				if not hrp then
					h.sensor:Destroy()
					toRemove[i] = true
					continue
				end

				-- Dirección deseada hacia el objetivo
				local desired = hrp.Position - h.pos
				desired = Vector3.new(desired.X, 0, desired.Z)
				if desired.Magnitude > 0.01 then desired = desired.Unit end

				-- Comprueba pared en dirección deseada
				local wallBlocked, wallNorm = robustWallCheck(h.pos, desired, h.normal)

				local moveDir = desired
				if wallBlocked and wallNorm then
					-- Desvía con getAvoidDirs
					for _, altDir in ipairs(getAvoidDirs(desired, wallNorm, h.normal)) do
						if not robustWallCheck(h.pos, altDir, h.normal) then
							moveDir = altDir
							break
						end
					end
				end

				-- Avanza por la superficie
				local sp, sn2 = nextSurf(h.pos, moveDir, h.normal, HUNTER_SPEED)
				if sp then
					-- Genera tendril visual (fino, color caza)
					local tp = spawnTendril(h.pos, sp, h.normal, 0.55, true, false)
					if tp then
						tp.Color = Color3.fromRGB(160, 30, 200)
						tp.Size  = Vector3.new(
							tp.Size.X * 0.55,
							tp.Size.Y * 0.55,
							tp.Size.Z)
					end

					h.pos    = sp
					h.normal = sn2
					h.dir    = moveDir

					-- Mueve el sensor al frente del hunter
					h.sensor.Position = sp + sn2 * 0.25

					-- ── Comprueba contacto manual (por si Touched falla) ──
					-- (Roblox a veces no dispara Touched en partes ancladas)
					local dist = (sp - hrp.Position).Magnitude
					if dist < 1.8 then
						-- ¡Contacto! Infecta
						if h.sensor and h.sensor.Parent then
							h.sensor:Destroy()
						end
						toRemove[i] = true

						if h.targetPlayer and not infected[h.targetPlayer] then
							task.spawn(startInfection, h.targetPlayer)
						elseif h.targetNpc and not infectedNpcs[h.targetNpc] then
							task.spawn(corruptNpc, h.targetNpc)
						end
					end
				else
					-- Atascado: pierde vida rápido
					h.life -= 8
				end
			end

			-- Limpia en orden inverso
			for i = #hunterNodes, 1, -1 do
				if toRemove[i] then
					table.remove(hunterNodes, i)
				end
			end
		end)

		-- ── Scan periódico: lanza hunters a objetivos cercanos ────────
		RunService.Heartbeat:Connect(function(dt)
			hunterScanT += dt
			if hunterScanT < 4.0 then return end
			hunterScanT = 0

			-- No lanza hunters si ya hay muchos activos (máx 4 simultáneos)
			if #hunterNodes >= 4 then return end

			local Players = game:GetService("Players")

			-- ── Jugadores no infectados ────────────────────────────────
			for _, plr in ipairs(Players:GetPlayers()) do
				if infected[plr] then continue end
				local ch = plr.Character
				if not ch then continue end
				local hrp = ch:FindFirstChild("HumanoidRootPart")
				if not hrp then continue end

				-- ¿Ya tiene un hunter asignado?
				local alreadyHunted = false
				for _, h in ipairs(hunterNodes) do
					if h.targetPlayer == plr then
						alreadyHunted = true
						break
					end
				end
				if alreadyHunted then continue end

				local blob = closestBlob(hrp.Position, HUNTER_RANGE)
				if blob then
					spawnHunter(blob.pos, blob.normal or Vector3.new(0,1,0),
						ch, plr, nil)
					print(string.format(
						"[Pibby|v3.23] Hunter lanzado → %s", plr.Name))
				end
			end

			-- ── NPCs no infectados ─────────────────────────────────────
			for _, npc in ipairs(infectedNpcs and {} or {}) do end   -- placeholder
			for _, obj in ipairs(workspace:GetChildren()) do
				if infectedNpcs[obj] then continue end
				local hum = obj:FindFirstChildOfClass("Humanoid")
				if not hum then continue end
				local hrp = obj:FindFirstChild("HumanoidRootPart")
				if not hrp then continue end
				-- No atacar a jugadores por esta rama
				if Players:GetPlayerFromCharacter(obj) then continue end

				local alreadyHunted = false
				for _, h in ipairs(hunterNodes) do
					if h.targetNpc == obj then
						alreadyHunted = true
						break
					end
				end
				if alreadyHunted then continue end

				local blob = closestBlob(hrp.Position, HUNTER_RANGE)
				if blob then
					spawnHunter(blob.pos, blob.normal or Vector3.new(0,1,0),
						obj, nil, obj)
				end
			end
		end)

		print("[Pibby|v3.23] Survivalist — infección por tendril cazador físico")
	end

	-- ════════════════════════════════════════════════════════════════
	--  BLOQUE 3 (SURVIVALIST): SUPRIMIR MENSAJES DEL MUNDO
	-- ════════════════════════════════════════════════════════════════

	if SURV then

		function spawnBillboard(part)
			return
		end

		folder.DescendantAdded:Connect(function(obj)
			if obj:IsA("BillboardGui") then
				task.defer(function()
					if obj and obj.Parent then obj:Destroy() end
				end)
			end
		end)

		local _survScreenMsg = screenMsg
		function screenMsg(player, txt, col, dur)
			if infected[player] then
				_survScreenMsg(player, txt, col, dur)
			end
		end

		task.defer(function()
			for _, obj in ipairs(folder:GetDescendants()) do
				if obj:IsA("BillboardGui") then
					pcall(function() obj:Destroy() end)
				end
			end
		end)

		print("[Pibby|v3.23] Survivalist — billboards del mundo eliminados")
		print("[Pibby|v3.23] Survivalist — screenMsg solo a jugadores infectados")
	end

	-- ════════════════════════════════════════════════════════════════
	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.23 — PAREDES ROBUSTAS + SURVIVALIST AVANZADO         ║")
	print("║  ✦ 7 rayos detectan pared ANTES de moverse                     ║")
	print("║  ✦ 5 rayos validan cada segmento (anti-penetración real)       ║")
	print("║  ✦ Ángulos de escape calculados desde la normal real de pared  ║")
	if SURV then
		print("║  ✦ [SURV] Abanico 7 rayos — elige la dirección más libre       ║")
		print("║  ✦ [SURV] Infección solo por tendril cazador físico             ║")
		print("║    el micelio rodea paredes para alcanzarte — no hay atajos     ║")
		print("║  ✦ [SURV] Billboards del mundo eliminados automáticamente       ║")
		print("║  ✦ [SURV] screenMsg silenciado para jugadores no infectados     ║")
	end
	print("╚══════════════════════════════════════════════════════════════════╝")

end)()
-- ════════════════════════════════════════════════════════════════════
--  v3.24 — PLUG & PLAY: AUTO-CREACIÓN Y AUTO-INSERCIÓN EN "Infeccion"
--
--  Pega este bloque AL PRINCIPIO de todo el script, antes de
--  cualquier otra cosa (incluso antes de local TweenService...).
--
--  Qué hace:
--  ✦ Si el script YA vive dentro de una BasePart llamada "Infeccion"
--    → no hace nada, arranca normalmente.
--  ✦ Si el script está en otro lado (ServerScriptService, workspace, etc.)
--    → busca una Part "Infeccion" existente.
--      - Si la encuentra → se mete dentro.
--      - Si NO la encuentra → crea la Part en el centro del mapa
--        con animación de aparición, luego se mete dentro.
--  ✦ Después de re-parentar el script, la ejecución continúa
--    en el nuevo contexto sin necesidad de reiniciar.
-- ════════════════════════════════════════════════════════════════════
;(function()

	-- ── ¿Ya estamos dentro de una Part "Infeccion"? ──────────────────
	if script.Parent and script.Parent:IsA("BasePart")
		and script.Parent.Name == "Infeccion" then
		-- Todo bien, ya estamos en su sitio
		print("[Pibby|v3.24] ✔ Script ya dentro de 'Infeccion' — arranque directo")
		return
	end

	-- ── Busca o crea la Part ──────────────────────────────────────────
	local infPart = workspace:FindFirstChild("Infeccion")

	if infPart and infPart:IsA("BasePart") then
		-- Ya existe en el workspace pero el script no está dentro
		print("[Pibby|v3.24] 🔍 'Infeccion' encontrada — insertando script")
	else
		-- No existe: la creamos con animación de aparición
		print("[Pibby|v3.24] ⚙  Creando Part 'Infeccion' automáticamente...")

		infPart = Instance.new("Part")
		infPart.Name        = "Infeccion"
		infPart.Anchored    = true
		infPart.CanCollide  = false
		infPart.CastShadow  = false
		infPart.Shape       = Enum.PartType.Block
		infPart.Size        = Vector3.new(4, 4, 4)
		infPart.Material    = Enum.Material.Neon
		infPart.Color       = Color3.fromRGB(255, 0, 255)
		infPart.Transparency= 1   -- empieza invisible

		-- ── Posición inteligente ──────────────────────────────────────
		-- Intenta aterrizar sobre el suelo del mapa usando un raycast.
		-- Si no hay suelo, usa 0,5,0 como fallback.
		local groundRay = workspace:Raycast(
			Vector3.new(0, 200, 0),
			Vector3.new(0, -1, 0) * 400,
			(function()
				local rp = RaycastParams.new()
				rp.FilterType = Enum.RaycastFilterType.Exclude
				rp.FilterDescendantsInstances = {}
				return rp
			end)()
		)

		if groundRay then
			infPart.Position = groundRay.Position + Vector3.new(0, 2.5, 0)
		else
			infPart.Position = Vector3.new(0, 5, 0)
		end

		infPart.Parent = workspace

		-- ── Animación de aparición (sin TweenService aún disponible) ──
		-- Usamos un loop manual porque TweenService todavía no está
		-- declarado en este punto del script.
		local TS = game:GetService("TweenService")

		-- Flash inicial
		local flash = Instance.new("Part")
		flash.Anchored=true; flash.CanCollide=false; flash.CastShadow=false
		flash.Shape=Enum.PartType.Ball; flash.Size=Vector3.new(0.5,0.5,0.5)
		flash.Position=infPart.Position; flash.Color=Color3.fromRGB(255,0,255)
		flash.Material=Enum.Material.Neon; flash.Transparency=0
		flash.Parent=workspace

		local li=Instance.new("PointLight")
		li.Color=Color3.fromRGB(255,0,255); li.Range=0; li.Brightness=12; li.Parent=flash

		-- Expansión del flash
		TS:Create(flash, TweenInfo.new(0.6, Enum.EasingStyle.Sine), {
			Size        = Vector3.new(18,18,18),
			Transparency= 1
		}):Play()
		TS:Create(li, TweenInfo.new(0.5), {Range=50, Brightness=0}):Play()

		-- Aparece la Part "Infeccion"
		task.delay(0.15, function()
			TS:Create(infPart, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
				Transparency = 0
			}):Play()

			-- Pulso de luz en la Part
			local pLi=Instance.new("PointLight")
			pLi.Color=Color3.fromRGB(255,0,255); pLi.Range=30; pLi.Brightness=5
			pLi.Parent=infPart
			TS:Create(pLi, TweenInfo.new(2), {Brightness=0.8, Range=12}):Play()
		end)

		-- Limpia el flash tras la animación
		task.delay(0.7, function()
			if flash then flash:Destroy() end
		end)

		-- BillboardGui de aviso flotante sobre la Part
		task.delay(0.2, function()
			if not (infPart and infPart.Parent) then return end
			local bb = Instance.new("BillboardGui")
			bb.Size = UDim2.new(0,200,0,40)
			bb.StudsOffset = Vector3.new(0,4,0)
			bb.AlwaysOnTop = true
			bb.Parent = infPart

			local lbl = Instance.new("TextLabel")
			lbl.Size = UDim2.new(1,0,1,0)
			lbl.BackgroundTransparency = 1
			lbl.Text = "◈ INFECCIÓN CREADA ◈"
			lbl.TextColor3 = Color3.fromRGB(255,0,255)
			lbl.TextSize = 18
			lbl.Font = Enum.Font.GothamBold
			lbl.TextStrokeTransparency = 0.3
			lbl.TextTransparency = 1
			lbl.Parent = bb

			TS:Create(lbl, TweenInfo.new(0.4), {TextTransparency=0}):Play()
			task.delay(3, function()
				TS:Create(lbl, TweenInfo.new(0.8), {TextTransparency=1}):Play()
				task.delay(0.9, function()
					if bb then bb:Destroy() end
				end)
			end)
		end)

		task.wait(0.25)   -- pequeña pausa para que la Part esté lista

		print(string.format(
			"[Pibby|v3.24] ✔ Part 'Infeccion' creada en (%.1f, %.1f, %.1f)",
			infPart.Position.X, infPart.Position.Y, infPart.Position.Z))
	end

	-- ── Inserta el script dentro de la Part ──────────────────────────
	-- Nota: en Roblox, re-parentar un Script que YA ESTÁ CORRIENDO
	-- es válido en el servidor. El script continúa ejecutándose
	-- normalmente desde donde estaba.
	local ok, err = pcall(function()
		script.Parent = infPart
	end)

	if ok then
		print("[Pibby|v3.24] ✔ Script insertado dentro de 'Infeccion' — continuando")
	else
		-- Si el re-parent falla (permisos, etc.), el script sigue corriendo
		-- desde su posición original. El resto del código usa getOrigin()
		-- que ya maneja este caso.
		warn("[Pibby|v3.24] ⚠ No se pudo re-parentar el script: "..tostring(err))
		warn("[Pibby|v3.24]   El script continuará desde su posición original")
	end

	-- ── Renombra el script para claridad (opcional) ───────────────────
	pcall(function()
		if script.Name ~= "Infeccion" and script.Name ~= "Scripteless" then
			script.Name = "PibbyCore"
		end
	end)

	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.24 — PLUG & PLAY                                     ║")
	if script.Parent == infPart then
		print("║  ✔ Script dentro de 'Infeccion' — listo para correr             ║")
	else
		print("║  ⚠ Script fuera de 'Infeccion' — usando getOrigin() como proxy  ║")
	end
	print("║  Posición del núcleo: "..string.format(
		"(%.0f, %.0f, %.0f)",
		infPart.Position.X, infPart.Position.Y, infPart.Position.Z).."                     ║")
	print("╚══════════════════════════════════════════════════════════════════╝")

end)()
-- ════════════════════════════════════════════════════════════════════
--  v3.25 — OPTIMIZACIÓN: CONTROL DE LUCES + FIX DE BLOBS GIGANTES
--
--  ✦ [TODOS LOS MODOS] Fix blobs oscuros enormes en Fase 3+
--  ✦ [TODOS LOS MODOS] Sistema de reciclaje automático de partes
--  ✦ [SURV] Sin PointLights en tendrils, blobs ni nódulos
--  ✦ [SURV] Bioluminiscencia solo cada 5 minutos
--  ✦ [SURV] Luces de esporas se desvanecen al aterrizar
--  ✦ [SURV] spawnFlash sin PointLight permanente (destello breve)
-- ════════════════════════════════════════════════════════════════════
;(function()

	local SURV = CFG.SurvivalistMode == true

	-- ════════════════════════════════════════════════════════════════
	--  BLOQUE 1 (TODOS LOS MODOS): FIX DE BLOBS GIGANTES
	--
	--  Problema: en Fase 3+ spawnCorruptionCluster y spawnBlob
	--  pueden generar esferas muy grandes porque:
	--  1. crad llega hasta 8 studs en spawnCorruptionCluster
	--  2. pressure_burst usa radius*0.08 * presión que puede dispararse
	--  3. En Fase 3+ se llaman con ageFrac alto → rD() + grande
	--
	--  Solución: caps duros por tipo de nodo y por fase.
	-- ════════════════════════════════════════════════════════════════

	-- Límites máximos de radio según fase y tipo
	local function maxBlobRadius(ageFrac)
		-- En fases altas los blobs oscuros (ageFrac > 0.42) se limitarán
		-- para evitar las esferas enormes negras
		if currentPhase >= 3 then
			if ageFrac and ageFrac > 0.42 then
				return 1.8   -- blobs oscuros: máx 1.8 studs en fase 3+
			end
			return 2.5       -- blobs normales: igual que BlobRadMax
		elseif currentPhase >= 2 then
			if ageFrac and ageFrac > 0.42 then
				return 2.2
			end
			return CFG.BlobRadMax
		end
		return CFG.BlobRadMax
	end

	-- Override de spawnBlob para aplicar el cap de tamaño
	local _v325SpawnBlob = spawnBlob
	function spawnBlob(pos, normal, radius, ageFrac)
		-- Aplica el límite de radio según fase
		local cap = maxBlobRadius(ageFrac)
		if radius and radius > cap then
			radius = cap
		end
		-- También limita el mínimo para no dejar blobs invisiblemente pequeños
		if radius then
			radius = math.max(CFG.BlobRadMin, radius)
		end
		return _v325SpawnBlob(pos, normal, radius, ageFrac)
	end

	-- Override de spawnCorruptionCluster para limitar crad en fases altas
	-- (no podemos tocar la función directamente, pero podemos hookear
	--  spawnBlob que es lo que usa internamente — ya hecho arriba)
	-- Adicionalmente: limita el radio de los satélites del cluster
	-- sobreescribiendo la lógica de clusterScanT indirectamente
	-- mediante un flag de radio máximo global.

	-- ════════════════════════════════════════════════════════════════
	--  BLOQUE 2 (TODOS LOS MODOS): RECICLAJE AUTOMÁTICO DE PARTES
	--
	--  Cuando partCount supera el 72% de MaxParts, el sistema
	--  empieza a disolver silenciosamente los blobs más antiguos
	--  (los primeros en blobReg). Así el micelio siempre tiene
	--  margen para crecer sin chocar con el límite duro.
	-- ════════════════════════════════════════════════════════════════

	local RECYCLE_THRESHOLD = 0.72   -- empieza a reciclar al 72% del límite
	local RECYCLE_RATE      = 0.5    -- segundos entre reciclajes
	local recycleTimer      = 0
	local recycledTotal     = 0

	-- Busca y disuelve la Part de micelio más antigua del folder
	local function recycleOldestPart()
		-- Recorre los primeros elementos del folder (los más viejos)
		for _, child in ipairs(folder:GetChildren()) do
			if child:IsA("BasePart")
				and child.Name ~= "HunterSensor"
				and child.Anchored
				and child.Transparency < 0.9 then

				-- Disuelve suavemente
				local ts = game:GetService("TweenService")
				ts:Create(child, TweenInfo.new(0.8, Enum.EasingStyle.Sine), {
					Transparency = 1,
					Size = child.Size * 0.4
				}):Play()

				task.delay(0.85, function()
					if child and child.Parent then
						child:Destroy()
						partCount = math.max(0, partCount - 1)
						recycledTotal += 1
					end
				end)
				return   -- solo 1 por tick
			end
		end
	end

	RunService.Heartbeat:Connect(function(dt)
		if not infectionReady then return end
		recycleTimer += dt
		if recycleTimer < RECYCLE_RATE then return end
		recycleTimer = 0

		local threshold = math.floor(CFG.MaxParts * RECYCLE_THRESHOLD)
		if partCount > threshold then
			local excess = partCount - threshold
			-- Recicla más rápido cuanto más cerca del límite
			local batchSize = math.min(math.ceil(excess / 100), 5)
			for _ = 1, batchSize do
				recycleOldestPart()
			end
		end
	end)

	-- ════════════════════════════════════════════════════════════════
	--  BLOQUE 3 (SOLO SURVIVALIST): CONTROL DE LUCES
	-- ════════════════════════════════════════════════════════════════

	if not SURV then
		print("╔══════════════════════════════════════════════════════════════════╗")
		print("║  PIBBY v3.25 — OPTIMIZACIÓN                                     ║")
		print("║  ✦ Fix blobs gigantes en Fase 3+ (cap de radio por fase)        ║")
		print("║  ✦ Reciclaje automático al superar 72%% del límite de partes    ║")
		print("║  [Modo Survivalist desactivado — sin más cambios]               ║")
		print("╚══════════════════════════════════════════════════════════════════╝")
		return
	end

	-- ── 3A: spawnBlob SIN PointLight en modo Survivalist ─────────────
	local _v325SurvSpawnBlob = spawnBlob
	function spawnBlob(pos, normal, radius, ageFrac)
		-- Llama al blob ya con el cap aplicado (heredado del bloque 1)
		local p = _v325SurvSpawnBlob(pos, normal, radius, ageFrac)
		if not p then return p end

		-- Elimina cualquier PointLight que el blob haya creado
		task.defer(function()
			if not (p and p.Parent) then return end
			for _, child in ipairs(p:GetChildren()) do
				if child:IsA("PointLight") then
					child:Destroy()
				end
			end
		end)
		return p
	end

	-- ── 3B: spawnTendril SIN PointLight en modo Survivalist ──────────
	local _v325SurvSpawnTendril = spawnTendril
	function spawnTendril(from, to, sn, age, isNeon, isRhizo)
		local p = _v325SurvSpawnTendril(from, to, sn, age, isNeon, isRhizo)
		if not p then return p end

		task.defer(function()
			if not (p and p.Parent) then return end
			for _, child in ipairs(p:GetChildren()) do
				if child:IsA("PointLight") then
					child:Destroy()
				end
			end
		end)
		return p
	end

	-- ── 3C: spawnFlash SIN PointLight permanente ─────────────────────
	-- En Survivalist el flash sigue siendo visible (es una Part que
	-- se expande), pero sin luz de punto. Así sigue siendo visible
	-- pero no afecta al rendimiento de red.
	local _v325SurvSpawnFlash = spawnFlash
	function spawnFlash(pos, normal, scale)
		if partCount >= CFG.MaxParts then return end
		scale = scale or 1

		local p = Instance.new("Part")
		p.Anchored=true; p.CanCollide=false; p.CastShadow=false
		p.Shape=Enum.PartType.Ball
		p.Size=Vector3.new(0.35,0.35,0.35)*scale
		p.Position=pos+normal*0.35
		p.Color=rN(); p.Material=Enum.Material.Neon; p.Transparency=0
		p.Parent=folder; partCount+=1

		-- Sin PointLight — solo la Part visual
		TweenService:Create(p,TweenInfo.new(0.22),{
			Size=Vector3.new(4.5,4.5,4.5)*scale,
			Transparency=1
		}):Play()
		task.delay(0.26,function()
			if p then p:Destroy(); partCount=math.max(0,partCount-1) end
		end)
	end

	-- ── 3D: BIOLUMINISCENCIA CADA 5 MINUTOS ──────────────────────────
	-- La bioluminiscencia original corre cada BioInterval = 4 segundos.
	-- En Survivalist la mantenemos pero con intervalo de 300s (5 min).
	-- Los pulsos morados siguen siendo visibles porque son cambios de
	-- color en Parts existentes, NO nuevas luces.

	local BIO_SURV_INTERVAL = 300   -- 5 minutos
	local bioSurvTimer      = 0
	local bioSurvReady      = true  -- permite el primer pulso al arrancar

	-- Desactiva el heartbeat de bioluminiscencia original reemplazando
	-- la función tickBioLum por una versión con intervalo extendido.
	local _v325OrigTickBioLum = tickBioLum
	function tickBioLum(dt)
		-- En Survivalist: ignoramos el timer original (bioTimer / BioInterval)
		-- y usamos nuestro propio contador de 5 minutos.
		bioSurvTimer += dt

		if bioSurvReady or bioSurvTimer >= BIO_SURV_INTERVAL then
			bioSurvReady  = false
			bioSurvTimer  = 0

			-- Dispara el pulso (usa bioLumReg existente, sin crear luces nuevas)
			if #blobReg > 0 then
				local origin = blobReg[math.random(#blobReg)].pos
				triggerBioPulse(origin)
				print("[Pibby|v3.25|Surv] 💜 Pulso de bioluminiscencia (próximo en 5 min)")
			end
		end
		-- NO llama a _v325OrigTickBioLum para evitar el pulso cada 4s
	end

	-- ── 3E: LUCES DE ESPORAS QUE SE DESVANECEN ───────────────────────
	-- Las esporas ya generan una PointLight al spawnearse.
	-- Nos aseguramos de que esa luz SIEMPRE se desvanezca y destruya
	-- al aterrizar la espora (o antes).
	-- Hook en updateSpores: cuando una espora aterriza, su luz muere.

	-- Interceptamos la creación de esporas para garantizar el fade-out
	local _v325OrigLaunchSpore = launchSpore
	function launchSpore(fromPos, fromNormal)
		_v325OrigLaunchSpore(fromPos, fromNormal)

		-- La espora recién creada es el último elemento de `spores`
		local s = spores[#spores]
		if not s then return end
		if not (s.part and s.part.Parent) then return end

		-- Asegura que la luz de la espora tenga un fade-out programado
		local li = s.light
		if li and li.Parent then
			-- Fade gradual durante el vuelo
			local flightTime = s.flightTime or CFG.SporeFlightMax
			task.spawn(function()
				-- Empieza brillante, va bajando
				local t0 = tick()
				while li and li.Parent and s.part and s.part.Parent do
					local elapsed = tick() - t0
					local frac    = math.clamp(elapsed / flightTime, 0, 1)
					-- Fade: 1.2 → 0 durante el vuelo
					li.Brightness = math.max(0, 1.2 * (1 - frac))
					li.Range      = math.max(0, 7 * (1 - frac * 0.7))
					if frac >= 1 then break end
					task.wait(0.08)
				end
				-- Destruye la luz al aterrizar
				task.delay(0.05, function()
					if li and li.Parent then li:Destroy() end
				end)
			end)
		end
	end

	-- ── 3F: LIMPIAR LUCES QUE OTROS SISTEMAS PUEDAN CREAR ────────────
	-- Vigilancia pasiva: cada 8 segundos elimina PointLights huérfanas
	-- que hayan quedado en partes del folder del micelio.
	local lightCleanT = 0
	RunService.Heartbeat:Connect(function(dt)
		lightCleanT += dt
		if lightCleanT < 8 then return end
		lightCleanT = 0

		local removed = 0
		for _, child in ipairs(folder:GetDescendants()) do
			if child:IsA("PointLight") then
				-- Permite solo luces con muy poca vida (brightness < 0.3)
				-- que ya casi han desaparecido — las destruye antes
				if child.Brightness <= 0.3 then
					child:Destroy()
					removed += 1
				elseif child.Brightness > 0.3 then
					-- Fuerza un fade hacia 0 en 1 segundo
					TweenService:Create(child, TweenInfo.new(1.0), {
						Brightness = 0,
						Range      = 0
					}):Play()
					task.delay(1.05, function()
						if child and child.Parent then child:Destroy() end
					end)
					removed += 1
				end
			end
		end
		if removed > 0 then
			print(string.format("[Pibby|v3.25|Surv] 🔦 %d luces eliminadas", removed))
		end
	end)

	-- ── 3G: SIN LUCES EN SISTEMAS SECUNDARIOS ────────────────────────
	-- Algunos sistemas (clusters, rizomorfos, frutos) crean PointLights.
	-- En Survivalist, cualquier Part nueva que entre al folder sin
	-- ser un HunterSensor pierde sus PointLights inmediatamente.

	folder.DescendantAdded:Connect(function(obj)
		if not SURV then return end
		if obj:IsA("PointLight") then
			-- Permite solo si su padre es una espora en vuelo
			-- (las esporas tienen el fade ya programado en 3E)
			local parent = obj.Parent
			if parent and parent.Name == "PibbySpore" then return end

			-- Todo lo demás: fade rápido y destruir
			TweenService:Create(obj, TweenInfo.new(0.5), {
				Brightness = 0, Range = 0
			}):Play()
			task.delay(0.55, function()
				if obj and obj.Parent then obj:Destroy() end
			end)
		end
	end)

	print("╔══════════════════════════════════════════════════════════════════╗")
	print("║  PIBBY v3.25 — OPTIMIZACIÓN COMPLETA                           ║")
	print("║  [Todos los modos]                                              ║")
	print("║  ✦ Blobs oscuros gigantes — cap de radio por fase              ║")
	print("║    Fase 3+: blobs oscuros ≤ 1.8 studs, normales ≤ 2.5         ║")
	print("║  ✦ Reciclaje automático de partes viejas al 72%% del límite   ║")
	print("║    → el micelio siempre tiene margen para expandirse           ║")
	print("║  [Solo Survivalist]                                             ║")
	print("║  ✦ Sin PointLights en blobs, tendrils, nódulos ni clusters     ║")
	print("║  ✦ spawnFlash sin luz de punto — solo partícula visual         ║")
	print("║  ✦ Bioluminiscencia cada 5 min (pulsos morados conservados)    ║")
	print("║  ✦ Luces de esporas se desvanecen durante el vuelo             ║")
	print("║  ✦ Vigilancia pasiva: elimina luces residuales cada 8s        ║")
	print("╚══════════════════════════════════════════════════════════════════╝")

end)()

--[[
╔══════════════════════════════════════════════════════════════════════════════╗
║ CORRUPCIÓN PIBBY — BIOMASA FÚNGICA v4.1                                      ║
║ • Bloque de audio independiente y autocontenido                              ║
║ • Fix DEFINITIVO de "pedazos huérfanos al lado del jugador"                  ║
╚══════════════════════════════════════════════════════════════════════════════╝
]]

local TweenService    = game:GetService("TweenService")
local Players         = game:GetService("Players")
local RunService      = game:GetService("RunService")
local Lighting        = game:GetService("Lighting")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SoundService    = game:GetService("SoundService")
local StarterPlayer   = game:GetService("StarterPlayer")

local CFG, PAL, STATE, UTIL, FX, REMOTE, AUDIO

-- ════════════════════════════════════════════════════════════════════
-- BLOQUE 1: CONFIG & PALETAS
-- ════════════════════════════════════════════════════════════════════
;(function()
    CFG = {
        StepSize=1.6, TickRate=0.8, LifeMin=20, LifeMax=55,
        BranchChance=0.18, BranchDecay=0.62, MaxDepth=8,
        MaxNodes=6000, MaxParts=300000,
        RayDown=35, SurfaceOff=0.05,
        TendrilW=0.14, TendrilH=0.06,
        NeonChance=0.07, RhizoChance=0.045,
        RhizoWidth=0.52, RhizoHeight=0.20,
        RhizoLifeMin=28, RhizoLifeMax=70, RhizoStep=4.8,
        BlobChance=0.12, BlobRadMin=0.4, BlobRadMax=2.5,
        BioInterval=4.0,
        MapConsumeOn=true, MapConsumeChance=0.007,
        MapConsumeRadius=3.5, MapConsumeTime=14,
        MemoryDecay=50, MemoryUpdateRate=2,
        CellSize=4, MinDist=1.6, PlayerRadius=5.5,
        SpreadRadius=9, SpreadChance=0.004,
        Phase1At=3200, Phase2At=20000, Phase3At=50000,
        Phase4At=120000, Phase5At=250000,
        AutoWaveSec=82, InitialWaves=3,
        NpcCorruptRadius=8, NpcChaseSpeed=0.85,
        NpcInfectRadius=4, NpcInfectChance=0.006,
        NpcScanInterval=4,
        -- ANTI-HUÉRFANOS (FIX REFORZADO)
        MaxOrphanFails=2,
        MaxBranchDist=200,
        AnchorRayLen=8,
        ConnectivityCheck=true,   -- valida que el segmento no atraviese aire vacío
        MaxStepDistance=4.0,      -- ningún segmento puede ser más largo que esto
        MinSpawnDistFromPlayer=4, -- no spawnees a <4 studs de un jugador NUNCA
        -- AUDIO
        AudioOn=true,
        HeartbeatBase=2.4,
    }

    PAL = {
        neon = {
            Color3.fromRGB(255,0,255), Color3.fromRGB(0,210,255),
            Color3.fromRGB(180,0,255), Color3.fromRGB(255,55,0),
            Color3.fromRGB(255,255,255), Color3.fromRGB(0,255,110),
            Color3.fromRGB(255,210,0),  Color3.fromRGB(80,255,200),
        },
        dark = {
            Color3.fromRGB(6,0,16), Color3.fromRGB(10,0,24),
            Color3.fromRGB(4,0,10), Color3.fromRGB(14,0,32),
            Color3.fromRGB(8,0,20), Color3.fromRGB(3,0,12),
        },
        mycel = {
            Color3.fromRGB(222,208,242), Color3.fromRGB(202,182,228),
            Color3.fromRGB(182,158,214), Color3.fromRGB(162,130,198),
            Color3.fromRGB(138,102,178), Color3.fromRGB(108,72,150),
            Color3.fromRGB(72,32,112),   Color3.fromRGB(42,8,74),
            Color3.fromRGB(18,0,38),
        },
        rhizo = {Color3.fromRGB(28,0,58),Color3.fromRGB(18,0,44),Color3.fromRGB(48,0,88),Color3.fromRGB(10,0,30)},
        glitch = {
            "ERROR %d%%","NULL PTR","STACK OVERFLOW","REALITY.EXE CRASH",
            "SYSTEM FAILURE","ENTITY OVERFLOW","FUNGAL OVERRIDE",
            "CONSCIOUSNESS LEAK","CONNECTION LOST","RENDER: 0",
        },
    }
end)()

-- ════════════════════════════════════════════════════════════════════
-- BLOQUE 2: ESTADO & UTILIDADES
-- ════════════════════════════════════════════════════════════════════
;(function()
    local folder = workspace:FindFirstChild("PibbyFolder")
    if not folder then
        folder = Instance.new("Folder"); folder.Name="PibbyFolder"; folder.Parent=workspace
    else
        folder:ClearAllChildren()
    end

    STATE = {
        folder=folder, partCount=0,
        nodes={}, blobReg={}, consumed={},
        infected={}, infectedNpcs={}, playerMem={},
        spatialGrid={},
        timerAcc=0, waveTimer=0, memTimer=0, npcScanTimer=0,
        currentPhase=0, infectionReady=false, running=true,
        playerDistortion={},
        origLighting={
            Ambient=Lighting.Ambient, OutdoorAmbient=Lighting.OutdoorAmbient,
            FogColor=Lighting.FogColor, FogEnd=Lighting.FogEnd,
            FogStart=Lighting.FogStart, Brightness=Lighting.Brightness,
        },
    }

    local rpMain = RaycastParams.new()
    rpMain.FilterType = Enum.RaycastFilterType.Exclude
    rpMain.FilterDescendantsInstances = {folder}
    rpMain.IgnoreWater = true

    local rpNoPlayer = RaycastParams.new()
    rpNoPlayer.FilterType = Enum.RaycastFilterType.Exclude
    rpNoPlayer.IgnoreWater = true

    local function refreshNoPlayer()
        local list = {folder}
        for _,pl in ipairs(Players:GetPlayers()) do
            if pl.Character then table.insert(list, pl.Character) end
        end
        rpNoPlayer.FilterDescendantsInstances = list
    end

    UTIL = {
        rpMain = rpMain, rpNoPlayer = rpNoPlayer,
        refreshNoPlayer = refreshNoPlayer,

        lerpC = function(a,b,t)
            return Color3.new(a.R+(b.R-a.R)*t, a.G+(b.G-a.G)*t, a.B+(b.B-a.B)*t)
        end,
        rN = function() return PAL.neon[math.random(#PAL.neon)] end,
        rD = function() return PAL.dark[math.random(#PAL.dark)] end,
        rR = function() return PAL.rhizo[math.random(#PAL.rhizo)] end,
        rG = function() return PAL.glitch[math.random(#PAL.glitch)] end,

        mycelColor = function(f)
            f = math.clamp(f,0,1); local n = #PAL.mycel
            local i = math.clamp(1+math.floor(f*(n-1)),1,n-1)
            local a, b = PAL.mycel[i], PAL.mycel[i+1]
            local t = (f*(n-1))-(i-1)
            return Color3.new(a.R+(b.R-a.R)*t, a.G+(b.G-a.G)*t, a.B+(b.B-a.B)*t)
        end,

        gKey = function(p)
            return math.floor(p.X/CFG.CellSize)..","..math.floor(p.Y/CFG.CellSize)..","..math.floor(p.Z/CFG.CellSize)
        end,

        isOcc = function(pos)
            local cx = math.floor(pos.X/CFG.CellSize)
            local cy = math.floor(pos.Y/CFG.CellSize)
            local cz = math.floor(pos.Z/CFG.CellSize)
            for dx=-1,1 do for dy=-1,1 do for dz=-1,1 do
                local k = (cx+dx)..","..(cy+dy)..","..(cz+dz)
                local cell = STATE.spatialGrid[k]
                if cell then
                    for _,p in ipairs(cell) do
                        if (p-pos).Magnitude < CFG.MinDist then return true end
                    end
                end
            end end end
            return false
        end,

        addToGrid = function(pos)
            local k = UTIL.gKey(pos)
            STATE.spatialGrid[k] = STATE.spatialGrid[k] or {}
            table.insert(STATE.spatialGrid[k], pos)
        end,

        nearPlayer = function(pos, customRadius)
            local r = customRadius or CFG.PlayerRadius
            for _,pl in ipairs(Players:GetPlayers()) do
                local ch = pl.Character
                if ch then
                    local hrp = ch:FindFirstChild("HumanoidRootPart")
                    if hrp and (hrp.Position-pos).Magnitude < r then
                        return true, pl
                    end
                end
            end
            return false
        end,

        castSurf = function(origin, dir, len, params)
            len = len or CFG.RayDown
            local r = workspace:Raycast(origin, dir.Unit*len, params or rpMain)
            if r then return r.Position + r.Normal*CFG.SurfaceOff, r.Normal end
            return nil, nil
        end,

        -- NUEVO: valida que dos puntos estén "conectados" (sin pared atravesada
        -- que indique salto raro). Devuelve true si la conexión es limpia.
        canConnect = function(fromPos, toPos)
            local diff = toPos - fromPos
            local dist = diff.Magnitude
            if dist < 0.01 then return true end
            if dist > CFG.MaxStepDistance then return false end
            -- Raycast desde fromPos hacia toPos: si choca antes de llegar al destino
            -- significa que hay una pared en medio = salto inválido
            local r = workspace:Raycast(fromPos + Vector3.new(0, 0.3, 0), diff, rpMain)
            if r and (r.Position - fromPos).Magnitude < dist - 0.5 then
                return false
            end
            return true
        end,
    }
end)()

