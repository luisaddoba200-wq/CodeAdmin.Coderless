-- BLOQUE 3: REMOTE EVENT + INYECCIÓN LOCALSCRIPT
-- ════════════════════════════════════════════════════════════════════
;(function()
    local re = ReplicatedStorage:FindFirstChild("__PibbyDistort")
    if not re then
        re = Instance.new("RemoteEvent")
        re.Name = "__PibbyDistort"
        re.Parent = ReplicatedStorage
    end
    REMOTE = re

    local sps = StarterPlayer:FindFirstChild("StarterPlayerScripts")
    local existing = sps:FindFirstChild("__PibbyClient")
    if existing then existing:Destroy() end

    local ls = Instance.new("LocalScript")
    ls.Name = "__PibbyClient"
    ls.Source = [==[
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local TS = game:GetService("TweenService")
local plr = Players.LocalPlayer
local re  = RS:WaitForChild("__PibbyDistort")
local NEON = {Color3.fromRGB(255,0,255),Color3.fromRGB(0,210,255),Color3.fromRGB(180,0,255),Color3.fromRGB(255,55,0),Color3.fromRGB(0,255,110)}
local DARK = {Color3.fromRGB(6,0,16),Color3.fromRGB(10,0,24),Color3.fromRGB(4,0,10)}
local GLITCH = {"ERROR %d%%","NULL PTR","REALITY.EXE","FUNGAL OVERRIDE"}
local function rN() return NEON[math.random(#NEON)] end
local function rD() return DARK[math.random(#DARK)] end
local function rG() return GLITCH[math.random(#GLITCH)] end
local activeGui, active = nil, false
local function clear()
    active = false
    if activeGui then activeGui:Destroy(); activeGui = nil end
end
local function start(dtype)
    clear(); active = true
    local sg = Instance.new("ScreenGui")
    sg.Name = "__PibbyDistort"; sg.ResetOnSpawn = false
    sg.IgnoreGuiInset = true; sg.DisplayOrder = 99999
    sg.Parent = plr:WaitForChild("PlayerGui"); activeGui = sg
    if dtype == "scanlines" then
        local n = 18
        for i=1,n do
            local f = Instance.new("Frame", sg)
            f.Size = UDim2.new(1,0,0,3)
            f.Position = UDim2.new(0,0,(i-1)/n,0)
            f.BackgroundColor3 = rN(); f.BackgroundTransparency = 0.55
            f.BorderSizePixel = 0
        end
        task.spawn(function()
            local off = 0
            while active and sg.Parent do
                off = (off+0.008)%1
                for i,f in ipairs(sg:GetChildren()) do
                    if f:IsA("Frame") then
                        f.Position = UDim2.new(0,0,((i-1)/n+off)%1,0)
                        if math.random()<0.04 then f.BackgroundColor3 = rN() end
                    end
                end
                task.wait(0.04)
            end
        end)
    elseif dtype == "static" then
        for _i=1,60 do
            local px = Instance.new("Frame", sg)
            px.Size = UDim2.new(0,math.random(2,8),0,math.random(2,8))
            px.Position = UDim2.new(math.random()*0.98,0,math.random()*0.98,0)
            px.BackgroundColor3 = math.random()<0.5 and rN() or rD()
            px.BackgroundTransparency = math.random()*0.5
            px.BorderSizePixel = 0
        end
        task.spawn(function()
            while active and sg.Parent do
                for _,p in ipairs(sg:GetChildren()) do
                    if p:IsA("Frame") and math.random()<0.35 then
                        p.Position = UDim2.new(math.random()*0.98,0,math.random()*0.98,0)
                        p.BackgroundColor3 = math.random()<0.5 and rN() or rD()
                        p.Visible = math.random()<0.7
                    end
                end
                task.wait(0.05)
            end
        end)
    elseif dtype == "chromatic" then
        local function layer(c,x,t)
            local f = Instance.new("Frame", sg)
            f.Size = UDim2.new(1,0,1,0); f.Position = UDim2.new(0,x,0,0)
            f.BackgroundColor3 = c; f.BackgroundTransparency = t; f.BorderSizePixel = 0
        end
        layer(Color3.fromRGB(255,0,0),4,0.82); layer(Color3.fromRGB(0,0,255),-4,0.82)
        local lbl = Instance.new("TextLabel", sg)
        lbl.Size = UDim2.new(1,0,0,30); lbl.BackgroundTransparency = 1
        lbl.Font = Enum.Font.Code; lbl.TextSize = 20; lbl.TextStrokeTransparency = 0.4
        task.spawn(function()
            while active and sg.Parent do
                lbl.Position = UDim2.new(0,(math.random()-0.5)*14,math.random()*0.9,0)
                lbl.Text = rG():format(math.random(10,99)); lbl.TextColor3 = rN()
                task.wait(0.12+math.random()*0.25)
            end
        end)
    elseif dtype == "fragment" then
        local segs = 6
        for i=1,segs do
            local f = Instance.new("Frame", sg)
            f.Size = UDim2.new(1/segs,0,1,0)
            f.Position = UDim2.new((i-1)/segs,0,0,0)
            f.BackgroundColor3 = rD(); f.BackgroundTransparency = 0.88
        end
        task.spawn(function()
            while active and sg.Parent do
                for _,f in ipairs(sg:GetChildren()) do
                    if f:IsA("Frame") and math.random()<0.20 then
                        local y = f.Position.Y.Scale
                        f.Position = UDim2.new(f.Position.X.Scale,0,y+(math.random()-0.5)*0.04,0)
                        if math.random()<0.08 then f.BackgroundColor3 = rN() end
                    end
                end
                task.wait(0.08)
            end
        end)
    elseif dtype == "invert" then
        local ov = Instance.new("Frame", sg)
        ov.Size = UDim2.new(1,0,1,0); ov.BackgroundColor3 = Color3.new(0,0,0)
        ov.BackgroundTransparency = 0.82
        task.spawn(function()
            while active and sg.Parent do
                TS:Create(ov,TweenInfo.new(0.3),{BackgroundTransparency=0.55}):Play()
                task.wait(0.3)
                TS:Create(ov,TweenInfo.new(0.5),{BackgroundTransparency=0.88}):Play()
                task.wait(1.5+math.random()*3)
            end
        end)
    elseif dtype == "zoom" then
        local zf = Instance.new("Frame", sg)
        zf.Size = UDim2.new(1.3,0,1.3,0); zf.Position = UDim2.new(-0.15,0,-0.15,0)
        zf.BackgroundColor3 = rD(); zf.BackgroundTransparency = 0.90
        task.spawn(function()
            while active and sg.Parent do
                task.wait(0.8+math.random()*2)
                local s = 0.88+math.random()*0.28
                TS:Create(zf,TweenInfo.new(0.06),{Size=UDim2.new(s,0,s,0),Position=UDim2.new(-(s-1)/2,0,-(s-1)/2,0)}):Play()
                task.wait(0.1)
                TS:Create(zf,TweenInfo.new(0.08),{Size=UDim2.new(1.3,0,1.3,0),Position=UDim2.new(-0.15,0,-0.15,0)}):Play()
            end
        end)
    elseif dtype == "drain" then
        local top = Instance.new("Frame", sg)
        top.Size = UDim2.new(1,0,0,0); top.BackgroundColor3 = rD()
        local bot = Instance.new("Frame", sg)
        bot.Size = UDim2.new(1,0,0,0); bot.Position = UDim2.new(0,0,1,0)
        bot.BackgroundColor3 = rD()
        task.spawn(function()
            while active and sg.Parent do
                local h = math.random()*0.12
                TS:Create(top,TweenInfo.new(0.4),{Size=UDim2.new(1,0,h,0)}):Play()
                TS:Create(bot,TweenInfo.new(0.4),{Size=UDim2.new(1,0,h,0),Position=UDim2.new(0,0,1-h,0)}):Play()
                task.wait(1.2+math.random()*2.5)
                TS:Create(top,TweenInfo.new(0.6),{Size=UDim2.new(1,0,0,0)}):Play()
                TS:Create(bot,TweenInfo.new(0.6),{Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,1,0)}):Play()
                task.wait(0.8+math.random()*1.5)
            end
        end)
    end
end
re.OnClientEvent:Connect(function(action, dtype)
    if action == "start" then start(dtype) elseif action == "stop" then clear() end
end)
]==]
    ls.Parent = sps
end)()

