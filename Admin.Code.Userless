-- ════════════════════════════════════════════════════════════════════
-- BLOQUE 5: 🔊 SISTEMA DE AUDIO COMPLETO (separado y autocontenido)
-- ════════════════════════════════════════════════════════════════════
;(function()
    AUDIO = {
        enabled = CFG.AudioOn,
        sounds = {},
        intensity = 0,
        running = true,
    }

    if not CFG.AudioOn then
        AUDIO.setIntensity = function() end
        AUDIO.stop = function() end
        return
    end

    -- SoundGroup central
    local sg = SoundService:FindFirstChild("__PibbyAudio")
    if sg then sg:Destroy() end
    sg = Instance.new("SoundGroup")
    sg.Name = "__PibbyAudio"; sg.Volume = 0.2
    sg.Parent = SoundService
    AUDIO.group = sg

    -- IDs públicos de Roblox (cámbialos por los tuyos si no cargan)
    local ASSETS = {
        heartbeat = "rbxassetid://9046447447",
        drone     = "rbxassetid://9112955391",
        whisper   = "rbxassetid://5982740948",
        glitch    = "rbxassetid://6890585437",
    }

    -- Helper para crear sonidos
    local function makeSound(name, id, looped, baseVol)
        local s = Instance.new("Sound")
        s.Name = "__Pibby_" .. name
        s.SoundId = id
        s.Looped = looped or false
        s.Volume = baseVol or 0.5
        s.SoundGroup = sg
        s.Parent = SoundService
        AUDIO.sounds[name] = s
        return s
    end

    makeSound("heart",   ASSETS.heartbeat, false, 0.0)
    makeSound("drone",   ASSETS.drone,     true,  0.0)
    makeSound("whisper", ASSETS.whisper,   false, 0.0)
    makeSound("glitch",  ASSETS.glitch,    false, 0.0)

    -- Drone arranca
    AUDIO.sounds.drone:Play()

    -- API pública: setIntensity(0..1)
    function AUDIO.setIntensity(value)
        AUDIO.intensity = math.clamp(value, 0, 1)
        TweenService:Create(sg, TweenInfo.new(2),
            {Volume = 0.15 + AUDIO.intensity * 0.55}):Play()
        TweenService:Create(AUDIO.sounds.drone, TweenInfo.new(2),
            {Volume = 0.25 + AUDIO.intensity * 0.45}):Play()
    end

    -- API pública: detener todo
    function AUDIO.stop()
        AUDIO.running = false
        for _, s in pairs(AUDIO.sounds) do
            if s.IsPlaying then s:Stop() end
            s:Destroy()
        end
        if sg then sg:Destroy() end
    end

    -- API pública: reproducir glitch one-shot manualmente
    function AUDIO.playGlitch(volume, speed)
        if not AUDIO.sounds.glitch then return end
        AUDIO.sounds.glitch.Volume = volume or (0.3 + math.random()*0.4)
        AUDIO.sounds.glitch.PlaybackSpeed = speed or (0.6 + math.random()*1.4)
        AUDIO.sounds.glitch:Play()
    end

    -- LATIDO: ritmo se acelera con la fase
    task.spawn(function()
        while AUDIO.running and STATE.running do
            local interval = CFG.HeartbeatBase - math.min(STATE.currentPhase * 0.25, 1.6)
            interval = math.max(0.55, interval)
            local h = AUDIO.sounds.heart
            if h then
                h.Volume = 0.4 + math.min(STATE.currentPhase * 0.1, 0.4)
                h.PlaybackSpeed = 0.85 + math.random()*0.3
                h:Play()
            end
            task.wait(interval + math.random()*0.4)
        end
    end)

    -- SUSURROS: aparecen desde fase 1
    task.spawn(function()
        while AUDIO.running and STATE.running do
            task.wait(6 + math.random()*10)
            if STATE.currentPhase >= 1 and math.random() < 0.5 then
                local w = AUDIO.sounds.whisper
                if w then
                    w.Volume = 0.25 + math.random()*0.3
                    w.PlaybackSpeed = 0.7 + math.random()*0.6
                    w:Play()
                end
            end
        end
    end)

    -- GLITCHES: aparecen desde fase 2
    task.spawn(function()
        while AUDIO.running and STATE.running do
            task.wait(3 + math.random()*8)
            if STATE.currentPhase >= 2 and math.random() < 0.4 then
                AUDIO.playGlitch()
            end
        end
    end)

    print("[Pibby Audio] Sistema de audio cargado")
end)()

-- ════════════════════════════════════════════════════════════════════
-- BLOQUE 6: SPAWNERS
-- ════════════════════════════════════════════════════════════════════
local SPAWN = {}
;(function()
    function SPAWN.tendril(from, to, sn, age, isNeon, isRhizo)
        if STATE.partCount >= CFG.MaxParts then return nil end
        local len = (to-from).Magnitude
        if len < 0.05 or len > CFG.MaxStepDistance then return nil end

        local p = Instance.new("Part")
        p.Anchored = true; p.CanCollide = false; p.CastShadow = false
        local w = isRhizo and (CFG.RhizoWidth+math.random()*0.14) or (CFG.TendrilW+math.random()*0.11)
        local h = isRhizo and (CFG.RhizoHeight+math.random()*0.05) or (CFG.TendrilH+math.random()*0.03)
        p.Size = Vector3.new(w, h, len)

        local look = (to-from).Unit
        local right = sn:Cross(look)
        right = right.Magnitude < 0.001 and Vector3.new(1,0,0) or right.Unit
        p.CFrame = CFrame.fromMatrix((from+to)/2, right, look:Cross(right).Unit)

        if isNeon then
            p.Color = UTIL.rN(); p.Material = Enum.Material.Neon
        elseif isRhizo then
            p.Color = UTIL.rR(); p.Material = Enum.Material.SmoothPlastic
        else
            p.Color = UTIL.mycelColor(age)
            p.Material = age > 0.72 and Enum.Material.SmoothPlastic or Enum.Material.Fabric
        end
        p.Transparency = 1; p.Parent = STATE.folder
        STATE.partCount += 1
        TweenService:Create(p, TweenInfo.new(0.20),
            {Transparency = isNeon and 0 or (isRhizo and 0.08 or 0.04)}):Play()

        if isRhizo then
            local li = Instance.new("PointLight", p)
            li.Color = Color3.fromRGB(110,0,190); li.Range = 5; li.Brightness = 0.35
        end
        return p
    end

    function SPAWN.blob(pos, normal, radius, ageFrac)
        if STATE.partCount >= CFG.MaxParts then return nil end
        radius = radius or (CFG.BlobRadMin + math.random()*(CFG.BlobRadMax-CFG.BlobRadMin))
        ageFrac = ageFrac or 1
        local p = Instance.new("Part")
        local shp = math.random(3)
        p.Shape = shp==1 and Enum.PartType.Ball
            or (shp==2 and Enum.PartType.Block or Enum.PartType.Cylinder)
        p.Anchored = true; p.CanCollide = false; p.CastShadow = false
        local ry = radius*(0.22+math.random()*0.52)
        p.Size = Vector3.new(radius, ry, radius*(0.75+math.random()*0.5))
        local br = normal:Cross(Vector3.new(0,0,1))
        br = br.Magnitude < 0.001 and Vector3.new(1,0,0) or br.Unit
        p.CFrame = CFrame.fromMatrix(pos+normal*(ry/2), br, normal, -br:Cross(normal).Unit)
            * CFrame.Angles(0, math.random()*math.pi*2, math.random()*0.35)
        local isNeon = math.random() < 0.09
        p.Color = isNeon and UTIL.rN() or (ageFrac > 0.42 and UTIL.rD() or UTIL.mycelColor(ageFrac))
        p.Material = isNeon and Enum.Material.Neon or Enum.Material.SmoothPlastic
        p.Transparency = 1; p.Parent = STATE.folder
        STATE.partCount += 1
        TweenService:Create(p, TweenInfo.new(0.38, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
            {Transparency = isNeon and 0 or 0.04}):Play()
        table.insert(STATE.blobReg, {pos = pos, time = tick()})
        if not isNeon and ageFrac > 0.28 and math.random() < 0.22 then
            local li = Instance.new("PointLight", p)
            li.Color = Color3.fromRGB(95,0,175)
            li.Range = 4 + radius*2.2; li.Brightness = 0.28 + ageFrac*0.38
        end
        return p
    end

    function SPAWN.flash(pos, normal, scale)
        if STATE.partCount >= CFG.MaxParts then return end
        scale = scale or 1
        local p = Instance.new("Part")
        p.Anchored = true; p.CanCollide = false; p.CastShadow = false
        p.Shape = Enum.PartType.Ball
        p.Size = Vector3.new(0.35,0.35,0.35)*scale
        p.Position = pos + normal*0.35
        p.Color = UTIL.rN(); p.Material = Enum.Material.Neon
        p.Parent = STATE.folder; STATE.partCount += 1
        local li = Instance.new("PointLight", p)
        li.Color = p.Color; li.Range = 14*scale; li.Brightness = 3
        TweenService:Create(p, TweenInfo.new(0.28),
            {Size = Vector3.new(4.5,4.5,4.5)*scale, Transparency = 1}):Play()
        TweenService:Create(li, TweenInfo.new(0.28), {Brightness = 0}):Play()
        task.delay(0.32, function()
            if p then p:Destroy(); STATE.partCount = math.max(0, STATE.partCount-1) end
        end)
    end
end)()

-- ════════════════════════════════════════════════════════════════════
-- BLOQUE 7: CRECIMIENTO DE NODOS — FIX REFORZADO ANTI-HUÉRFANOS
-- ════════════════════════════════════════════════════════════════════
local GROW = {}
;(function()
    function GROW.cleanBlobReg()
        local t = tick(); local clean = {}
        for _,b in ipairs(STATE.blobReg) do
            if t - b.time <= 130 then table.insert(clean, b) end
        end
        STATE.blobReg = clean
    end

    function GROW.getBlobDensity(pos, radius)
        local count = 0
        for _,b in ipairs(STATE.blobReg) do
            if (b.pos-pos).Magnitude < radius then count += 1 end
        end
        return count
    end

    -- Step de un nodo con TODAS las validaciones
    function GROW.stepNode(node)
        if node.life <= 0 then return false end
        node.life -= 1
        node.age = 1 - (node.life / node.maxLife)

        -- VALIDACIÓN A: la posición del nodo padre debe ser válida
        if not node.pos or node.pos.Magnitude < 1 then return false end

        -- VALIDACIÓN B: rechazar si hay jugador MUY cerca de la posición actual
        if UTIL.nearPlayer(node.pos, CFG.MinSpawnDistFromPlayer) then
            return false  -- mata la rama, no spawnea pegado al jugador
        end

        -- Calcular nueva posición
        local jitter = Vector3.new((math.random()-0.5)*0.6, 0, (math.random()-0.5)*0.6)
        local dir = (node.dir + jitter).Unit
        local stepSize = node.nodeType == "rhizo" and CFG.RhizoStep or CFG.StepSize
        local newPos = node.pos + dir * stepSize

        -- VALIDACIÓN C: distancia razonable desde nodo padre
        if (newPos - node.pos).Magnitude > CFG.MaxBranchDist then
            return false
        end

        -- VALIDACIÓN D: anclaje a superficie
        local sp, sn = UTIL.castSurf(newPos + Vector3.new(0,2,0),
            Vector3.new(0,-1,0), CFG.AnchorRayLen, UTIL.rpMain)
        if not sp then
            node.orphanFails = (node.orphanFails or 0) + 1
            if node.orphanFails >= CFG.MaxOrphanFails then return false end
            return true
        end
        node.orphanFails = 0

        -- VALIDACIÓN E: pos absoluta no puede ser cerca de (0,0,0)
        if sp.Magnitude < 1 then return false end

        -- VALIDACIÓN F (LA CLAVE DEL FIX): conectividad entre nodo padre y nuevo
        if CFG.ConnectivityCheck and not UTIL.canConnect(node.pos, sp) then
            return false  -- hay pared/aire en medio = sería un "salto huérfano"
        end

        -- VALIDACIÓN G: no spawnear cerca del jugador
        if UTIL.nearPlayer(sp, CFG.MinSpawnDistFromPlayer) then
            node.dir = -node.dir  -- huye
            return true
        end

        -- VALIDACIÓN H: evitar saturación
        if UTIL.isOcc(sp) then return false end

        -- TODAS LAS VALIDACIONES OK → crear segmento
        local isNeon = math.random() < CFG.NeonChance
        local isRhizo = node.nodeType == "rhizo"
        local part = SPAWN.tendril(node.pos, sp, sn, node.age, isNeon, isRhizo)
        if not part then return false end  -- spawn falló, mata rama

        UTIL.addToGrid(sp)

        if math.random() < CFG.BlobChance then
            SPAWN.blob(sp, sn, nil, node.age)
        end

        node.pos = sp; node.normal = sn; node.dir = dir

        -- Branching (con misma validación de jugador)
        if node.depth < CFG.MaxDepth
           and math.random() < CFG.BranchChance * (CFG.BranchDecay^node.depth) then
            if #STATE.nodes < CFG.MaxNodes
               and not UTIL.nearPlayer(sp, CFG.MinSpawnDistFromPlayer) then
                local angle = (math.random()-0.5) * math.pi
                local newDir = CFrame.Angles(0, angle, 0):VectorToWorldSpace(node.dir)
                local nl = math.random(CFG.LifeMin, CFG.LifeMax)
                table.insert(STATE.nodes, {
                    pos = sp, dir = newDir, normal = sn,
                    life = nl, maxLife = nl,
                    depth = node.depth+1, age = node.age,
                    nodeType = node.nodeType, orphanFails = 0,
                })
            end
        end

        -- Conversión a rhizomorph
        if not isRhizo and math.random() < CFG.RhizoChance and node.depth <= 2 then
            local nl = math.random(CFG.RhizoLifeMin, CFG.RhizoLifeMax)
            table.insert(STATE.nodes, {
                pos = sp, dir = Vector3.new(dir.X,0,dir.Z).Unit,
                normal = sn, life = nl, maxLife = nl,
                depth = 0, age = 0, nodeType = "rhizo", orphanFails = 0,
            })
        end

        return true
    end

    function GROW.tickAll()
        local alive = {}
        for _,n in ipairs(STATE.nodes) do
            if GROW.stepNode(n) then table.insert(alive, n) end
        end
        STATE.nodes = alive
    end

    function GROW.seed(pos, normal)
        if not pos or pos.Magnitude < 1 then return end
        -- VALIDACIÓN: no sembrar cerca de jugadores
        if UTIL.nearPlayer(pos, CFG.MinSpawnDistFromPlayer * 2) then return end
        for i=1,6 do
            local a = (i/6) * math.pi * 2
            local nl = math.random(CFG.LifeMin, CFG.LifeMax)
            table.insert(STATE.nodes, {
                pos = pos,
                dir = Vector3.new(math.cos(a),0,math.sin(a)),
                normal = normal or Vector3.new(0,1,0),
                life = nl, maxLife = nl,
                depth = 0, age = 0,
                nodeType = "normal", orphanFails = 0,
            })
        end
    end
end)()

-- ════════════════════════════════════════════════════════════════════
-- BLOQUE 8: INFECCIÓN DE JUGADORES
-- ════════════════════════════════════════════════════════════════════
local INFECT = {}
;(function()
    local DTYPES = {"scanlines","static","chromatic","fragment","invert","zoom","drain"}

    function INFECT.assign(player)
        local used = {}
        for _,t in pairs(STATE.playerDistortion) do used[t] = true end
        local pool = {}
        for _,t in ipairs(DTYPES) do
            if not used[t] then table.insert(pool, t) end
        end
        if #pool == 0 then pool = DTYPES end
        local pick = pool[math.random(#pool)]
        STATE.playerDistortion[player] = pick
        return pick
    end

    function INFECT.start(player)
        if STATE.infected[player] then return end
        STATE.infected[player] = true
        local dtype = INFECT.assign(player)
        REMOTE:FireClient(player, "start", dtype)
        if AUDIO.playGlitch then AUDIO.playGlitch(0.6, 0.8) end
        print("[Pibby] Jugador infectado: "..player.Name.." → "..dtype)
    end

    function INFECT.stop(player)
        STATE.infected[player] = nil
        STATE.playerDistortion[player] = nil
        if player and player.Parent then REMOTE:FireClient(player, "stop") end
    end

    function INFECT.tickContact()
        for _,pl in ipairs(Players:GetPlayers()) do
            if not STATE.infected[pl] and pl.Character then
                local hrp = pl.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local density = GROW.getBlobDensity(hrp.Position, 12)
                    if density > 4 and math.random() < 0.02 then
                        INFECT.start(pl)
                    end
                end
            end
        end
    end

    Players.PlayerRemoving:Connect(function(pl) INFECT.stop(pl) end)
end)()

-- ════════════════════════════════════════════════════════════════════
-- BLOQUE 9: NPCs CORROMPIDOS
-- ════════════════════════════════════════════════════════════════════
local NPC = {}
;(function()
    local function isPlayerCharacter(model)
        for _,pl in ipairs(Players:GetPlayers()) do
            if pl.Character == model then return true end
        end
        return false
    end

    function NPC.corrupt(model)
        if STATE.infectedNpcs[model] then return end
        local hum = model:FindFirstChildOfClass("Humanoid")
        local hrp = model:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then return end
        STATE.infectedNpcs[model] = true

        task.spawn(function()
            for _,p in ipairs(model:GetDescendants()) do
                if p:IsA("BasePart") then
                    task.spawn(function()
                        task.wait(math.random()*1.5)
                        TweenService:Create(p, TweenInfo.new(1.2), {Color = UTIL.rD()}):Play()
                    end)
                end
            end
            local head = model:FindFirstChild("Head")
            if head then
                local hl = Instance.new("PointLight", head)
                hl.Color = Color3.fromRGB(180,0,255); hl.Range = 16; hl.Brightness = 3
            end

            task.wait(2.5)
            if not (model.Parent and STATE.infectedNpcs[model]) then return end
            hum.WalkSpeed = (hum.WalkSpeed or 16) * CFG.NpcChaseSpeed * 1.8

            while model.Parent and STATE.infectedNpcs[model] and hum.Health > 0 do
                local target, bestDist
                for _,pl in ipairs(Players:GetPlayers()) do
                    if pl.Character then
                        local phrp = pl.Character:FindFirstChild("HumanoidRootPart")
                        if phrp then
                            local d = (phrp.Position - hrp.Position).Magnitude
                            if not bestDist or d < bestDist then
                                bestDist = d; target = phrp
                            end
                        end
                    end
                end

                if target then
                    hum:MoveTo(target.Position)
                    if bestDist <= CFG.NpcInfectRadius and math.random() < CFG.NpcInfectChance then
                        for _,pl in ipairs(Players:GetPlayers()) do
                            if pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") == target then
                                INFECT.start(pl); break
                            end
                        end
                    end
                end
                task.wait(0.5 + math.random()*0.5)
            end
            STATE.infectedNpcs[model] = nil
        end)
    end

    function NPC.scanAndCorrupt()
        for _,model in ipairs(workspace:GetDescendants()) do
            if model:IsA("Model") and not STATE.infectedNpcs[model] and not isPlayerCharacter(model) then
                local hum = model:FindFirstChildOfClass("Humanoid")
                local hrp = model:FindFirstChild("HumanoidRootPart")
                if hum and hrp and hum.Health > 0 then
                    if GROW.getBlobDensity(hrp.Position, CFG.NpcCorruptRadius) >= 2 then
                        NPC.corrupt(model)
                    end
                end
            end
        end
    end
end)()

-- ════════════════════════════════════════════════════════════════════
-- BLOQUE 10: CONSUMO DEL MAPA
-- ════════════════════════════════════════════════════════════════════
local CONSUME = {}
;(function()
    function CONSUME.tryAt(pos)
        if not CFG.MapConsumeOn or math.random() >= CFG.MapConsumeChance then return end
        -- No consumir cerca de jugadores
        if UTIL.nearPlayer(pos, CFG.MinSpawnDistFromPlayer * 2) then return end

        local dir = Vector3.new((math.random()-0.5)*2, -0.6, (math.random()-0.5)*2).Unit
        local r = workspace:Raycast(pos + Vector3.new(0,0.3,0), dir*CFG.MapConsumeRadius, UTIL.rpMain)
        if not r then return end
        local inst = r.Instance
        if not inst or not inst:IsA("BasePart") then return end
        if inst.Name == "Baseplate" or inst:FindFirstAncestor("PibbyFolder") then return end
        if STATE.consumed[inst] or inst.Locked or not inst.Anchored then return end

        STATE.consumed[inst] = true
        task.spawn(function()
            local oc, om, ot, os = inst.Color, inst.Material, inst.Transparency, inst.Size
            TweenService:Create(inst, TweenInfo.new(CFG.MapConsumeTime*0.32),
                {Color = UTIL.lerpC(oc, UTIL.rD(), 0.55)}):Play()
            task.wait(CFG.MapConsumeTime*0.32)
            if not (inst and inst.Parent) then STATE.consumed[inst] = nil; return end
            inst.Material = Enum.Material.Neon
            TweenService:Create(inst, TweenInfo.new(CFG.MapConsumeTime*0.3),
                {Color = UTIL.rN(), Transparency = 0.45}):Play()
            task.wait(CFG.MapConsumeTime*0.3)
            if not (inst and inst.Parent) then STATE.consumed[inst] = nil; return end
            SPAWN.flash(inst.Position, Vector3.new(0,1,0),
                math.clamp(inst.Size.Magnitude*0.18, 0.4, 3))
            TweenService:Create(inst, TweenInfo.new(CFG.MapConsumeTime*0.22),
                {Transparency = 1, Size = os*0.08}):Play()
            task.wait(CFG.MapConsumeTime*0.22 + 0.1)
            if inst and inst.Parent then
                inst.Transparency = ot; inst.Color = oc
                inst.Material = om; inst.Size = os
            end
            STATE.consumed[inst] = nil
        end)
    end
end)()

-- ════════════════════════════════════════════════════════════════════
-- BLOQUE 11: FASES (controla intensidad visual + audio)
-- ════════════════════════════════════════════════════════════════════
local PHASE = {}
;(function()
    function PHASE.update()
        local pc = STATE.partCount
        local newPhase = STATE.currentPhase
        if pc >= CFG.Phase5At and newPhase < 5 then newPhase = 5
        elseif pc >= CFG.Phase4At and newPhase < 4 then newPhase = 4
        elseif pc >= CFG.Phase3At and newPhase < 3 then newPhase = 3
        elseif pc >= CFG.Phase2At and newPhase < 2 then newPhase = 2
        elseif pc >= CFG.Phase1At and newPhase < 1 then newPhase = 1
        end

        if newPhase ~= STATE.currentPhase then
            STATE.currentPhase = newPhase
            print("[Pibby] FASE "..newPhase)

            local intensity = newPhase / 5
            TweenService:Create(FX.atmo, TweenInfo.new(3), {
                Density = 0.1 + intensity*0.35,
                Haze = intensity*4,
            }):Play()
            TweenService:Create(FX.bloom, TweenInfo.new(3), {
                Intensity = intensity*1.2,
            }):Play()
            TweenService:Create(FX.cc, TweenInfo.new(3), {
                Saturation = -intensity*0.4,
                Contrast = intensity*0.3,
                TintColor = UTIL.lerpC(Color3.new(1,1,1), Color3.fromRGB(180,140,200), intensity),
            }):Play()
            TweenService:Create(Lighting, TweenInfo.new(3), {
                Brightness = math.max(0.5, STATE.origLighting.Brightness - intensity*0.6),
                Ambient = UTIL.lerpC(STATE.origLighting.Ambient, Color3.fromRGB(40,15,55), intensity),
                FogColor = UTIL.lerpC(STATE.origLighting.FogColor, Color3.fromRGB(50,20,70), intensity),
                FogEnd = math.max(80, 500 - intensity*400),
            }):Play()

            -- Audio reacciona a la fase
            if AUDIO and AUDIO.setIntensity then
                AUDIO.setIntensity(intensity)
            end
        end
    end
end)()

-- ════════════════════════════════════════════════════════════════════
-- BLOQUE 12: WAVES (siembra inicial + olas periódicas)
-- ════════════════════════════════════════════════════════════════════
local WAVE = {}
;(function()
    function WAVE.spawnSeedNear(centerPos, radius)
        radius = radius or 80
        for _=1, 4 do
            local angle = math.random()*math.pi*2
            local dist = 20 + math.random()*radius  -- mínimo 20 studs de distancia
            local probe = centerPos + Vector3.new(
                math.cos(angle)*dist, 30, math.sin(angle)*dist)
            local sp, sn = UTIL.castSurf(probe, Vector3.new(0,-1,0), 80, UTIL.rpMain)
            if sp then GROW.seed(sp, sn) end
        end
    end

    function WAVE.initial()
        local origin
        local infPart = workspace:FindFirstChild("Infeccion", true)
        if infPart and infPart:IsA("BasePart") then
            origin = infPart.Position
        else
            local firstPlayer = Players:GetPlayers()[1]
            if firstPlayer and firstPlayer.Character then
                local hrp = firstPlayer.Character:FindFirstChild("HumanoidRootPart")
                if hrp then origin = hrp.Position + Vector3.new(0, 0, -40) end
            end
            origin = origin or Vector3.new(0, 50, 0)
        end

        local sp, sn = UTIL.castSurf(origin + Vector3.new(0,40,0), Vector3.new(0,-1,0), 100, UTIL.rpMain)
        if sp then
            GROW.seed(sp, sn)
            for _=1, CFG.InitialWaves do WAVE.spawnSeedNear(sp, 60) end
        end
        STATE.infectionReady = true
        print("[Pibby] Infección iniciada en "..tostring(sp))
    end

    function WAVE.auto()
        if #STATE.blobReg == 0 then return end
        local b = STATE.blobReg[math.random(#STATE.blobReg)]
        if b and b.pos then WAVE.spawnSeedNear(b.pos, 50) end
    end
end)()

-- ════════════════════════════════════════════════════════════════════
-- BLOQUE 13: LOOP PRINCIPAL
-- ════════════════════════════════════════════════════════════════════
;(function()
    task.delay(2, function() WAVE.initial() end)

    RunService.Heartbeat:Connect(function(dt)
        if not STATE.running or not STATE.infectionReady then return end

        STATE.timerAcc   += dt
        STATE.waveTimer  += dt
        STATE.memTimer   += dt
        STATE.npcScanTimer += dt

        if STATE.timerAcc >= CFG.TickRate then
            STATE.timerAcc = 0
            UTIL.refreshNoPlayer()
            GROW.tickAll()
            GROW.cleanBlobReg()
            PHASE.update()

            if #STATE.blobReg > 0 then
                for _=1, math.min(3, #STATE.blobReg) do
                    local b = STATE.blobReg[math.random(#STATE.blobReg)]
                    if b then CONSUME.tryAt(b.pos) end
                end
            end

            INFECT.tickContact()
        end

        if STATE.waveTimer >= CFG.AutoWaveSec then
            STATE.waveTimer = 0
            WAVE.auto()
        end

        if STATE.memTimer >= CFG.MemoryUpdateRate then
            STATE.memTimer = 0
            local t = tick()
            for _,pl in ipairs(Players:GetPlayers()) do
                if pl.Character then
                    local hrp = pl.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        table.insert(STATE.playerMem, {pos = hrp.Position, time = t})
                    end
                end
            end
            for i = #STATE.playerMem, 1, -1 do
                if t - STATE.playerMem[i].time > CFG.MemoryDecay then
                    table.remove(STATE.playerMem, i)
                end
            end
            while #STATE.playerMem > 120 do table.remove(STATE.playerMem, 1) end
        end

        if STATE.npcScanTimer >= CFG.NpcScanInterval then
            STATE.npcScanTimer = 0
            NPC.scanAndCorrupt()
        end
    end)

    game:BindToClose(function()
        STATE.running = false
        for pl,_ in pairs(STATE.infected) do INFECT.stop(pl) end
        if AUDIO and AUDIO.stop then AUDIO.stop() end
    end)

    print("[Pibby] v4.1 cargado correctamente. Audio separado + fix anti-huérfanos activo.")
end)()
